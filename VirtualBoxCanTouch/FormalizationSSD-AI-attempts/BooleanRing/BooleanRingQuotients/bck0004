-- Reindexing: if ŌÉ : Iso X Y, then A /Im f ‚ČÖ A /Im (f ‚ąė Iso.inv ŌÉ)
module reindex {A : BooleanRing ‚Ąď-zero} {X Y : Type} (ŌÉ : Iso X Y) (f : X ‚Üí ‚ü® A ‚ü©) where
  open BooleanRingStr ‚¶É...‚¶Ą
  instance
    _ = snd A
    _ = snd (A QB./Im f)
    _ = snd (A QB./Im (f ‚ąė Iso.inv ŌÉ))

  f' : Y ‚Üí ‚ü® A ‚ü©
  f' = f ‚ąė Iso.inv ŌÉ

  fwdKills : (x : X) ‚Üí QB.quotientImageHom {B = A} {f = f'} $cr f x ‚Č° ūĚüė
  fwdKills x = subst (őĽ a ‚Üí QB.quotientImageHom {B = A} {f = f'} $cr a ‚Č° ūĚüė)
    (cong f (Iso.ret ŌÉ x))
    (QB.zeroOnImage (Iso.fun ŌÉ x))

  fwd : BoolHom (A QB./Im f) (A QB./Im f')
  fwd = QB.inducedHom (A QB./Im f') QB.quotientImageHom fwdKills

  bwdKills : (y : Y) ‚Üí QB.quotientImageHom {B = A} {f = f} $cr f' y ‚Č° ūĚüė
  bwdKills y = QB.zeroOnImage (Iso.inv ŌÉ y)

  bwd : BoolHom (A QB./Im f') (A QB./Im f)
  bwd = QB.inducedHom (A QB./Im f) QB.quotientImageHom bwdKills

  fwd‚ąėŌÄ : fwd ‚ąėcr QB.quotientImageHom {B = A} {f = f} ‚Č° QB.quotientImageHom
  fwd‚ąėŌÄ = QB.evalInduce (A QB./Im f')

  bwd‚ąėŌÄ : bwd ‚ąėcr QB.quotientImageHom {B = A} {f = f'} ‚Č° QB.quotientImageHom
  bwd‚ąėŌÄ = QB.evalInduce (A QB./Im f)

  ret‚ąėŌÄ : (bwd ‚ąėcr fwd) ‚ąėcr QB.quotientImageHom {B = A} {f = f} ‚Č°
          idCommRingHom (BooleanRing‚ÜíCommRing (A QB./Im f)) ‚ąėcr QB.quotientImageHom
  ret‚ąėŌÄ =
    (bwd ‚ąėcr fwd) ‚ąėcr QB.quotientImageHom
      ‚Č°‚ü® CommRingHom‚Č° refl ‚ü©
    bwd ‚ąėcr (fwd ‚ąėcr QB.quotientImageHom)
      ‚Č°‚ü® cong (bwd ‚ąėcr_) fwd‚ąėŌÄ ‚ü©
    bwd ‚ąėcr QB.quotientImageHom {B = A} {f = f'}
      ‚Č°‚ü® bwd‚ąėŌÄ ‚ü©
    QB.quotientImageHom
      ‚Č°‚ü® sym (idCompCommRingHom QB.quotientImageHom) ‚ü©
    idCommRingHom _ ‚ąėcr QB.quotientImageHom ‚ąé

  sec‚ąėŌÄ : (fwd ‚ąėcr bwd) ‚ąėcr QB.quotientImageHom {B = A} {f = f'} ‚Č°
          idCommRingHom (BooleanRing‚ÜíCommRing (A QB./Im f')) ‚ąėcr QB.quotientImageHom
  sec‚ąėŌÄ =
    (fwd ‚ąėcr bwd) ‚ąėcr QB.quotientImageHom
      ‚Č°‚ü® CommRingHom‚Č° refl ‚ü©
    fwd ‚ąėcr (bwd ‚ąėcr QB.quotientImageHom)
      ‚Č°‚ü® cong (fwd ‚ąėcr_) bwd‚ąėŌÄ ‚ü©
    fwd ‚ąėcr QB.quotientImageHom {B = A} {f = f}
      ‚Č°‚ü® fwd‚ąėŌÄ ‚ü©
    QB.quotientImageHom
      ‚Č°‚ü® sym (idCompCommRingHom QB.quotientImageHom) ‚ü©
    idCommRingHom _ ‚ąėcr QB.quotientImageHom ‚ąé

  ret : bwd ‚ąėcr fwd ‚Č° idCommRingHom (BooleanRing‚ÜíCommRing (A QB./Im f))
  ret = CommRingHom‚Č° $
    QB.quotientImageHomEpi {B = A} {f = f}
      (‚ü® A QB./Im f ‚ü© , BooleanRingStr.is-set (snd (A QB./Im f)))
      (cong fst ret‚ąėŌÄ)

  sec : fwd ‚ąėcr bwd ‚Č° idCommRingHom (BooleanRing‚ÜíCommRing (A QB./Im f'))
  sec = CommRingHom‚Č° $
    QB.quotientImageHomEpi {B = A} {f = f'}
      (‚ü® A QB./Im f' ‚ü© , BooleanRingStr.is-set (snd (A QB./Im f')))
      (cong fst sec‚ąėŌÄ)

  reindexEquiv : BooleanRingEquiv (A QB./Im f) (A QB./Im f')
  reindexEquiv = isoToCommRingEquiv fwd (fst bwd)
    (funExt‚ĀĽ (cong fst sec)) (funExt‚ĀĽ (cong fst ret))

open import BooleanRing.BoolRingUnivalence

-- Given f, g : ‚Ąē ‚Üí ‚ü® freeBA ‚Ąē ‚ü©, the combined quotient is countably presented.
-- freeBA ‚Ąē /Im (‚äé.rec f g) ‚ČÖ freeBA ‚Ąē /Im k where k : ‚Ąē ‚Üí ‚ü® freeBA ‚Ąē ‚ü©
sumQuotientPresented : (f g : ‚Ąē ‚Üí ‚ü® freeBA ‚Ąē ‚ü©) ‚Üí has-Boole-ŌČ' (freeBA ‚Ąē QB./Im (‚äé.rec f g))
sumQuotientPresented f g = k , equivChain where
  k : ‚Ąē ‚Üí ‚ü® freeBA ‚Ąē ‚ü©
  k = ‚äé.rec f g ‚ąė Iso.inv ‚Ąē‚äé‚Ąē‚ČÖ‚Ąē

  equivChain : BooleanRingEquiv (freeBA ‚Ąē QB./Im (‚äé.rec f g)) (freeBA ‚Ąē QB./Im k)
  equivChain = reindex.reindexEquiv ‚Ąē‚äé‚Ąē‚ČÖ‚Ąē (‚äé.rec f g)

-- BoolQuotientEquiv gives a CommRing path. We extract a BoolRing path from it.
sumToBoolPath : (f g : ‚Ąē ‚Üí ‚ü® freeBA ‚Ąē ‚ü©) ‚Üí
  freeBA ‚Ąē QB./Im (‚äé.rec f g) ‚Č°
  (freeBA ‚Ąē QB./Im f) QB./Im (fst QB.quotientImageHom ‚ąė g)
sumToBoolPath f g = uaBoolRing
  (invEq (CommRingPath _ _) (BoolQuotientEquiv (freeBA ‚Ąē) f g))

-- The iterated quotient (freeBA ‚Ąē /Im f) /Im (ŌÄ ‚ąė g) is countably presented.
iteratedQuotientPresented : (f g : ‚Ąē ‚Üí ‚ü® freeBA ‚Ąē ‚ü©) ‚Üí
  has-Boole-ŌČ' ((freeBA ‚Ąē QB./Im f) QB./Im (fst QB.quotientImageHom ‚ąė g))
iteratedQuotientPresented f g = subst has-Boole-ŌČ' (sumToBoolPath f g) (sumQuotientPresented f g)

-- Quotient compatible with equivalence: if A ‚ČÖ B then A /Im h ‚ČÖ B /Im (e ‚ąė h)
module equivQuot {A B : BooleanRing ‚Ąď-zero} (e : BooleanRingEquiv A B)
  {X : Type} (h : X ‚Üí ‚ü® A ‚ü©) where
  open BooleanRingStr ‚¶É...‚¶Ą
  instance
    _ = snd A
    _ = snd B
    _ = snd (A QB./Im h)
    _ = snd (B QB./Im (fst (fst e) ‚ąė h))

  eFwd : ‚ü® A ‚ü© ‚Üí ‚ü® B ‚ü©
  eFwd = fst (fst e)

  eBwd : ‚ü® B ‚ü© ‚Üí ‚ü® A ‚ü©
  eBwd = fst (fst (invBooleanRingEquiv A B e))

  eFwdHom : BoolHom A B
  eFwdHom = BooleanEquivToHom A B e

  eBwdHom : BoolHom B A
  eBwdHom = BooleanEquivToHomInv A B e

  eBwd‚ąėeFwd : eBwdHom ‚ąėcr eFwdHom ‚Č° idBoolHom A
  eBwd‚ąėeFwd = BooleanEquivLeftInv A B e

  eFwd‚ąėeBwd : eFwdHom ‚ąėcr eBwdHom ‚Č° idBoolHom B
  eFwd‚ąėeBwd = BooleanEquivRightInv A B e

  -- Forward: A ‚Üí B /Im (e ‚ąė h) via e then quotient
  ŌÜ : BoolHom A (B QB./Im (eFwd ‚ąė h))
  ŌÜ = QB.quotientImageHom ‚ąėcr eFwdHom

  ŌÜKills : (x : X) ‚Üí ŌÜ $cr h x ‚Č° ūĚüė
  ŌÜKills x = QB.zeroOnImage x

  fwdQ : BoolHom (A QB./Im h) (B QB./Im (eFwd ‚ąė h))
  fwdQ = QB.inducedHom (B QB./Im (eFwd ‚ąė h)) ŌÜ ŌÜKills

  -- Backward: B ‚Üí A /Im h via e‚ĀĽ¬Ļ then quotient
  Ōą : BoolHom B (A QB./Im h)
  Ōą = QB.quotientImageHom ‚ąėcr eBwdHom

  ŌąKills : (x : X) ‚Üí Ōą $cr (eFwd (h x)) ‚Č° ūĚüė
  ŌąKills x = cong (fst QB.quotientImageHom) (funExt‚ĀĽ (cong fst eBwd‚ąėeFwd) (h x))
    ‚ąô QB.zeroOnImage x

  bwdQ : BoolHom (B QB./Im (eFwd ‚ąė h)) (A QB./Im h)
  bwdQ = QB.inducedHom (A QB./Im h) Ōą ŌąKills

  fwdQ‚ąėŌÄ : fwdQ ‚ąėcr QB.quotientImageHom {B = A} {f = h} ‚Č° ŌÜ
  fwdQ‚ąėŌÄ = QB.evalInduce (B QB./Im (eFwd ‚ąė h))

  bwdQ‚ąėŌÄ : bwdQ ‚ąėcr QB.quotientImageHom {B = B} {f = eFwd ‚ąė h} ‚Č° Ōą
  bwdQ‚ąėŌÄ = QB.evalInduce (A QB./Im h)

  ret‚ąėŌÄ : (bwdQ ‚ąėcr fwdQ) ‚ąėcr QB.quotientImageHom {B = A} {f = h} ‚Č°
    idCommRingHom (BooleanRing‚ÜíCommRing (A QB./Im h)) ‚ąėcr QB.quotientImageHom
  ret‚ąėŌÄ =
    (bwdQ ‚ąėcr fwdQ) ‚ąėcr QB.quotientImageHom
      ‚Č°‚ü® CommRingHom‚Č° refl ‚ü©
    bwdQ ‚ąėcr (fwdQ ‚ąėcr QB.quotientImageHom)
      ‚Č°‚ü® cong (bwdQ ‚ąėcr_) fwdQ‚ąėŌÄ ‚ü©
    bwdQ ‚ąėcr (QB.quotientImageHom ‚ąėcr eFwdHom)
      ‚Č°‚ü® CommRingHom‚Č° refl ‚ü©
    (bwdQ ‚ąėcr QB.quotientImageHom) ‚ąėcr eFwdHom
      ‚Č°‚ü® cong (_‚ąėcr eFwdHom) bwdQ‚ąėŌÄ ‚ü©
    (QB.quotientImageHom ‚ąėcr eBwdHom) ‚ąėcr eFwdHom
      ‚Č°‚ü® CommRingHom‚Č° refl ‚ü©
    QB.quotientImageHom ‚ąėcr (eBwdHom ‚ąėcr eFwdHom)
      ‚Č°‚ü® cong (QB.quotientImageHom ‚ąėcr_) eBwd‚ąėeFwd ‚ü©
    QB.quotientImageHom ‚ąėcr idBoolHom A
      ‚Č°‚ü® CommRingHom‚Č° refl ‚ü©
    QB.quotientImageHom
      ‚Č°‚ü® sym (idCompCommRingHom QB.quotientImageHom) ‚ü©
    idCommRingHom _ ‚ąėcr QB.quotientImageHom ‚ąé

  sec‚ąėŌÄ : (fwdQ ‚ąėcr bwdQ) ‚ąėcr QB.quotientImageHom {B = B} {f = eFwd ‚ąė h} ‚Č°
    idCommRingHom (BooleanRing‚ÜíCommRing (B QB./Im (eFwd ‚ąė h))) ‚ąėcr QB.quotientImageHom
  sec‚ąėŌÄ =
    (fwdQ ‚ąėcr bwdQ) ‚ąėcr QB.quotientImageHom
      ‚Č°‚ü® CommRingHom‚Č° refl ‚ü©
    fwdQ ‚ąėcr (bwdQ ‚ąėcr QB.quotientImageHom)
      ‚Č°‚ü® cong (fwdQ ‚ąėcr_) bwdQ‚ąėŌÄ ‚ü©
    fwdQ ‚ąėcr (QB.quotientImageHom ‚ąėcr eBwdHom)
      ‚Č°‚ü® CommRingHom‚Č° refl ‚ü©
    (fwdQ ‚ąėcr QB.quotientImageHom) ‚ąėcr eBwdHom
      ‚Č°‚ü® cong (_‚ąėcr eBwdHom) fwdQ‚ąėŌÄ ‚ü©
    (QB.quotientImageHom ‚ąėcr eFwdHom) ‚ąėcr eBwdHom
      ‚Č°‚ü® CommRingHom‚Č° refl ‚ü©
    QB.quotientImageHom ‚ąėcr (eFwdHom ‚ąėcr eBwdHom)
      ‚Č°‚ü® cong (QB.quotientImageHom ‚ąėcr_) eFwd‚ąėeBwd ‚ü©
    QB.quotientImageHom ‚ąėcr idBoolHom B
      ‚Č°‚ü® CommRingHom‚Č° refl ‚ü©
    QB.quotientImageHom
      ‚Č°‚ü® sym (idCompCommRingHom QB.quotientImageHom) ‚ü©
    idCommRingHom _ ‚ąėcr QB.quotientImageHom ‚ąé

  retQ : bwdQ ‚ąėcr fwdQ ‚Č° idCommRingHom (BooleanRing‚ÜíCommRing (A QB./Im h))
  retQ = CommRingHom‚Č° $
    QB.quotientImageHomEpi {B = A} {f = h}
      (‚ü® A QB./Im h ‚ü© , BooleanRingStr.is-set (snd (A QB./Im h)))
      (cong fst ret‚ąėŌÄ)

  secQ : fwdQ ‚ąėcr bwdQ ‚Č° idCommRingHom (BooleanRing‚ÜíCommRing (B QB./Im (eFwd ‚ąė h)))
  secQ = CommRingHom‚Č° $
    QB.quotientImageHomEpi {B = B} {f = eFwd ‚ąė h}
      (‚ü® B QB./Im (eFwd ‚ąė h) ‚ü© , BooleanRingStr.is-set (snd (B QB./Im (eFwd ‚ąė h))))
      (cong fst sec‚ąėŌÄ)

  equivQuotient : BooleanRingEquiv (A QB./Im h) (B QB./Im (eFwd ‚ąė h))
  equivQuotient = isoToCommRingEquiv fwdQ (fst bwdQ)
    (funExt‚ĀĽ (cong fst secQ)) (funExt‚ĀĽ (cong fst retQ))

-- Main theorem: if B is countably presented and g lifts h through the quotient map,
-- then B /Im h is countably presented.
module mainTheorem (B : BooleanRing ‚Ąď-zero)
  (pres : has-Boole-ŌČ' B) (h : ‚Ąē ‚Üí ‚ü® B ‚ü©)
  (g : ‚Ąē ‚Üí ‚ü® freeBA ‚Ąē ‚ü©)
  (liftCond : fst QB.quotientImageHom ‚ąė g ‚Č° fst (fst (snd pres)) ‚ąė h) where

  f : ‚Ąē ‚Üí ‚ü® freeBA ‚Ąē ‚ü©
  f = fst pres

  e : BooleanRingEquiv B (freeBA ‚Ąē QB./Im f)
  e = snd pres

  eFwd : ‚ü® B ‚ü© ‚Üí ‚ü® freeBA ‚Ąē QB./Im f ‚ü©
  eFwd = fst (fst e)

  -- Step 1: B /Im h ‚ČÖ (freeBA ‚Ąē /Im f) /Im (e ‚ąė h) via equivQuot
  step1 : BooleanRingEquiv (B QB./Im h) ((freeBA ‚Ąē QB./Im f) QB./Im (eFwd ‚ąė h))
  step1 = equivQuot.equivQuotient e h

  -- Step 2: (freeBA ‚Ąē /Im f) /Im (e ‚ąė h) = (freeBA ‚Ąē /Im f) /Im (ŌÄ ‚ąė g)
  -- by the lift condition: ŌÄ ‚ąė g = e ‚ąė h
  step2Path : (freeBA ‚Ąē QB./Im f) QB./Im (eFwd ‚ąė h) ‚Č°
    (freeBA ‚Ąē QB./Im f) QB./Im (fst QB.quotientImageHom ‚ąė g)
  step2Path = cong (őĽ q ‚Üí (freeBA ‚Ąē QB./Im f) QB./Im q) (sym liftCond)

  -- Step 3: (freeBA ‚Ąē /Im f) /Im (ŌÄ ‚ąė g) is countably presented
  step3 : has-Boole-ŌČ' ((freeBA ‚Ąē QB./Im f) QB./Im (fst QB.quotientImageHom ‚ąė g))
  step3 = iteratedQuotientPresented f g

  -- Combine: B /Im h is countably presented
  result : has-Boole-ŌČ' (B QB./Im h)
  result = subst has-Boole-ŌČ' (sym chainPath) step3 where
    path1 : B QB./Im h ‚Č° (freeBA ‚Ąē QB./Im f) QB./Im (eFwd ‚ąė h)
    path1 = uaBoolRing step1

    chainPath : B QB./Im h ‚Č° (freeBA ‚Ąē QB./Im f) QB./Im (fst QB.quotientImageHom ‚ąė g)
    chainPath = path1 ‚ąô step2Path

-- Top-level theorem: countably presented quotients are countably presented,
-- given a lift of h through the quotient map.
countablyPresentedQuotient :
  (B : BooleanRing ‚Ąď-zero) ‚Üí
  (pres : has-Boole-ŌČ' B) ‚Üí
  (h : ‚Ąē ‚Üí ‚ü® B ‚ü©) ‚Üí
  (g : ‚Ąē ‚Üí ‚ü® freeBA ‚Ąē ‚ü©) ‚Üí
  (liftCond : fst QB.quotientImageHom ‚ąė g ‚Č° fst (fst (snd pres)) ‚ąė h) ‚Üí
  has-Boole-ŌČ' (B QB./Im h)
countablyPresentedQuotient B pres h g lc = mainTheorem.result B pres h g lc

-- Variant: when h already factors through the quotient map
-- (i.e., h = e‚ĀĽ¬Ļ ‚ąė ŌÄ ‚ąė g for some g : ‚Ąē ‚Üí ‚ü® freeBA ‚Ąē ‚ü©)
countablyPresentedQuotientViaLift :
  (f g : ‚Ąē ‚Üí ‚ü® freeBA ‚Ąē ‚ü©) ‚Üí
  has-Boole-ŌČ' ((freeBA ‚Ąē QB./Im f) QB./Im (fst QB.quotientImageHom ‚ąė g))
countablyPresentedQuotientViaLift = iteratedQuotientPresented


