-- Reindexing: if Пғ : Iso X Y, then A /Im f вү… A /Im (f вҲҳ Iso.inv Пғ)
module reindex {A : BooleanRing в„“-zero} {X Y : Type} (Пғ : Iso X Y) (f : X вҶ’ вҹЁ A вҹ©) where
  open BooleanRingStr вҰғ...вҰ„
  instance
    _ = snd A
    _ = snd (A QB./Im f)
    _ = snd (A QB./Im (f вҲҳ Iso.inv Пғ))

  f' : Y вҶ’ вҹЁ A вҹ©
  f' = f вҲҳ Iso.inv Пғ

  fwdKills : (x : X) вҶ’ QB.quotientImageHom {B = A} {f = f'} $cr f x вүЎ рқҹҳ
  fwdKills x = subst (О» a вҶ’ QB.quotientImageHom {B = A} {f = f'} $cr a вүЎ рқҹҳ)
    (cong f (Iso.ret Пғ x))
    (QB.zeroOnImage (Iso.fun Пғ x))

  fwd : BoolHom (A QB./Im f) (A QB./Im f')
  fwd = QB.inducedHom (A QB./Im f') QB.quotientImageHom fwdKills

  bwdKills : (y : Y) вҶ’ QB.quotientImageHom {B = A} {f = f} $cr f' y вүЎ рқҹҳ
  bwdKills y = QB.zeroOnImage (Iso.inv Пғ y)

  bwd : BoolHom (A QB./Im f') (A QB./Im f)
  bwd = QB.inducedHom (A QB./Im f) QB.quotientImageHom bwdKills

  fwdвҲҳПҖ : fwd вҲҳcr QB.quotientImageHom {B = A} {f = f} вүЎ QB.quotientImageHom
  fwdвҲҳПҖ = QB.evalInduce (A QB./Im f')

  bwdвҲҳПҖ : bwd вҲҳcr QB.quotientImageHom {B = A} {f = f'} вүЎ QB.quotientImageHom
  bwdвҲҳПҖ = QB.evalInduce (A QB./Im f)

  retвҲҳПҖ : (bwd вҲҳcr fwd) вҲҳcr QB.quotientImageHom {B = A} {f = f} вүЎ
          idCommRingHom (BooleanRingвҶ’CommRing (A QB./Im f)) вҲҳcr QB.quotientImageHom
  retвҲҳПҖ =
    (bwd вҲҳcr fwd) вҲҳcr QB.quotientImageHom
      вүЎвҹЁ CommRingHomвүЎ refl вҹ©
    bwd вҲҳcr (fwd вҲҳcr QB.quotientImageHom)
      вүЎвҹЁ cong (bwd вҲҳcr_) fwdвҲҳПҖ вҹ©
    bwd вҲҳcr QB.quotientImageHom {B = A} {f = f'}
      вүЎвҹЁ bwdвҲҳПҖ вҹ©
    QB.quotientImageHom
      вүЎвҹЁ sym (idCompCommRingHom QB.quotientImageHom) вҹ©
    idCommRingHom _ вҲҳcr QB.quotientImageHom вҲҺ

  secвҲҳПҖ : (fwd вҲҳcr bwd) вҲҳcr QB.quotientImageHom {B = A} {f = f'} вүЎ
          idCommRingHom (BooleanRingвҶ’CommRing (A QB./Im f')) вҲҳcr QB.quotientImageHom
  secвҲҳПҖ =
    (fwd вҲҳcr bwd) вҲҳcr QB.quotientImageHom
      вүЎвҹЁ CommRingHomвүЎ refl вҹ©
    fwd вҲҳcr (bwd вҲҳcr QB.quotientImageHom)
      вүЎвҹЁ cong (fwd вҲҳcr_) bwdвҲҳПҖ вҹ©
    fwd вҲҳcr QB.quotientImageHom {B = A} {f = f}
      вүЎвҹЁ fwdвҲҳПҖ вҹ©
    QB.quotientImageHom
      вүЎвҹЁ sym (idCompCommRingHom QB.quotientImageHom) вҹ©
    idCommRingHom _ вҲҳcr QB.quotientImageHom вҲҺ

  ret : bwd вҲҳcr fwd вүЎ idCommRingHom (BooleanRingвҶ’CommRing (A QB./Im f))
  ret = CommRingHomвүЎ $
    QB.quotientImageHomEpi {B = A} {f = f}
      (вҹЁ A QB./Im f вҹ© , BooleanRingStr.is-set (snd (A QB./Im f)))
      (cong fst retвҲҳПҖ)

  sec : fwd вҲҳcr bwd вүЎ idCommRingHom (BooleanRingвҶ’CommRing (A QB./Im f'))
  sec = CommRingHomвүЎ $
    QB.quotientImageHomEpi {B = A} {f = f'}
      (вҹЁ A QB./Im f' вҹ© , BooleanRingStr.is-set (snd (A QB./Im f')))
      (cong fst secвҲҳПҖ)

  reindexEquiv : BooleanRingEquiv (A QB./Im f) (A QB./Im f')
  reindexEquiv = isoToCommRingEquiv fwd (fst bwd)
    (funExtвҒ» (cong fst sec)) (funExtвҒ» (cong fst ret))

open import BooleanRing.BoolRingUnivalence

-- Given f, g : в„• вҶ’ вҹЁ freeBA в„• вҹ©, the combined quotient is countably presented.
-- freeBA в„• /Im (вҠҺ.rec f g) вү… freeBA в„• /Im k where k : в„• вҶ’ вҹЁ freeBA в„• вҹ©
sumQuotientPresented : (f g : в„• вҶ’ вҹЁ freeBA в„• вҹ©) вҶ’ has-Boole-Пү' (freeBA в„• QB./Im (вҠҺ.rec f g))
sumQuotientPresented f g = k , equivChain where
  k : в„• вҶ’ вҹЁ freeBA в„• вҹ©
  k = вҠҺ.rec f g вҲҳ Iso.inv в„•вҠҺв„•вү…в„•

  equivChain : BooleanRingEquiv (freeBA в„• QB./Im (вҠҺ.rec f g)) (freeBA в„• QB./Im k)
  equivChain = reindex.reindexEquiv в„•вҠҺв„•вү…в„• (вҠҺ.rec f g)

-- BoolQuotientEquiv gives a CommRing path. We extract a BoolRing path from it.
sumToBoolPath : (f g : в„• вҶ’ вҹЁ freeBA в„• вҹ©) вҶ’
  freeBA в„• QB./Im (вҠҺ.rec f g) вүЎ
  (freeBA в„• QB./Im f) QB./Im (fst QB.quotientImageHom вҲҳ g)
sumToBoolPath f g = uaBoolRing
  (invEq (CommRingPath _ _) (BoolQuotientEquiv (freeBA в„•) f g))

-- The iterated quotient (freeBA в„• /Im f) /Im (ПҖ вҲҳ g) is countably presented.
iteratedQuotientPresented : (f g : в„• вҶ’ вҹЁ freeBA в„• вҹ©) вҶ’
  has-Boole-Пү' ((freeBA в„• QB./Im f) QB./Im (fst QB.quotientImageHom вҲҳ g))
iteratedQuotientPresented f g = subst has-Boole-Пү' (sumToBoolPath f g) (sumQuotientPresented f g)

-- Quotient compatible with equivalence: if A вү… B then A /Im h вү… B /Im (e вҲҳ h)
module equivQuot {A B : BooleanRing в„“-zero} (e : BooleanRingEquiv A B)
  {X : Type} (h : X вҶ’ вҹЁ A вҹ©) where
  open BooleanRingStr вҰғ...вҰ„
  instance
    _ = snd A
    _ = snd B
    _ = snd (A QB./Im h)
    _ = snd (B QB./Im (fst (fst e) вҲҳ h))

  eFwd : вҹЁ A вҹ© вҶ’ вҹЁ B вҹ©
  eFwd = fst (fst e)

  eBwd : вҹЁ B вҹ© вҶ’ вҹЁ A вҹ©
  eBwd = fst (fst (invBooleanRingEquiv A B e))

  eFwdHom : BoolHom A B
  eFwdHom = BooleanEquivToHom A B e

  eBwdHom : BoolHom B A
  eBwdHom = BooleanEquivToHomInv A B e

  eBwdвҲҳeFwd : eBwdHom вҲҳcr eFwdHom вүЎ idBoolHom A
  eBwdвҲҳeFwd = BooleanEquivLeftInv A B e

  eFwdвҲҳeBwd : eFwdHom вҲҳcr eBwdHom вүЎ idBoolHom B
  eFwdвҲҳeBwd = BooleanEquivRightInv A B e

  -- Forward: A вҶ’ B /Im (e вҲҳ h) via e then quotient
  ПҶ : BoolHom A (B QB./Im (eFwd вҲҳ h))
  ПҶ = QB.quotientImageHom вҲҳcr eFwdHom

  ПҶKills : (x : X) вҶ’ ПҶ $cr h x вүЎ рқҹҳ
  ПҶKills x = QB.zeroOnImage x

  fwdQ : BoolHom (A QB./Im h) (B QB./Im (eFwd вҲҳ h))
  fwdQ = QB.inducedHom (B QB./Im (eFwd вҲҳ h)) ПҶ ПҶKills

  -- Backward: B вҶ’ A /Im h via eвҒ»В№ then quotient
  ПҲ : BoolHom B (A QB./Im h)
  ПҲ = QB.quotientImageHom вҲҳcr eBwdHom

  ПҲKills : (x : X) вҶ’ ПҲ $cr (eFwd (h x)) вүЎ рқҹҳ
  ПҲKills x = cong (fst QB.quotientImageHom) (funExtвҒ» (cong fst eBwdвҲҳeFwd) (h x))
    вҲҷ QB.zeroOnImage x

  bwdQ : BoolHom (B QB./Im (eFwd вҲҳ h)) (A QB./Im h)
  bwdQ = QB.inducedHom (A QB./Im h) ПҲ ПҲKills

  fwdQвҲҳПҖ : fwdQ вҲҳcr QB.quotientImageHom {B = A} {f = h} вүЎ ПҶ
  fwdQвҲҳПҖ = QB.evalInduce (B QB./Im (eFwd вҲҳ h))

  bwdQвҲҳПҖ : bwdQ вҲҳcr QB.quotientImageHom {B = B} {f = eFwd вҲҳ h} вүЎ ПҲ
  bwdQвҲҳПҖ = QB.evalInduce (A QB./Im h)

  retвҲҳПҖ : (bwdQ вҲҳcr fwdQ) вҲҳcr QB.quotientImageHom {B = A} {f = h} вүЎ
    idCommRingHom (BooleanRingвҶ’CommRing (A QB./Im h)) вҲҳcr QB.quotientImageHom
  retвҲҳПҖ =
    (bwdQ вҲҳcr fwdQ) вҲҳcr QB.quotientImageHom
      вүЎвҹЁ CommRingHomвүЎ refl вҹ©
    bwdQ вҲҳcr (fwdQ вҲҳcr QB.quotientImageHom)
      вүЎвҹЁ cong (bwdQ вҲҳcr_) fwdQвҲҳПҖ вҹ©
    bwdQ вҲҳcr (QB.quotientImageHom вҲҳcr eFwdHom)
      вүЎвҹЁ CommRingHomвүЎ refl вҹ©
    (bwdQ вҲҳcr QB.quotientImageHom) вҲҳcr eFwdHom
      вүЎвҹЁ cong (_вҲҳcr eFwdHom) bwdQвҲҳПҖ вҹ©
    (QB.quotientImageHom вҲҳcr eBwdHom) вҲҳcr eFwdHom
      вүЎвҹЁ CommRingHomвүЎ refl вҹ©
    QB.quotientImageHom вҲҳcr (eBwdHom вҲҳcr eFwdHom)
      вүЎвҹЁ cong (QB.quotientImageHom вҲҳcr_) eBwdвҲҳeFwd вҹ©
    QB.quotientImageHom вҲҳcr idBoolHom A
      вүЎвҹЁ CommRingHomвүЎ refl вҹ©
    QB.quotientImageHom
      вүЎвҹЁ sym (idCompCommRingHom QB.quotientImageHom) вҹ©
    idCommRingHom _ вҲҳcr QB.quotientImageHom вҲҺ

  secвҲҳПҖ : (fwdQ вҲҳcr bwdQ) вҲҳcr QB.quotientImageHom {B = B} {f = eFwd вҲҳ h} вүЎ
    idCommRingHom (BooleanRingвҶ’CommRing (B QB./Im (eFwd вҲҳ h))) вҲҳcr QB.quotientImageHom
  secвҲҳПҖ =
    (fwdQ вҲҳcr bwdQ) вҲҳcr QB.quotientImageHom
      вүЎвҹЁ CommRingHomвүЎ refl вҹ©
    fwdQ вҲҳcr (bwdQ вҲҳcr QB.quotientImageHom)
      вүЎвҹЁ cong (fwdQ вҲҳcr_) bwdQвҲҳПҖ вҹ©
    fwdQ вҲҳcr (QB.quotientImageHom вҲҳcr eBwdHom)
      вүЎвҹЁ CommRingHomвүЎ refl вҹ©
    (fwdQ вҲҳcr QB.quotientImageHom) вҲҳcr eBwdHom
      вүЎвҹЁ cong (_вҲҳcr eBwdHom) fwdQвҲҳПҖ вҹ©
    (QB.quotientImageHom вҲҳcr eFwdHom) вҲҳcr eBwdHom
      вүЎвҹЁ CommRingHomвүЎ refl вҹ©
    QB.quotientImageHom вҲҳcr (eFwdHom вҲҳcr eBwdHom)
      вүЎвҹЁ cong (QB.quotientImageHom вҲҳcr_) eFwdвҲҳeBwd вҹ©
    QB.quotientImageHom вҲҳcr idBoolHom B
      вүЎвҹЁ CommRingHomвүЎ refl вҹ©
    QB.quotientImageHom
      вүЎвҹЁ sym (idCompCommRingHom QB.quotientImageHom) вҹ©
    idCommRingHom _ вҲҳcr QB.quotientImageHom вҲҺ

  retQ : bwdQ вҲҳcr fwdQ вүЎ idCommRingHom (BooleanRingвҶ’CommRing (A QB./Im h))
  retQ = CommRingHomвүЎ $
    QB.quotientImageHomEpi {B = A} {f = h}
      (вҹЁ A QB./Im h вҹ© , BooleanRingStr.is-set (snd (A QB./Im h)))
      (cong fst retвҲҳПҖ)

  secQ : fwdQ вҲҳcr bwdQ вүЎ idCommRingHom (BooleanRingвҶ’CommRing (B QB./Im (eFwd вҲҳ h)))
  secQ = CommRingHomвүЎ $
    QB.quotientImageHomEpi {B = B} {f = eFwd вҲҳ h}
      (вҹЁ B QB./Im (eFwd вҲҳ h) вҹ© , BooleanRingStr.is-set (snd (B QB./Im (eFwd вҲҳ h))))
      (cong fst secвҲҳПҖ)

  equivQuotient : BooleanRingEquiv (A QB./Im h) (B QB./Im (eFwd вҲҳ h))
  equivQuotient = isoToCommRingEquiv fwdQ (fst bwdQ)
    (funExtвҒ» (cong fst secQ)) (funExtвҒ» (cong fst retQ))

-- Main theorem: if B is countably presented and g lifts h through the quotient map,
-- then B /Im h is countably presented.
module mainTheorem (B : BooleanRing в„“-zero)
  (pres : has-Boole-Пү' B) (h : в„• вҶ’ вҹЁ B вҹ©)
  (g : в„• вҶ’ вҹЁ freeBA в„• вҹ©)
  (liftCond : fst QB.quotientImageHom вҲҳ g вүЎ fst (fst (snd pres)) вҲҳ h) where

  f : в„• вҶ’ вҹЁ freeBA в„• вҹ©
  f = fst pres

  e : BooleanRingEquiv B (freeBA в„• QB./Im f)
  e = snd pres

  eFwd : вҹЁ B вҹ© вҶ’ вҹЁ freeBA в„• QB./Im f вҹ©
  eFwd = fst (fst e)

  -- Step 1: B /Im h вү… (freeBA в„• /Im f) /Im (e вҲҳ h) via equivQuot
  step1 : BooleanRingEquiv (B QB./Im h) ((freeBA в„• QB./Im f) QB./Im (eFwd вҲҳ h))
  step1 = equivQuot.equivQuotient e h

  -- Step 2: (freeBA в„• /Im f) /Im (e вҲҳ h) = (freeBA в„• /Im f) /Im (ПҖ вҲҳ g)
  -- by the lift condition: ПҖ вҲҳ g = e вҲҳ h
  step2Path : (freeBA в„• QB./Im f) QB./Im (eFwd вҲҳ h) вүЎ
    (freeBA в„• QB./Im f) QB./Im (fst QB.quotientImageHom вҲҳ g)
  step2Path = cong (О» q вҶ’ (freeBA в„• QB./Im f) QB./Im q) (sym liftCond)

  -- Step 3: (freeBA в„• /Im f) /Im (ПҖ вҲҳ g) is countably presented
  step3 : has-Boole-Пү' ((freeBA в„• QB./Im f) QB./Im (fst QB.quotientImageHom вҲҳ g))
  step3 = iteratedQuotientPresented f g

  -- Combine: B /Im h is countably presented
  result : has-Boole-Пү' (B QB./Im h)
  result = subst has-Boole-Пү' (sym chainPath) step3 where
    path1 : B QB./Im h вүЎ (freeBA в„• QB./Im f) QB./Im (eFwd вҲҳ h)
    path1 = uaBoolRing step1

    chainPath : B QB./Im h вүЎ (freeBA в„• QB./Im f) QB./Im (fst QB.quotientImageHom вҲҳ g)
    chainPath = path1 вҲҷ step2Path

-- Top-level theorem: countably presented quotients are countably presented,
-- given a lift of h through the quotient map.
countablyPresentedQuotient :
  (B : BooleanRing в„“-zero) вҶ’
  (pres : has-Boole-Пү' B) вҶ’
  (h : в„• вҶ’ вҹЁ B вҹ©) вҶ’
  (g : в„• вҶ’ вҹЁ freeBA в„• вҹ©) вҶ’
  (liftCond : fst QB.quotientImageHom вҲҳ g вүЎ fst (fst (snd pres)) вҲҳ h) вҶ’
  has-Boole-Пү' (B QB./Im h)
countablyPresentedQuotient B pres h g lc = mainTheorem.result B pres h g lc

-- Variant: when h already factors through the quotient map
-- (i.e., h = eвҒ»В№ вҲҳ ПҖ вҲҳ g for some g : в„• вҶ’ вҹЁ freeBA в„• вҹ©)
countablyPresentedQuotientViaLift :
  (f g : в„• вҶ’ вҹЁ freeBA в„• вҹ©) вҶ’
  has-Boole-Пү' ((freeBA в„• QB./Im f) QB./Im (fst QB.quotientImageHom вҲҳ g))
countablyPresentedQuotientViaLift = iteratedQuotientPresented

-- Application: BoolBR /Im Оұ is countably presented for any Оұ : в„• вҶ’ Bool
open import Cubical.Data.Bool using (Bool ; true ; false)
open import Cubical.Algebra.BooleanRing.Instances.Bool using (BoolBR)
open import CountablyPresentedBooleanRings.Examples.Bool using (is-cp-2)

module boolQuotient where
  open IsCommRingHom
  open BooleanRingStr (snd (freeBA в„•)) using (рқҹҷ ; рқҹҳ)

  private
    fвӮҖ = fst is-cp-2
    e = snd is-cp-2
    eFwd = fst (fst e)
    ПҖ : BoolHom (freeBA в„•) (freeBA в„• QB./Im fвӮҖ)
    ПҖ = QB.quotientImageHom

  boolLift : Bool вҶ’ вҹЁ freeBA в„• вҹ©
  boolLift true  = рқҹҷ
  boolLift false = рқҹҳ

  liftCondition : (Оұ : в„• вҶ’ Bool) вҶ’
    fst ПҖ вҲҳ (boolLift вҲҳ Оұ) вүЎ eFwd вҲҳ Оұ
  liftCondition Оұ = funExt pointwise where
    pointwise : (n : в„•) вҶ’ fst ПҖ (boolLift (Оұ n)) вүЎ eFwd (Оұ n)
    pointwise n with Оұ n
    ... | true  = pres1 (snd ПҖ) вҲҷ sym (pres1 (snd e))
    ... | false = pres0 (snd ПҖ) вҲҷ sym (pres0 (snd e))

  boolQuotientPresented : (Оұ : в„• вҶ’ Bool) вҶ’ has-Boole-Пү' (BoolBR QB./Im Оұ)
  boolQuotientPresented Оұ =
    countablyPresentedQuotient BoolBR is-cp-2 Оұ (boolLift вҲҳ Оұ) (liftCondition Оұ)

-- Equivalence of has-Boole-Пү and has-Boole-Пү'
open import CountablyPresentedBooleanRings.Examples.FreeCase
import BooleanRing.BooleanRingQuotients.QuotientCase as QC
open import WLPO using (binarySequence)

module omegaCore (Оұ Оі : binarySequence) where
  private
    A' = ОЈ[ n вҲҲ в„• ] Оұ n вүЎ true
    r = gensThatAreNotInA Оұ

  quotientOfFreeIsCP :
    (f : (ОЈ[ n вҲҲ в„• ] Оі n вүЎ true) вҶ’ вҹЁ freeBA A' вҹ©) вҶ’
    has-Boole-Пү' (freeBA A' QB./Im f)
  quotientOfFreeIsCP f = subst has-Boole-Пү' (sym chainPath) step5 where
    g : в„• вҶ’ вҹЁ freeBA A' вҹ©
    g = QC.expand.g {Оі = Оі} {в„“ = в„“-zero} (freeBA A') f

    expandEquiv : BooleanRingEquiv (freeBA A' QB./Im g) (freeBA A' QB./Im f)
    expandEquiv = QC.expand.claim {Оі} (freeBA A') f

    fwdEquiv : BooleanRingEquiv (freeBA A') (freeBA в„• QB./Im r)
    fwdEquiv .fst .fst = fst (freeAвҶ’freeAcp Оұ)
    fwdEquiv .fst .snd = isoToIsEquiv myIso where
      myIso : Iso вҹЁ freeBA A' вҹ© вҹЁ freeBA в„• QB./Im r вҹ©
      myIso .Iso.fun = fst (freeAвҶ’freeAcp Оұ)
      myIso .Iso.inv = fst (freeAcpвҶ’freeA Оұ)
      myIso .Iso.sec = funExtвҒ» (freeAcpвҶ’freeAcpвүЎid Оұ)
      myIso .Iso.ret = funExtвҒ» (cong fst (freeAвҶ’freeAвүЎid Оұ))
    fwdEquiv .snd = snd (freeAвҶ’freeAcp Оұ)

    liftG : в„• вҶ’ вҹЁ freeBA в„• вҹ©
    liftG = fst (freeAвҶ’freeв„• Оұ) вҲҳ g

    quotEquiv : BooleanRingEquiv (freeBA A' QB./Im g)
      ((freeBA в„• QB./Im r) QB./Im (fst (freeAвҶ’freeAcp Оұ) вҲҳ g))
    quotEquiv = equivQuot.equivQuotient fwdEquiv g

    step5 : has-Boole-Пү' ((freeBA в„• QB./Im r) QB./Im (fst QB.quotientImageHom вҲҳ liftG))
    step5 = iteratedQuotientPresented r liftG

    chainPath : freeBA A' QB./Im f вүЎ
      (freeBA в„• QB./Im r) QB./Im (fst QB.quotientImageHom вҲҳ liftG)
    chainPath = sym (uaBoolRing expandEquiv) вҲҷ uaBoolRing quotEquiv

has-BooleвҶ’has-Boole' : (B : BooleanRing в„“-zero) вҶ’ has-Boole-Пү B вҶ’ has-Boole-Пү' B
