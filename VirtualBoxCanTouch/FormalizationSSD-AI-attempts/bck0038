record SeqFib (A : Sequence в„“) : Type (в„“-suc в„“) where
  field
    P    : (n : в„•) вҶ’ obj A n вҶ’ Type в„“
    Pmap : (n : в„•) (a : obj A n) вҶ’ P n a вҶ’ P (suc n) (map A a)
open SeqFib

ОЈSeq : (A : Sequence в„“) вҶ’ SeqFib A вҶ’ Sequence в„“
obj (ОЈSeq A B) n = ОЈ (obj A n) (P B n)
map (ОЈSeq A B) (a , b) = map A a , Pmap B _ a b

ОЈ-proj : (A : Sequence в„“) (B : SeqFib A) вҶ’ SeqColim (ОЈSeq A B) вҶ’ SeqColim A
ОЈ-proj A B (incl (a , _)) = incl a
ОЈ-proj A B (push (a , _) i) = push a i

singletonSeq : (A : Sequence в„“) вҶ’ obj A 0 вҶ’ Sequence в„“
obj (singletonSeq A xвӮҖ) n = ОЈ (obj A (n + 0)) (О» a вҶ’ iterMap A n xвӮҖ вүЎ a)
map (singletonSeq A xвӮҖ) (a , p) = map A a , cong (map A) p

singletonSeq-colim-contr : (A : Sequence в„“) (xвӮҖ : obj A 0) вҶ’ isContr (SeqColim (singletonSeq A xвӮҖ))
singletonSeq-colim-contr A xвӮҖ = colimitContr (singletonSeq A xвӮҖ)
  (О» n вҶ’ (iterMap A n xвӮҖ , refl) , О» { (a , p) i вҶ’ p i , О» j вҶ’ p (i вҲ§ j) })
