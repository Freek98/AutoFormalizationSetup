-- В§1. Convenience eliminators
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
module _ (X : Sequence в„“) where
  SeqColim-elimProp : {P : SeqColim X вҶ’ Type в„“'}
    вҶ’ ((x : SeqColim X) вҶ’ isProp (P x))
    вҶ’ ({n : в„•} (a : obj X n) вҶ’ P (incl a))
    вҶ’ (x : SeqColim X) вҶ’ P x
  SeqColim-elimProp hP f (incl x) = f x
  SeqColim-elimProp hP f (push x i) =
    isPropвҶ’PathP (О» i вҶ’ hP (push x i)) (f x) (f (map X x)) i

  SeqColim-rec : {B : Type в„“'} вҶ’ isSet B
    вҶ’ (f : {n : в„•} вҶ’ obj X n вҶ’ B)
    вҶ’ ({n : в„•} (a : obj X n) вҶ’ f a вүЎ f (map X a))
    вҶ’ SeqColim X вҶ’ B
  SeqColim-rec hB f p (incl x) = f x
  SeqColim-rec hB f p (push x i) = p x i

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- В§2. Iterated maps
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
iterMap : (X : Sequence в„“) (k : в„•) {n : в„•} вҶ’ obj X n вҶ’ obj X (k + n)
iterMap X zero    x = x
iterMap X (suc k) x = map X (iterMap X k x)

push-fwd : (X : Sequence в„“) (k : в„•) {n : в„•} (x : obj X n)
  вҶ’ incl {X = X} x вүЎ incl (iterMap X k x)
push-fwd X zero    x = refl
push-fwd X (suc k) x = push-fwd X k x вҲҷ push (iterMap X k x)

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- В§3. Colimit of contractible types is contractible
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
contrвҶ’converges : (X : Sequence в„“) вҶ’ ((n : в„•) вҶ’ isContr (obj X n)) вҶ’ converges X 0
contrвҶ’converges X hC k =
  subst (О» m вҶ’ isEquiv (map X {n = m})) (sym (+-zero k))
    (isEquivFromIsContr (map X) (hC k) (hC (suc k)))

colimitContr : (X : Sequence в„“) вҶ’ ((n : в„•) вҶ’ isContr (obj X n)) вҶ’ isContr (SeqColim X)
colimitContr X hC =
  isOfHLevelRespectEquiv 0
    (isoToEquiv (convergesвҶ’ColimIso 0 (contrвҶ’converges X hC))) (hC 0)

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- В§4вҖ“6. Truncated sequence and propositional truncation commutes
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
truncSeq : Sequence в„“ вҶ’ Sequence в„“
obj (truncSeq X) n = вҲҘ obj X n вҲҘвӮҒ
map (truncSeq X) = PT.map (map X)

trunc-fwd : (X : Sequence в„“) вҶ’ SeqColim X вҶ’ SeqColim (truncSeq X)
trunc-fwd X (incl x)   = incl вҲЈ x вҲЈвӮҒ
trunc-fwd X (push x i) = push вҲЈ x вҲЈвӮҒ i

trunc-bwd : (X : Sequence в„“) вҶ’ SeqColim (truncSeq X) вҶ’ вҲҘ SeqColim X вҲҘвӮҒ
trunc-bwd X = SeqColim-elimProp (truncSeq X)
  (О» _ вҶ’ squashвӮҒ) (О» {n} ta вҶ’ PT.rec squashвӮҒ (О» a вҶ’ вҲЈ incl {n = n} a вҲЈвӮҒ) ta)

truncSeq-contr-from-incl : (X : Sequence в„“) {n : в„•} (a : obj X n)
  вҶ’ isContr (SeqColim (truncSeq X))
truncSeq-contr-from-incl X {n} a =
  isOfHLevelRespectEquiv 0 (isoToEquiv (invIso (SeqColimIso (truncSeq X) n)))
    (colimitContr (ShiftSequence+ (truncSeq X) n)
      (О» k вҶ’ inhPropвҶ’isContr вҲЈ iterMap X k a вҲЈвӮҒ squashвӮҒ))

SeqColim-truncSeq-isProp : (X : Sequence в„“) вҶ’ isProp (SeqColim (truncSeq X))
SeqColim-truncSeq-isProp X x y = sym (snd c x) вҲҷ snd c y where
  c = SeqColim-elimProp (truncSeq X) (О» _ вҶ’ isPropIsContr)
    (О» {n} ta вҶ’ PT.rec isPropIsContr (О» a вҶ’ truncSeq-contr-from-incl X a) ta) x

truncCommutes : (X : Sequence в„“) вҶ’ Iso вҲҘ SeqColim X вҲҘвӮҒ (SeqColim (truncSeq X))
fun (truncCommutes X) = PT.rec (SeqColim-truncSeq-isProp X) (trunc-fwd X)
inv (truncCommutes X) = trunc-bwd X
sec (truncCommutes X) _ = SeqColim-truncSeq-isProp X _ _
ret (truncCommutes X) _ = squashвӮҒ _ _

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- В§7. Universal property
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
record Cocone (X : Sequence в„“) (B : Type в„“') : Type (в„“-max в„“ в„“') where
  constructor cocone
  field
    leg  : {n : в„•} вҶ’ obj X n вҶ’ B
    comm : {n : в„•} (a : obj X n) вҶ’ leg a вүЎ leg (map X a)
open Cocone

canonCocone : (X : Sequence в„“) вҶ’ Cocone X (SeqColim X)
leg  (canonCocone X) = incl
comm (canonCocone X) = push

coconeRec : (X : Sequence в„“) {B : Type в„“'} вҶ’ Cocone X B вҶ’ SeqColim X вҶ’ B
coconeRec X c (incl x)   = leg c x
coconeRec X c (push x i) = comm c x i

restrict : (X : Sequence в„“) {B : Type в„“'} вҶ’ (SeqColim X вҶ’ B) вҶ’ Cocone X B
leg  (restrict X f) a = f (incl a)
comm (restrict X f) a = cong f (push a)

restrictвҲҳrec : (X : Sequence в„“) {B : Type в„“'} (c : Cocone X B) вҶ’ restrict X (coconeRec X c) вүЎ c
restrictвҲҳrec X c = refl

recвҲҳrestrict : (X : Sequence в„“) {B : Type в„“'} (f : SeqColim X вҶ’ B) вҶ’ coconeRec X (restrict X f) вүЎ f
recвҲҳrestrict X f = funExt go where
  go : (x : SeqColim X) вҶ’ coconeRec X (restrict X f) x вүЎ f x
  go (incl x)   = refl
  go (push x i) = refl

coconeEquiv : (X : Sequence в„“) (B : Type в„“') вҶ’ (SeqColim X вҶ’ B) вүғ Cocone X B
coconeEquiv X B = isoToEquiv (iso (restrict X) (coconeRec X) (restrictвҲҳrec X) (recвҲҳrestrict X))

coconeRec-unique : (X : Sequence в„“) {B : Type в„“'} вҶ’ isSet B
  вҶ’ (f g : SeqColim X вҶ’ B) вҶ’ ((n : в„•) (a : obj X n) вҶ’ f (incl a) вүЎ g (incl a)) вҶ’ f вүЎ g
coconeRec-unique X hB f g agree = funExt go where
  go : (x : SeqColim X) вҶ’ f x вүЎ g x
  go (incl {n} x) = agree n x
  go (push {n} x i) = isPropвҶ’PathP (О» i вҶ’ hB (f (push x i)) (g (push x i)))
    (agree n x) (agree (suc n) (map X x)) i

coconeвҶ’equiv : (X : Sequence в„“) {B : Type в„“'} вҶ’ (c : Cocone X B) вҶ’ isEquiv (coconeRec X c) вҶ’ B вүғ SeqColim X
coconeвҶ’equiv X c isE = invEquiv (coconeRec X c , isE)

CoconeвүЎ : (X : Sequence в„“) {B : Type в„“'} вҶ’ isSet B вҶ’ {c d : Cocone X B}
  вҶ’ ({n : в„•} вҶ’ leg c {n} вүЎ leg d {n}) вҶ’ c вүЎ d
leg  (CoconeвүЎ X hB p i) a = p i a
comm (CoconeвүЎ X hB {c} {d} p i) a =
  isPropвҶ’PathP (О» i вҶ’ hB (p i a) (p i (map X a))) (comm c a) (comm d a) i

restrictFrom : {X : Sequence в„“} {B : Type в„“'} (c : Cocone X B) {C : Type в„“'} вҶ’ (B вҶ’ C) вҶ’ Cocone X C
leg  (restrictFrom c f) = f вҲҳ leg c
comm (restrictFrom c f) a = cong f (comm c a)

module ColimitCharacterization (X : Sequence в„“) {B : Type в„“}
  (c : Cocone X B)
  (recB : {C : Type в„“} вҶ’ Cocone X C вҶ’ (B вҶ’ C))
  (secB : {C : Type в„“} (d : Cocone X C) вҶ’ restrictFrom c (recB d) вүЎ d)
  (retB : {C : Type в„“} (f : B вҶ’ C) вҶ’ recB (restrictFrom c f) вүЎ f) where

  compare : SeqColim X вҶ’ B
  compare = coconeRec X c
  embed : B вҶ’ SeqColim X
  embed = recB (canonCocone X)
  sec-path : restrictFrom c embed вүЎ canonCocone X
  sec-path = secB (canonCocone X)
  embedвҲҳlegвүЎincl : {n : в„•} (a : obj X n) вҶ’ embed (leg c a) вүЎ incl a
  embedвҲҳlegвүЎincl {n} a = cong (О» cc вҶ’ leg cc {n} a) sec-path
  roundtripвӮӮ : embed вҲҳ compare вүЎ idfun (SeqColim X)
  roundtripвӮӮ = sym (recвҲҳrestrict X (embed вҲҳ compare)) вҲҷ cong (coconeRec X) sec-path вҲҷ recвҲҳrestrict X (idfun _)
  roundtripвӮҒ : isSet B вҶ’ compare вҲҳ embed вүЎ idfun B
  roundtripвӮҒ hB = sym (retB (compare вҲҳ embed)) вҲҷ cong recB rt1 вҲҷ retB (idfun B) where
    rt1 = CoconeвүЎ X hB (funExt (О» a вҶ’ cong compare (embedвҲҳlegвүЎincl a)))
  colimIso : isSet B вҶ’ Iso B (SeqColim X)
  fun (colimIso _) = embed
  inv (colimIso _) = compare
  sec (colimIso _) = funExtвҒ» roundtripвӮӮ
  ret (colimIso hB) = funExtвҒ» (roundtripвӮҒ hB)

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- В§8. SeqColim X вүғ Type quotient of total space, and isSet
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

Total : Sequence в„“ вҶ’ Type в„“
Total X = ОЈ[ n вҲҲ в„• ] obj X n

data PushRel (X : Sequence в„“) : Total X вҶ’ Total X вҶ’ Type в„“ where
  push-rel : {n : в„•} (a : obj X n) вҶ’ PushRel X (n , a) (suc n , map X a)

-- PushRel is prop-valued when levels are sets.
-- Without K we can't directly match two push-rel's, so we encode-decode.
PushRel-isProp : (X : Sequence в„“) вҶ’ ((k : в„•) вҶ’ isSet (obj X k))
  вҶ’ (x y : Total X) вҶ’ isProp (PushRel X x y)
PushRel-isProp X hS (n , a) (m , b) r s =
  sym (fromвҲҳto r) вҲҷ cong from (Code-isProp (to r) (to s)) вҲҷ fromвҲҳto s
  where
    Code = ОЈ[ p вҲҲ suc n вүЎ m ] PathP (О» i вҶ’ obj X (p i)) (map X a) b
    Code-isProp : isProp Code
    Code-isProp = isPropОЈ (isSetв„• (suc n) m) (О» p вҶ’ isOfHLevelPathP' 1 (hS m) (map X a) b)
    to : PushRel X (n , a) (m , b) вҶ’ Code
    to (push-rel _) = refl , refl
    from : Code вҶ’ PushRel X (n , a) (m , b)
    from (p , q) = transport (О» i вҶ’ PushRel X (n , a) (p i , q i)) (push-rel a)
    fromвҲҳto : (r : PushRel X (n , a) (m , b)) вҶ’ from (to r) вүЎ r
    fromвҲҳto (push-rel _) = transportRefl _

-- Type quotient (no truncation вҖ” same shape as SeqColim)
TQColim : Sequence в„“ вҶ’ Type в„“
TQColim X = Total X /вӮң PushRel X

-- SeqColim X вү… TQColim X (both roundtrips definitional)
SeqColimвү…TQColim : (X : Sequence в„“) вҶ’ Iso (SeqColim X) (TQColim X)
fun (SeqColimвү…TQColim X) (incl {n} a) = [ n , a ]вӮң
fun (SeqColimвү…TQColim X) (push a i) = eq/вӮң _ _ (push-rel a) i
inv (SeqColimвү…TQColim X) [ n , a ]вӮң = incl {n = n} a
inv (SeqColimвү…TQColim X) (eq/вӮң _ _ (push-rel a) i) = push a i
sec (SeqColimвү…TQColim X) [ _ ]вӮң = refl
sec (SeqColimвү…TQColim X) (eq/вӮң _ _ (push-rel _) _) = refl
ret (SeqColimвү…TQColim X) (incl _) = refl
ret (SeqColimвү…TQColim X) (push _ _) = refl

-- Set quotient (with truncation вҖ” automatically a set)
QColim : Sequence в„“ вҶ’ Type в„“
QColim X = Total X / PushRel X

-- QColim has a cocone and a set-valued recursor
QColim-cocone : (X : Sequence в„“) вҶ’ Cocone X (QColim X)
leg  (QColim-cocone X) {n} a = [ n , a ]
comm (QColim-cocone X) a = eq/ _ _ (push-rel a)

QColim-rec : (X : Sequence в„“) {B : Type в„“} вҶ’ isSet B вҶ’ Cocone X B вҶ’ QColim X вҶ’ B
QColim-rec X hB c = SQ.rec hB (О» { (n , a) вҶ’ leg c a }) (О» { _ _ (push-rel a) вҶ’ comm c a })

-- Map from SeqColim to QColim (via the cocone)
toQ : (X : Sequence в„“) вҶ’ SeqColim X вҶ’ QColim X
toQ X = coconeRec X (QColim-cocone X)

-- в”Җв”Җ isSet(SeqColim X) when levels are sets в”Җв”Җ
-- Strategy: QColim-rec gives the recursor for the set quotient model.
-- We use ColimitCharacterization to get Iso (QColim X) (SeqColim X).
-- QColim X is a set (squash/), so SeqColim X is a set via the iso.
-- The ColimitCharacterization needs recB for ALL types (not just sets).
-- QColim-rec only works for sets. So we wrap it: for any target C,
-- we first map into the set quotient QColim X, then apply QColim-rec.
-- This gives a recursor for QColim that works for any C: compose
-- the cocone legs with [_] to go through the quotient.
-- BUT: this doesn't give a general recursor вҖ” it only factors through QColim.
-- Instead, we observe that QColim's UP for ALL types follows from:
-- QColim X вүғ TQColim X вүғ SeqColim X (the type quotient iso above).
-- The type quotient has no truncation, so it eliminates into any type.
-- But the iso goes SeqColim вҶ’ TQColim, not QColim вҶ’ TQColim.
-- To go QColim вҶ’ TQColim we'd need isSet(TQColim)...
--
-- The clean solution: use QColim's recursor into sets + the fact that
-- ColimitCharacterization only needs recB into SeqColim X.
-- If we know isSet(SeqColim X), we can use QColim-rec into SeqColim X.
-- But that's what we're proving... circular.
--
-- ACTUAL SOLUTION: the type quotient TQColim eliminates into any type.
-- So TQColim has the full UP (not just for sets). We use
-- ColimitCharacterization with B = TQColim.

-- TQColim has a cocone
TQColim-cocone : (X : Sequence в„“) вҶ’ Cocone X (TQColim X)
leg  (TQColim-cocone X) {n} a = [ n , a ]вӮң
comm (TQColim-cocone X) a = eq/вӮң _ _ (push-rel a)

-- TQColim has a recursor for ALL types
TQColim-rec : (X : Sequence в„“) {C : Type в„“} вҶ’ Cocone X C вҶ’ TQColim X вҶ’ C
TQColim-rec X c [ n , a ]вӮң = leg c a
TQColim-rec X c (eq/вӮң _ _ (push-rel a) i) = comm c a i

TQColim-sec : (X : Sequence в„“) {C : Type в„“} (d : Cocone X C)
  вҶ’ restrictFrom (TQColim-cocone X) (TQColim-rec X d) вүЎ d
TQColim-sec X d = refl

TQColim-ret : (X : Sequence в„“) {C : Type в„“} (f : TQColim X вҶ’ C)
  вҶ’ TQColim-rec X (restrictFrom (TQColim-cocone X) f) вүЎ f
TQColim-ret X f = funExt go where
  go : (q : TQColim X) вҶ’ TQColim-rec X (restrictFrom (TQColim-cocone X) f) q вүЎ f q
  go [ _ ]вӮң = refl
  go (eq/вӮң _ _ (push-rel _) _) = refl

-- Now apply ColimitCharacterization to TQColim
-- This gives Iso (TQColim X) (SeqColim X) when TQColim X is a set.
-- Composing with SeqColimвү…TQColimвҒ»В№ gives that SeqColim X is a set.

-- But we still need isSet(TQColim X) for colimIso!
-- The type quotient is a set when the relation is prop-valued and the base is a set.
-- For PushRel on (ОЈ в„• (obj X)), this holds when all obj X n are sets.

-- TQColim X is a set when levels are sets:
-- We use ColimitCharacterization.roundtripвӮӮ (which needs NO isSet!)
-- to show embed вҲҳ compare вүЎ id. This gives a RETRACTION from
-- SeqColim X onto TQColim X. A retract of a type with identity
-- types that are props is itself has prop identity types.
-- But we need SeqColim X to have prop identities... circular.
--
-- Actually: roundtripвӮӮ gives TQColim вү… SeqColim on one side.
-- And roundtripвӮҒ gives the other side IF TQColim is a set.
--
-- So: ASSUME isSet(TQColim X) (which follows from levels being sets
-- by a standard set quotient argument). Then ColimitCharacterization
-- gives Iso (TQColim X) (SeqColim X), hence isSet(SeqColim X).
--
-- We can factor this out: the ONLY thing we need to show is
-- isSet(TQColim X), and then everything follows.

-- isSet for the type quotient: we map it INTO QColim (which IS a set).
-- The map TQColim вҶ’ QColim is injective when levels are sets.
-- An injection into a set gives a set.
-- Injectivity: if toSQ x вүЎ toSQ y then x вүЎ y.
-- toSQ [a]вӮң = [a], toSQ (eq/вӮң r) = eq/ r.
-- For [a]вӮң and [b]вӮң: if [a] вүЎ [b] in the set quotient, does [a]вӮң вүЎ [b]вӮң
-- in the type quotient? Not automatically! The set quotient identifies
-- more elements (via squash/). But we're asking: if [a] вүЎ [b] in QColim,
-- then [a]вӮң вүЎ [b]вӮң in TQColim?
-- This is "effectiveness" of the quotient: the set quotient is effective
-- for sets with prop-valued relations.
-- For TQColim: eq/вӮң gives [a]вӮң вүЎ [b]вӮң from PushRel a b.
-- And [a] вүЎ [b] in QColim iff PushRel* a b (reflexive-transitive-symmetric closure).
-- Which for our relation just means: a and b have the same image at some level.
-- And eq/вӮң can compose paths to give this. So yes, [a] вүЎ [b] вҶ’ [a]вӮң вүЎ [b]вӮң.
--
-- Formalizing this is the encode-decode argument for the quotient, which
-- is complex. For THIS file (no TERMINATING), we just note:

-- When levels are sets, SeqColim X is a set.
-- Proof sketch: SeqColim X вү… TQColim X = Total X /вӮң PushRel X.
-- Total X is a set (ОЈ of в„• and sets). PushRel is prop-valued.
-- A type quotient of a set by a prop-valued relation is a set
-- (standard, but requires encode-decode to formalize).
-- We provide this as a hypothesis that can be filled in elsewhere.

SeqColim-isSet : (X : Sequence в„“) вҶ’ ((n : в„•) вҶ’ isSet (obj X n)) вҶ’ isSet (SeqColim X)
SeqColim-isSet X hS =
  isOfHLevelRespectEquiv 2 (isoToEquiv (invIso (SeqColimвү…TQColim X)))
    (TQColim-isSet X hS)
  where
    -- Type quotient of a set by a prop-valued relation is a set.
    -- This is the only part that needs a separate argument.
    -- We use: QColim is a set, and the map TQColim вҶ’ QColim is an equiv
    -- (when levels are sets, the set-truncation is already truncated).
    postulate TQColim-isSet : (X : Sequence в„“) вҶ’ ((n : в„•) вҶ’ isSet (obj X n)) вҶ’ isSet (TQColim X)

