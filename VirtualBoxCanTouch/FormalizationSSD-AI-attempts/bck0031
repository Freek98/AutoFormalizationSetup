weakMarkovPrinciple = (Оұ : binarySequence) вҶ’ В¬' (вҲҖ n вҶ’ Оұ n вүЎ false) вҶ’ вҲғ[ n вҲҲ в„• ] Оұ n вүЎ true

module MarkovResults (wMP : weakMarkovPrinciple) where

  -- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  -- Negation of closed is open
  -- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

  negClosedWitnessIsOpenWitness : (P : hProp в„“-zero) вҶ’
    isClosedWitness P вҶ’ isOpenWitness (В¬ P)
  negClosedWitnessIsOpenWitness P (Оұ , PвҶ’вҲҖОұfalse , вҲҖОұfalseвҶ’P) =
    Оұ , В¬PвҶ’ОЈОұ , ОЈОұвҶ’В¬P where
    ОЈОұвҶ’В¬P : ОЈв„• Оұ вҶ’ вҹЁ В¬ P вҹ©
    ОЈОұвҶ’В¬P (n , Оұn=t) p = trueвүўfalse $
      true вүЎвҹЁ sym Оұn=t вҹ© Оұ n вүЎвҹЁ PвҶ’вҲҖОұfalse p n вҹ© false вҲҺ
    В¬PвҶ’ОЈОұ : вҹЁ В¬ P вҹ© вҶ’ ОЈв„• Оұ
    В¬PвҶ’ОЈОұ В¬p = extractFirstHitInBinarySequence.extract Оұ
      (wMP Оұ О» allfalse вҶ’ В¬p (вҲҖОұfalseвҶ’P allfalse))

  negClosedIsOpen : (P : hProp в„“-zero) вҶ’ isClosedProp P вҶ’ isOpenProp (В¬ P)
  negClosedIsOpen P = PT.rec squashвӮҒ (idfun _) вҲҳ
    PT.map (О» w вҶ’ вҲЈ negClosedWitnessIsOpenWitness P w вҲЈвӮҒ)

  -- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  -- Open propositions are В¬В¬-stable
  -- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

  open-В¬В¬-stable : (P : hProp в„“-zero) вҶ’ isOpenWitness P вҶ’ В¬' (В¬' вҹЁ P вҹ©) вҶ’ вҹЁ P вҹ©
  open-В¬В¬-stable P (Оұ , PвҶ’ОЈОұ , ОЈОұвҶ’P) В¬В¬p = ОЈОұвҶ’P (fst found , snd found) where
    В¬allfalse : В¬' ((n : в„•) вҶ’ Оұ n вүЎ false)
    В¬allfalse af = В¬В¬p (О» p вҶ’ trueвүўfalse (sym (snd (PвҶ’ОЈОұ p)) вҲҷ af (fst (PвҶ’ОЈОұ p))))
    found : ОЈв„• Оұ
    found = extractFirstHitInBinarySequence.extract Оұ (wMP Оұ В¬allfalse)

  -- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  -- Implication: (P closed) вҶ’ (Q open) is open
  -- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

  -- Оі(k) = Оұ(n) or ОІ(m) where (n,m) = unpair(k).
  -- If вҲғk.Оі(k)=true then either Оұ(n)=true (contradicts P, so PвҶ’Q vacuously)
  -- or ОІ(m)=true (so Q holds, giving PвҶ’Q).
  -- Conversely, if PвҶ’Q and вҲҖk.Оі(k)=false, then all Оұ(n)=false and all ОІ(m)=false,
  -- so P holds, so Q holds, but Q needs some ОІ(m)=true вҖ” contradiction.

  closedвҶ’open-is-open : (P Q : hProp в„“-zero) вҶ’
    isClosedWitness P вҶ’ isOpenWitness Q вҶ’
    isOpenWitness ((вҹЁ P вҹ© вҶ’ вҹЁ Q вҹ©) , isPropО  (О» _ вҶ’ snd Q))
  closedвҶ’open-is-open P Q (Оұ , PвҶ’вҲҖОұfalse , вҲҖОұfalseвҶ’P) (ОІ , QвҶ’ОЈОІ , ОЈОІвҶ’Q) =
    Оі , implвҶ’ОЈОі , ОЈОівҶ’impl where
    Оі : binarySequence
    Оі = uncurry (О» n m вҶ’ Оұ n or ОІ m) вҲҳ unpair

    -- Helper: decompose Оі(pair(n,m)) = false into Оұ(n)=false and ОІ(m)=false
    Оіpair-falseвҶ’Г— : (n m : в„•) вҶ’ Оі (pair (n , m)) вүЎ false вҶ’
      (Оұ n вүЎ false) Г— (ОІ m вүЎ false)
    Оіpair-falseвҶ’Г— n m p = or-falseвҶ’fst (Оұ n) (ОІ m) step ,
                            or-falseвҶ’snd (Оұ n) (ОІ m) step where
      step : Оұ n or ОІ m вүЎ false
      step = sym (cong (uncurry (О» n m вҶ’ Оұ n or ОІ m)) (unpair-pair (n , m))) вҲҷ p

    ОЈОівҶ’impl : ОЈв„• Оі вҶ’ вҹЁ P вҹ© вҶ’ вҹЁ Q вҹ©
    ОЈОівҶ’impl (k , Оіk=t) allОұ-P = case or-trueвҶ’вҠҺ (Оұ n) (ОІ m) Оіk=t of О»
