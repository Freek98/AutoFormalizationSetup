  Оі , implвҶ’вҲҖОіfalse , вҲҖОіfalseвҶ’impl where
  Оі : binarySequence
  Оі = uncurry (О» n m вҶ’ Оұ n and ОІ m) вҲҳ unpair

  implвҶ’вҲҖОіfalse : (вҹЁ P вҹ© вҶ’ вҹЁ Q вҹ©) вҶ’ (k : в„•) вҶ’ Оі k вүЎ false
  implвҶ’вҲҖОіfalse f k = go (Оұ n) refl where
    n = fst (unpair k)
    m = snd (unpair k)
    go : (b : Bool) вҶ’ Оұ n вүЎ b вҶ’ b and ОІ m вүЎ false
    go false _ = refl
    go true  Оұn=t = QвҶ’вҲҖОІfalse (f (ОЈОұвҶ’P (n , Оұn=t))) m

  вҲҖОіfalseвҶ’impl : ((k : в„•) вҶ’ Оі k вүЎ false) вҶ’ вҹЁ P вҹ© вҶ’ вҹЁ Q вҹ©
  вҲҖОіfalseвҶ’impl allОі p = вҲҖОІfalseвҶ’Q ОІm-allfalse where
    nвӮҖ = fst (PвҶ’ОЈОұ p)
    ОұnвӮҖ = snd (PвҶ’ОЈОұ p)
    ОІm-allfalse : (m : в„•) вҶ’ ОІ m вүЎ false
    ОІm-allfalse m = subst (О» x вҶ’ x and ОІ m вүЎ false) ОұnвӮҖ step where
      step : Оұ nвӮҖ and ОІ m вүЎ false
      step = sym (cong (uncurry (О» n m вҶ’ Оұ n and ОІ m)) (unpair-pair (nвӮҖ , m))) вҲҷ
             allОі (pair (nвӮҖ , m))

