-- ┬ž4ÔÇô6. Truncated sequence and propositional truncation commutes
-- ÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉ
truncSeq : Sequence Ôäô Ôćĺ Sequence Ôäô
obj (truncSeq X) n = Ôłą obj X n ÔłąÔéü
map (truncSeq X) = PT.map (map X)

trunc-fwd : (X : Sequence Ôäô) Ôćĺ SeqColim X Ôćĺ SeqColim (truncSeq X)
trunc-fwd X (incl x)   = incl Ôłú x ÔłúÔéü
trunc-fwd X (push x i) = push Ôłú x ÔłúÔéü i

trunc-bwd : (X : Sequence Ôäô) Ôćĺ SeqColim (truncSeq X) Ôćĺ Ôłą SeqColim X ÔłąÔéü
trunc-bwd X = SeqColim-elimProp (truncSeq X)
  (╬╗ _ Ôćĺ squashÔéü) (╬╗ {n} ta Ôćĺ PT.rec squashÔéü (╬╗ a Ôćĺ Ôłú incl {n = n} a ÔłúÔéü) ta)

truncSeq-contr-from-incl : (X : Sequence Ôäô) {n : ÔäĽ} (a : obj X n)
  Ôćĺ isContr (SeqColim (truncSeq X))
truncSeq-contr-from-incl X {n} a =
  isOfHLevelRespectEquiv 0 (isoToEquiv (invIso (SeqColimIso (truncSeq X) n)))
    (colimitContr (ShiftSequence+ (truncSeq X) n)
      (╬╗ k Ôćĺ inhPropÔćĺisContr Ôłú iterMap X k a ÔłúÔéü squashÔéü))

SeqColim-truncSeq-isProp : (X : Sequence Ôäô) Ôćĺ isProp (SeqColim (truncSeq X))
SeqColim-truncSeq-isProp X x y = sym (snd c x) ÔłÖ snd c y where
  c = SeqColim-elimProp (truncSeq X) (╬╗ _ Ôćĺ isPropIsContr)
    (╬╗ {n} ta Ôćĺ PT.rec isPropIsContr (╬╗ a Ôćĺ truncSeq-contr-from-incl X a) ta) x

truncCommutes : (X : Sequence Ôäô) Ôćĺ Iso Ôłą SeqColim X ÔłąÔéü (SeqColim (truncSeq X))
fun (truncCommutes X) = PT.rec (SeqColim-truncSeq-isProp X) (trunc-fwd X)
inv (truncCommutes X) = trunc-bwd X
sec (truncCommutes X) _ = SeqColim-truncSeq-isProp X _ _
ret (truncCommutes X) _ = squashÔéü _ _

-- ÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉ
-- ┬ž7. Universal property
-- ÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉ
record Cocone (X : Sequence Ôäô) (B : Type Ôäô') : Type (Ôäô-max Ôäô Ôäô') where
  constructor cocone
  field
    leg  : {n : ÔäĽ} Ôćĺ obj X n Ôćĺ B
    comm : {n : ÔäĽ} (a : obj X n) Ôćĺ leg a Ôëí leg (map X a)
open Cocone

canonCocone : (X : Sequence Ôäô) Ôćĺ Cocone X (SeqColim X)
leg  (canonCocone X) = incl
comm (canonCocone X) = push

coconeRec : (X : Sequence Ôäô) {B : Type Ôäô'} Ôćĺ Cocone X B Ôćĺ SeqColim X Ôćĺ B
coconeRec X c (incl x)   = leg c x
coconeRec X c (push x i) = comm c x i

restrict : (X : Sequence Ôäô) {B : Type Ôäô'} Ôćĺ (SeqColim X Ôćĺ B) Ôćĺ Cocone X B
leg  (restrict X f) a = f (incl a)
comm (restrict X f) a = cong f (push a)

restrictÔłśrec : (X : Sequence Ôäô) {B : Type Ôäô'} (c : Cocone X B) Ôćĺ restrict X (coconeRec X c) Ôëí c
restrictÔłśrec X c = refl

recÔłśrestrict : (X : Sequence Ôäô) {B : Type Ôäô'} (f : SeqColim X Ôćĺ B) Ôćĺ coconeRec X (restrict X f) Ôëí f
recÔłśrestrict X f = funExt go where
  go : (x : SeqColim X) Ôćĺ coconeRec X (restrict X f) x Ôëí f x
  go (incl x)   = refl
  go (push x i) = refl

coconeEquiv : (X : Sequence Ôäô) (B : Type Ôäô') Ôćĺ (SeqColim X Ôćĺ B) Ôëâ Cocone X B
coconeEquiv X B = isoToEquiv (iso (restrict X) (coconeRec X) (restrictÔłśrec X) (recÔłśrestrict X))

coconeRec-unique : (X : Sequence Ôäô) {B : Type Ôäô'} Ôćĺ isSet B
  Ôćĺ (f g : SeqColim X Ôćĺ B) Ôćĺ ((n : ÔäĽ) (a : obj X n) Ôćĺ f (incl a) Ôëí g (incl a)) Ôćĺ f Ôëí g
coconeRec-unique X hB f g agree = funExt go where
  go : (x : SeqColim X) Ôćĺ f x Ôëí g x
  go (incl {n} x) = agree n x
  go (push {n} x i) = isPropÔćĺPathP (╬╗ i Ôćĺ hB (f (push x i)) (g (push x i)))
    (agree n x) (agree (suc n) (map X x)) i

coconeÔćĺequiv : (X : Sequence Ôäô) {B : Type Ôäô'} Ôćĺ (c : Cocone X B) Ôćĺ isEquiv (coconeRec X c) Ôćĺ B Ôëâ SeqColim X
coconeÔćĺequiv X c isE = invEquiv (coconeRec X c , isE)

CoconeÔëí : (X : Sequence Ôäô) {B : Type Ôäô'} Ôćĺ isSet B Ôćĺ {c d : Cocone X B}
  Ôćĺ ({n : ÔäĽ} Ôćĺ leg c {n} Ôëí leg d {n}) Ôćĺ c Ôëí d
leg  (CoconeÔëí X hB p i) a = p i a
comm (CoconeÔëí X hB {c} {d} p i) a =
  isPropÔćĺPathP (╬╗ i Ôćĺ hB (p i a) (p i (map X a))) (comm c a) (comm d a) i

restrictFrom : {X : Sequence Ôäô} {B : Type Ôäô'} (c : Cocone X B) {C : Type Ôäô'} Ôćĺ (B Ôćĺ C) Ôćĺ Cocone X C
leg  (restrictFrom c f) = f Ôłś leg c
comm (restrictFrom c f) a = cong f (comm c a)

module ColimitCharacterization (X : Sequence Ôäô) {B : Type Ôäô}
  (c : Cocone X B)
  (recB : {C : Type Ôäô} Ôćĺ Cocone X C Ôćĺ (B Ôćĺ C))
  (secB : {C : Type Ôäô} (d : Cocone X C) Ôćĺ restrictFrom c (recB d) Ôëí d)
  (retB : {C : Type Ôäô} (f : B Ôćĺ C) Ôćĺ recB (restrictFrom c f) Ôëí f) where

  compare : SeqColim X Ôćĺ B
  compare = coconeRec X c
  embed : B Ôćĺ SeqColim X
  embed = recB (canonCocone X)
  sec-path : restrictFrom c embed Ôëí canonCocone X
  sec-path = secB (canonCocone X)
  embedÔłślegÔëíincl : {n : ÔäĽ} (a : obj X n) Ôćĺ embed (leg c a) Ôëí incl a
  embedÔłślegÔëíincl {n} a = cong (╬╗ cc Ôćĺ leg cc {n} a) sec-path
  roundtripÔéé : embed Ôłś compare Ôëí idfun (SeqColim X)
  roundtripÔéé = sym (recÔłśrestrict X (embed Ôłś compare)) ÔłÖ cong (coconeRec X) sec-path ÔłÖ recÔłśrestrict X (idfun _)
  -- Roundtrip 1: compare Ôłś embed Ôëí id (no isSet needed!)
  -- restrictFrom c is an equivalence (with inverse recB, by secB/retB).
  -- So it's injective: restrictFrom c f Ôëí restrictFrom c g Ôćĺ f Ôëí g.
  -- We show restrictFrom c (compare Ôłś embed) Ôëí restrictFrom c id:
  -- By HIT computation, restrictFrom c (compare Ôłś embed) =
  --   restrictFrom c (coconeRec X c Ôłś recB (canonCocone X))
  -- The legs: coconeRec X c (recB(canonCocone X)(leg c a)) = coconeRec X c (incl a) = leg c a Ôťô
  -- But the full cocone equality needs the comms too.
  -- We use: restrictFrom c (compare Ôłś embed) = restrictFrom c (recB (canonCocone X) |> coconeRec X c)
  -- = ... this doesn't simplify cleanly.
  -- Instead: use secB on both sides.
  -- secB(restrictFrom c (compare Ôłś embed)) : restrictFrom c (recB(restrictFrom c (compare Ôłś embed))) Ôëí restrictFrom c (compare Ôłś embed)
  -- retB(compare Ôłś embed) : recB(restrictFrom c (compare Ôłś embed)) Ôëí compare Ôłś embed
  -- So: restrictFrom c (compare Ôłś embed) = restrictFrom c (recB (restrictFrom c (compare Ôłś embed)))  [by sym Ôłś cong(restrictFrom c) Ôłś retB]
  --   Ôëí secB(restrictFrom c (compare Ôłś embed))  ... hmm this is going in circles.
  --
  -- Clean approach: restrictFrom c is injective because retB gives a left inverse.
  -- retB f : recB(restrictFrom c f) Ôëí f. So if restrictFrom c f Ôëí restrictFrom c g,
  -- then f Ôëí recB(restrictFrom c f) Ôëí recB(restrictFrom c g) Ôëí g.
  -- We need: restrictFrom c (compare Ôłś embed) Ôëí c.
  -- sec-path gives: restrictFrom c embed Ôëí canonCocone X.
  -- By HIT computation on coconeRec X c:
  --   restrictFrom c (compare Ôłś embed)
  --   has leg: compare Ôłś embed Ôłś leg c
  --   has comm a: cong (compare Ôłś embed) (comm c a)
  -- And: restrictFrom c compare = restrict X (coconeRec X c) |> ... no, restrictFrom c compare
  --   has leg: compare Ôłś leg c = coconeRec X c Ôłś leg c = leg c
  --   has comm a: cong compare (comm c a) = cong (coconeRec X c) (comm c a) = comm c a
  -- So restrictFrom c compare = c (definitionally, since coconeRec computes).
  -- And restrictFrom c (compare Ôłś embed) = restrictFrom (restrictFrom c compare) embed
  -- ... that doesn't help syntactically.
  --
  -- Direct: secB gives restrictFrom c (recB d) Ôëí d for any cocone d.
  -- Set d = c. Then restrictFrom c (recB c) Ôëí c.
  -- And recB c = recB (restrictFrom c id) [since restrictFrom c id = c definitionally].
  -- By retB: recB (restrictFrom c id) Ôëí id.
  -- Wait: restrictFrom c id has leg = id Ôłś leg c = leg c and comm = cong id Ôłś comm c.
  -- And c has leg = leg c and comm = comm c.
  -- Is restrictFrom c id Ôëí c? cong id p = p in cubical, so yes, restrictFrom c id Ôëí c definitionally. Ôťô
  -- So recB c Ôëí recB (restrictFrom c id) Ôëí id (by retB id... wait, retB gives recB(restrictFrom c f) Ôëí f).
  -- retB id : recB(restrictFrom c id) Ôëí id. And restrictFrom c id = c. So recB c Ôëí id. Ôťô
  -- Then: restrictFrom c (compare Ôłś embed).
  --   compare = coconeRec X c. embed = recB(canonCocone X).
  --   compare Ôłś embed = coconeRec X c Ôłś recB(canonCocone X).
  --   restrictFrom c (compare Ôłś embed) = restrictFrom c (coconeRec X c Ôłś recB(canonCocone X)).
  -- Hmm I can't simplify this further without CoconeÔëí.
  --
  -- Let me use the roundtrip differently:
  -- retB (compare Ôłś embed) : recB(restrictFrom c (compare Ôłś embed)) Ôëí compare Ôłś embed
  -- retB id : recB(restrictFrom c id) Ôëí id = recB c Ôëí id (since restrictFrom c id = c)
  -- If restrictFrom c (compare Ôłś embed) Ôëí restrictFrom c id = c,
  -- then recB(restrictFrom c (compare Ôłś embed)) Ôëí recB c Ôëí id.
  -- Together with retB: compare Ôłś embed Ôëí recB(...) Ôëí id.
  -- But I STILL need restrictFrom c (compare Ôłś embed) Ôëí c.
  --
  -- Key insight: secB(canonCocone X) Ôëí sec-path gives restrictFrom c embed Ôëí canonCocone.
  -- Now: restrictFrom c (compare Ôłś embed) =
  --   cocone (compare Ôłś embed Ôłś leg c) (cong (compare Ôłś embed) Ôłś comm c).
  -- And c = restrictFrom c id =
  --   cocone (leg c) (comm c).  [since cong id = id in cubical]
  -- Legs agree: compare(embed(leg c a)) = compare(incl a) = leg c a. [using embedÔłślegÔëíincl + def of compare]
  -- Comms: cong(compare Ôłś embed)(comm c a) vs comm c a.
  -- This is where isSet B was needed! Two paths in B with the same endpoints.

  -- BUT: I don't need the cocone equality! I use retB directly:
  -- roundtripÔéü = sym(retB(compare Ôłś embed)) ÔłÖ cong recB(?) ÔłÖ retB(id)
  -- where ? : restrictFrom c (compare Ôłś embed) Ôëí restrictFrom c id = c.
  -- And for ?: I use secB.
  -- secB(restrictFrom c (compare Ôłś embed)) :
  --   restrictFrom c (recB(restrictFrom c (compare Ôłś embed))) Ôëí restrictFrom c (compare Ôłś embed)
  -- retB(compare Ôłś embed) :
  --   recB(restrictFrom c (compare Ôłś embed)) Ôëí compare Ôłś embed
  -- So: restrictFrom c (compare Ôłś embed)
  --   Ôëí restrictFrom c (recB(restrictFrom c (compare Ôłś embed)))  [by sym(cong(restrictFrom c)(retB(compare Ôłś embed)))]
  --   Ôëí restrictFrom c (compare Ôłś embed)  [by secB]  -- circular!
  --
  -- The issue is real: without isSet B (or some equivalent), I can't show
  -- restrictFrom c (compare Ôłś embed) Ôëí c because the comm components
  -- are paths in B that might differ.
  --
  -- HOWEVER: I can bypass the cocone equality entirely and use the EQUIVALENCE.
  -- restrictFrom c is an equivalence (isEquiv via retB/secB).
  -- An equivalence is injective: restrictFrom c f Ôëí restrictFrom c g Ôćĺ f Ôëí g.
  -- Via: f = sym(retB f) ; recB(restrictFrom c f) = cong recB (hypothesis) ; recB(restrictFrom c g) = retB g ; g.
  -- I need: restrictFrom c (compare Ôłś embed) Ôëí restrictFrom c id.
  -- STILL needs the cocone equality!
  --
  -- OK the issue is genuine: roundtripÔéü needs isSet B for the comm coherence,
  -- OR I need a different proof strategy. Let me check if there's a way
  -- using only sec-path (which IS a full cocone equality, for the other direction).

  -- sec-path : restrictFrom c embed Ôëí canonCocone X (full cocone equality!)
  -- This works because canonCocone has comm = push, and restrictFrom c embed
  -- has comm = cong embed Ôłś comm c. These are paths in SeqColim X, not in B.
  -- The roundtripÔéé proof used this and it worked WITHOUT isSet.

  -- For roundtripÔéü: I need a cocone equality in Cocone X B. The comms are in B.
  -- Without isSet B, two paths in B with the same endpoints might differ.

  -- Conclusion: isSet B IS needed for roundtripÔéü. The comms in B are genuinely
  -- not determined by the legs without isSet.
  roundtripÔéü : isSet B Ôćĺ compare Ôłś embed Ôëí idfun B
  roundtripÔéü hB = sym (retB (compare Ôłś embed))
    ÔłÖ cong recB (CoconeÔëí X hB (funExt (╬╗ a Ôćĺ cong compare (embedÔłślegÔëíincl a))))
    ÔłÖ retB (idfun B)

  colimIso : isSet B Ôćĺ Iso B (SeqColim X)
  fun (colimIso _) = embed
  inv (colimIso _) = compare
  sec (colimIso _) = funExtÔü╗ roundtripÔéé
  ret (colimIso hB) = funExtÔü╗ (roundtripÔéü hB)

