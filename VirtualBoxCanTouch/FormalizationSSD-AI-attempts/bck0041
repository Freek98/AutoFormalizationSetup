-- ┬ž1. Convenience eliminators
-- ÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉÔĽÉ
module _ (X : Sequence Ôäô) where
  SeqColim-elimProp : {P : SeqColim X Ôćĺ Type Ôäô'}
    Ôćĺ ((x : SeqColim X) Ôćĺ isProp (P x))
    Ôćĺ ({n : ÔäĽ} (a : obj X n) Ôćĺ P (incl a))
    Ôćĺ (x : SeqColim X) Ôćĺ P x
  SeqColim-elimProp hP f (incl x) = f x
  SeqColim-elimProp hP f (push x i) =
    isPropÔćĺPathP (╬╗ i Ôćĺ hP (push x i)) (f x) (f (map X x)) i

  SeqColim-rec : {B : Type Ôäô'} Ôćĺ isSet B
    Ôćĺ (f : {n : ÔäĽ} Ôćĺ obj X n Ôćĺ B)
    Ôćĺ ({n : ÔäĽ} (a : obj X n) Ôćĺ f a Ôëí f (map X a))
    Ôćĺ SeqColim X Ôćĺ B
  SeqColim-rec hB f p (incl x) = f x
  SeqColim-rec hB f p (push x i) = p x i

