toNNFneg BFalse = BTrue
toNNFneg (BAnd a b) = BOr (toNNFneg a) (toNNFneg b)
toNNFneg (BOr a b) = BAnd (toNNFneg a) (toNNFneg b)
toNNFneg (BNot a) = toNNF a

