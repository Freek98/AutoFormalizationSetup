toNNF (BLit l) = BLit l
toNNF BTrue = BTrue
toNNF BFalse = BFalse
toNNF (BAnd a b) = BAnd (toNNF a) (toNNF b)
toNNF (BOr a b) = BOr (toNNF a) (toNNF b)
