    evalBE (BOr (BAnd t' (BNot s')) (BAnd (BNot t') s'))
      ‚Č°‚ü® cong‚āā _‚ą®B_ (cong‚āā _‚ąßB_ (termToBoolExpr-correct t) (cong ¬¨B_ (termToBoolExpr-correct s)))
