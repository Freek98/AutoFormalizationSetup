  -- ‚ēź‚ēź‚ēź xor-as-bool: a + b = (a ‚ąß ¬¨b) ‚ą® (¬¨a ‚ąß b) ‚ēź‚ēź‚ēź
  xor-as-bool : (a b : ‚ü® B ‚ü©) ‚Üí BR._+_ a b ‚Č° (a ‚ąßB (¬¨B b)) ‚ą®B ((¬¨B a) ‚ąßB b)
  xor-as-bool a b = sym rhs‚Č°lhs
    where
      ab  = a ‚ąßB b
      a¬¨b = a ‚ąßB (¬¨B b)
      ¬¨ab = (¬¨B a) ‚ąßB b

      -- Cross product (a¬∑¬¨b)¬∑(¬¨a¬∑b) = 0 by rearranging to (a¬∑¬¨a)¬∑... = 0
      cross-zero : a¬¨b ‚ąßB ¬¨ab ‚Č° ūĚüėB
      cross-zero =
        a¬¨b ‚ąßB ¬¨ab
          ‚Č°‚ü® BR.¬∑Assoc a¬¨b (¬¨B a) b ‚ü©
        (a¬¨b ‚ąßB (¬¨B a)) ‚ąßB b
          ‚Č°‚ü® cong (_‚ąßB b) (sym (BR.¬∑Assoc a (¬¨B b) (¬¨B a))) ‚ü©
        (a ‚ąßB ((¬¨B b) ‚ąßB (¬¨B a))) ‚ąßB b
          ‚Č°‚ü® cong (őĽ z ‚Üí (a ‚ąßB z) ‚ąßB b) (BR.¬∑Comm (¬¨B b) (¬¨B a)) ‚ü©
        (a ‚ąßB ((¬¨B a) ‚ąßB (¬¨B b))) ‚ąßB b
          ‚Č°‚ü® cong (_‚ąßB b) (BR.¬∑Assoc a (¬¨B a) (¬¨B b)) ‚ü©
        ((a ‚ąßB (¬¨B a)) ‚ąßB (¬¨B b)) ‚ąßB b
          ‚Č°‚ü® cong (őĽ z ‚Üí (z ‚ąßB (¬¨B b)) ‚ąßB b) BA.¬¨Cancels‚ąßR ‚ü©
        (ūĚüėB ‚ąßB (¬¨B b)) ‚ąßB b
          ‚Č°‚ü® cong (_‚ąßB b) (0-absorbs-left (¬¨B b)) ‚ü©
        ūĚüėB ‚ąßB b
          ‚Č°‚ü® 0-absorbs-left b ‚ü©
        ūĚüėB ‚ąé

      -- a¬∑(1+b) = a + ab
      expand-a¬¨b : a¬¨b ‚Č° BR._+_ a ab
      expand-a¬¨b =
        a ‚ąßB (¬¨B b)
          ‚Č°‚ü® BR.¬∑DistR+ a ūĚüôB b ‚ü©
        BR._+_ (a ‚ąßB ūĚüôB) ab
          ‚Č°‚ü® cong (őĽ z ‚Üí BR._+_ z ab) (BR.¬∑IdR a) ‚ü©
        BR._+_ a ab ‚ąé

      -- (1+a)¬∑b = b + ab
      expand-¬¨ab : ¬¨ab ‚Č° BR._+_ b ab
      expand-¬¨ab =
        (¬¨B a) ‚ąßB b
          ‚Č°‚ü® BR.¬∑DistL+ ūĚüôB a b ‚ü©
        BR._+_ (ūĚüôB ‚ąßB b) ab
          ‚Č°‚ü® cong (őĽ z ‚Üí BR._+_ z ab) (BR.¬∑IdL b) ‚ü©
        BR._+_ b ab ‚ąé

      -- (a + ab) + (b + ab) = a + b  via reassociation and char 2
      sum-simplify : BR._+_ (BR._+_ a ab) (BR._+_ b ab) ‚Č° BR._+_ a b
      sum-simplify =
        BR._+_ (BR._+_ a ab) (BR._+_ b ab)
          ‚Č°‚ü® BR.+Assoc (BR._+_ a ab) b ab ‚ü©
        BR._+_ (BR._+_ (BR._+_ a ab) b) ab
          ‚Č°‚ü® cong (őĽ z ‚Üí BR._+_ z ab) (sym (BR.+Assoc a ab b)) ‚ü©
        BR._+_ (BR._+_ a (BR._+_ ab b)) ab
          ‚Č°‚ü® cong (őĽ z ‚Üí BR._+_ (BR._+_ a z) ab) (BR.+Comm ab b) ‚ü©
        BR._+_ (BR._+_ a (BR._+_ b ab)) ab
          ‚Č°‚ü® cong (őĽ z ‚Üí BR._+_ z ab) (BR.+Assoc a b ab) ‚ü©
        BR._+_ (BR._+_ (BR._+_ a b) ab) ab
          ‚Č°‚ü® sym (BR.+Assoc (BR._+_ a b) ab ab) ‚ü©
        BR._+_ (BR._+_ a b) (BR._+_ ab ab)
          ‚Č°‚ü® cong (BR._+_ (BR._+_ a b)) BA.characteristic2 ‚ü©
        BR._+_ (BR._+_ a b) ūĚüėB
          ‚Č°‚ü® BR.+IdR (BR._+_ a b) ‚ü©
        BR._+_ a b ‚ąé

      -- Main chain: RHS ‚Üí LHS
      rhs‚Č°lhs : a¬¨b ‚ą®B ¬¨ab ‚Č° BR._+_ a b
      rhs‚Č°lhs =
        a¬¨b ‚ą®B ¬¨ab
          ‚Č°‚ü® cong (BR._+_ (BR._+_ a¬¨b ¬¨ab)) cross-zero ‚ü©
        BR._+_ (BR._+_ a¬¨b ¬¨ab) ūĚüėB
          ‚Č°‚ü® BR.+IdR (BR._+_ a¬¨b ¬¨ab) ‚ü©
        BR._+_ a¬¨b ¬¨ab
          ‚Č°‚ü® cong‚āā BR._+_ expand-a¬¨b expand-¬¨ab ‚ü©
        BR._+_ (BR._+_ a ab) (BR._+_ b ab)
          ‚Č°‚ü® sum-simplify ‚ü©
        BR._+_ a b ‚ąé

  negateLit-correct : (l : Literal) ‚Üí evalLit (negateLit l) ‚Č° ¬¨B (evalLit l)
  negateLit-correct (n , true) = refl
