  toNNFneg-correct BFalse = sym (BR.+IdR ūĚüôB)
  toNNFneg-correct (BAnd a b) =
    evalBE (BOr (toNNFneg a) (toNNFneg b))
      ‚Č°‚ü® cong‚āā _‚ą®B_ (toNNFneg-correct a) (toNNFneg-correct b) ‚ü©
