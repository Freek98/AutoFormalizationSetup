  -- termToBoolExpr preserves semantics
  termToBoolExpr-correct : (t : freeBATerms ‚Ąē) ‚Üí evalBE (termToBoolExpr t) ‚Č° interpretInB t
  termToBoolExpr-correct (Tvar n) = refl
  termToBoolExpr-correct (Tconst false) = refl
