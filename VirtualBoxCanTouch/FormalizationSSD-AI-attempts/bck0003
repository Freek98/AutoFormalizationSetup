module EvalNF (B : BooleanRing ‚Ąď-zero) (gen : ‚Ąē ‚Üí ‚ü® B ‚ü©) where
  private
    module BA = BooleanAlgebraStr B
    module BR = BooleanRingStr (snd B)

  _‚ąßB_ : ‚ü® B ‚ü© ‚Üí ‚ü® B ‚ü© ‚Üí ‚ü® B ‚ü©
  _‚ąßB_ = BR._¬∑_

  _‚ą®B_ : ‚ü® B ‚ü© ‚Üí ‚ü® B ‚ü© ‚Üí ‚ü® B ‚ü©
  _‚ą®B_ = BA._‚ą®_

  ¬¨B_ : ‚ü® B ‚ü© ‚Üí ‚ü® B ‚ü©
  ¬¨B_ = BA.¬¨_

  ūĚüėB : ‚ü® B ‚ü©
  ūĚüėB = BR.ūĚüė

  ūĚüôB : ‚ü® B ‚ü©
  ūĚüôB = BR.ūĚüô

  evalLit : Literal ‚Üí ‚ü® B ‚ü©
  evalLit (n , true)  = gen n
  evalLit (n , false) = ¬¨B (gen n)

  negateLit : Literal ‚Üí Literal
  negateLit (n , b) = (n , not b)

  evalConjClause : Clause ‚Üí ‚ü® B ‚ü©
  evalConjClause [] = ūĚüôB
  evalConjClause (l ‚ą∑ ls) = evalLit l ‚ąßB evalConjClause ls

  evalDisjClause : Clause ‚Üí ‚ü® B ‚ü©
  evalDisjClause [] = ūĚüėB
  evalDisjClause (l ‚ą∑ ls) = evalLit l ‚ą®B evalDisjClause ls

  evalDNF : DNF ‚Üí ‚ü® B ‚ü©
  evalDNF [] = ūĚüėB
  evalDNF (c ‚ą∑ cs) = evalConjClause c ‚ą®B evalDNF cs

  evalCNF : CNF ‚Üí ‚ü® B ‚ü©
  evalCNF [] = ūĚüôB
  evalCNF (c ‚ą∑ cs) = evalDisjClause c ‚ąßB evalCNF cs

