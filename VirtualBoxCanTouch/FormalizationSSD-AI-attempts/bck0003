  -- ‚ēź‚ēź‚ēź XOR and AND on OrthoNF ‚ēź‚ēź‚ēź
  -- These mirror xor-nf and meet-nf from FinCofinAlgebra.agda

  xor-onf : OrthoNF ‚Üí OrthoNF ‚Üí OrthoNF
  xor-onf (orthoJoin ns) (orthoJoin ms)     = orthoJoin (ns ‚Ė≥L ms)
  xor-onf (orthoJoin ns) (orthoMeetNeg ms)  = orthoMeetNeg (ns ‚Ė≥L ms)
  xor-onf (orthoMeetNeg ns) (orthoJoin ms)  = orthoMeetNeg (ms ‚Ė≥L ns)
  xor-onf (orthoMeetNeg ns) (orthoMeetNeg ms) = orthoJoin (ns ‚Ė≥L ms)

  meet-onf : OrthoNF ‚Üí OrthoNF ‚Üí OrthoNF
  meet-onf (orthoJoin ns) (orthoJoin ms)     = orthoJoin (ns ‚ą©L ms)
  meet-onf (orthoJoin ns) (orthoMeetNeg ms)  = orthoJoin (ns ‚ąĖL ms)
  meet-onf (orthoMeetNeg ns) (orthoJoin ms)  = orthoJoin (ms ‚ąĖL ns)
  meet-onf (orthoMeetNeg ns) (orthoMeetNeg ms) = orthoMeetNeg (ns ++ ms)

  neg-onf : OrthoNF ‚Üí OrthoNF
  neg-onf (orthoJoin ns) = orthoMeetNeg ns
  neg-onf (orthoMeetNeg ns) = orthoJoin ns

  -- ‚ēź‚ēź‚ēź Direct normalization: freeBATerms ‚Üí OrthoNF ‚ēź‚ēź‚ēź

  normalizeToONF : freeBATerms ‚Ąē ‚Üí OrthoNF
  normalizeToONF (Tvar n) = orthoJoin (n ‚ą∑ [])
  normalizeToONF (Tconst false) = orthoJoin []
  normalizeToONF (Tconst true) = orthoMeetNeg []
  normalizeToONF (t +T s) = xor-onf (normalizeToONF t) (normalizeToONF s)
  normalizeToONF (-T t) = normalizeToONF t
  normalizeToONF (t ¬∑T s) = meet-onf (normalizeToONF t) (normalizeToONF s)

  -- ‚ēź‚ēź‚ēź Correctness infrastructure ‚ēź‚ēź‚ēź
  -- Core lemmas connecting list operations to ring operations.
  -- These mirror FinCofinAlgebra's finJoin‚ąě-‚ą©L etc.

  -- De Morgan: finMeetNeg ns = ¬¨(finJoin ns)
  deMorgan-finMeetNeg : (ns : List ‚Ąē) ‚Üí finMeetNeg ns ‚Č° ¬¨B (finJoin ns)
  deMorgan-finMeetNeg [] = sym (BR.+IdR ūĚüôB)
