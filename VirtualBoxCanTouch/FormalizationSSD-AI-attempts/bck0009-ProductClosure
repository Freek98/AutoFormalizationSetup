-- Countability of generator and relation index types
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

-- G = в„• вҠҺ (в„• вҠҺ Unit): left gens, right gens, separator
G : TypeвӮҖ
G = в„• вҠҺ (в„• вҠҺ Unit)

-- в„• вҠҺ Unit вү… в„• via 0 вҶҰ inr tt, suc n вҶҰ inl n
private
  в„•вҠҺ1вү…в„• : Iso (в„• вҠҺ Unit) в„•
  Iso.fun в„•вҠҺ1вү…в„• (inl n) = suc n
  Iso.fun в„•вҠҺ1вү…в„• (inr tt) = zero
  Iso.inv в„•вҠҺ1вү…в„• zero = inr tt
  Iso.inv в„•вҠҺ1вү…в„• (suc n) = inl n
  Iso.sec в„•вҠҺ1вү…в„• zero = refl
  Iso.sec в„•вҠҺ1вү…в„• (suc n) = refl
  Iso.ret в„•вҠҺ1вү…в„• (inl n) = refl
  Iso.ret в„•вҠҺ1вү…в„• (inr tt) = refl

-- G вү… в„• вҠҺ в„• вү… в„• (via в„• вҠҺ (в„• вҠҺ 1) вү… в„• вҠҺ в„• вү… в„•)
Gвү…в„• : Iso G в„•
Gвү…в„• = compIso (вҠҺIso idIso в„•вҠҺ1вү…в„•) в„•вҠҺв„•вү…в„•

-- has-Countability-structure for G
-- We use Оұ = const true, since G вү… в„•.
G-countable : has-Countability-structure G
G-countable = (О» _ вҶ’ true) , G-to-ОЈ
  where
    G-to-ОЈ : Iso G (ОЈ[ n вҲҲ в„• ] true вүЎ true)
    Iso.fun G-to-ОЈ x = Iso.fun Gвү…в„• x , refl
    Iso.inv G-to-ОЈ (n , _) = Iso.inv Gвү…в„• n
    Iso.sec G-to-ОЈ (n , p) = ОЈвүЎProp (О» _ вҶ’ isSetBool _ _) (Iso.sec Gвү…в„• n)
    Iso.ret G-to-ОЈ x = Iso.ret Gвү…в„• x

-- RelIdx = (в„• вҠҺ в„•) вҠҺ (в„• вҠҺ в„•) вү… в„•
RelIdx : TypeвӮҖ
RelIdx = (в„• вҠҺ в„•) вҠҺ (в„• вҠҺ в„•)

в„•4вү…в„• : Iso RelIdx в„•
в„•4вү…в„• = compIso (вҠҺIso в„•вҠҺв„•вү…в„• в„•вҠҺв„•вү…в„•) в„•вҠҺв„•вү…в„•

RelIdx-countable : has-Countability-structure RelIdx
RelIdx-countable = (О» _ вҶ’ true) , R-to-ОЈ
  where
    R-to-ОЈ : Iso RelIdx (ОЈ[ n вҲҲ в„• ] true вүЎ true)
    Iso.fun R-to-ОЈ x = Iso.fun в„•4вү…в„• x , refl
    Iso.inv R-to-ОЈ (n , _) = Iso.inv в„•4вү…в„• n
    Iso.sec R-to-ОЈ (n , p) = ОЈвүЎProp (О» _ вҶ’ isSetBool _ _) (Iso.sec в„•4вү…в„• n)
    Iso.ret R-to-ОЈ x = Iso.ret в„•4вү…в„• x

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- Product presentation
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

-- Generator embeddings
e-gen : вҹЁ freeBA G вҹ©
e-gen = generator (inr (inr tt))

left-gen : в„• вҶ’ вҹЁ freeBA G вҹ©
left-gen n = generator (inl n)

right-gen : в„• вҶ’ вҹЁ freeBA G вҹ©
right-gen n = generator (inr (inl n))

-- Lift maps: freeBA в„• вҶ’ freeBA G
liftL : BoolHom (freeBA в„•) (freeBA G)
liftL = inducedBAHom в„• (freeBA G) left-gen

liftR : BoolHom (freeBA в„•) (freeBA G)
liftR = inducedBAHom в„• (freeBA G) right-gen

module ProductPresentation (f g : в„• вҶ’ вҹЁ freeBA в„• вҹ©) where

  private
    A = freeBA в„• QB./Im f
    B = freeBA в„• QB./Im g

    instance
      _ = snd (freeBA G)
      _ = snd A
      _ = snd B
      _ = snd (A Г—BR B)

  -- 4 families of relations
  -- Note: A-rels are multiplied by e, B-rels by (1+e), so that ПҶ-free kills them
  -- (In Q, eВ·aвӮҷ=aвӮҷ ensures eВ·r(a)=r(a), so these generate the same ideal)
  rel4 : RelIdx вҶ’ вҹЁ freeBA G вҹ©
  rel4 (inl (inl n)) = e-gen В· fst liftL (f n)         -- e В· A-relations
  rel4 (inl (inr n)) = (рқҹҷ + e-gen) В· fst liftR (g n)  -- (1+e) В· B-relations
  rel4 (inr (inl n)) = (e-gen В· left-gen n) + left-gen n  -- eВ·aвӮҷ = aвӮҷ
  rel4 (inr (inr n)) = e-gen В· right-gen n     -- eВ·bвӮҷ = 0

  Q : BooleanRing в„“-zero
  Q = freeBA G QB./Im rel4

  -- Q is countably presented (since G and RelIdx are countable)
  Q-is-cp : has-quotient-of-freeв„•-presentation Q
  Q-is-cp = quotient-of-free-on-countable-by-countable-has-freeв„•-presentation
    G G-countable RelIdx RelIdx-countable rel4

  private instance _ = snd Q

  -- в”Җв”Җв”Җ Forward: ПҶ : Q вҶ’ A Г—BR B в”Җв”Җв”Җ

  private
    qA : BoolHom (freeBA в„•) A
    qA = QB.quotientImageHom

    qB : BoolHom (freeBA в„•) B
    qB = QB.quotientImageHom

    qG : BoolHom (freeBA G) Q
    qG = QB.quotientImageHom

  -- Map on generators G вҶ’ вҹЁ A Г—BR B вҹ©
  ПҶ-on-gens : G вҶ’ вҹЁ A Г—BR B вҹ©
  ПҶ-on-gens (inl n) = (qA $cr generator n , рқҹҳ)
  ПҶ-on-gens (inr (inl n)) = (рқҹҳ , qB $cr generator n)
  ПҶ-on-gens (inr (inr tt)) = (рқҹҷ , рқҹҳ)

  ПҶ-free : BoolHom (freeBA G) (A Г—BR B)
  ПҶ-free = inducedBAHom G (A Г—BR B) ПҶ-on-gens

  -- ПҶ-free kills all relations
  private
    -- Helper: ПҶ-free on generators
    ПҶ-eval : (x : G) вҶ’ ПҶ-free $cr generator x вүЎ ПҶ-on-gens x
    ПҶ-eval x = funExtвҒ» (evalBAInduce G (A Г—BR B) ПҶ-on-gens) x

    -- Case inl (inl n): ПҶ-free вҲҳ liftL kills f
    -- Strategy: identify ПҶ-free вҲҳcr liftL with вҹЁqA, zeroвҹ© on generators, use zeroOnImage
    ПҶ-freeвҲҳliftLвүЎ : ПҶ-free вҲҳcr liftL вүЎ вҹЁ A , B вҹ©BR qA (inducedBAHom в„• B (О» _ вҶ’ рқҹҳ))
    ПҶ-freeвҲҳliftLвүЎ = inducedBAHomUnique в„• (A Г—BR B)
      (О» k вҶ’ (qA $cr generator k , рқҹҳ))
      (ПҶ-free вҲҳcr liftL)
      (funExt (О» k вҶ’
        cong (fst ПҶ-free) (funExtвҒ» (evalBAInduce в„• (freeBA G) left-gen) k)
        вҲҷ ПҶ-eval (inl k)))
      вҲҷ sym (inducedBAHomUnique в„• (A Г—BR B)
        (О» k вҶ’ (qA $cr generator k , рқҹҳ))
        (вҹЁ A , B вҹ©BR qA (inducedBAHom в„• B (О» _ вҶ’ рқҹҳ)))
        (funExt (О» k вҶ’ ОЈPathP (refl , sym (funExtвҒ» (evalBAInduce в„• B (О» _ вҶ’ рқҹҳ)) k)))))

    -- Case inl (inr n): ПҶ-free вҲҳ liftR kills g (analogous)
    ПҶ-freeвҲҳliftRвүЎ : ПҶ-free вҲҳcr liftR вүЎ вҹЁ A , B вҹ©BR (inducedBAHom в„• A (О» _ вҶ’ рқҹҳ)) qB
    ПҶ-freeвҲҳliftRвүЎ = inducedBAHomUnique в„• (A Г—BR B)
      (О» k вҶ’ (рқҹҳ , qB $cr generator k))
      (ПҶ-free вҲҳcr liftR)
      (funExt (О» k вҶ’
        cong (fst ПҶ-free) (funExtвҒ» (evalBAInduce в„• (freeBA G) right-gen) k)
        вҲҷ ПҶ-eval (inr (inl k))))
      вҲҷ sym (inducedBAHomUnique в„• (A Г—BR B)
        (О» k вҶ’ (рқҹҳ , qB $cr generator k))
        (вҹЁ A , B вҹ©BR (inducedBAHom в„• A (О» _ вҶ’ рқҹҳ)) qB)
        (funExt (О» k вҶ’ ОЈPathP (sym (funExtвҒ» (evalBAInduce в„• A (О» _ вҶ’ рқҹҳ)) k) , refl))))

    ПҶ-kills-rels : (x : RelIdx) вҶ’ ПҶ-free $cr rel4 x вүЎ рқҹҳ
    ПҶ-kills-rels (inl (inl n)) =
      funExtвҒ» (cong fst ПҶ-freeвҲҳliftLвүЎ) (f n)
      вҲҷ ОЈPathP (QB.zeroOnImage {f = f} n , IsCommRingHom.pres0 (snd (inducedBAHom в„• B (О» _ вҶ’ рқҹҳ))))
    ПҶ-kills-rels (inl (inr n)) =
      funExtвҒ» (cong fst ПҶ-freeвҲҳliftRвүЎ) (g n)
      вҲҷ ОЈPathP (IsCommRingHom.pres0 (snd (inducedBAHom в„• A (О» _ вҶ’ рқҹҳ))) , QB.zeroOnImage {f = g} n)
    ПҶ-kills-rels (inr (inl n)) = {!  !}
    ПҶ-kills-rels (inr (inr n)) = {!  !}

  ПҶ : BoolHom Q (A Г—BR B)
  ПҶ = QB.inducedHom (A Г—BR B) ПҶ-free ПҶ-kills-rels

  -- в”Җв”Җв”Җ Backward: ПҲ : A Г—BR B вҶ’ Q в”Җв”Җв”Җ

  -- Оұ : A вҶ’ Q sends [gen(n)] вҶҰ qG(left-gen n)
  private
    Оұ-free : BoolHom (freeBA в„•) Q
    Оұ-free = inducedBAHom в„• Q (О» n вҶ’ qG $cr left-gen n)

    Оұ-freeвүЎqGвҲҳliftL : Оұ-free вүЎ qG вҲҳcr liftL
    Оұ-freeвүЎqGвҲҳliftL = inducedBAHomUnique в„• Q (О» n вҶ’ qG $cr left-gen n)
      (qG вҲҳcr liftL)
      (funExt (О» k вҶ’ cong (fst qG) (funExtвҒ» (evalBAInduce в„• (freeBA G) left-gen) k)))

    Оұ-kills-f : (n : в„•) вҶ’ Оұ-free $cr f n вүЎ рқҹҳ
    Оұ-kills-f n =
      funExtвҒ» (cong fst Оұ-freeвүЎqGвҲҳliftL) (f n) вҲҷ QB.zeroOnImage (inl (inl n))

    Оұ : BoolHom A Q
    Оұ = QB.inducedHom Q Оұ-free Оұ-kills-f

  -- ОІ : B вҶ’ Q sends [gen(n)] вҶҰ qG(right-gen n)
  private
    ОІ-free : BoolHom (freeBA в„•) Q
    ОІ-free = inducedBAHom в„• Q (О» n вҶ’ qG $cr right-gen n)

    ОІ-freeвүЎqGвҲҳliftR : ОІ-free вүЎ qG вҲҳcr liftR
    ОІ-freeвүЎqGвҲҳliftR = inducedBAHomUnique в„• Q (О» n вҶ’ qG $cr right-gen n)
      (qG вҲҳcr liftR)
      (funExt (О» k вҶ’ cong (fst qG) (funExtвҒ» (evalBAInduce в„• (freeBA G) right-gen) k)))

    ОІ-kills-g : (n : в„•) вҶ’ ОІ-free $cr g n вүЎ рқҹҳ
    ОІ-kills-g n =
      funExtвҒ» (cong fst ОІ-freeвүЎqGвҲҳliftR) (g n) вҲҷ QB.zeroOnImage (inl (inr n))

    ОІ : BoolHom B Q
    ОІ = QB.inducedHom Q ОІ-free ОІ-kills-g

  -- ПҲ(a,b) = qG(e) В· Оұ(a) + qG(1+e) В· ОІ(b)
  private
    eQ : вҹЁ Q вҹ©
    eQ = qG $cr e-gen

    e'Q : вҹЁ Q вҹ©
    e'Q = qG $cr (рқҹҷ + e-gen)

  ПҲ-fun : вҹЁ A Г—BR B вҹ© вҶ’ вҹЁ Q вҹ©
  ПҲ-fun (a , b) = eQ В· (Оұ $cr a) + e'Q В· (ОІ $cr b)

  -- ПҲ is a ring hom
  postulate
    ПҲ-is-hom : IsCommRingHom
      (BooleanRingStrвҶ’CommRingStr (snd (A Г—BR B)))
      ПҲ-fun
      (BooleanRingStrвҶ’CommRingStr (snd Q))

  ПҲ : BoolHom (A Г—BR B) Q
  fst ПҲ = ПҲ-fun
  snd ПҲ = ПҲ-is-hom

  -- в”Җв”Җв”Җ Roundtrips в”Җв”Җв”Җ

  postulate
    ПҶвҲҳПҲ=id : ПҶ вҲҳcr ПҲ вүЎ idCommRingHom (BooleanRingвҶ’CommRing (A Г—BR B))
    ПҲвҲҳПҶ=id : ПҲ вҲҳcr ПҶ вүЎ idCommRingHom (BooleanRingвҶ’CommRing Q)

  -- The equivalence
  QвүғAГ—B : BooleanRingEquiv Q (A Г—BR B)
  QвүғAГ—B = isoToCommRingEquiv ПҶ (fst ПҲ)
    (funExtвҒ» (cong fst ПҶвҲҳПҲ=id))
    (funExtвҒ» (cong fst ПҲвҲҳПҶ=id))

  -- A Г—BR B has a freeв„• presentation
  AГ—B-has-freeв„•-pres : has-quotient-of-freeв„•-presentation (A Г—BR B)
  AГ—B-has-freeв„•-pres =
    subst has-quotient-of-freeв„•-presentation
      (uaBoolRing QвүғAГ—B)
      Q-is-cp

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- Product preserves equivalences
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

Г—BR-resp-equiv : (A A' B B' : BooleanRing в„“-zero) вҶ’
  BooleanRingEquiv A A' вҶ’ BooleanRingEquiv B B' вҶ’
  BooleanRingEquiv (A Г—BR B) (A' Г—BR B')
fst (fst (Г—BR-resp-equiv A A' B B' eA eB)) (a , b) =
  fst (fst eA) a , fst (fst eB) b
snd (fst (Г—BR-resp-equiv A A' B B' eA eB)) =
  isoToIsEquiv theIso
  where
    theIso : Iso (вҹЁ A вҹ© Г— вҹЁ B вҹ©) (вҹЁ A' вҹ© Г— вҹЁ B' вҹ©)
    Iso.fun theIso (a , b) = fst (fst eA) a , fst (fst eB) b
    Iso.inv theIso (a' , b') = invEq (fst eA) a' , invEq (fst eB) b'
    Iso.sec theIso (a' , b') = ОЈPathP (secEq (fst eA) a' , secEq (fst eB) b')
    Iso.ret theIso (a , b) = ОЈPathP (retEq (fst eA) a , retEq (fst eB) b)
snd (Г—BR-resp-equiv A A' B B' eA eB) = makeIsCommRingHom
  (ОЈPathP (IsCommRingHom.pres1 (snd eA) , IsCommRingHom.pres1 (snd eB)))
  (О» x y вҶ’ ОЈPathP (IsCommRingHom.pres+ (snd eA) _ _ , IsCommRingHom.pres+ (snd eB) _ _))
  (О» x y вҶ’ ОЈPathP (IsCommRingHom.presВ· (snd eA) _ _ , IsCommRingHom.presВ· (snd eB) _ _))

