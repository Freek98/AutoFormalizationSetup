private module _ {‚Ąď : Level} (R : CommRing ‚Ąď) where
  open CommRingStr (snd R)

  isIdemRing' : Type ‚Ąď
  isIdemRing' = ‚ąÄ (r : ‚ü® R ‚ü©) ‚Üí r ¬∑ r - r ‚Č° 0r
  
  IdemRing'‚Üí : isIdemRing' ‚Üí isIdemRing R
  IdemRing'‚Üí p r = equalByDifference (CommRing‚ÜíRing R) _ _ (p r)

  IdemRing‚Üí' : isIdemRing R ‚Üí isIdemRing'
  IdemRing‚Üí' p r = r ¬∑ r - r ‚Č°‚ü® cong (őĽ a ‚Üí a - r) (p r) ‚ü© r - r ‚Č°‚ü® solve! R ‚ü© 0r ‚ąé

module _ {‚Ąď : Level} (R : CommRing ‚Ąď) where
  open CommRingStr ‚¶É...‚¶Ą
  instance
    _ = snd R

  idemFunc : ‚ü® R ‚ü© ‚Üí ‚ü® R ‚ü©
  idemFunc a = a ¬∑ a - a

  idemIdeal : IdealsIn R
  idemIdeal = genIdeal R idemFunc

  _/Idem : CommRing ‚Ąď
  _/Idem = R /Im idemFunc

  _/IdemisIdem : isIdemRing _/Idem
  _/IdemisIdem = IdemRing'‚Üí _/Idem (SQ.elimProp (őĽ y ‚Üí CommRingStr.is-set (str _/Idem) _ _) (zeroOnImage _ _ ))

  forceBA : BooleanRing ‚Ąď
  forceBA = idemCommRing‚ÜíBR _/Idem _/IdemisIdem 

  module _ {‚Ąď' : Level} (B : BooleanRing ‚Ąď') (f : CommRingHom R (BooleanRing‚ÜíCommRing B)) where

    instance
      _ = (snd (BooleanRing‚ÜíCommRing B))

    open IsCommRingHom (snd f)

    mapsIntoBAsAnnihilatesIdemFunc : (x : ‚ü® R ‚ü©) ‚Üí
                                     f $cr (idemFunc x) ‚Č° 0r
    mapsIntoBAsAnnihilatesIdemFunc x = f $cr ( x ¬∑ x - x)
                                         ‚Č°‚ü® pres+ _ _ ‚ü©
                                       f $cr (x ¬∑ x) + f $cr (- x )
                                         ‚Č°‚ü® cong (őĽ a ‚Üí _ + a) (pres- _) ‚ü©
                                       f $cr (x ¬∑ x) - f $cr x
                                         ‚Č°‚ü® cong (őĽ a ‚Üí a - _) (pres¬∑ _ _) ‚ü©
                                       f $cr x ¬∑ f $cr x - f $cr x
                                         ‚Č°‚ü® IdemRing‚Üí' (BooleanRing‚ÜíCommRing B) (BooleanRingStr.¬∑Idem (snd B)) (f $cr x) ‚ü©
                                       0r ‚ąé

opaque 
  freeBA : {‚Ąď : Level} ‚Üí (A : Type ‚Ąď) ‚Üí BooleanRing ‚Ąď
  freeBA A = forceBA (BoolCR [ A ])

opaque
  unfolding freeBA
  generator : {‚Ąď : Level} ‚Üí {A : Type ‚Ąď} ‚Üí A ‚Üí ‚ü® freeBA A ‚ü©
  generator a = quotientHom _ (idemIdeal _) $cr var a

module _ {‚Ąď : Level} (A : Type ‚Ąď) (B : BooleanRing ‚Ąď) (f : A ‚Üí ‚ü® B ‚ü©) where
  open IsCommRingHom
  open CommRingStr ‚¶É...‚¶Ą
  instance
    _ = str (BooleanRing‚ÜíCommRing B)

  private
    2[A] : CommRing _
    2[A] = BoolCR [ A ]

    2[A]‚ÜíB : (CommRingHom 2[A] (BooleanRing‚ÜíCommRing B) )
    2[A]‚ÜíB = TV.inducedHom (BooleanRing‚ÜíCommRing B) (BoolBR‚Üí B) f

    idem : ‚ü® 2[A] ‚ü© ‚Üí ‚ü® 2[A] ‚ü©
    idem = idemFunc 2[A]
    
    2[A]‚ÜíBRespIdem : (x : ‚ü® 2[A] ‚ü©) ‚Üí 2[A]‚ÜíB $cr (idem x) ‚Č° 0r
    2[A]‚ÜíBRespIdem = mapsIntoBAsAnnihilatesIdemFunc _ B 2[A]‚ÜíB
  
  instance
    _ = str 2[A]
  opaque
    unfolding freeBA
    unfolding IQ.inducedHom
    inducedBAHom : BoolHom (freeBA A) B
    inducedBAHom = IQ.inducedHom 2[A] idem 2[A]‚ÜíB 2[A]‚ÜíBRespIdem 

  opaque
    unfolding freeBA 
    unfolding generator
    unfolding inducedBAHom
    unfolding IQ.inducedHom
    inducedBAHomUnique : (g : BoolHom (freeBA A) B) ‚Üí
                         ((fst g) ‚ąė generator ‚Č° f)  ‚Üí
                         inducedBAHom ‚Č° g
    inducedBAHomUnique g agreeOnGens = IQ.inducedHomUnique 2[A] idem 2[A]‚ÜíB 2[A]‚ÜíBRespIdem g 2[A]‚ÜíB=gq where
 
      g‚ąėquot : CommRingHom 2[A] (BooleanRing‚ÜíCommRing B)
      g‚ąėquot = g ‚ąėcr quotientHom _ _ 
 
      2[A]‚ÜíB=gq : 2[A]‚ÜíB ‚Č° g‚ąėquot
      2[A]‚ÜíB=gq = TV.inducedHomUnique _ _ f g‚ąėquot (BoolBR‚ÜíIsUnique B (g‚ąėquot ‚ąėcr constPolynomial BoolCR A)) agreeOnGens


module _ {‚Ąď : Level} (A : Type ‚Ąď) (B : BooleanRing ‚Ąď) (f : A ‚Üí ‚ü® B ‚ü©) where
  opaque 
    unfolding generator 
    unfolding inducedBAHom
    unfolding IQ.inducedHom
    evalBAInduce : fst (inducedBAHom A B f) ‚ąė generator ‚Č° f
    evalBAInduce = TV.evalInduce _ _ f

freeBA-universal-property : {‚Ąď : Level} ‚Üí (A : Type ‚Ąď) ‚Üí (B : BooleanRing ‚Ąď) ‚Üí 
                            Iso (A ‚Üí ‚ü® B ‚ü©)
                            (BoolHom (freeBA A) B)
Iso.fun (freeBA-universal-property A B)   = inducedBAHom A B
Iso.inv (freeBA-universal-property A B) f = fst f ‚ąė generator
Iso.sec (freeBA-universal-property A B) f = inducedBAHomUnique A B (fst f ‚ąė generator) f refl 
Iso.ret (freeBA-universal-property A B)   = evalBAInduce _ _ 

