module adjunctionFact 
  {в„“C в„“C' в„“D в„“D' : Level} {C : Category в„“C в„“C'} {D : Category в„“D в„“D'}
  (F : Functor C D) (G : Functor D C) (adj : F UnitCounit.вҠЈ G) where

  open UnitCounit._вҠЈ_ adj

  adjIso : (c : C .ob) (d : D .ob) вҶ’ RealIso (C [ c , G вҹ… d вҹҶ ]) (D [ F вҹ… c вҹҶ , d ])
  adjIso c d = invRealIso $ adjвҶ’adj' F G adj .NaturalBijection._вҠЈ_.adjIso {c} {d} 
  
  compО· : (x y : C .ob) вҶ’ (C [ x , y ]) вҶ’ C [ x , (G вҲҳF F) вҹ… y вҹҶ ]
  compО· _ y f = f вӢҶвҹЁ C вҹ© (О· вҹҰ y вҹ§)

  module _ (x y : C .ob) where 
-- x вҶ’ y -------> F x вҶ’ F y
--  _вӢҶО· \           / adjIso
--        x вҶ’ G F y
    opaque
      compose : RealIso.fun (adjIso x (F вҹ… y вҹҶ)) вҲҳ compО· x y вүЎ F .F-hom {x = x} {y = y}
      compose = funExt О» f вҶ’  
        F вҹӘ f   вӢҶвҹЁ C вҹ© (О· вҹҰ y вҹ§)вҹ«      вӢҶвҹЁ D вҹ© (Оө вҹҰ F вҹ… y вҹҶ вҹ§) 
          вүЎвҹЁ cong (О» h вҶ’ h вӢҶвҹЁ D вҹ© (Оө вҹҰ F вҹ… y вҹҶ вҹ§)) (F .F-seq f (О· вҹҰ y вҹ§)) вҹ©
        F вҹӘ f вҹ« вӢҶвҹЁ D вҹ© F вҹӘ О· вҹҰ y вҹ§ вҹ«   вӢҶвҹЁ D вҹ© (Оө вҹҰ F вҹ… y вҹҶ вҹ§) 
          вүЎвҹЁ D .вӢҶAssoc _ _ _ вҹ© 
        F вҹӘ f вҹ« вӢҶвҹЁ D вҹ© ((F вҹӘ О· вҹҰ y вҹ§ вҹ«)вӢҶвҹЁ D вҹ© (Оө вҹҰ F вҹ… y вҹҶ вҹ§) )
          вүЎвҹЁ cong (О» h вҶ’ F вҹӘ f вҹ« вӢҶвҹЁ D вҹ© h) (О”вӮҒ y) вҹ© 
        F вҹӘ f вҹ« вӢҶвҹЁ D вҹ© D .id 
          вүЎвҹЁ D .вӢҶIdR (F вҹӘ f вҹ«) вҹ© 
        F вҹӘ f вҹ« вҲҺ
    module _ (О·Isoy : isIso C (О· вҹҰ y вҹ§)) where
      О·IsoвҶ’FHomEqu : isEquiv $ F . F-hom {x = x} {y = y}
      О·IsoвҶ’FHomEqu = 2/3.ghEqu (F .F-hom) (compО· x y) (RealIso.fun $ adjIso x (F .F-ob y)) compose 
        (isIsoToIsEquiv (composeWithIsoRisIso C (О· вҹҰ y вҹ§) О·Isoy)) 
        (snd (isoToEquiv (adjIso x (F .F-ob y)))) 

  О·IsIso : C . ob вҶ’ hProp _
  О·IsIso c = isIso C (О· вҹҰ c вҹ§) , isPropIsIso (О· вҹҰ c вҹ§)

  ОөIsIso : D . ob вҶ’ hProp _
  ОөIsIso d = isIso D (Оө вҹҰ d вҹ§) , isPropIsIso (Оө вҹҰ d вҹ§)

  Fpreserves : (c : C .ob) вҶ’ вҹЁ О·IsIso c вҹ© вҶ’ вҹЁ ОөIsIso (F вҹ… c вҹҶ) вҹ©
  Fpreserves c О·cIso = isoUniqueness.SectionIsIsoToIsIso (О”вӮҒ c) (F-PresIsIso {F = F} О·cIso)
  
  Gpreserves : (d : D .ob) вҶ’ вҹЁ ОөIsIso d вҹ© вҶ’ вҹЁ О·IsIso (G вҹ… d вҹҶ) вҹ© 
  Gpreserves d ОөdIso = isoUniqueness.RetractionIsIsoToIsIso (О”вӮӮ d) (F-PresIsIso {F = G} ОөdIso) 

  О·IsoSubCat : Category _ _ 
  О·IsoSubCat = ОЈPropCat* C О·IsIso

  ОөIsoSubCat  : Category _ _ 
  ОөIsoSubCat = ОЈPropCat* D ОөIsIso
  
  open NatTrans
  open NatIso
  open UnitCounit.TriangleIdentities
  О·IsoвүғОөIso : AdjointEquivalence О·IsoSubCat ОөIsoSubCat 
  О·IsoвүғОөIso .AdjointEquivalence.fun = FrestrictedToPropCat ОөIsIso (F вҲҳF fstFunctor C О·IsIso) (uncurry Fpreserves)
  О·IsoвүғОөIso .AdjointEquivalence.inv = FrestrictedToPropCat О·IsIso (G вҲҳF fstFunctor D ОөIsIso) (uncurry Gpreserves)
  О·IsoвүғОөIso .AdjointEquivalence.О· .trans .N-ob         (c , _)        = О· вҹҰ c вҹ§
  О·IsoвүғОөIso .AdjointEquivalence.Оө .trans .N-ob         (d , _)        = Оө вҹҰ d вҹ§
  О·IsoвүғОөIso .AdjointEquivalence.О· .trans .N-hom                       = О· .N-hom
  О·IsoвүғОөIso .AdjointEquivalence.Оө .trans .N-hom                       = Оө .N-hom
  О·IsoвүғОөIso .AdjointEquivalence.О· .nIso                (c , О·cIso)    = isIsoОЈPropCat* C О·IsIso О·cIso 
  О·IsoвүғОөIso .AdjointEquivalence.Оө .nIso                (d , ОөdIso)    = isIsoОЈPropCat* D ОөIsIso ОөdIso
  О·IsoвүғОөIso .AdjointEquivalence.triangleIdentities .О”вӮҒ (c , _)        = О”вӮҒ triangleIdentities c
  О·IsoвүғОөIso .AdjointEquivalence.triangleIdentities .О”вӮӮ (d , _)        = О”вӮӮ triangleIdentities d
 
  
  module _ {в„“S в„“S' : Level} {S : Category в„“S в„“S'} (H : Functor S О·IsoSubCat) (HfullyFaithful : isFullyFaithful H) where
    private
      F' = О·IsoвүғОөIso .AdjointEquivalence.fun
      G' = О·IsoвүғОөIso .AdjointEquivalence.inv

      G'isEquivalence : isEquivalence G'
      G'isEquivalence = basicFacts.invEquivalence О·IsoвүғОөIso


    О·HIso : (x : S .ob) вҶ’ CatIso О·IsoSubCat (H вҹ… x вҹҶ) ((G' вҲҳF F' вҲҳF H) вҹ… x вҹҶ) 
    О·HIso x .fst = О· вҹҰ fst $ H вҹ… x вҹҶ вҹ§ 
    О·HIso x .snd = isIsoОЈPropCat* C О·IsIso (snd $ H вҹ… x вҹҶ)
    
    module morphAction {x y : S .ob} where 
      О·conjugationIso : RealIso 
        (О·IsoSubCat [ (G' вҲҳF F' вҲҳF H) вҹ… x вҹҶ , (G' вҲҳF F' вҲҳF H) вҹ… y вҹҶ ]) 
        (О·IsoSubCat [              H  вҹ… x вҹҶ ,              H  вҹ… y вҹҶ ])
      О·conjugationIso = compRealIso 
        (uncurry (composeWithIsoRIso О·IsoSubCat) (invIso (О·HIso y)) {z = (G' вҲҳF F' вҲҳF H) вҹ… x вҹҶ}) 
        (uncurry (composeWithIsoLIso О·IsoSubCat)         (О·HIso x)  {z =              H  вҹ… y вҹҶ}) 
      
      О·conjugation = RealIso.fun О·conjugationIso 
      
      reflectBackIntoE : О·IsoSubCat [ H вҹ… x вҹҶ  , H вҹ… y вҹҶ ] вҶ’ S [ x , y ] 
      reflectBackIntoE = fst $ invEquiv (H .F-hom , HfullyFaithful x y)

      totalAction : ОөIsoSubCat [ (F' вҲҳF H) вҹ… x вҹҶ , (F' вҲҳF H) вҹ… y вҹҶ ] вҶ’ S [ x , y ]
      totalAction = (reflectBackIntoE вҲҳ О·conjugation вҲҳ G .F-hom)
      
      totalActionEquiv : ОөIsoSubCat [ (F' вҲҳF H) вҹ… x вҹҶ , (F' вҲҳF H) вҹ… y вҹҶ ] вүғ S [ x , y ]
      totalActionEquiv = 
        G'HomEquiv  вҲҷвӮ‘ О·conjugationEquiv вҲҷвӮ‘ GhomEquiv  where 
          G'HomEquiv : ОөIsoSubCat [       (F' вҲҳF H) вҹ… x вҹҶ ,       (F' вҲҳF H) вҹ… y вҹҶ ] вүғ 
                       О·IsoSubCat [ (G' вҲҳF F' вҲҳF H) вҹ… x вҹҶ , (G' вҲҳF F' вҲҳF H) вҹ… y вҹҶ ] 
          G'HomEquiv .fst = G' .F-hom {x = (F' вҲҳF H) вҹ… x вҹҶ} {y = (F' вҲҳF H) вҹ… y вҹҶ}
          G'HomEquiv .snd = (isEquivвҶ’FullyFaithful G'isEquivalence ((F' вҲҳF H) вҹ… x вҹҶ) ((F' вҲҳF H) вҹ… y вҹҶ)) 
          О·conjugationEquiv = isoToEquiv О·conjugationIso
          GhomEquiv = invEquiv (H .F-hom , HfullyFaithful x y)

    module morphActionId {x : S .ob} where
      open morphAction
      О·conjugationId : О·conjugation {x = x} (C .id) вүЎ C .id
      О·conjugationId = О·conjugation (C .id) 
                         вүЎвҹЁ solveCat! C вҹ©
                       О· вҹҰ fst (H вҹ… x вҹҶ) вҹ§ вӢҶвҹЁ C вҹ© (snd (H вҹ… x вҹҶ) .isIso.inv)
                         вүЎвҹЁ snd (H вҹ… x вҹҶ) .isIso.ret вҹ©
                       C .id вҲҺ

      reflectBackIntoEId : reflectBackIntoE {x = x} (C .id) вүЎ S .id
      reflectBackIntoEId = invEquivFact.knownInfo (H .F-hom , HfullyFaithful x x) (S .id) (C .id) (H .F-id) 

      totalActionId : totalAction {x = x} (D .id) вүЎ S .id
      totalActionId =
        (reflectBackIntoE вҲҳ О·conjugation вҲҳ (G .F-hom)) (D .id) 
          вүЎвҹЁ cong (reflectBackIntoE вҲҳ О·conjugation) (G .F-id) вҹ© 
        (reflectBackIntoE вҲҳ О·conjugation) (C .id) 
          вүЎвҹЁ cong reflectBackIntoE О·conjugationId вҹ© 
        reflectBackIntoE (C .id) 
          вүЎвҹЁ reflectBackIntoEId вҹ© 
        S .id вҲҺ
    module morphActionSeq {x y z : S .ob} 
        where
      open morphAction 
      О·conjugationSeq : 
        (f : О·IsoSubCat [ (G' вҲҳF F' вҲҳF H) вҹ… x вҹҶ , (G' вҲҳF F' вҲҳF H) вҹ… y вҹҶ ]) вҶ’
        (g : О·IsoSubCat [ (G' вҲҳF F' вҲҳF H) вҹ… y вҹҶ , (G' вҲҳF F' вҲҳF H) вҹ… z вҹҶ ]) вҶ’ 
        О·conjugation (f вӢҶвҹЁ C вҹ© g) вүЎ ((О·conjugation f) вӢҶвҹЁ C вҹ© (О·conjugation g))
      О·conjugationSeq f g = 
        О·x вӢҶвҹЁ C вҹ© ((f вӢҶвҹЁ C вҹ©                          g) вӢҶвҹЁ C вҹ© О·zInv)
          вүЎвҹЁ solveCat! C вҹ© 
        О·x вӢҶвҹЁ C вҹ© (f вӢҶвҹЁ C вҹ©      (C .id) вӢҶвҹЁ C вҹ©      g) вӢҶвҹЁ C вҹ© О·zInv 
          вүЎвҹЁ cong (О» h вҶ’ 
        О·x вӢҶвҹЁ C вҹ© (f вӢҶвҹЁ C вҹ©        h вӢҶвҹЁ C вҹ©          g) вӢҶвҹЁ C вҹ© О·zInv) 
          (sym (sec $ snd $ H вҹ… y вҹҶ )) 
           вҹ© 
        О·x вӢҶвҹЁ C вҹ© (f вӢҶвҹЁ C вҹ© (О·yInv вӢҶвҹЁ C вҹ© О·y) вӢҶвҹЁ C вҹ© g) вӢҶвҹЁ C вҹ© О·zInv
          вүЎвҹЁ solveCat! C вҹ©
        (О·conjugation f) вӢҶвҹЁ C вҹ© (О·conjugation g) 
          вҲҺ where
          open isIso 
          E = О·IsoSubCat
          О·x    = О· вҹҰ fst $ H вҹ… x вҹҶ вҹ§
          О·y    = О· вҹҰ fst $ H вҹ… y вҹҶ вҹ§
          О·yInv = inv (snd $ H вҹ… y вҹҶ)
          О·zInv = inv (snd $ H вҹ… z вҹҶ)

      reflectBackIntoESeq : 
        (f : О·IsoSubCat [ H вҹ… x вҹҶ  , H вҹ… y вҹҶ ]) вҶ’ 
        (g : О·IsoSubCat [ H вҹ… y вҹҶ  , H вҹ… z вҹҶ ]) вҶ’ 
        reflectBackIntoE (f вӢҶвҹЁ C вҹ© g) вүЎ 
        (reflectBackIntoE f вӢҶвҹЁ S вҹ© reflectBackIntoE g)
      reflectBackIntoESeq f g = 
          invEquivFact.embedding (F-hom H , HfullyFaithful x z) _ _ $
            H вҹӘ invHhom (f вӢҶвҹЁ C вҹ© g) вҹ« 
              вүЎвҹЁ lInvH вҹ© 
            f вӢҶвҹЁ C вҹ© g
              вүЎвҹЁ sym $ congвӮӮ (C ._вӢҶ_) lInvH lInvH вҹ© 
            H вҹӘ (invHhom f) вҹ« вӢҶвҹЁ C вҹ© H вҹӘ (invHhom g) вҹ«
              вүЎвҹЁ sym (H .F-seq (invHhom f) (invHhom g)) вҹ© 
            H вҹӘ (invHhom f) вӢҶвҹЁ S вҹ© (invHhom g) вҹ« вҲҺ
            where
              HhomEqu : {x y : S .ob} вҶ’ S [ x , y ] вүғ О·IsoSubCat [ H вҹ… x вҹҶ  , H вҹ… y вҹҶ ] 
              HhomEqu {x = x} {y = y} = (H .F-hom , HfullyFaithful x y)
              invHhom : {x y : S .ob} вҶ’ О·IsoSubCat [ H вҹ… x вҹҶ  , H вҹ… y вҹҶ ] вҶ’ S [ x , y ]
              invHhom = fst $ invEquiv HhomEqu
              lInvH   : {x y : S .ob} вҶ’ {f : О·IsoSubCat [ H вҹ… x вҹҶ , H вҹ… y вҹҶ ]} вҶ’ (H вҹӘ invHhom f вҹ« вүЎ f)
              lInvH {x = x} {y = y} {f = f} = cong (О» e вҶ’ fst e f) (invEquiv-is-linv HhomEqu) 

      totalActionSeq : 
        (f : ОөIsoSubCat [ (F' вҲҳF H) вҹ… x вҹҶ , (F' вҲҳF H) вҹ… y вҹҶ ]) вҶ’ 
        (g : ОөIsoSubCat [ (F' вҲҳF H) вҹ… y вҹҶ , (F' вҲҳF H) вҹ… z вҹҶ ]) вҶ’ 
        totalAction (f вӢҶвҹЁ D вҹ©  g) вүЎ totalAction f вӢҶвҹЁ S вҹ© totalAction g
      totalActionSeq f g = 
        (reflectBackIntoE вҲҳ О·conjugation вҲҳ G .F-hom) (f вӢҶвҹЁ D вҹ© g) 
          вүЎвҹЁ cong (reflectBackIntoE вҲҳ О·conjugation) (G .F-seq f g) вҹ© 
        (reflectBackIntoE вҲҳ О·conjugation) ( (G .F-hom f) вӢҶвҹЁ C вҹ© (G .F-hom g) ) 
          вүЎвҹЁ cong reflectBackIntoE (О·conjugationSeq _ _) вҹ© 
        (reflectBackIntoE) (((О·conjugation вҲҳ G .F-hom) f) вӢҶвҹЁ C вҹ© (О·conjugation вҲҳ G .F-hom) g ) 
          вүЎвҹЁ reflectBackIntoESeq _ _ вҹ© 
        (reflectBackIntoE вҲҳ О·conjugation вҲҳ G .F-hom) f вӢҶвҹЁ S вҹ© 
        (reflectBackIntoE вҲҳ О·conjugation вҲҳ G .F-hom) g  вҲҺ
    restrictRightAdjoint : Functor (ImageFunctor.Image (F' вҲҳF H)) S
    restrictRightAdjoint .F-ob e = e 
    restrictRightAdjoint .F-hom  = totalAction where
      open morphAction
    restrictRightAdjoint .F-id = totalActionId where
      open morphActionId 
    restrictRightAdjoint .F-seq = totalActionSeq where
      open morphActionSeq
    
    open AdjointEquivalence renaming (О· to О·AdjEqu)
    open ImageFunctor

    -- Key roundtrip: totalAction вҲҳ (F'вҲҳH).F-hom = id
    roundtrip-О· : {x y : S .ob} (f : S [ x , y ]) вҶ’
      morphAction.totalAction {x} {y} ((F' вҲҳF H) .F-hom f) вүЎ f
    roundtrip-О· {x} {y} f =
      let open morphAction {x} {y}
          open isIso
          О·x = О· вҹҰ fst (H вҹ… x вҹҶ) вҹ§
          О·y = О· вҹҰ fst (H вҹ… y вҹҶ) вҹ§
          О·yInv = inv (snd (H вҹ… y вҹҶ))
          Hf = H .F-hom f
      in
      cong reflectBackIntoE (
        sym (C .вӢҶAssoc О·x _ О·yInv)
        вҲҷ cong (О» h вҶ’ h вӢҶвҹЁ C вҹ© О·yInv) (sym (О· .N-hom Hf))
        вҲҷ C .вӢҶAssoc Hf О·y О·yInv
        вҲҷ cong (О» h вҶ’ Hf вӢҶвҹЁ C вҹ© h) (ret (snd (H вҹ… y вҹҶ)))
        вҲҷ C .вӢҶIdR Hf)
      вҲҷ invEquivFact.knownInfo (H .F-hom , HfullyFaithful x y) f (H .F-hom f) refl

    -- Other roundtrip: (F'вҲҳH).F-hom вҲҳ totalAction = id (via equivalence + roundtrip-О·)
    roundtrip-Оө : {x y : S .ob} (g : ОөIsoSubCat [ (F' вҲҳF H) вҹ… x вҹҶ , (F' вҲҳF H) вҹ… y вҹҶ ]) вҶ’
      (F' вҲҳF H) .F-hom (morphAction.totalAction {x} {y} g) вүЎ g
    roundtrip-Оө {x} {y} g =
      let open morphAction {x} {y}
          e = totalActionEquiv
          FHf=invEq : (f : S [ x , y ]) вҶ’
            (F' вҲҳF H) .F-hom f вүЎ invEq e f
          FHf=invEq f = cong fst (isContrвҶ’isProp (e .snd .equiv-proof f)
            ((F' вҲҳF H) .F-hom f , roundtrip-О· f)
            (invEq e f , secEq e f))
      in FHf=invEq (totalAction g) вҲҷ retEq e g

    restrictedAdjunction : AdjointEquivalence S $ Image (F' вҲҳF H)
    restrictedAdjunction .fun = RestrictCodomain (F' вҲҳF H)
    restrictedAdjunction .inv = restrictRightAdjoint
    restrictedAdjunction .О·AdjEqu .trans .N-ob x = S .id
    restrictedAdjunction .О·AdjEqu .trans .N-hom {x} {y} f =
      S .вӢҶIdR f вҲҷ sym (roundtrip-О· f) вҲҷ sym (S .вӢҶIdL _)
    restrictedAdjunction .О·AdjEqu .nIso x = isiso (S .id) (S .вӢҶIdL _) (S .вӢҶIdL _)
    restrictedAdjunction .Оө .trans .N-ob x = D .id
    restrictedAdjunction .Оө .trans .N-hom {x} {y} f =
