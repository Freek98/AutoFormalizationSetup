    BoolHom-ext : {A B : BooleanRing в„“-zero} вҶ’ (h k : BoolHom A B)
      вҶ’ ((x : вҹЁ A вҹ©) вҶ’ fst h x вүЎ fst k x) вҶ’ h вүЎ k
