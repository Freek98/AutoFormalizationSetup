    DПғ (a , b) = D a
    xyInDПғ : inDec (ОЈStoneCHaus S T) (x , y) DПғ
    xyInDПғ = xInD
    x'y'InDПғ : inDec (ОЈStoneCHaus S T) (x' , y') DПғ
    x'y'InDПғ = ccПғ DПғ xyInDПғ
    goal : inDec (StoneвҶ’CHaus S) x' D
    goal = x'y'InDПғ

  -- Proof of ОЈStone-isTotallyDisconnected following tex Theorem 2214
  ОЈStone-isTotallyDisconnected : (S : Stone) (T : fst S вҶ’ Stone)
    вҶ’ isTotallyDisconnected (ОЈStoneCHaus S T)
  ОЈStone-isTotallyDisconnected S T (x , y) (x' , y') ccПғ = goal
    where
    x'InQx : fst (ConnectedComponent (StoneвҶ’CHaus S) x x')
    x'InQx = projвӮҒ-preserves-CC S T x y x' y' ccПғ

    xвүЎx' : x вүЎ x'
    xвүЎx' = StoneCompactHausdorffTotallyDisconnected-forward S x x' x'InQx

    y'-in-Tx : fst (T x)
    y'-in-Tx = subst (О» z вҶ’ fst (T z)) (sym xвүЎx') y'

    QПғ : TypeвӮҖ
    QПғ = ОЈ[ p вҲҲ SigmaStoneType S T ] fst (ConnectedComponent (ОЈStoneCHaus S T) (x , y) p)

    xy-in-QПғ : QПғ
    xy-in-QПғ = (x , y) , О» D xInD вҶ’ xInD  -- reflexivity of connected component

    x'y'-in-QПғ : QПғ
    x'y'-in-QПғ = (x' , y') , ccПғ

    make-f : (g : fst (T x) вҶ’ Bool) вҶ’ QПғ вҶ’ Bool
    make-f g ((a , b) , cc) = g (subst (О» z вҶ’ fst (T z)) (sym p_a) b)
      where
      p_a : x вүЎ a
      p_a = StoneCompactHausdorffTotallyDisconnected-forward S x a
            (projвӮҒ-preserves-CC S T x y a b cc)

    f-constant : (g : fst (T x) вҶ’ Bool) вҶ’ make-f g xy-in-QПғ вүЎ make-f g x'y'-in-QПғ
    f-constant g = ConnectedComponentConnected (ОЈStoneCHaus S T) (x , y) (make-f g) xy-in-QПғ x'y'-in-QПғ

    isSetS : isSet (fst S)
    isSetS = StoneEqualityClosedModule.hasStoneStrвҶ’isSet S

    p_x : x вүЎ x
    p_x = StoneCompactHausdorffTotallyDisconnected-forward S x x
          (projвӮҒ-preserves-CC S T x y x y (О» D xInD вҶ’ xInD))

    p_xвүЎrefl : p_x вүЎ refl
    p_xвүЎrefl = isSetS x x p_x refl

    p_x' : x вүЎ x'
    p_x' = StoneCompactHausdorffTotallyDisconnected-forward S x x'
           (projвӮҒ-preserves-CC S T x y x' y' ccПғ)

    make-f-xy : (g : fst (T x) вҶ’ Bool) вҶ’ make-f g xy-in-QПғ вүЎ g y
    make-f-xy g = cong (О» p вҶ’ g (subst (О» z вҶ’ fst (T z)) (sym p) y)) p_xвүЎrefl
                вҲҷ cong g (transportRefl y)

    p_x'вүЎxвүЎx' : p_x' вүЎ xвүЎx'
    p_x'вүЎxвүЎx' = isSetS x x' p_x' xвүЎx'

    make-f-x'y' : (g : fst (T x) вҶ’ Bool) вҶ’ make-f g x'y'-in-QПғ вүЎ g y'-in-Tx
    make-f-x'y' g = cong (О» p вҶ’ g (subst (О» z вҶ’ fst (T z)) (sym p) y')) p_x'вүЎxвүЎx'

    g-agrees : (g : fst (T x) вҶ’ Bool) вҶ’ g y вүЎ g y'-in-Tx
    g-agrees g = sym (make-f-xy g) вҲҷ f-constant g вҲҷ make-f-x'y' g

    y'-in-Qy : fst (ConnectedComponent (StoneвҶ’CHaus (T x)) y y'-in-Tx)
    y'-in-Qy D yInD = goal'
      where
      goal' : D y'-in-Tx вүЎ true
      goal' = sym (g-agrees D) вҲҷ yInD

    yвүЎy'-in-Tx : y вүЎ y'-in-Tx
    yвүЎy'-in-Tx = StoneCompactHausdorffTotallyDisconnected-forward (T x) y y'-in-Tx y'-in-Qy

    goal : (x , y) вүЎ (x' , y')
    goal = ОЈPathP (xвүЎx' , toPathP y'-path)
      where
      y'-path : transport (О» i вҶ’ fst (T (xвүЎx' i))) y вүЎ y'
      y'-path = cong (subst (О» z вҶ’ fst (T z)) xвүЎx') yвүЎy'-in-Tx
              вҲҷ transportTransportвҒ» (cong (О» z вҶ’ fst (T z)) xвүЎx') y'

  StoneSigmaClosed : (S : Stone) (T : fst S вҶ’ Stone)
    вҶ’ hasStoneStr (SigmaStoneType S T)
  StoneSigmaClosed S T = StoneCompactHausdorffTotallyDisconnected-backward
    (ОЈStoneCHaus S T)
    (ОЈStone-isTotallyDisconnected S T)

  StoneОЈ : (S : Stone) вҶ’ (T : fst S вҶ’ Stone) вҶ’ Stone
  StoneОЈ S T = SigmaStoneType S T , StoneSigmaClosed S T

