f-injective-05a x y fx=fy =
  let xy-diff : вҹЁ BвҲһ вҹ©
      xy-diff = x +вҲһ y

      f-xy-diff : fst f xy-diff вүЎ (рқҹҳвҲһ , рқҹҳвҲһ)
      f-xy-diff =
