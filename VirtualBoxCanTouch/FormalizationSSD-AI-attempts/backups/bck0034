    h'-presВ· = IsCommRingHom.presВ· (snd h')
    prod-zero : unit-right В·Г— (x , рқҹҳвҲһ) вүЎ (рқҹҳвҲһ , рқҹҳвҲһ)
    prod-zero = unit-right-left-orth x
