classify-BoolВІ-hom : (h : Sp BoolВІ-BooleПү) вҶ’ (h вүЎ projвӮҒ-BoolВІ-hom) вҠҺ.вҠҺ (h вүЎ projвӮӮ-BoolВІ-hom)
classify-BoolВІ-hom h = helper (fst h BoolВІ-unit-left) refl
  where
  hвүЎprojвӮҒ : fst h BoolВІ-unit-left вүЎ true вҶ’ h вүЎ projвӮҒ-BoolВІ-hom
  hвүЎprojвӮҒ h-ul-true = ОЈвүЎProp (О» f вҶ’ isPropIsCommRingHom (snd (BooleanRingвҶ’CommRing BoolВІ)) f (snd (BooleanRingвҶ’CommRing BoolBR))) (sym funEq)
    where
    h-ur : fst h BoolВІ-unit-right вүЎ false
    h-ur =
      fst h (false , true)
        вүЎвҹЁ cong (fst h) (congвӮӮ _,_ refl (sym (вҠ•-comm false true))) вҹ©
      fst h (false , true вҠ• false)
        вүЎвҹЁ cong (fst h) (congвӮӮ _,_ (sym (вҠ•-comm true true)) refl) вҹ©
      fst h ((true вҠ• true) , (true вҠ• false))
        вүЎвҹЁ IsCommRingHom.pres+ (snd h) (true , true) (true , false) вҹ©
      (fst h (true , true)) вҠ• (fst h (true , false))
        вүЎвҹЁ congвӮӮ _вҠ•_ (IsCommRingHom.pres1 (snd h)) h-ul-true вҹ©
      true вҠ• true
        вүЎвҹЁ вҠ•-comm true true вҹ©
      false вҲҺ
    funEq : projвӮҒ-BoolВІ вүЎ fst h
    funEq = funExt О» { (false , false) вҶ’ sym (IsCommRingHom.pres0 (snd h))
                     ; (false , true) вҶ’ sym h-ur
                     ; (true , false) вҶ’ sym h-ul-true
                     ; (true , true) вҶ’ sym (IsCommRingHom.pres1 (snd h)) }

  hвүЎprojвӮӮ : fst h BoolВІ-unit-left вүЎ false вҶ’ h вүЎ projвӮӮ-BoolВІ-hom
  hвүЎprojвӮӮ h-ul-false = ОЈвүЎProp (О» f вҶ’ isPropIsCommRingHom (snd (BooleanRingвҶ’CommRing BoolВІ)) f (snd (BooleanRingвҶ’CommRing BoolBR))) (sym funEq)
    where
    h-ur : fst h BoolВІ-unit-right вүЎ true
    h-ur =
      fst h (false , true)
        вүЎвҹЁ cong (fst h) (congвӮӮ _,_ refl (sym (вҠ•-comm false true))) вҹ©
      fst h (false , true вҠ• false)
        вүЎвҹЁ cong (fst h) (congвӮӮ _,_ (sym (вҠ•-comm true true)) refl) вҹ©
      fst h ((true вҠ• true) , (true вҠ• false))
        вүЎвҹЁ IsCommRingHom.pres+ (snd h) (true , true) (true , false) вҹ©
      (fst h (true , true)) вҠ• (fst h (true , false))
        вүЎвҹЁ congвӮӮ _вҠ•_ (IsCommRingHom.pres1 (snd h)) h-ul-false вҹ©
      true вҠ• false
        вүЎвҹЁ вҠ•-comm true false вҹ©
      true вҲҺ
    funEq : projвӮӮ-BoolВІ вүЎ fst h
    funEq = funExt О» { (false , false) вҶ’ sym (IsCommRingHom.pres0 (snd h))
                     ; (false , true) вҶ’ sym h-ur
                     ; (true , false) вҶ’ sym h-ul-false
                     ; (true , true) вҶ’ sym (IsCommRingHom.pres1 (snd h)) }

  helper : (b : Bool) вҶ’ fst h BoolВІ-unit-left вүЎ b вҶ’ (h вүЎ projвӮҒ-BoolВІ-hom) вҠҺ.вҠҺ (h вүЎ projвӮӮ-BoolВІ-hom)
  helper true = О» eq вҶ’ вҠҺ.inl (hвүЎprojвӮҒ eq)
  helper false = О» eq вҶ’ вҠҺ.inr (hвүЎprojвӮӮ eq)

