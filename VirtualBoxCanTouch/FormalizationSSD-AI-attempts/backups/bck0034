    go' false h'-left-false = вҠҺ.inl evens-zero-case
      where
      open BooleanRingStr (snd BвҲһ) using () renaming (рқҹҷ to рқҹҷBвҲһ ; _+_ to _+BвҲһ_)
      open BooleanRingStr (snd BвҲһГ—BвҲһ) using () renaming (_+_ to _+Г—local_)
