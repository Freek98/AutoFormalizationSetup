  BoolВІвҶ’quotient : BoolHom BoolВІ BoolВІ-quotient
  BoolВІвҶ’quotient = BoolВІвҶ’quotient-fun , record
    { pres0 = refl
    ; pres1 = refl
    ; pres+ = BoolВІвҶ’quotient-pres+
    ; presВ· = BoolВІвҶ’quotient-presВ·
    ; pres- = BoolВІвҶ’quotient-pres-
    }
    where
      BoolВІвҶ’quotient-pres- : (x : вҹЁ BoolВІ вҹ©) вҶ’ BoolВІвҶ’quotient-fun (BooleanRingStr.-_ (snd BoolВІ) x) вүЎ BooleanRingStr.-_ (snd BoolВІ-quotient) (BoolВІвҶ’quotient-fun x)
      BoolВІвҶ’quotient-pres- x = cong BoolВІвҶ’quotient-fun (negвүЎselfВІ x) вҲҷ sym (negвүЎselfQ (BoolВІвҶ’quotient-fun x))

  roundtrip-BoolВІ : (x : вҹЁ BoolВІ вҹ©) вҶ’ fst quotientвҶ’BoolВІ (BoolВІвҶ’quotient-fun x) вүЎ x
  roundtrip-BoolВІ (false , false) = IsCommRingHom.pres0 (snd quotientвҶ’BoolВІ)
  roundtrip-BoolВІ (false , true) =
    fst quotientвҶ’BoolВІ (fst ПҖ gвӮҒ)
      вүЎвҹЁ cong (fst quotientвҶ’BoolВІ) refl вҹ©
    fst (quotientвҶ’BoolВІ вҲҳcr ПҖ) gвӮҒ
      вүЎвҹЁ cong (О» h вҶ’ fst h gвӮҒ) (QB.evalInduce BoolВІ freeBoolвҶ’BoolВІ freeBoolвҶ’BoolВІ-on-rels) вҹ©
    fst freeBoolвҶ’BoolВІ gвӮҒ
      вүЎвҹЁ evalBAInduce в„• BoolВІ gensвҶ’BoolВІ вүЎ$ 1 вҹ©
