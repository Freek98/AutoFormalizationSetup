-- ==========================================================================
--
--  Part A.  N∞ IS A STONE SPACE
--
-- ==========================================================================
--
-- Recall from the tex (Example (iv), lines 230–243):
--
--   B∞  is the Boolean algebra generated by (gₙ)_{n:ℕ} quotiented by
--   the relations  gₘ ∧ gₙ = 0  for m ≠ n.
--
--   A morphism B∞ → 2 corresponds to a function ℕ → 2 that hits 1 at
--   most once.  We denote Sp(B∞) by N∞.
--
-- Therefore  Sp(B∞) ≅ N∞  and  N∞  is a Stone space.

-- ──────────────────────────────────────────────────────────────────────────
-- A1.  B∞ and its generators
-- ──────────────────────────────────────────────────────────────────────────
--
-- B∞  is constructed in Part03 as  freeBA ℕ /Im relB∞, where
--   relB∞ k  encodes  gen a · gen (a + suc d) = 0  for (a,d) = cantorUnpair k.
--
-- Key definitions (re-exported from Part03):
--   B∞       : BooleanRing ℓ-zero
--   g∞       : ℕ → ⟨ B∞ ⟩                  (generators in the quotient)
--   B∞-Booleω : Booleω                      (B∞ is countably presented)
--
-- Key property (proved in Part03):
--   g∞-distinct-mult-zero : (m n : ℕ) → ¬(m ≡ n) → g∞ m ·∞ g∞ n ≡ 𝟘∞

-- ──────────────────────────────────────────────────────────────────────────
-- A2.  Forward map:  Sp(B∞) → N∞
-- ──────────────────────────────────────────────────────────────────────────
--
-- Given  h : Sp(B∞) = BoolHom B∞ BoolBR, extract the binary sequence
--   αₙ = h(g∞ n).
-- The relations  g∞ m ·∞ g∞ n = 0  for m ≠ n  force  α  to hit true
-- at most once.
--
-- Proved in Part03:
--   SpB∞-to-ℕ∞-seq    : Sp B∞-Booleω → ℕ → Bool
--   SpB∞-seq-atMostOnce : (h : Sp B∞-Booleω) → hitsAtMostOnce (SpB∞-to-ℕ∞-seq h)
--   SpB∞-to-ℕ∞         : Sp B∞-Booleω → ℕ∞

-- ──────────────────────────────────────────────────────────────────────────
-- A3.  Backward map:  N∞ → Sp(B∞)
-- ──────────────────────────────────────────────────────────────────────────
--
-- Given α : N∞ (a sequence hitting 1 at most once), construct
--   h : B∞ → BoolBR  by setting h(gₙ) = αₙ.
--
-- The at-most-once condition ensures the relations are respected:
--   h(gₘ · gₙ) = h(gₘ) ∧ h(gₙ) = αₘ ∧ αₙ = 0  when m ≠ n.
--
-- Then h descends from freeBA ℕ to the quotient B∞ by the universal
-- property.
--
-- Proved in Part05:
--   ℕ∞-to-SpB∞ : ℕ∞ → Sp B∞-Booleω

-- ──────────────────────────────────────────────────────────────────────────
-- A4.  Sp(B∞) ≃ N∞   ⟹   hasStoneStr N∞
-- ──────────────────────────────────────────────────────────────────────────
--
-- Roundtrip 1 (proved in Part05):
--   SpB∞-roundtrip : (α : ℕ∞) → SpB∞-to-ℕ∞ (ℕ∞-to-SpB∞ α) ≡ α
--
-- Roundtrip 2 (proved below):
--   SpB∞-roundtrip-inv : (h : Sp B∞-Booleω) → ℕ∞-to-SpB∞ (SpB∞-to-ℕ∞ h) ≡ h
--
-- The key observation for Roundtrip 2 is that two BoolHom's from B∞ to
-- BoolBR (the 2-element ring) are equal whenever they agree on generators.
-- This follows from two facts:
--   (a) The quotient map π∞ : freeBA ℕ → B∞ is surjective.
--   (b) Two ring homs from freeBA ℕ that agree on generators are equal
--       (by the universal property of free Boolean algebras).

-- The proof of Roundtrip 2 proceeds in two steps:
--
-- Step 1:  Show that the "free maps" are equal.
--   ℕ∞-to-SpB∞-free (SpB∞-to-ℕ∞ h)  and  h ∘cr π∞
--   are both BoolHom's from freeBA ℕ to BoolBR.
--   They agree on generators:
--     LHS sends generator n to ℕ∞-on-gen (SpB∞-to-ℕ∞ h) n = h $cr (g∞ n).
--     RHS sends generator n to h $cr (fst π∞ (generator n)) = h $cr (g∞ n).
--   By the universal property of free Boolean algebras
--   (inducedBAHomUnique), they are equal.
--
-- Step 2:  Lift to the quotient B∞.
--   Since ℕ∞-to-SpB∞ α = QB.inducedHom BoolBR (ℕ∞-to-SpB∞-free α) ...,
--   we use QB.inducedHomUnique to conclude ℕ∞-to-SpB∞ (SpB∞-to-ℕ∞ h) ≡ h.

open import BooleanRing.FreeBooleanRing.FreeBool
  using (freeBA; generator; inducedBAHom; evalBAInduce; inducedBAHomUnique)

-- Step 1: The free maps agree on generators (definitionally).
-- h ∘cr π∞ sends generator n  to  h $cr (g∞ n).
-- ℕ∞-to-SpB∞-free (SpB∞-to-ℕ∞ h) = inducedBAHom ℕ BoolBR (λ n → h $cr (g∞ n)).
-- By inducedBAHomUnique, these are equal.

free-maps-agree : (h : Sp B∞-Booleω) →
  ℕ∞-to-SpB∞-free (SpB∞-to-ℕ∞ h) ≡ h ∘cr π∞
free-maps-agree h =
  inducedBAHomUnique ℕ BoolBR (ℕ∞-on-gen (SpB∞-to-ℕ∞ h)) (h ∘cr π∞) refl

-- Step 2: Lift to the quotient.
-- QB.inducedHomUnique says: if g ≡ h ∘cr π∞, then inducedHom ≡ h.
-- Here inducedHom = ℕ∞-to-SpB∞ (SpB∞-to-ℕ∞ h).

SpB∞-roundtrip-inv : (h : Sp B∞-Booleω) →
  ℕ∞-to-SpB∞ (SpB∞-to-ℕ∞ h) ≡ h
SpB∞-roundtrip-inv h =
  QB.inducedHomUnique {B = freeBA ℕ} {f = relB∞}
    BoolBR
    (ℕ∞-to-SpB∞-free (SpB∞-to-ℕ∞ h))
    (ℕ∞-to-SpB∞-respects-rel (SpB∞-to-ℕ∞ h))
    h
    (free-maps-agree h)

-- The isomorphism Sp(B∞) ≅ ℕ∞ (alternative proof via universal property)
-- Part06 proves this differently, using SpB∞-to-ℕ∞-injective + SpB∞-roundtrip.
-- Here we give a direct proof via the universal property of free Boolean algebras.
SpB∞-Iso-ℕ∞ : Iso (Sp B∞-Booleω) ℕ∞
SpB∞-Iso-ℕ∞ = iso SpB∞-to-ℕ∞ ℕ∞-to-SpB∞ SpB∞-roundtrip SpB∞-roundtrip-inv

-- The equivalence and Stone structure are already established in Part06:
--   SpB∞≃ℕ∞      : Sp B∞-Booleω ≃ ℕ∞                 (Part06:242)
--   ℕ∞-has-StoneStr : hasStoneStr ℕ∞                   (Part06:258)
--   ℕ∞-Stone      : Stone                              (Part06:439)

-- ==========================================================================
--
--  Part B.  PROOF OF LLPO
--
-- ==========================================================================
--
-- Recall from the tex (Theorem LLPO, lines 541–595):
--
--   For all α : N∞,
--     (∀ k. α_{2k} = 0) ∨ (∀ k. α_{2k+1} = 0)
--
-- The proof constructs a map  f : B∞ → B∞ × B∞  and shows it is injective.
-- By the axiom SurjectionsAreFormalSurjections, the induced map
--   Sp(f) : Sp(B∞ × B∞) → Sp(B∞)
-- is surjective.  Case-splitting on the preimage yields LLPO.

-- ──────────────────────────────────────────────────────────────────────────
-- B1.  The parity map  f : B∞ → B∞ × B∞
-- ──────────────────────────────────────────────────────────────────────────
--
-- (tex lines 554–560)
--
-- Define f on generators by:
--   f(gₙ) = (gₖ, 0)   if n = 2k     (even index → left factor)
--   f(gₙ) = (0, gₖ)   if n = 2k+1   (odd index → right factor)
--
-- This is well-defined because  f(gₘ) ∧ f(gₙ) = 0  whenever m ≠ n:
-- both components are products of distinct generators (which are 0 in B∞),
-- or cross-factor products (which are componentwise 0).
--
-- The map f is constructed in Part04 as a BoolHom:
--   f : BoolHom B∞ B∞×B∞
--
-- Key properties (proved in Part04):
--   f-even-gen : (k : ℕ) → fst f (g∞ (2 · k)) ≡ (g∞ k , 𝟘∞)
--   f-odd-gen  : (k : ℕ) → fst f (g∞ (suc (2 · k))) ≡ (𝟘∞ , g∞ k)

-- ──────────────────────────────────────────────────────────────────────────
-- B2.  f is injective
-- ──────────────────────────────────────────────────────────────────────────
--
-- (tex lines 567–583)
--
-- Recall that any x : B∞ can be written in one of two normal forms:
--   ⋁_{i∈I} gᵢ         (join of generators, for finite I ⊆ ℕ)
--   ⋀_{i∈I} ¬gᵢ        (meet of negated generators, for finite I ⊆ ℕ)
--
-- Case 1: x = ⋁_{i∈I} gᵢ.
--   Split I into even and odd parts:
--     I₀ = {k | 2k ∈ I},  I₁ = {k | 2k+1 ∈ I}.
--   Then f(x) = (⋁_{k∈I₀} gₖ, ⋁_{k∈I₁} gₖ).
--   If f(x) = 0, then both joins are empty, so I = ∅ and x = 0.
--
-- Case 2: x = ⋀_{i∈I} ¬gᵢ.
--   Then f(x) = (⋀_{k∈I₀} ¬gₖ, ⋀_{k∈I₁} ¬gₖ).
--   Each component is a meet of negated generators, which is always
--   non-zero (witnessed by the "infinity" homomorphism h₀ that sends
--   all generators to false).  So f(x) ≠ 0.
--
-- In both cases, f(x) = 0 implies x = 0.  Hence f is injective.
--
-- The formal proof is in Part05a (using truncated normal forms):
--   f-injective-05a : (x y : ⟨ B∞ ⟩) → fst f x ≡ fst f y → x ≡ y
--
-- NOTE: This relies on two postulates in Part05a:
--   normalizeTerm-correct     (correctness of normalization)
--   f-kernel-normalForm-05a   (kernel of f on normal forms is trivial)
-- The latter is proved in Part05 (f-kernel-normalForm, lines 1648–1758),
-- establishing the argument above.  A circular-import issue prevents
-- directly connecting them in the current file structure.

-- ──────────────────────────────────────────────────────────────────────────
-- B3.  Sp(f) is surjective  (from SurjectionsAreFormalSurjections)
-- ──────────────────────────────────────────────────────────────────────────
--
-- (tex lines 584–587)
--
-- By the axiom SurjectionsAreFormalSurjections (tex Axiom 2, line 294):
--
--   For g : B → C in Boole,  g is injective  ⟺  Sp(g) is surjective.
--
-- Since f : B∞ → B∞×B∞ is injective, the induced map
--   Sp(f) : Sp(B∞×B∞) → Sp(B∞),  defined by  h ↦ h ∘ f,
-- is surjective.
--
-- Proved in Part05:
--   Sp-f-surjective : (h : Sp B∞-Booleω) →
--     ∥ Σ[ h' ∈ Sp B∞×B∞-Booleω ] Sp-f h' ≡ h ∥₁
--
-- NOTE: B∞×B∞ being a Booleω (countably presented) uses the postulate
-- B∞×B∞≃quotient.  This is mathematically true but the current proof
-- has a gap; see Part05 documentation.

-- ──────────────────────────────────────────────────────────────────────────
-- B4.  Deriving LLPO from surjectivity of Sp(f)
-- ──────────────────────────────────────────────────────────────────────────
--
-- (tex lines 588–595)
--
-- Given α : N∞, convert to h : Sp(B∞) via ℕ∞-to-SpB∞.
-- By surjectivity, there exists h' : Sp(B∞×B∞) with h' ∘ f = h.
--
-- The product B∞×B∞ has orthogonal units:
--   unit-left  = (1, 0)    unit-right = (0, 1)
-- satisfying (1,0) + (0,1) = (1,1)  and  (1,0) · (0,1) = (0,0).
--
-- For any h' : Sp(B∞×B∞), exactly one of h'(1,0), h'(0,1) is true.
--
-- Case 1: h'(1,0) = true.
--   Then for any y : ⟨ B∞ ⟩,  h'(0,y) = false.
--   (Proof: (1,0) · (0,y) = (0,0), so h'(1,0) ∧ h'(0,y) = h'(0,0) = 0.
--    Since h'(1,0) = true, we get h'(0,y) = false.)
--
--   In particular, for all k:
--     α_{2k+1} = h(g_{2k+1}) = h'(f(g_{2k+1})) = h'(0, gₖ) = false.
--   So all odd-indexed entries are 0.
--
-- Case 2: h'(0,1) = true.
--   By the symmetric argument, h'(x,0) = false for all x.
--   In particular, for all k:
--     α_{2k} = h(g_{2k}) = h'(f(g_{2k})) = h'(gₖ, 0) = false.
--   So all even-indexed entries are 0.
--
-- Therefore:  (∀k. α_{2k} = 0) ∨ (∀k. α_{2k+1} = 0).

-- The formal proof (from Part05, reorganized for clarity):

-- Key orthogonality lemmas (from Part05):
--
--   h'-left-true→right-false :
--     h' $cr unit-left ≡ true → (y : ⟨ B∞ ⟩) → h' $cr (𝟘∞ , y) ≡ false
--
--   h'-right-true→left-false :
--     h' $cr unit-right ≡ true → (x : ⟨ B∞ ⟩) → h' $cr (x , 𝟘∞) ≡ false

-- The complete LLPO theorem:
--
-- llpo-from-SD : LLPO
-- llpo-from-SD α = ...
--
-- This is proved in Part05 (lines 1971–1992).  The proof:
-- 1. Converts α : ℕ∞ to h = ℕ∞-to-SpB∞ α : Sp B∞.
-- 2. Gets h' : Sp(B∞×B∞) with h' ∘ f = h  (by Sp-f-surjective, truncated).
-- 3. Case-splits on h'(unit-left):
--      true  → odd indices are 0   (h'(0, gₖ) = false by orthogonality)
--      false → even indices are 0  (h'(gₖ, 0) = false by orthogonality)
-- 4. Transports via SpB∞-roundtrip to get the statement in terms of α.
--
-- NOTE: The proof uses PT.rec which requires the target to be a prop.
-- The disjunction P₀ ⊎ P₁ is not always a prop (both hold for the zero
-- sequence).  The current proof postulates disjointness (evens-odds-disjoint).
-- A fully rigorous treatment would use the Local Choice axiom (tex Axiom 3).
--
-- The statement and proof are re-exported from Part05:

LLPO-from-StoneDuality : LLPO
LLPO-from-StoneDuality = llpo-from-SD

