  -- tex Theorem StoneClosedSubsets, (v)вҶ’(i) direction
  -- Proved from localChoice-axiom + ImageStoneMapDecidableIntersection + quotientBySeqPreservesBooleПү
  closedFamilyChoice : (S : Stone) (A : fst S вҶ’ hProp в„“-zero)
    вҶ’ ((x : fst S) вҶ’ isClosedProp (A x))
    вҶ’ вҲҘ ((x : fst S) вҶ’ ОЈ[ Оұ вҲҲ binarySequence ] вҹЁ A x вҹ© вҶ” ((n : в„•) вҶ’ Оұ n вүЎ false)) вҲҘвӮҒ
  closedFamilyChoice S A A-closed =
    PT.rec squashвӮҒ step1 (localChoice-axiom B P P-trunc)
    where
    |S| = fst S
    B : BooleПү
    B = fst (snd S)
    SpBвүЎS : Sp B вүЎ |S|
    SpBвүЎS = snd (snd S)
    P : Sp B вҶ’ Type в„“-zero
    P s = ОЈ[ Оұ вҲҲ binarySequence ] вҹЁ A (transport SpBвүЎS s) вҹ© вҶ” ((n : в„•) вҶ’ Оұ n вүЎ false)
    P-trunc : (s : Sp B) вҶ’ вҲҘ P s вҲҘвӮҒ
    P-trunc s = A-closed (transport SpBвүЎS s)

    step1 : ОЈ[ C вҲҲ BooleПү ] ОЈ[ q вҲҲ (Sp C вҶ’ Sp B) ]
              (isSurjectiveSpMap {B} {C} q Г— ((t : Sp C) вҶ’ P (q t)))
          вҶ’ вҲҘ ((x : |S|) вҶ’ ОЈ[ Оұ вҲҲ binarySequence ] вҹЁ A x вҹ© вҶ” ((n : в„•) вҶ’ Оұ n вүЎ false)) вҲҘвӮҒ
    step1 (C , q , q-surj , h) =
      PT.rec squashвӮҒ step2 (quotientBySeqPreservesBooleПү C d')
      where
      ОІ : Sp C вҶ’ в„• вҶ’ Bool
      ОІ c n = fst (h c) n
      d' : в„• вҶ’ вҹЁ fst C вҹ©
      d' n = elemFromDecPred sd-axiom C (О» c вҶ’ ОІ c n)
      d'-prop : (n : в„•) (c : Sp C) вҶ’ fst c (d' n) вүЎ ОІ c n
      d'-prop n c = decPred-elem-correspondence sd-axiom C (О» c вҶ’ ОІ c n) c

      step2 : ОЈ[ T вҲҲ BooleПү ] (Sp T вүғ (ОЈ[ c вҲҲ Sp C ] ((n : в„•) вҶ’ fst c (d' n) вүЎ false)))
            вҶ’ вҲҘ ((x : |S|) вҶ’ ОЈ[ Оұ вҲҲ binarySequence ] вҹЁ A x вҹ© вҶ” ((n : в„•) вҶ’ Оұ n вүЎ false)) вҲҘвӮҒ
      step2 (T , SpTвүғCS) =
        PT.rec squashвӮҒ step3 (ImageStoneMapDecidableIntersection B T fTвҶ’B)
        where
        fTвҶ’B : Sp T вҶ’ Sp B
        fTвҶ’B t = q (fst (equivFun SpTвүғCS t))

        -- Im(fTвҶ’B)(x) вҶ” A(transport SpBвүЎS x)
        imfвҶ’A : (x : Sp B) вҶ’ вҲҘ ОЈ[ t вҲҲ Sp T ] fTвҶ’B t вүЎ x вҲҘвӮҒ вҶ’ вҹЁ A (transport SpBвүЎS x) вҹ©
        imfвҶ’A x = PT.rec (snd (A (transport SpBвүЎS x))) go
          where
          go : ОЈ[ t вҲҲ Sp T ] fTвҶ’B t вүЎ x вҶ’ вҹЁ A (transport SpBвүЎS x) вҹ©
          go (t , ftвүЎx) = subst (О» z вҶ’ вҹЁ A (transport SpBвүЎS z) вҹ©) ftвүЎx witness
            where
            cs = equivFun SpTвүғCS t
            c = fst cs
            c-all-false : (n : в„•) вҶ’ fst c (d' n) вүЎ false
            c-all-false = snd cs
            ОІ-false : (n : в„•) вҶ’ ОІ c n вүЎ false
            ОІ-false n = sym (d'-prop n c) вҲҷ c-all-false n
            witness : вҹЁ A (transport SpBвүЎS (q c)) вҹ©
            witness = snd (snd (h c)) ОІ-false

        AвҶ’imf : (x : Sp B) вҶ’ вҹЁ A (transport SpBвүЎS x) вҹ© вҶ’ вҲҘ ОЈ[ t вҲҲ Sp T ] fTвҶ’B t вүЎ x вҲҘвӮҒ
        AвҶ’imf x Ax = PT.rec squashвӮҒ go (q-surj x)
          where
          go : ОЈ[ c вҲҲ Sp C ] q c вүЎ x вҶ’ вҲҘ ОЈ[ t вҲҲ Sp T ] fTвҶ’B t вүЎ x вҲҘвӮҒ
          go (c , qcвүЎx) = вҲЈ t , ftвүЎx вҲЈвӮҒ
            where
            Aqc : вҹЁ A (transport SpBвүЎS (q c)) вҹ©
            Aqc = subst (О» z вҶ’ вҹЁ A (transport SpBвүЎS z) вҹ©) (sym qcвүЎx) Ax
            ОІ-false : (n : в„•) вҶ’ ОІ c n вүЎ false
            ОІ-false = fst (snd (h c)) Aqc
            c-all-false : (n : в„•) вҶ’ fst c (d' n) вүЎ false
            c-all-false n = d'-prop n c вҲҷ ОІ-false n
            cs : ОЈ[ c' вҲҲ Sp C ] ((n : в„•) вҶ’ fst c' (d' n) вүЎ false)
            cs = c , c-all-false
            t : Sp T
            t = invEq SpTвүғCS cs
            ftвүЎx : fTвҶ’B t вүЎ x
            ftвүЎx =
              q (fst (equivFun SpTвүғCS (invEq SpTвүғCS cs))) вүЎвҹЁ cong (О» z вҶ’ q (fst z)) (secEq SpTвүғCS cs) вҹ©
              q c                                           вүЎвҹЁ qcвүЎx вҹ©
              x вҲҺ

        step3 : ОЈ[ d вҲҲ (в„• вҶ’ вҹЁ fst B вҹ©) ]
                  ((x : Sp B) вҶ’ (вҲҘ ОЈ[ t вҲҲ Sp T ] fTвҶ’B t вүЎ x вҲҘвӮҒ) вҶ” ((n : в„•) вҶ’ fst x (d n) вүЎ false))
              вҶ’ вҲҘ ((y : |S|) вҶ’ ОЈ[ Оұ вҲҲ binarySequence ] вҹЁ A y вҹ© вҶ” ((n : в„•) вҶ’ Оұ n вүЎ false)) вҲҘвӮҒ
        step3 (d , d-iff) = вҲЈ result вҲЈвӮҒ
          where
          result : (y : |S|) вҶ’ ОЈ[ Оұ вҲҲ binarySequence ] вҹЁ A y вҹ© вҶ” ((n : в„•) вҶ’ Оұ n вүЎ false)
          result y = Оұ-y , fwd , bwd
            where
            x : Sp B
            x = transport (sym SpBвүЎS) y
            Оұ-y : binarySequence
            Оұ-y n = fst x (d n)
            fwd : вҹЁ A y вҹ© вҶ’ (n : в„•) вҶ’ Оұ-y n вүЎ false
            fwd Ay = fst (d-iff x) (AвҶ’imf x (subst (О» z вҶ’ вҹЁ A z вҹ©) (sym (transportTransportвҒ» SpBвүЎS y)) Ay))
            bwd : ((n : в„•) вҶ’ Оұ-y n вүЎ false) вҶ’ вҹЁ A y вҹ©
            bwd all-false = subst (О» z вҶ’ вҹЁ A z вҹ©) (transportTransportвҒ» SpBвүЎS y)
              (imfвҶ’A x (snd (d-iff x) all-false))

  ClosedInStoneIsStone : (S : Stone) вҶ’ (A : fst S вҶ’ hProp в„“-zero)
                       вҶ’ ((x : fst S) вҶ’ isClosedProp (A x))
                       вҶ’ hasStoneStr (ОЈ (fst S) (О» x вҶ’ fst (A x)))
  ClosedInStoneIsStone S A A-closed =
    PT.rec (isPropHasStoneStr sd-axiom _) mainConstruct (closedFamilyChoice S A A-closed)
    where
    |S| : Type в„“-zero
    |S| = fst S

    mainConstruct : ((x : |S|) вҶ’ ОЈ[ Оұ вҲҲ binarySequence ] вҹЁ A x вҹ© вҶ” ((n : в„•) вҶ’ Оұ n вүЎ false))
                  вҶ’ hasStoneStr (ОЈ |S| (О» x вҶ’ fst (A x)))
    mainConstruct A-closed-bare =
      PT.rec (isPropHasStoneStr sd-axiom _) extractC (quotientBySeqPreservesBooleПү B d)
      where
      Оұ : |S| вҶ’ в„• вҶ’ Bool
      Оұ x = fst (A-closed-bare x)

      B : BooleПү
      B = fst (snd S)

      SpBвүЎS : Sp B вүЎ |S|
      SpBвүЎS = snd (snd S)

      Оұ' : Sp B вҶ’ в„• вҶ’ Bool
      Оұ' x n = Оұ (transport SpBвүЎS x) n

      d : в„• вҶ’ вҹЁ fst B вҹ©
      d n = elemFromDecPred sd-axiom B (О» x вҶ’ Оұ' x n)

      d-property : (n : в„•) (x : Sp B) вҶ’ fst x (d n) вүЎ Оұ' x n
      d-property n x = decPred-elem-correspondence sd-axiom B (О» x вҶ’ Оұ' x n) x

      extractC : ОЈ[ C вҲҲ BooleПү ] (Sp C вүғ (ОЈ[ x вҲҲ Sp B ] ((n : в„•) вҶ’ fst x (d n) вүЎ false)))
               вҶ’ hasStoneStr (ОЈ |S| (О» x вҶ’ fst (A x)))
      extractC (C , SpCвүғClosedSubset) = C , SpCвүЎОЈA
        where
        ClosedSubsetB : Type в„“-zero
        ClosedSubsetB = ОЈ[ x вҲҲ Sp B ] ((n : в„•) вҶ’ fst x (d n) вүЎ false)

        ClosedSubsetBвҶ’ОЈA : ClosedSubsetB вҶ’ ОЈ |S| (О» y вҶ’ fst (A y))
        ClosedSubsetBвҶ’ОЈA (x , all-zero) = transport SpBвүЎS x , snd (snd (A-closed-bare (transport SpBвүЎS x))) (О» n вҶ’
            Оұ (transport SpBвүЎS x) n   вүЎвҹЁ sym (d-property n x) вҹ©
            fst x (d n)               вүЎвҹЁ all-zero n вҹ©
            false вҲҺ)

        ОЈAвҶ’ClosedSubsetB : ОЈ |S| (О» y вҶ’ fst (A y)) вҶ’ ClosedSubsetB
        ОЈAвҶ’ClosedSubsetB (y , Ay) = x , all-zero
          where
          x : Sp B
          x = transport (sym SpBвүЎS) y

          all-zero : (n : в„•) вҶ’ fst x (d n) вүЎ false
          all-zero n =
            fst x (d n)             вүЎвҹЁ d-property n x вҹ©
            Оұ (transport SpBвүЎS x) n вүЎвҹЁ cong (О» z вҶ’ Оұ z n) (transportTransportвҒ» SpBвүЎS y) вҹ©
            Оұ y n                   вүЎвҹЁ fst (snd (A-closed-bare y)) Ay n вҹ©
            false вҲҺ

        ClosedSubsetBвҶ’ОЈAвҶ’ClosedSubsetB : (xa : ClosedSubsetB) вҶ’ ОЈAвҶ’ClosedSubsetB (ClosedSubsetBвҶ’ОЈA xa) вүЎ xa
        ClosedSubsetBвҶ’ОЈAвҶ’ClosedSubsetB (x , all-zero) =
          ОЈвүЎProp (О» _ вҶ’ isPropО  (О» _ вҶ’ isSetBool _ _))
                 (transportвҒ»Transport SpBвүЎS x)

        ОЈAвҶ’ClosedSubsetBвҶ’ОЈA : (yAy : ОЈ |S| (О» y вҶ’ fst (A y))) вҶ’ ClosedSubsetBвҶ’ОЈA (ОЈAвҶ’ClosedSubsetB yAy) вүЎ yAy
        ОЈAвҶ’ClosedSubsetBвҶ’ОЈA (y , Ay) =
          ОЈвүЎProp (О» z вҶ’ snd (A z))
                 (transportTransportвҒ» SpBвүЎS y)

        ClosedSubsetBвүғОЈA : ClosedSubsetB вүғ ОЈ |S| (О» y вҶ’ fst (A y))
        ClosedSubsetBвүғОЈA = isoToEquiv (iso ClosedSubsetBвҶ’ОЈA ОЈAвҶ’ClosedSubsetB ОЈAвҶ’ClosedSubsetBвҶ’ОЈA ClosedSubsetBвҶ’ОЈAвҶ’ClosedSubsetB)

        SpCвүғОЈA : Sp C вүғ ОЈ |S| (О» y вҶ’ fst (A y))
        SpCвүғОЈA = compEquiv SpCвүғClosedSubset ClosedSubsetBвүғОЈA

        SpCвүЎОЈA : Sp C вүЎ ОЈ |S| (О» y вҶ’ fst (A y))
        SpCвүЎОЈA = ua SpCвүғОЈA

