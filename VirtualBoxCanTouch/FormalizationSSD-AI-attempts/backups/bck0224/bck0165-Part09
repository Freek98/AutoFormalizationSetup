-- Finite join in a Boolean ring (defined using ring ops directly)
finJoinBR : (B : BooleanRing в„“-zero) вҶ’ (в„• вҶ’ вҹЁ B вҹ©) вҶ’ в„• вҶ’ вҹЁ B вҹ©
finJoinBR B d zero = BooleanRingStr.рқҹҳ (snd B)
finJoinBR B d (suc n) = BooleanAlgebraStr._вҲЁ_ B (d n) (finJoinBR B d n)

-- General ideal bound: from 0вүЎ1 in B/d, extract N with finJoinBR d N вүЎ 1
module IdealBound (B : BooleanRing в„“-zero) (d : в„• вҶ’ вҹЁ B вҹ©) where
  private
    R = BooleanRingвҶ’CommRing B
    module CRS = CommRingStr (snd R)
    module BA = BooleanAlgebraStr B
    рқҹҳB = BooleanRingStr.рқҹҳ (snd B)
    _вҲЁB_ = BA._вҲЁ_
    _В·B_ = CRS._В·_
    _+B_ = CRS._+_
    fJ = finJoinBR B d

  leq-suc : {r : вҹЁ B вҹ©} (N : в„•) вҶ’ r В·B fJ N вүЎ r вҶ’ r В·B fJ (suc N) вүЎ r
  leq-suc {r} N p =
    r В·B (d N вҲЁB fJ N)
      вүЎвҹЁ sym (cong (_В·B (d N вҲЁB fJ N)) p) вҹ©
    (r В·B fJ N) В·B (d N вҲЁB fJ N)
      вүЎвҹЁ sym (CRS.В·Assoc r (fJ N) (d N вҲЁB fJ N)) вҹ©
    r В·B (fJ N В·B (d N вҲЁB fJ N))
      вүЎвҹЁ cong (r В·B_) (cong (fJ N В·B_) BA.вҲЁComm) вҹ©
    r В·B (fJ N В·B (fJ N вҲЁB d N))
      вүЎвҹЁ cong (r В·B_) BA.вҲ§AbsorbLвҲЁ вҹ©
    r В·B fJ N
      вүЎвҹЁ p вҹ©
    r вҲҺ

  leq-extend : {r : вҹЁ B вҹ©} (N k : в„•) вҶ’ r В·B fJ N вүЎ r вҶ’ r В·B fJ (k +в„• N) вүЎ r
  leq-extend N zero p = p
  leq-extend N (suc k) p = leq-suc (k +в„• N) (leq-extend N k p)

  leq-max-left : {r : вҹЁ B вҹ©} (NвӮҒ NвӮӮ : в„•) вҶ’ r В·B fJ NвӮҒ вүЎ r вҶ’ r В·B fJ (max NвӮҒ NвӮӮ) вүЎ r
  leq-max-left {r} NвӮҒ NвӮӮ p =
    subst (О» M вҶ’ r В·B fJ M вүЎ r) (вүӨ-вҲё-+-cancel {NвӮҒ} {max NвӮҒ NвӮӮ} (left-вүӨ-max {NвӮҒ} {NвӮӮ}))
          (leq-extend NвӮҒ (max NвӮҒ NвӮӮ вҲёв„• NвӮҒ) p)
    where open import Cubical.Data.Nat.Order using (left-вүӨ-max; вүӨ-вҲё-+-cancel)

  leq-max-right : {r : вҹЁ B вҹ©} (NвӮҒ NвӮӮ : в„•) вҶ’ r В·B fJ NвӮӮ вүЎ r вҶ’ r В·B fJ (max NвӮҒ NвӮӮ) вүЎ r
  leq-max-right {r} NвӮҒ NвӮӮ p =
    subst (О» M вҶ’ r В·B fJ M вүЎ r) (вүӨ-вҲё-+-cancel {NвӮӮ} {max NвӮҒ NвӮӮ} (right-вүӨ-max {NвӮӮ} {NвӮҒ}))
          (leq-extend NвӮӮ (max NвӮҒ NвӮӮ вҲёв„• NвӮӮ) p)
    where open import Cubical.Data.Nat.Order using (right-вүӨ-max; вүӨ-вҲё-+-cancel)

  idealBound : {r : вҹЁ B вҹ©} вҶ’ isInIdeal R d r вҶ’ ОЈ[ N вҲҲ в„• ] (r В·B fJ N вүЎ r)
  idealBound (isImage r n p) = suc n ,
    (r В·B (d n вҲЁB fJ n)
      вүЎвҹЁ cong (О» z вҶ’ z В·B (d n вҲЁB fJ n)) (sym p) вҹ©
    d n В·B (d n вҲЁB fJ n)
      вүЎвҹЁ BA.вҲ§AbsorbLвҲЁ вҹ©
    d n
      вүЎвҹЁ p вҹ©
    r вҲҺ)
  idealBound (iszero r p) = zero ,
    (r В·B рқҹҳB
      вүЎвҹЁ cong (О» z вҶ’ z В·B рқҹҳB) (sym p) вҹ©
    рқҹҳB В·B рқҹҳB
      вүЎвҹЁ RingTheory.0LeftAnnihilates (CommRingвҶ’Ring R) рқҹҳB вҹ©
    рқҹҳB
      вүЎвҹЁ p вҹ©
    r вҲҺ)
  idealBound (isSum r s t r=s+t sI tI) =
    let (NвӮҒ , pвӮҒ) = idealBound sI
        (NвӮӮ , pвӮӮ) = idealBound tI
        M = max NвӮҒ NвӮӮ
        pвӮҒ' = leq-max-left {s} NвӮҒ NвӮӮ pвӮҒ
        pвӮӮ' = leq-max-right {t} NвӮҒ NвӮӮ pвӮӮ
    in M ,
      (r В·B fJ M
        вүЎвҹЁ cong (_В·B fJ M) r=s+t вҹ©
      (s +B t) В·B fJ M
        вүЎвҹЁ CRS.В·Comm (s +B t) (fJ M) вҹ©
      fJ M В·B (s +B t)
        вүЎвҹЁ CRS.В·DistR+ (fJ M) s t вҹ©
      (fJ M В·B s) +B (fJ M В·B t)
        вүЎвҹЁ congвӮӮ _+B_ (CRS.В·Comm (fJ M) s) (CRS.В·Comm (fJ M) t) вҹ©
      (s В·B fJ M) +B (t В·B fJ M)
        вүЎвҹЁ congвӮӮ _+B_ pвӮҒ' pвӮӮ' вҹ©
      s +B t
        вүЎвҹЁ sym r=s+t вҹ©
