module CantorIsStoneModule where
  open import Axioms.StoneDuality using (Stone; hasStoneStr; SpGeneralBooleanRing)
  open import BooleanRing.FreeBooleanRing.FreeBool using (freeBA; freeBA-universal-property)
  import QuotientBool as QB
  open import CommRingQuotients.IdealTerms using (isInIdeal; isImage; iszero; isSum; isMul; idealDecomp)
  open import CommRingQuotients.TrivialIdeal using (quotientFiber)
  import Cubical.Algebra.CommRing.Quotient.ImageQuotient as IQ
  open import Cubical.Algebra.CommRing.Quotient.Base using (quotientHomSurjective)
  open import Cubical.HITs.PropositionalTruncation as PT
  open import Cubical.Data.Sigma using (ОЈвүЎProp)
  open import Cubical.Tactics.CommRingSolver

  private
    R = BooleanRingвҶ’CommRing (freeBA в„•)
  open BooleanRingStr (snd (freeBA в„•)) using (рқҹҳ; рқҹҷ)

  constZero : в„• вҶ’ вҹЁ freeBA в„• вҹ©
  constZero _ = BooleanRingStr.рқҹҳ (snd (freeBA в„•))

  private
    R' = R IQ./Im constZero
    I' = IQ.genIdeal R constZero
    instance
      _ = snd R'

    ПҖ = IQ.quotientImageHom R constZero

    private
      module CRS = CommRingStr (snd R)
    _+R_ = CRS._+_
    _В·R_ = CRS._В·_
    _-R_ = CRS._-_
    0R = CRS.0r

    trivConstZero : (i : вҹЁ R вҹ©) вҶ’ isInIdeal R constZero i вҶ’ i вүЎ 0R
    trivConstZero i (isImage .i n p) = sym p
    trivConstZero i (iszero .i p) = sym p
    trivConstZero i (isSum .i s t i=s+t sвҲҲI tвҲҲI) =
      i           вүЎвҹЁ i=s+t вҹ©
      s +R t      вүЎвҹЁ congвӮӮ _+R_ (trivConstZero s sвҲҲI) (trivConstZero t tвҲҲI) вҹ©
      0R +R 0R    вүЎвҹЁ CRS.+IdL 0R вҹ©
      0R          вҲҺ
    trivConstZero i (isMul .i s t i=st tвҲҲI) =
      i           вүЎвҹЁ i=st вҹ©
      s В·R t      вүЎвҹЁ cong (s В·R_) (trivConstZero t tвҲҲI) вҹ©
      s В·R 0R     вүЎвҹЁ RingTheory.0RightAnnihilates (CommRingвҶ’Ring R) s вҹ©
      0R          вҲҺ

    fiberProp : (c : вҹЁ R' вҹ©) вҶ’ isProp (fiber (fst ПҖ) c)
    fiberProp c (x , qx=c) (y , qy=c) = ОЈвүЎProp (О» d вҶ’ CommRingStr.is-set (snd R') _ _) help'' where
      help : (x -R y) вҲҲ fst I'
      help = quotientFiber R I' x y (qx=c вҲҷ sym qy=c)

      help' : x -R y вүЎ 0R
      help' = PT.rec (CRS.is-set _ _) (trivConstZero (x -R y)) (idealDecomp R constZero (x -R y) help)

      help'' : x вүЎ y
      help'' = x вүЎвҹЁ solve! R вҹ© (x -R y) +R y вүЎвҹЁ cong (_+R y) help' вҹ© 0R +R y вүЎвҹЁ solve! R вҹ© y вҲҺ

    fiberInhabited : (c : вҹЁ R' вҹ©) вҶ’ fiber (fst ПҖ) c
    fiberInhabited c = transport (propTruncIdempotent (fiberProp c))
      (quotientHomSurjective R I' c)

  opaque
    unfolding QB._/Im_
    quotientByConstZeroвүғOriginal : BooleanRingEquiv (freeBA в„•) (freeBA в„• QB./Im constZero)
    fst (fst quotientByConstZeroвүғOriginal) = fst ПҖ
    equiv-proof (snd (fst quotientByConstZeroвүғOriginal)) y = fiberInhabited y , fiberProp y _
    snd quotientByConstZeroвүғOriginal = snd ПҖ

  freeBA-в„•-is-BooleПү' : has-Boole-Пү' (freeBA в„•)
  freeBA-в„•-is-BooleПү' = constZero , quotientByConstZeroвүғOriginal

  freeBA-в„•-BooleПү : BooleПү
  freeBA-в„•-BooleПү = freeBA в„• , вҲЈ freeBA-в„•-is-BooleПү' вҲЈвӮҒ

  Sp-freeBA-в„•-Iso : Iso (SpGeneralBooleanRing (freeBA в„•)) CantorSpace
  Sp-freeBA-в„•-Iso = invIso (freeBA-universal-property в„• BoolBR)

  Sp-freeBA-в„•-вүЎ-Cantor : SpGeneralBooleanRing (freeBA в„•) вүЎ CantorSpace
  Sp-freeBA-в„•-вүЎ-Cantor = isoToPath Sp-freeBA-в„•-Iso

  CantorIsStone : hasStoneStr CantorSpace
  CantorIsStone = freeBA-в„•-BooleПү , Sp-freeBA-в„•-вүЎ-Cantor

-- MapsStoneToNareBounded (tex Lemma 1568)
module MapsStoneToNareBoundedModule where
  open import Axioms.StoneDuality using (Stone; hasStoneStr; isSetBoolHom)
  open StoneClosedSubsetsModule
  open SDDecToElemModule
  open import Cubical.Data.Bool using (DecвҶ’Bool; trueвүўfalse; falseвүўtrue)
  open import Cubical.Data.Nat.Properties using (discreteв„•)
  open import Cubical.Foundations.Equiv using (equivFun)
  open import Cubical.Foundations.Transport using (transportTransportвҒ»)
  open import Cubical.Algebra.CommRing using (IsCommRingHom)
  open import Cubical.Data.Nat.Order using (_вүӨ_; _<_; splitв„•-<; <вүӨ-trans; вүӨ-suc; <вҶ’вүў)
  open import Cubical.Relation.Nullary using (Dec; yes; no; В¬_)
  import QuotientBool as QB
  import Cubical.Data.Sum as вҠҺ

  private
    DecвҶ’Bool-yes : вҲҖ {в„“'} {P : Type в„“'} (dc : Dec P) вҶ’ P вҶ’ DecвҶ’Bool dc вүЎ true
    DecвҶ’Bool-yes (yes _) _ = refl
    DecвҶ’Bool-yes (no В¬p) p = Empty.rec (В¬p p)

    DecвҶ’Bool-false : вҲҖ {в„“'} {P : Type в„“'} (dc : Dec P) вҶ’ В¬ P вҶ’ DecвҶ’Bool dc вүЎ false
    DecвҶ’Bool-false (yes p) В¬p = Empty.rec (В¬p p)
    DecвҶ’Bool-false (no _) _ = refl

    _вҲЁBool_ = BooleanAlgebraStr._вҲЁ_ BoolBR

    boolhom-вҲЁ : (B' : BooleПү) (x : Sp B') (a b : вҹЁ fst B' вҹ©)
      вҶ’ fst x (BooleanAlgebraStr._вҲЁ_ (fst B') a b) вүЎ fst x a вҲЁBool fst x b
    boolhom-вҲЁ B' x a b =
      let _+S_ = CommRingStr._+_ (snd (BooleanRingвҶ’CommRing BoolBR))
          _+B'_ = CommRingStr._+_ (snd (BooleanRingвҶ’CommRing (fst B')))
          _В·B'_ = CommRingStr._В·_ (snd (BooleanRingвҶ’CommRing (fst B')))
      in fst x (BooleanAlgebraStr._вҲЁ_ (fst B') a b)
        вүЎвҹЁ IsCommRingHom.pres+ (snd x) (a +B' b) (a В·B' b) вҹ©
      fst x (a +B' b) +S fst x (a В·B' b)
        вүЎвҹЁ congвӮӮ _+S_ (IsCommRingHom.pres+ (snd x) a b)
                       (IsCommRingHom.presВ· (snd x) a b) вҹ©
      fst x a вҲЁBool fst x b вҲҺ

    joinAllFalse : (B' : BooleПү) (d' : в„• вҶ’ вҹЁ fst B' вҹ©) (x : Sp B') (N : в„•)
      вҶ’ ((n : в„•) вҶ’ n < N вҶ’ fst x (d' n) вүЎ false)
      вҶ’ fst x (finJoinBR (fst B') d' N) вүЎ false
    joinAllFalse B' d' x zero _ = IsCommRingHom.pres0 (snd x)
    joinAllFalse B' d' x (suc N) allF =
      fst x (BooleanAlgebraStr._вҲЁ_ (fst B') (d' N) (finJoinBR (fst B') d' N))
        вүЎвҹЁ boolhom-вҲЁ B' x (d' N) (finJoinBR (fst B') d' N) вҹ©
      fst x (d' N) вҲЁBool fst x (finJoinBR (fst B') d' N)
        вүЎвҹЁ congвӮӮ _вҲЁBool_ (allF N (0 , refl)) (joinAllFalse B' d' x N (О» n h вҶ’ allF n (вүӨ-suc h))) вҹ©
      false вҲҺ

  MapsStoneToNareBounded : (S : Stone) вҶ’ (f : fst S вҶ’ в„•)
    вҶ’ вҲҘ ОЈ[ N вҲҲ в„• ] ((s : fst S) вҶ’ f s < N) вҲҘвӮҒ
  MapsStoneToNareBounded S f = PT.map mainProof (extract-finJoin-bound 0вүЎ1)
    where
    |S| = fst S
    B : BooleПү
    B = fst (snd S)
    SpBвүЎS = snd (snd S)

    fiber-pred : в„• вҶ’ Sp B вҶ’ Bool
    fiber-pred n x = DecвҶ’Bool (discreteв„• (f (transport SpBвүЎS x)) n)

    d : в„• вҶ’ вҹЁ fst B вҹ©
    d n = elemFromDecPred sd-axiom B (fiber-pred n)

    d-property : (n : в„•) (x : Sp B) вҶ’ fst x (d n) вүЎ fiber-pred n x
    d-property n x = decPred-elem-correspondence sd-axiom B (fiber-pred n) x

    open IdealBound (fst B) d

    B/d-BooleПү : BooleПү
    B/d-BooleПү = fst B QB./Im d , quotientBySeqHasBooleПү B d

    spEmpty : Sp B/d-BooleПү вҶ’ вҠҘ
    spEmpty sp-hom =
      let open SpOfQuotientBySeq (fst B) d using (Sp-quotient-вүғ)
          (x , allZero) = equivFun Sp-quotient-вүғ sp-hom
          y = transport SpBвүЎS x
          m = f y
      in trueвүўfalse (sym (d-property m x вҲҷ DecвҶ’Bool-yes (discreteв„• m m) refl) вҲҷ allZero m)

    0вүЎ1 : BooleanRingStr.рқҹҳ (snd (fst B/d-BooleПү)) вүЎ BooleanRingStr.рқҹҷ (snd (fst B/d-BooleПү))
    0вүЎ1 = SpectrumEmptyImpliesTrivial.0вүЎ1-in-B sd-axiom B/d-BooleПү spEmpty

    mainProof : ОЈ[ N вҲҲ в„• ] finJoinBR (fst B) d N вүЎ BooleanRingStr.рқҹҷ (snd (fst B))
      вҶ’ ОЈ[ N вҲҲ в„• ] ((s : |S|) вҶ’ f s < N)
    mainProof (N , fJвүЎ1) = suc N , bound
      where
      bound : (s : |S|) вҶ’ f s < suc N
      bound s with splitв„•-< (f s) N
      ... | вҠҺ.inl fs<N = вүӨ-suc fs<N
      ... | вҠҺ.inr NвүӨfs = Empty.rec (trueвүўfalse (sym fJ-true вҲҷ fJ-false))
        where
        x : Sp B
        x = transport (sym SpBвүЎS) s
        m = f (transport SpBвүЎS x)
        NвүӨm : N вүӨ m
        NвүӨm = subst (N вүӨ_) (sym (cong f (transportTransportвҒ» SpBвүЎS s))) NвүӨfs

        fJ-true : fst x (finJoinBR (fst B) d N) вүЎ true
        fJ-true =
          fst x (finJoinBR (fst B) d N)
            вүЎвҹЁ cong (fst x) fJвүЎ1 вҹ©
          fst x (BooleanRingStr.рқҹҷ (snd (fst B)))
            вүЎвҹЁ IsCommRingHom.pres1 (snd x) вҹ©
          true вҲҺ

        all-false : (n : в„•) вҶ’ n < N вҶ’ fst x (d n) вүЎ false
        all-false n n<N =
          fst x (d n)
            вүЎвҹЁ d-property n x вҹ©
          DecвҶ’Bool (discreteв„• m n)
            вүЎвҹЁ DecвҶ’Bool-false (discreteв„• m n) (О» mвүЎn вҶ’ <вҶ’вүў (<вүӨ-trans n<N NвүӨm) (sym mвүЎn)) вҹ©
          false вҲҺ

        fJ-false : fst x (finJoinBR (fst B) d N) вүЎ false
        fJ-false = joinAllFalse B d x N all-false
