        -- Diagonal sequence
        D : Sequence έΕΥ-zero
        D = record
          { obj = ╬╗ n έΗΤ obj (qpSeq (q n)) n
          ; map = ╬╗ {n} x έΗΤ vMap n (suc n) (map (qpSeq (q n)) x)
