                           (right-έΚν-max {max Ny (max N' (maxFin c mFin))} {suc k})
              leN' : N' έΚν N
              leN' = έΚν-trans (left-έΚν-max {N'} {maxFin c mFin})
                     (έΚν-trans (right-έΚν-max {max N' (maxFin c mFin)} {Ny})
                              (right-έΚν-max {max Ny (max N' (maxFin c mFin))} {suc k}))
              leM : (x : obj B k) έΗΤ M x έΚν N
