            ((x : obj B 0) έΗΤ incl (gέΓΑ x) έΚκ f (incl x))
          έΗΤ έΙξ DecompData B C f έΙξέΓΒ
    step0 initέΓΑ = PT.rec squashέΓΒ (╬╗ x έΗΤ έΙμ extract x έΙμέΓΒ)
      (dependentChoice-axiom PD pdProj pdSurj pdέΓΑ) where
      PD : έΕΧ έΗΤ Type έΕΥ-zero
      pdData : {k : έΕΧ} έΗΤ PD k έΗΤ ╬μ[ N έΙΙ έΕΧ ] ╬μ[ g έΙΙ (obj B k έΗΤ obj C N) ]
               ((x : obj B k) έΗΤ incl (g x) έΚκ f (incl x))
      PD zero = έΕΧ
      PD (suc k) = ╬μ[ prev έΙΙ PD k ]
        let Np = fst (pdData prev) ; gp = fst (snd (pdData prev)) in
        ╬μ[ N έΙΙ έΕΧ ] ╬μ[ le έΙΙ Np έΚν N ] ╬μ[ _ έΙΙ suc k έΚν N ]
        ╬μ[ g έΙΙ (obj B (suc k) έΗΤ obj C N) ]
        ((x : obj B (suc k)) έΗΤ incl (g x) έΚκ f (incl x)) ├Ω
        ((x : obj B k) έΗΤ liftTo le (gp x) έΚκ g (map B x))
      pdData {zero} _ = initέΓΑ
      pdData {suc _} (_ , N , _ , _ , g , ok , _) = N , g , ok
      pdProj : (k : έΕΧ) έΗΤ PD (suc k) έΗΤ PD k
      pdProj _ (prev , _) = prev
