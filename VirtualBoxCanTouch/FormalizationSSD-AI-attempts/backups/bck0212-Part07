    PT.rec squashέΓΒ go (countableChoiceέΓΒ _ odiscN) where
    go : ((n : έΕΧ) έΗΤ ╬μ[ T έΙΙ Sequence έΕΥ-zero ]
           ((k : έΕΧ) έΗΤ isFinSet (obj T k)) ├Ω (SeqColim T έΚΔ obj SέΓΑ n))
       έΗΤ isODisc (SeqColim SέΓΑ)
    go w = PT.rec squashέΓΒ buildDiag (dependentChoice-axiom QP qpProj qpSurj qpέΓΑ) where
      T : έΕΧ έΗΤ Sequence έΕΥ-zero
      T n = fst (w n)
      finT : (n k : έΕΧ) έΗΤ isFinSet (obj (T n) k)
      finT n = fst (snd (w n))
      eT : (n : έΕΧ) έΗΤ SeqColim (T n) έΚΔ obj SέΓΑ n
      eT n = snd (snd (w n))
      ╧Ι : (n : έΕΧ) έΗΤ SeqColim (T n) έΗΤ SeqColim (T (suc n))
      ╧Ι n c = invEq (eT (suc n)) (map SέΓΑ (equivFun (eT n) c))
      setT : (n k : έΕΧ) έΗΤ isSet (obj (T n) k)
      setT n k = isFinSetέΗΤisSet (finT n k)
        where open import Cubical.Data.FinSet.Base using (isFinSetέΗΤisSet)
      -- Quarter-plane data at step n: decomposition of ╧Ι(n-1) into level-wise maps
      QP : έΕΧ έΗΤ Type έΕΥ-zero
      qpSeq : {n : έΕΧ} έΗΤ QP n έΗΤ Sequence έΕΥ-zero
      qpFin : {n : έΕΧ} (q : QP n) έΗΤ (k : έΕΧ) έΗΤ isFinSet (obj (qpSeq q) k)
      qpEquiv : {n : έΕΧ} (q : QP n) έΗΤ SeqColim (qpSeq q) έΚΔ obj SέΓΑ n
      transition : {n : έΕΧ} (q : QP n) έΗΤ SeqColim (qpSeq q) έΗΤ SeqColim (T (suc n))
      QP zero = έΕΧ
      QP (suc n) = ╬μ[ prev έΙΙ QP n ] DecompData (qpSeq prev) (T (suc n)) (transition prev)
      qpSeq {zero} _ = T 0
      qpSeq {suc n} (_ , dd) = record
        { obj = ╬╗ k έΗΤ obj (T (suc n)) (DecompData.lvl dd k)
        ; map = ╬╗ {k} έΗΤ ColimCompactHelpers.liftTo (T (suc n)) (DecompData.lvlMono dd k)
        }
      qpFin {zero} _ = finT 0
      qpFin {suc n} (_ , dd) k = finT (suc n) (DecompData.lvl dd k)
      qpEquiv {zero} _ = eT 0
      qpEquiv {suc n} (_ , dd) = compEquiv
        (subSeqEquiv (T (suc n)) (DecompData.lvl dd) (setT (suc n))
          (DecompData.lvlMono dd) (DecompData.lvlGrow dd))
        (eT (suc n))
      transition q = invEq (eT _) έΙα map SέΓΑ έΙα equivFun (qpEquiv q)
      qpProj : (n : έΕΧ) έΗΤ QP (suc n) έΗΤ QP n
      qpProj _ (prev , _) = prev
      qpSurj : (n : έΕΧ) (y : QP n) έΗΤ έΙξ ╬μ[ x έΙΙ QP (suc n) ] qpProj n x έΚκ y έΙξέΓΒ
      qpSurj n y = PT.map (╬╗ dd έΗΤ (y , dd) , refl)
        (lemDecompColimMorphisms (qpSeq y) (T (suc n))
          (qpFin y) (setT (suc n)) (transition y))
