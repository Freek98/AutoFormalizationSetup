            έΙβ cong (map SέΓΑ) step4
            -- Step 5: equivFun qpEquiv qn (incl y) έΚκ equivFun qpEquiv qn (incl x) via push
            έΙβ cong (map SέΓΑ) (sym (cong (equivFun (qpEquiv qn)) (push x)))
            where
