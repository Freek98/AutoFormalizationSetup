        -- Column iteration: push from row n to row (d+n) at column k
        colIter : (d : έΕΧ) {n : έΕΧ} (k : έΕΧ)
          έΗΤ obj (qpSeq (q n)) k έΗΤ obj (qpSeq (q (d +έΕΧ n))) k
