            έΙβ cong (equivFun (eT (suc n))) (DecompData.fOk ddn (suc n) y')
            -- Step 3: equivFun eT έΙα transition = map SέΓΑ έΙα equivFun qpEquiv (by secEq)
            έΙβ secEq (eT (suc n)) _
