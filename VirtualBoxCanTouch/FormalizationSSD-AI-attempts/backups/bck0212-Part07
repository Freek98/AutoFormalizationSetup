      qpέΓΑ = 0
      buildDiag : ╬μ[ s έΙΙ SeqLimit QP qpProj ] seqLim-projέΓΑ QP qpProj s έΚκ qpέΓΑ
                έΗΤ isODisc (SeqColim SέΓΑ)
      buildDiag ((q , qcompat) , _) = έΙμ D , finD , diagEquiv έΙμέΓΒ where
        dd : (n : έΕΧ) έΗΤ DecompData (qpSeq (fst (q (suc n)))) (T (suc n)) (transition (fst (q (suc n))))
        dd n = snd (q (suc n))
