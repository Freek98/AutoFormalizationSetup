        monoAndCompat : (k : έΕΧ) έΗΤ ╬μ[ le έΙΙ lvl k έΚν lvl (suc k) ]
          ((x : obj B k) έΗΤ liftTo le (fMap k x) έΚκ fMap (suc k) (map B x))
        monoAndCompat k = subst (╬╗ pk έΗΤ ╬μ[ le έΙΙ fst (pdData pk) έΚν lvl (suc k) ]
            ((x : obj B k) έΗΤ liftTo le (fst (snd (pdData pk)) x) έΚκ fMap (suc k) (map B x)))
          (compat k) (rawLe k , rawCompat k)
