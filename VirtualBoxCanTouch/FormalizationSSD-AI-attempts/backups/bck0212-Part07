          -- follows from naturality of map w.r.t. transport along qcompat
          vPathP : PathP (╬╗ i έΗΤ obj (qpSeq (qcompat n i)) k) v' v
          vPathP = symP (transport-filler (cong (╬╗ r έΗΤ obj (qpSeq r) k) (sym (qcompat n))) v)
          mapPathP : PathP (╬╗ i έΗΤ P' (qcompat n i))
                       (map (qpSeq (fst (q (suc n)))) v')
                       (map (qpSeq (q n)) v)
