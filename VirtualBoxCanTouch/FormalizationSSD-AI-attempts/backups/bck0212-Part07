              okN : (x : obj B (suc k)) έΗΤ incl (gN x) έΚκ f (incl x)
              okN x = sym (inclLift leN' (g' x)) έΙβ ok' x
              compat : (x : obj B k) έΗΤ liftTo le (gy x) έΚκ gN (map B x)
              compat x =
                let (Mx , leέΓΒ , leέΓΓ , p) = wit x
