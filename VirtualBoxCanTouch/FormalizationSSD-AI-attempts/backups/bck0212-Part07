        open ColimCompactHelpers using (liftTo; inclLift; inStage)
        -- hv-swapέΓΒ: horizontal and vertical maps commute (one step)
        -- map (qpSeq (q (suc n))) (vMap n k v) έΚκ vMap n (suc k) (map (qpSeq (q n)) v)
        hv-swapέΓΒ : (n k : έΕΧ) (v : obj (qpSeq (q n)) k)
          έΗΤ map (qpSeq (q (suc n))) (vMap n k v) έΚκ vMap n (suc k) (map (qpSeq (q n)) v)
        hv-swapέΓΒ n k v =
          DecompData.fCompat (dd n) k v'
          έΙβ cong (DecompData.fMap (dd n) (suc k)) mapConn
          where
