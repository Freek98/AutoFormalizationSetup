    PT.rec squashέΓΒ step0 (colimCompact C _ (finB 0) (f έΙα incl))
    where
    open ColimCompactHelpers C
    open ColimSep C setC using (colimSeparation)
    -- maxFin: compute max of a function over Fin c
    maxFin : (c : έΕΧ) έΗΤ (Fin c έΗΤ έΕΧ) έΗΤ έΕΧ
    maxFin zero _ = 0
    maxFin (suc c) h = max (h fzero) (maxFin c (h έΙα fsuc))
