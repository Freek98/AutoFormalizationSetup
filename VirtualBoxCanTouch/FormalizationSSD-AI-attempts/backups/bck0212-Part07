      pdSurj k y = PT.rec squashέΓΒ combine
        (colimCompact C _ (finB (suc k)) (f έΙα incl)) where
        Ny = fst (pdData y) ; gy = fst (snd (pdData y)) ; oky = snd (snd (pdData y))
        combine : ╬μ[ N' έΙΙ έΕΧ ] ╬μ[ g' έΙΙ (obj B (suc k) έΗΤ obj C N') ]
                  ((x : obj B (suc k)) έΗΤ incl (g' x) έΚκ f (incl x))
                έΗΤ έΙξ ╬μ[ x έΙΙ PD (suc k) ] pdProj k x έΚκ y έΙξέΓΒ
        combine (N' , g' , ok') = PT.rec squashέΓΒ step2
          (FC.choice (_ , finB k) _ sepWit) where
          agree : (x : obj B k) έΗΤ incl (gy x) έΚκ incl (g' (map B x))
          agree x = oky x έΙβ cong f (push x) έΙβ sym (ok' (map B x))
          sepWit : (x : obj B k) έΗΤ
            έΙξ ╬μ[ M έΙΙ έΕΧ ] ╬μ[ leέΓΒ έΙΙ Ny έΚν M ] ╬μ[ leέΓΓ έΙΙ N' έΚν M ]
              (liftTo leέΓΒ (gy x) έΚκ liftTo leέΓΓ (g' (map B x))) έΙξέΓΒ
          sepWit x = colimSeparation (gy x) (g' (map B x)) (agree x)
          step2 : ((x : obj B k) έΗΤ ╬μ[ M έΙΙ έΕΧ ] ╬μ[ leέΓΒ έΙΙ Ny έΚν M ] ╬μ[ leέΓΓ έΙΙ N' έΚν M ]
                   (liftTo leέΓΒ (gy x) έΚκ liftTo leέΓΓ (g' (map B x))))
                έΗΤ έΙξ ╬μ[ x έΙΙ PD (suc k) ] pdProj k x έΚκ y έΙξέΓΒ
          step2 wit = PT.rec squashέΓΒ (╬╗ eq έΗΤ έΙμ mkPD eq , refl έΙμέΓΒ) (snd (finB k)) where
            M : obj B k έΗΤ έΕΧ
            M x = fst (wit x)
            mkPD : obj B k έΚΔ Fin (fst (finB k)) έΗΤ PD (suc k)
            mkPD eq = (y , N , le , leSucK , gN , okN , compat) where
              c = fst (finB k)
              mFin : Fin c έΗΤ έΕΧ
              mFin i = M (invEq eq i)
              Nmax = max (suc k) (max Ny (max N' (maxFin c mFin)))
              N = Nmax
              leSucK : suc k έΚν N
              leSucK = left-έΚν-max {suc k} {max Ny (max N' (maxFin c mFin))}
              le : Ny έΚν N
