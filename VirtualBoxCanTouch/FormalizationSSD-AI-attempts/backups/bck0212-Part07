                (subst (╬╗ z έΗΤ M z έΚν maxFin c mFin) (retEq eq x)
                  (maxFin-le c mFin (equivFun eq x)))
                (έΚν-trans (right-έΚν-max {maxFin c mFin} {N'})
                  (έΚν-trans (right-έΚν-max {max N' (maxFin c mFin)} {Ny})
                           (right-έΚν-max {max Ny (max N' (maxFin c mFin))} {suc k})))
