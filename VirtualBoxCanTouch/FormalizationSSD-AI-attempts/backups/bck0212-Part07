                liftTo le (gy x)
                  έΚκέθρ liftTo-isProp le (έΚν-trans leέΓΒ mle) (gy x) έθσ
                liftTo (έΚν-trans leέΓΒ mle) (gy x)
                  έΚκέθρ sym (liftTo-comp leέΓΒ mle (gy x)) έθσ
                liftTo mle (liftTo leέΓΒ (gy x))
                  έΚκέθρ cong (liftTo mle) p έθσ
                liftTo mle (liftTo leέΓΓ (g' (map B x)))
                  έΚκέθρ liftTo-comp leέΓΓ mle (g' (map B x)) έθσ
                liftTo (έΚν-trans leέΓΓ mle) (g' (map B x))
                  έΚκέθρ liftTo-isProp (έΚν-trans leέΓΓ mle) leN' (g' (map B x)) έθσ
                liftTo leN' (g' (map B x)) έΙΟ
      pdέΓΑ : PD 0
      pdέΓΑ = 0
      extract : ╬μ[ s έΙΙ SeqLimit PD pdProj ] seqLim-projέΓΑ PD pdProj s έΚκ pdέΓΑ
              έΗΤ DecompData B C f
      extract ((p , compat) , _) = record
        { lvl = lvl ; fMap = fMap ; fOk = fOk
        ; lvlMono = lvlMono ; lvlGrow = lvlGrow ; fCompat = fCompat'
        } where
        lvl : έΕΧ έΗΤ έΕΧ
        lvl k = fst (pdData (p k))
        fMap : (k : έΕΧ) έΗΤ obj B k έΗΤ obj C (lvl k)
        fMap k = fst (snd (pdData (p k)))
        fOk : (k : έΕΧ) (x : obj B k) έΗΤ incl (fMap k x) έΚκ f (incl x)
        fOk k = snd (snd (pdData (p k)))
        lvlGrow : (k : έΕΧ) έΗΤ k έΚν lvl k
        lvlGrow zero = zero-έΚν
        lvlGrow (suc k) = fst (snd (snd (snd (p (suc k)))))
        prev : (k : έΕΧ) έΗΤ PD k
        prev k = fst (p (suc k))
        rawLe : (k : έΕΧ) έΗΤ fst (pdData (prev k)) έΚν lvl (suc k)
        rawLe k = fst (snd (snd (p (suc k))))
        rawCompat : (k : έΕΧ) (x : obj B k) έΗΤ
          liftTo (rawLe k) (fst (snd (pdData (prev k))) x) έΚκ fMap (suc k) (map B x)
        rawCompat k = snd (snd (snd (snd (snd (snd (p (suc k)))))))
