        ColimCompactHelpers.liftTo C (lvlMono k) (fMap k x) έΚκ fMap (suc k) (map B x)
  lemDecompColimMorphisms : (B C : Sequence έΕΥ-zero)
    έΗΤ ((k : έΕΧ) έΗΤ isFinSet (obj B k))
