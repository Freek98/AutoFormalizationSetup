    maxFin-le (suc c) h fzero = left-έΚν-max {h fzero}
    maxFin-le (suc c) h (fsuc i) =
      έΚν-trans (maxFin-le c (h έΙα fsuc) i) (right-έΚν-max {maxFin c (h έΙα fsuc)} {h fzero})
    -- Factor f έΙα incl at stage 0, then use dep. choice for remaining stages
