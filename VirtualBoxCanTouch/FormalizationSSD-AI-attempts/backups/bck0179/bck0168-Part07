      ev-eq = funExt ќї h вЖТ
        fst h a
          вЙ°вЯ® cong (ќї g вЖТ fst g a) (sym (inducedBAHomUnique вДХ BoolBR _ h refl)) вЯ©
        fst (ѕЖ (fst h вИШ generator)) a
