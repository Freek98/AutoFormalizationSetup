    -- buildAssignment: accumulate updates from œÉ into œÅ for listed variables
    buildAssignment : (œÉ œÅ : ‚Ñï ‚Üí Bool) ‚Üí List ‚Ñï ‚Üí (‚Ñï ‚Üí Bool)
    buildAssignment œÉ œÅ [] = œÅ
