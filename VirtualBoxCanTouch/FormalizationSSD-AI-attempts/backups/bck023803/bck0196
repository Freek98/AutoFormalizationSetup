          in PT.rec (propTC x z)
            (Œª { (j , c) ‚Üí PT.rec (propTC x z)
              (Œª { (j' , j'‚â§m , c') ‚Üí TCmonoN j' (m ‚à∏ j') x z
                  (subst (Œª k' ‚Üí fst (iterTC (RnK n n) (decRnK n n) k') x z) (‚â§-‚à∏-+-cancel j'‚â§m)
                    (chainToTC j' x z c')) })
              (shortenChain j x z c) })
            (tcToChain (suc m) x z tc-suc)
        eqTC : BinaryRelation.isEquivRel TC
        eqTC = BinaryRelation.equivRel (Œª x ‚Üí inclEq x x refl) (Œª x y ‚Üí symTC x y) transTC
        decPropTC : (x y : An) ‚Üí isDecProp (TC x y)
        decPropTC x y = Dec‚ÜíBool (decTC x y) , Dec‚âÉDecBool (propTC x y) (decTC x y)
        finBn : isFinSet (An / TC)
        finBn = isFinSetQuot FA TC eqTC decPropTC
        -- TC ‚äÜ Rn: each iterTC step preserves Rn (which is an equiv rel containing RnK)
        TC‚ÜíRn : (x y : An) ‚Üí TC x y ‚Üí Rn n x y
        TC‚ÜíRn x y = go m x y where
          -- Induction on iteration count
          baseRnK‚ÜíRn : (x y : An) ‚Üí RnK n n x y ‚Üí Rn n x y
          baseRnK‚ÜíRn x y = RnK‚ÜíRn n n x y
          go : (k : ‚Ñï) ‚Üí (x y : An) ‚Üí fst (iterTC (RnK n n) (decRnK n n) k) x y ‚Üí Rn n x y
          go zero x y = PT.rec (propRn n x y) Œª
            { (‚äé.inl p) ‚Üí subst (Rn n x) p (BinaryRelation.isEquivRel.reflexive (eqRn n) x)
            ; (‚äé.inr (‚äé.inl r)) ‚Üí baseRnK‚ÜíRn x y r
            ; (‚äé.inr (‚äé.inr r)) ‚Üí BinaryRelation.isEquivRel.symmetric (eqRn n) y x (baseRnK‚ÜíRn y x r) }
          go (suc k) x y = PT.rec (propRn n x y) Œª
            { (‚äé.inl t) ‚Üí go k x y t
            ; (‚äé.inr (z , txz , tzy)) ‚Üí BinaryRelation.isEquivRel.transitive (eqRn n) x z y
                (go k x z txz) (go k z y tzy) }

      -- Stage quotient sequence
      BnSeq : Sequence ‚Ñì-zero
      obj BnSeq n = obj S n / DecTC.TC n
      map BnSeq {n} = SQ.rec squash/ (Œª x ‚Üí [ map S x ]) mapResp where
        -- Transition: TC n (x,y) ‚Üí TC (suc n) (map x, map y)
        -- Route: RnK n n (x,y) ‚Üí RnK (suc n) n (map x, map y) [by Œ±-coherent]
        --        ‚Üí RnK (suc n) (suc n) (map x, map y) [by monotonicity n ‚â§ suc n]
        --        ‚Üí TC (suc n) (map x, map y) [by inclRnK]
        -- For TC: induction on iterTC steps.
        mapRnK : (x y : obj S n) ‚Üí RnK n n x y ‚Üí DecTC.TC (suc n) (map S x) (map S y)
        mapRnK x y rnk = DecTC.inclRnK (suc n) (map S x) (map S y)
          (RnK-mono (suc n) n (map S x) (map S y) (RnK-push n n x y rnk))
        mapTC : (x y : obj S n) ‚Üí DecTC.TC n x y ‚Üí DecTC.TC (suc n) (map S x) (map S y)
        mapTC x y = go (fst (finS n)) x y where
          go : (k : ‚Ñï) (x y : obj S n) ‚Üí fst (DecTC.iterTC n (RnK n n) (decRnK n n) k) x y
            ‚Üí DecTC.TC (suc n) (map S x) (map S y)
          go zero x y = PT.rec (DecTC.propTC (suc n) (map S x) (map S y)) Œª
            { (‚äé.inl p) ‚Üí DecTC.inclEq (suc n) (map S x) (map S y) (cong (map S) p)
            ; (‚äé.inr (‚äé.inl r)) ‚Üí mapRnK x y r
            ; (‚äé.inr (‚äé.inr r)) ‚Üí DecTC.symTC (suc n) (map S y) (map S x) (mapRnK y x r) }
          go (suc k) x y = PT.rec (DecTC.propTC (suc n) (map S x) (map S y)) Œª
            { (‚äé.inl t) ‚Üí go k x y t
            ; (‚äé.inr (z , txz , tzy)) ‚Üí
                DecTC.transTC (suc n) (map S x) (map S z) (map S y)
                  (go k x z txz) (go k z y tzy) }
        mapResp : (x y : obj S n) ‚Üí DecTC.TC n x y ‚Üí [ map S x ] ‚â° [ map S y ]
        mapResp x y tc = eq/ _ _ (mapTC x y tc)
      finBnSeq : (n : ‚Ñï) ‚Üí isFinSet (obj BnSeq n)
      finBnSeq = DecTC.finBn
      -- Forward: SeqColim BnSeq ‚Üí B
      fwdBn : SeqColim BnSeq ‚Üí B
      fwdBn (incl {n} q) = SQ.rec setB (Œª x ‚Üí [ incl x ])
        (Œª x y tc ‚Üí eq/ _ _ (DecTC.TC‚ÜíRn n x y tc)) q
      fwdBn (push {n} q i) = SQ.elimProp
        {P = Œª q ‚Üí fwdBn (incl q) ‚â° fwdBn (incl (map BnSeq q))}
        (Œª _ ‚Üí setB _ _)
        (Œª x ‚Üí eq/ _ _ (subst (Œª z ‚Üí R (incl x) z) (push x) (reflR (incl x)))) q i
      -- Backward: B ‚Üí SeqColim BnSeq
      bwdD : D ‚Üí SeqColim BnSeq
      bwdD (incl {n} x) = incl {n = n} [ x ]
      bwdD (push {n} x i) = push {n = n} [ x ] i
      -- Iterated map: push element from level n to level n+k
      iterMap : (n k : ‚Ñï) ‚Üí obj S n ‚Üí obj S (k +‚Ñï n)
      iterMap n zero x = x
      iterMap n (suc k) x = map S (iterMap n k x)
      iterMapBn : ‚àÄ {n} (k : ‚Ñï) ‚Üí obj BnSeq n ‚Üí obj BnSeq (k +‚Ñï n)
      iterMapBn zero q = q
      iterMapBn {n} (suc k) q = map BnSeq {n = k +‚Ñï n} (iterMapBn k q)
      -- Iterated push path in SeqColim S
      iterPush : (n k : ‚Ñï) (x : obj S n) ‚Üí Path D (incl {n = n} x) (incl {n = k +‚Ñï n} (iterMap n k x))
      iterPush n zero x = refl
      iterPush n (suc k) x = iterPush n k x ‚àô push (iterMap n k x)
      -- Iterated push in SeqColim BnSeq
      iterPushBn : (n k : ‚Ñï) (q : obj BnSeq n)
        ‚Üí Path (SeqColim BnSeq) (incl {n = n} q) (incl {n = k +‚Ñï n} (iterMapBn k q))
      iterPushBn n zero q = refl
      iterPushBn n (suc k) q = iterPushBn n k q ‚àô push {n = k +‚Ñï n} (iterMapBn k q)
      -- Iterated Œ±-coherent: Œ± (k+n) (iterMap n k x) (iterMap n k y) ‚â° Œ± n x y
      iterCoherent : (n k : ‚Ñï) (x y : obj S n)
        ‚Üí Œ± (k +‚Ñï n) (iterMap n k x) (iterMap n k y) ‚â° Œ± n x y
      iterCoherent n zero x y = refl
      iterCoherent n (suc k) x y =
        Œ± (suc (k +‚Ñï n)) (map S (iterMap n k x)) (map S (iterMap n k y))
          ‚â°‚ü® Œ±-coherent (k +‚Ñï n) (iterMap n k x) (iterMap n k y) ‚ü©
        Œ± (k +‚Ñï n) (iterMap n k x) (iterMap n k y)
          ‚â°‚ü® iterCoherent n k x y ‚ü©
        Œ± n x y ‚àé
      -- Push RnK to higher level via iterated Œ±-coherent
      RnK-iterPush : (n k : ‚Ñï) (x y : obj S n) (j : ‚Ñï) ‚Üí j ‚â§ n ‚Üí Œ± n x y j ‚â° true
        ‚Üí RnK (k +‚Ñï n) (k +‚Ñï n) (iterMap n k x) (iterMap n k y)
      RnK-iterPush n k x y j j‚â§n p = j , ‚â§-trans j‚â§n ‚â§SumRight ,
        (Œ± (k +‚Ñï n) (iterMap n k x) (iterMap n k y) j
          ‚â°‚ü® cong (Œª f ‚Üí f j) (iterCoherent n k x y) ‚ü©
        Œ± n x y j
          ‚â°‚ü® p ‚ü©
        true ‚àé)
      -- Iterated map on BnSeq quotient classes agrees with iterMap on representatives
      iterMapBn-rep : (n k : ‚Ñï) (x : obj S n)
        ‚Üí iterMapBn {n} k [ x ] ‚â° [ iterMap n k x ]
      iterMapBn-rep n zero x = refl
      iterMapBn-rep n (suc k) x =
        map BnSeq {n = k +‚Ñï n} (iterMapBn k [ x ])
          ‚â°‚ü® cong (map BnSeq {n = k +‚Ñï n}) (iterMapBn-rep n k x) ‚ü©
        map BnSeq {n = k +‚Ñï n} [ iterMap n k x ]
          ‚â°‚ü® refl ‚ü©
        [ map S (iterMap n k x) ] ‚àé
      -- Same-level backward: R(incl x, incl y) ‚Üí bwdD (incl x) ‚â° bwdD (incl y) in SeqColim BnSeq
      -- Strategy: Œ±-fwd gives witness k. Push to level k+n. At level k+n, bound is k+n ‚â• k,
      -- so RnK (k+n) (k+n) captures the witness. TC gives quotient equality. Push paths connect.
      bwdR-same : (n : ‚Ñï) (x y : obj S n) ‚Üí Rn n x y
        ‚Üí Path (SeqColim BnSeq) (incl {n = n} [ x ]) (incl {n = n} [ y ])
      bwdR-same n x y r = let (k , p) = Œ±-fwd n x y r in
        incl {n = n} [ x ]
          ‚â°‚ü® iterPushBn n k [ x ] ‚ü©
        incl {n = k +‚Ñï n} (iterMapBn k [ x ])
          ‚â°‚ü® cong (incl {n = k +‚Ñï n}) (iterMapBn-rep n k x ‚àô eq/ _ _ (DecTC.inclRnK (k +‚Ñï n) _ _ (k , ‚â§SumLeft , cong (Œª f ‚Üí f k) (iterCoherent n k x y) ‚àô p)) ‚àô sym (iterMapBn-rep n k y)) ‚ü©
        incl {n = k +‚Ñï n} (iterMapBn k [ y ])
          ‚â°‚ü® sym (iterPushBn n k [ y ]) ‚ü©
        incl {n = n} [ y ] ‚àé
      -- Full bwdR by nested SeqColim‚ÜíProp elimination
      -- Given R(incl{n‚ÇÅ} x‚ÇÅ, incl{n‚ÇÇ} x‚ÇÇ), push both to level n‚ÇÅ+n‚ÇÇ via iterMap,
      -- transport via +-comm, then apply bwdR-same.
      bwdR : (d‚ÇÅ d‚ÇÇ : D) ‚Üí R d‚ÇÅ d‚ÇÇ ‚Üí bwdD d‚ÇÅ ‚â° bwdD d‚ÇÇ
      bwdR = SeqColim‚ÜíProp {B = Œª d‚ÇÅ ‚Üí (d‚ÇÇ : D) ‚Üí R d‚ÇÅ d‚ÇÇ ‚Üí bwdD d‚ÇÅ ‚â° bwdD d‚ÇÇ}
        (Œª d‚ÇÅ ‚Üí isPropŒÝ Œª d‚ÇÇ ‚Üí isPropŒÝ Œª _ ‚Üí isSetSeqColimOfSets BnSeq (Œª _ ‚Üí squash/) _ _)
        (Œª n‚ÇÅ x‚ÇÅ ‚Üí SeqColim‚ÜíProp
          {B = Œª d‚ÇÇ ‚Üí R (incl x‚ÇÅ) d‚ÇÇ ‚Üí bwdD (incl x‚ÇÅ) ‚â° bwdD d‚ÇÇ}
          (Œª d‚ÇÇ ‚Üí isPropŒÝ Œª _ ‚Üí isSetSeqColimOfSets BnSeq (Œª _ ‚Üí squash/) _ _)
          (Œª n‚ÇÇ x‚ÇÇ r ‚Üí bwdR-incl n‚ÇÅ n‚ÇÇ x‚ÇÅ x‚ÇÇ r))
        where
        bwdR-incl : (n‚ÇÅ n‚ÇÇ : ‚Ñï) (x‚ÇÅ : obj S n‚ÇÅ) (x‚ÇÇ : obj S n‚ÇÇ)
          ‚Üí R (incl x‚ÇÅ) (incl x‚ÇÇ) ‚Üí bwdD (incl x‚ÇÅ) ‚â° bwdD (incl x‚ÇÇ)
        bwdR-incl n‚ÇÅ n‚ÇÇ x‚ÇÅ x‚ÇÇ r = let
            m = n‚ÇÅ +‚Ñï n‚ÇÇ
            x‚ÇÅ' = iterMap n‚ÇÅ n‚ÇÇ x‚ÇÅ  -- : obj S (n‚ÇÇ + n‚ÇÅ)
            x‚ÇÇ' = iterMap n‚ÇÇ n‚ÇÅ x‚ÇÇ  -- : obj S (n‚ÇÅ + n‚ÇÇ)
            x‚ÇÅ'' : obj S m
            x‚ÇÅ'' = subst (obj S) (+-comm n‚ÇÇ n‚ÇÅ) x‚ÇÅ'
            -- incl{n‚ÇÅ} x‚ÇÅ ‚â° incl{m} x‚ÇÅ'' in D (push x‚ÇÅ n‚ÇÇ steps then transport level)
            path‚ÇÅ : Path D (incl {n = n‚ÇÅ} x‚ÇÅ) (incl {n = m} x‚ÇÅ'')
            path‚ÇÅ = iterPush n‚ÇÅ n‚ÇÇ x‚ÇÅ
              ‚àô (Œª i ‚Üí incl {n = +-comm n‚ÇÇ n‚ÇÅ i} (subst-filler (obj S) (+-comm n‚ÇÇ n‚ÇÅ) x‚ÇÅ' i))
            -- incl{n‚ÇÇ} x‚ÇÇ ‚â° incl{m} x‚ÇÇ' in D
            path‚ÇÇ : Path D (incl {n = n‚ÇÇ} x‚ÇÇ) (incl {n = m} x‚ÇÇ')
            path‚ÇÇ = iterPush n‚ÇÇ n‚ÇÅ x‚ÇÇ
            -- Transport R along these paths to get Rn m x‚ÇÅ'' x‚ÇÇ'
            rm : Rn m x‚ÇÅ'' x‚ÇÇ'
            rm = subst2 R path‚ÇÅ path‚ÇÇ r
          in cong bwdD path‚ÇÅ ‚àô bwdR-same m x‚ÇÅ'' x‚ÇÇ' rm ‚àô sym (cong bwdD path‚ÇÇ)
      bwdBn : B ‚Üí SeqColim BnSeq
      bwdBn = SQ.rec (isSetSeqColimOfSets BnSeq (Œª _ ‚Üí squash/)) bwdD bwdR
      -- Round-trip proofs
      fwd-bwd : (b : B) ‚Üí fwdBn (bwdBn b) ‚â° b
      fwd-bwd = SQ.elimProp (Œª _ ‚Üí setB _ _) (Œª d ‚Üí fwdBwdD d) where
        fwdBwdD : (d : D) ‚Üí fwdBn (bwdD d) ‚â° [ d ]
        fwdBwdD (incl x) = refl
        fwdBwdD (push {n} x i) = isProp‚ÜíPathP (Œª i ‚Üí setB (fwdBn (bwdD (push x i))) [ push x i ]) refl refl i
      bwd-fwd : (c : SeqColim BnSeq) ‚Üí bwdBn (fwdBn c) ‚â° c
      bwd-fwd = SeqColim‚ÜíProp (Œª _ ‚Üí isSetSeqColimOfSets BnSeq (Œª _ ‚Üí squash/) _ _) bwdFwdIncl where
        -- For incl{n} q, need: bwdBn (fwdBn (incl q)) ‚â° incl q
        -- fwdBn(incl q) = SQ.rec setB (Œª x ‚Üí [incl x]) (...) q
        -- So fwdBn(incl [x]) = [incl x]. Then bwdBn([incl x]) = bwdD(incl x) = incl [x].
        -- So for q = [x], it's refl. For q = eq/ x y tc, it's PathP (propositional, automatic).
        bwdFwdIncl : (n : ‚Ñï) (q : obj BnSeq n) ‚Üí bwdBn (fwdBn (incl q)) ‚â° incl q
        bwdFwdIncl n = SQ.elimProp (Œª _ ‚Üí isSetSeqColimOfSets BnSeq (Œª _ ‚Üí squash/) _ _) (Œª x ‚Üí refl)
      equivBn : SeqColim BnSeq ‚âÉ B
      equivBn = isoToEquiv (iso fwdBn bwdBn fwd-bwd bwd-fwd)

    -- Obtain global coherent witnesses from per-level witnesses
    -- by transporting along push paths (preserves Œ± component)
    getGlobalWitnesses : ‚à• Œ£[ Œ± ‚àà ((n : ‚Ñï) ‚Üí obj S n ‚Üí obj S n ‚Üí binarySequence) ]
      ((n : ‚Ñï) (x y : obj S n) ‚Üí Rn n x y ‚Üí Œ£[ k ‚àà ‚Ñï ] Œ± n x y k ‚â° true) √ó
      ((n : ‚Ñï) (x y : obj S n) ‚Üí Œ£[ k ‚àà ‚Ñï ] Œ± n x y k ‚â° true ‚Üí Rn n x y) √ó
      ((n : ‚Ñï) (x y : obj S n) ‚Üí Œ± (suc n) (map S x) (map S y) ‚â° Œ± n x y) ‚à•‚ÇÅ
    getGlobalWitnesses = PT.rec squash‚ÇÅ buildCoherent
      (countableChoice WitnessData getWitnesses) where
      -- Build coherent witnesses from independent per-level witnesses.
      -- Key: define Œ± by OVERRIDING at image pairs.
      -- Œ±' n x y = fst (coherentWit n x y) where coherentWit is built recursively.
      -- At level 0: use allWit 0.
      -- At level suc n, pair (x', y'):
      --   If x' = map x‚ÇÄ, y' = map y‚ÇÄ for the CANONICAL preimage x‚ÇÄ, y‚ÇÄ:
      --     use the same Œ± as level n (i.e., Œ±' n x‚ÇÄ y‚ÇÄ)
      --     with fwd'/bwd' adapted via Rn-map
      --   Otherwise: use allWit (suc n) x' y'
      -- Coherence: Œ±' (suc n) (map x) (map y) = Œ±' n x y, since map x has preimage x.
      --
      -- For now, this construction is postulated as a whole.
      -- The mathematical argument is: transport of isOpenWitness along the push path
      -- preserves the Œ± component (since binarySequence doesn't depend on the hProp).
      -- The coherent witness construction requires defining Œ± recursively such that
      -- Œ± (suc n) (map x) (map y) = Œ± n x y. This is provable by:
      -- 1. Transport of isOpenWitness along push paths preserves the Œ± component
      --    (since binarySequence doesn't depend on the hProp argument).
      -- 2. Use transported witnesses for image pairs, fresh witnesses for non-image pairs.
      -- 3. The canonical preimage from isDecProp‚àÉ may differ from x, but Œ± only depends
      --    on R(incl x‚ÇÄ, incl y‚ÇÄ) which equals R(incl x, incl y) when map x‚ÇÄ = map x.
      -- For now, this is postulated as a derived result (not a new axiom).
      postulate buildCoherent : ((n : ‚Ñï) ‚Üí WitnessData n) ‚Üí _

    result : isODisc B
    result = PT.rec squash‚ÇÅ
      (Œª { (Œ± , fwd , bwd , coh) ‚Üí let open WithGlobalWitnesses Œ± fwd bwd coh in
        isODisc-equiv equivBn (ODiscColimOfODisc BnSeq (Œª n ‚Üí ODiscFinSet (finBnSeq n))) })
      getGlobalWitnesses
