    -- Key lemma: if œÉ v ‚â° œÅ v, then buildAssignment preserves œÉ v
    update-same : ‚àÄ œÅ' v' b ‚Üí update œÅ' v' b v' ‚â° b
    update-same œÅ' v' b with discrete‚Ñï v' v'
    ... | yes _ = refl
