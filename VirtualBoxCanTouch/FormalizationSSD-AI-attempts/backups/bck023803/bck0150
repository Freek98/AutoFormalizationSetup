                        ((x : fst X) ‚Üí isOpenProp (U x)) √ó
                        ((x : fst X) ‚Üí isOpenProp (V x)) √ó
                        subsetOf A U √ó subsetOf B V √ó areDisjoint U V ‚ą•‚āĀ
      fromSeparator (D , D-sep-A , D-sep-B) = ‚ą£ U , V , U-open , V-open , A‚äÜU , B‚äÜV , UV-disjoint ‚ą£‚āĀ
        where
        -- D-subset: {s : S | D s = true}
        D-true : fst S ‚Üí hProp ‚Ąď-zero
        D-true s = (D s ‚Č° true) , isSetBool (D s) true

        D-false : fst S ‚Üí hProp ‚Ąď-zero
        D-false s = (D s ‚Č° false) , isSetBool (D s) false

        D-true-closed : (s : fst S) ‚Üí isClosedProp (D-true s)
        D-true-closed s = Bool-equality-closed (D s) true

        D-false-closed : (s : fst S) ‚Üí isClosedProp (D-false s)
        D-false-closed s = Bool-equality-closed (D s) false

        -- q(D) and q(¬¨D) as closed subsets of X
