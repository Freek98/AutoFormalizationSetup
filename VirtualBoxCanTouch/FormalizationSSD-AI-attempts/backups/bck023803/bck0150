        qD x = ‚ą• ő£[ s ‚ąą fst S ] (D s ‚Č° true) √ó (q s ‚Č° x) ‚ą•‚āĀ , squash‚āĀ

        q¬¨D : fst X ‚Üí hProp ‚Ąď-zero
        q¬¨D x = ‚ą• ő£[ s ‚ąą fst S ] (D s ‚Č° false) √ó (q s ‚Č° x) ‚ą•‚āĀ , squash‚āĀ

        qD-closed : (x : fst X) ‚Üí isClosedProp (qD x)
        qD-closed = CompactHausdorffClosed-backward X S q q-surj D-true D-true-closed

        q¬¨D-closed : (x : fst X) ‚Üí isClosedProp (q¬¨D x)
        q¬¨D-closed = CompactHausdorffClosed-backward X S q q-surj D-false D-false-closed

        -- U = ¬¨q(¬¨D), V = ¬¨q(D)
        U : fst X ‚Üí hProp ‚Ąď-zero
        U x = ¬¨hProp (q¬¨D x)

        V : fst X ‚Üí hProp ‚Ąď-zero
        V x = ¬¨hProp (qD x)

        U-open : (x : fst X) ‚Üí isOpenProp (U x)
        U-open x = PT.rec squash‚āĀ
          (őĽ (ő≤ , fwd , bwd) ‚Üí negClosedIsOpen mp (q¬¨D x) ő≤ (fwd , bwd))
          (q¬¨D-closed x)

        V-open : (x : fst X) ‚Üí isOpenProp (V x)
        V-open x = PT.rec squash‚āĀ
          (őĽ (ő≤ , fwd , bwd) ‚Üí negClosedIsOpen mp (qD x) ő≤ (fwd , bwd))
