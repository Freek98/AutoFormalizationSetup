          where
          N = fst (idealBound iI)
          fJ-eq : fJ d N ‚Č° ūĚüôB
          fJ-eq =
            fJ d N        ‚Č°‚ü® sym (CRS.¬∑IdL (fJ d N)) ‚ü©
            ūĚüôB ¬∑B fJ d N ‚Č°‚ü® snd (idealBound iI) ‚ü©
            ūĚüôB ‚ąé

          K : ‚Ąē
          K = maxFst N

          conclusion : (x : fst X) ‚Üí ¬¨ fst (finiteIntersectionClosed C K x)
          conclusion x finK =
            PT.rec isProp‚ä• (őĽ { (s , qs‚Č°x) ‚Üí contradiction s qs‚Č°x }) (q-surj x)
            where
            contradiction : (s : fst S) ‚Üí q s ‚Č° x ‚Üí ‚ä•
            contradiction s qs‚Č°x = true‚ČĘfalse contra
              where
