        -- B ‚äÜ V: if x ‚ąą B, then ¬¨‚ąÉs, D(s)=true ‚ąß q(s)=x
        B‚äÜV : subsetOf B V
        B‚äÜV x bx = PT.rec isProp‚ä• őĽ { (s , ds‚Č°true , qs‚Č°x) ‚Üí
          true‚ČĘfalse (sym ds‚Č°true ‚ąô D-sep-B s (subst (őĽ y ‚Üí fst (B y)) (sym qs‚Č°x) bx)) }

        -- U ‚ą© V = ‚ąÖ: ¬¨q(¬¨D)(x) ‚ąß ¬¨q(D)(x) ‚Üí ‚ä•
        UV-disjoint : areDisjoint U V
        UV-disjoint x (ux , vx) = PT.rec isProp‚ä• helper (q-surj x)
          where
          helper : ő£[ s ‚ąą fst S ] q s ‚Č° x ‚Üí ‚ä•
          helper (s , qs‚Č°x) = case-bool (D s) refl
            where
            case-bool : (b : Bool) ‚Üí D s ‚Č° b ‚Üí ‚ä•
            case-bool true  eq = vx ‚ą£ s , eq , qs‚Č°x ‚ą£‚āĀ
