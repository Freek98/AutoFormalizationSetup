        maxFst zero = 0
        maxFst (suc k) = max (fst (dec k)) (maxFst k)

        open import Cubical.Data.Nat.Properties using (+-suc)

        maxFst-bound : (N k : ‚Ąē) ‚Üí k < N ‚Üí fst (dec k) ‚Č§ maxFst N
        maxFst-bound zero k (j , p) = ‚ä•.rec (snotz (sym (+-suc j k) ‚ąô p))
