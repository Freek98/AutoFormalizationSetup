    module _ where
      open WF.WFI (<-wellfounded)

      ResultEven : ℕ → Type₀
      ResultEven n = interleave α β n ≡ true
                   → ((k : ℕ) → firstTrue (interleave α β) (suc (2 ·ℕ k)) ≡ false)
