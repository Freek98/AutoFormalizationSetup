    helper : ((k : ℕ) → firstTrue (interleave α β) (2 ·ℕ k) ≡ false)
           ⊎ ((k : ℕ) → firstTrue (interleave α β) (suc (2 ·ℕ k)) ≡ false)
           → ∥ ⟨ P ⟩ ⊎ ⟨ Q ⟩ ∥₁
    helper (inl allEvensF) = ∣ inl (allEvensF-implies-P allEvensF) ∣₁
    helper (inr allOddsF) = ∣ inr (allOddsF-implies-Q allOddsF) ∣₁

