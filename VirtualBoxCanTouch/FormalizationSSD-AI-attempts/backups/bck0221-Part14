    BZ-funspace-set-trunc-contr S =
      ‚ą£ (őĽ _ ‚Üí 0‚āĖ {G = ‚Ą§AbGroup} 1) ‚ą£‚āā ,
      ST.elim (őĽ _ ‚Üí isSetPathImplicit) (őĽ f ‚Üí sym (eilenberg-stone-vanish S ‚ą£ f ‚ą£‚āā))

    -- tex Corollary 2895: B(‚Ą§^|S|) ‚ČÉ (|S| ‚Üí BZ) for Stone S
    open import Cubical.Homotopy.WhiteheadsLemma using (ő©Equiv‚ÜíEquiv)
    open import Cubical.Foundations.Equiv.Properties using (isEquivFromIsContr)
    open import Cubical.Homotopy.Loopspace using (ő©‚Üí)
    open import Cubical.Foundations.Equiv using (isPropIsEquiv; invEquiv)
    open import Cubical.HITs.Truncation.Properties using (setTrunc‚ČÉTrunc2)

    private
      G : Type‚āÄ ‚Üí AbGroup ‚Ąď-zero
      G X = ő†AbGroup (őĽ (_ : X) ‚Üí ‚Ą§AbGroup)

      -- Set-truncation of source is contractible
