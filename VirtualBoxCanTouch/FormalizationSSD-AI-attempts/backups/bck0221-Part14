      -- Iso.fun(ő©-iso) = target-loop-iso ‚ąė encode, which on emloop g gives:
      -- target-loop-iso (encode embase (emloop g)) = target-loop-iso g (by encode-emloop = id)
      -- = funExt(őĽ s ‚Üí emloop(g s)) = cong(canonicalMap X)(emloop g) [by canonicalMap-on-emloop]
      -- So cong(canonicalMap) agrees with Iso.fun(ő©-iso) on emloop generators.
      -- Since both are groupoid homomorphisms (preserve ‚ąô), they agree on all loops.

      cong-canonicalMap-on-emloop : (X : Type‚āÄ) (g : fst (G X))
        ‚Üí cong (canonicalMap X) (emloop g) ‚Č° Iso.fun (ő©-iso X) (emloop g)
      cong-canonicalMap-on-emloop X g =
        cong (canonicalMap X) (emloop g)
          ‚Č°‚ü® canonicalMap-on-emloop X g ‚ü©
        funExt (őĽ s ‚Üí emloop (g s))
          ‚Č°‚ü® sym (cong (Iso.fun (target-loop-iso X)) (Iso.sec (ő©EM‚āĀIso-GX) g)) ‚ü©
        Iso.fun (target-loop-iso X) (Iso.inv (ő©EM‚āĀ (G X)) (emloop g)) ‚ąé
        where
        open import Cubical.Homotopy.EilenbergMacLane.Properties using (ő©EM‚āĀIso)
        ő©EM‚āĀIso-GX = ő©EM‚āĀIso (AbGroup‚ÜíGroup (G X))
        -- ő©EM‚āĀIso.sec g : encode embase (emloop g) ‚Č° g

      -- Since EM‚āĀ is a groupoid, loops form a set. Both cong(canonicalMap) and ő©-iso.fun
      -- are group homomorphisms agreeing on generators emloop g, so they agree on all loops.
      -- The key: ő©EM‚āĀIso.inv = emloop generates all loops (ő©EM‚āĀIso is an iso).
      cong-canonicalMap-is-ő©-iso : (X : Type‚āÄ) (q : 0‚āĖ {G = G X} 1 ‚Č° 0‚āĖ {G = G X} 1)
        ‚Üí cong (canonicalMap X) q ‚Č° Iso.fun (ő©-iso X) q
      cong-canonicalMap-is-ő©-iso X q =
        cong (canonicalMap X) q
          ‚Č°‚ü® cong (cong (canonicalMap X)) (sym (Iso.sec (ő©EM‚āĀ (G X)) q)) ‚ü©
        cong (canonicalMap X) (emloop (Iso.inv (ő©EM‚āĀ (G X)) q))
          ‚Č°‚ü® cong-canonicalMap-on-emloop X (Iso.inv (ő©EM‚āĀ (G X)) q) ‚ü©
        Iso.fun (ő©-iso X) (emloop (Iso.inv (ő©EM‚āĀ (G X)) q))
          ‚Č°‚ü® cong (Iso.fun (ő©-iso X)) (Iso.sec (ő©EM‚āĀ (G X)) q) ‚ü©
        Iso.fun (ő©-iso X) q ‚ąé

