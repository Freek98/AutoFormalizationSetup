      ő©‚Üí-isEquiv-at-base X = subst isEquiv (sym (funExt (ő©‚Üí-at-base-is-cong X)))
        (cong-canonicalMap-isEquiv X)

      -- Transport ő©‚Üí equivalence from basepoint to any point via connectedness
      ő©‚Üí-isEquiv-all : (X : Type‚āÄ)
