  -- ńĆech Complex (tex Definition 2784-2795)

  module CechComplex {‚Ąď : Level} (S : Type ‚Ąď) (T : S ‚Üí Type ‚Ąď) (A : S ‚Üí AbGroup ‚Ąď) where

    |A|_ : S ‚Üí Type ‚Ąď
    |A| x = fst (A x)

    module AGx (x : S) = AbGroupStr (snd (A x))

    C‚Āį : Type ‚Ąď
    C‚Āį = (x : S) ‚Üí T x ‚Üí |A| x

    C¬Ļ : Type ‚Ąď
    C¬Ļ = (x : S) ‚Üí T x ‚Üí T x ‚Üí |A| x

    C¬≤ : Type ‚Ąď
    C¬≤ = (x : S) ‚Üí T x ‚Üí T x ‚Üí T x ‚Üí |A| x

    d‚āÄ : C‚Āį ‚Üí C¬Ļ
    d‚āÄ őĪ x u v = AGx._-_ x (őĪ x v) (őĪ x u)

    d‚āĀ : C¬Ļ ‚Üí C¬≤
    d‚āĀ ő≤ x u v w = AGx._+_ x (AGx._-_ x (ő≤ x v w) (ő≤ x u w)) (ő≤ x u v)

    is1Cocycle : C¬Ļ ‚Üí Type ‚Ąď
    is1Cocycle ő≤ = (x : S) (u v w : T x) ‚Üí d‚āĀ ő≤ x u v w ‚Č° AGx.0g x

    is1Coboundary : C¬Ļ ‚Üí Type ‚Ąď
    is1Coboundary ő≤ = ő£[ őĪ ‚ąą C‚Āį ] d‚āÄ őĪ ‚Č° ő≤

    »ě¬Ļ-vanishes : Type ‚Ąď
    »ě¬Ļ-vanishes = (ő≤ : C¬Ļ) ‚Üí is1Cocycle ő≤ ‚Üí ‚ą• is1Coboundary ő≤ ‚ą•‚āĀ

    -- d‚āĀ ‚ąė d‚āÄ = 0: coboundaries are automatically cocycles
    d‚āĀ‚ąėd‚āÄ‚Č°0 : (őĪ : C‚Āį) (x : S) (u v w : T x) ‚Üí d‚āĀ (d‚āÄ őĪ) x u v w ‚Č° AGx.0g x
    d‚āĀ‚ąėd‚āÄ‚Č°0 őĪ x u v w = goal where
      module G = AbGroupStr (snd (A x))
      module Gx = GrpProps.GroupTheory (AbGroup‚ÜíGroup (A x))
      a = őĪ x u ; b = őĪ x v ; c = őĪ x w
      -- d‚āĀ(d‚āÄ őĪ)(x,u,v,w) = ((c-b) - (c-a)) + (b-a)
      -- Step 1: (c-b) + (b-a) = c-a
      step1 : G._+_ (G._-_ c b) (G._-_ b a) ‚Č° G._-_ c a
      step1 =
        G._+_ (G._+_ c (G.-_ b)) (G._+_ b (G.-_ a))
          ‚Č°‚ü® G.+Assoc (G._+_ c (G.-_ b)) b (G.-_ a) ‚ü©
        G._+_ (G._+_ (G._+_ c (G.-_ b)) b) (G.-_ a)
          ‚Č°‚ü® cong (őĽ z ‚Üí G._+_ z (G.-_ a))
               (sym (G.+Assoc c (G.-_ b) b)
                ‚ąô cong (G._+_ c) (G.+InvL b)
                ‚ąô G.+IdR c) ‚ü©
        G._+_ c (G.-_ a) ‚ąé
      -- Step 2: ((c-b) - (c-a)) + (b-a) = ((c-b) + (b-a)) - (c-a) [by commutativity]
      -- = (c-a) - (c-a) = 0
      goal : G._+_ (G._-_ (G._-_ c b) (G._-_ c a)) (G._-_ b a) ‚Č° G.0g
      goal =
        G._+_ (G._+_ (G._-_ c b) (G.-_ (G._-_ c a))) (G._-_ b a)
          ‚Č°‚ü® sym (G.+Assoc (G._-_ c b) (G.-_ (G._-_ c a)) (G._-_ b a)) ‚ü©
        G._+_ (G._-_ c b) (G._+_ (G.-_ (G._-_ c a)) (G._-_ b a))
          ‚Č°‚ü® cong (G._+_ (G._-_ c b)) (G.+Comm (G.-_ (G._-_ c a)) (G._-_ b a)) ‚ü©
        G._+_ (G._-_ c b) (G._+_ (G._-_ b a) (G.-_ (G._-_ c a)))
          ‚Č°‚ü® G.+Assoc (G._-_ c b) (G._-_ b a) (G.-_ (G._-_ c a)) ‚ü©
        G._+_ (G._+_ (G._-_ c b) (G._-_ b a)) (G.-_ (G._-_ c a))
          ‚Č°‚ü® cong (őĽ z ‚Üí G._+_ z (G.-_ (G._-_ c a))) step1 ‚ü©
        G._+_ (G._-_ c a) (G.-_ (G._-_ c a))
          ‚Č°‚ü® G.+InvR (G._-_ c a) ‚ü©
        G.0g ‚ąé

    -- Cocycle properties
    module CocycleProps (ő≤ : C¬Ļ) (cocyc : is1Cocycle ő≤) where
      private module Gx (x : S) = GrpProps.GroupTheory (AbGroup‚ÜíGroup (A x))

      -- ő≤(x)(u)(u) = 0 (diagonality)
      -- Proof: d‚āĀ(ő≤)(x)(u)(u)(u) = (ő≤(u)(u) - ő≤(u)(u)) + ő≤(u)(u) = 0 + ő≤(u)(u) = ő≤(u)(u) = 0
      cocycle-diag : (x : S) (u : T x) ‚Üí ő≤ x u u ‚Č° AGx.0g x
      cocycle-diag x u =
        ő≤ x u u
          ‚Č°‚ü® sym (AGx.+IdL x (ő≤ x u u)) ‚ü©
        AGx._+_ x (AGx.0g x) (ő≤ x u u)
          ‚Č°‚ü® cong (őĽ z ‚Üí AGx._+_ x z (ő≤ x u u)) (sym (AGx.+InvR x (ő≤ x u u))) ‚ü©
        AGx._+_ x (AGx._-_ x (ő≤ x u u) (ő≤ x u u)) (ő≤ x u u)
          ‚Č°‚ü® cocyc x u u u ‚ü©
        AGx.0g x ‚ąé

      -- ő≤(x)(u)(v) = -ő≤(x)(v)(u) (antisymmetry)
      -- From d‚āĀ(ő≤)(x)(v)(u)(v) = (ő≤(u)(v) - ő≤(v)(v)) + ő≤(v)(u) = 0
      -- and ő≤(v)(v) = 0 we get ő≤(u)(v) + ő≤(v)(u) = 0
      cocycle-antisym : (x : S) (u v : T x) ‚Üí ő≤ x u v ‚Č° AGx.-_ x (ő≤ x v u)
      cocycle-antisym x u v = Gx.invUniqueR x (sym d‚āĀ-expand ‚ąô cocyc x v u v)
        where
        -- d‚āĀ ő≤ x v u v ‚Č° ő≤(v)(u) + ő≤(u)(v)
        -- by definition: (ő≤(u)(v) - ő≤(v)(v)) + ő≤(v)(u)
        -- = (ő≤(u)(v) - 0) + ő≤(v)(u) = ő≤(u)(v) + ő≤(v)(u) = ő≤(v)(u) + ő≤(u)(v) [+Comm]
        d‚āĀ-expand : d‚āĀ ő≤ x v u v ‚Č° AGx._+_ x (ő≤ x v u) (ő≤ x u v)
        d‚āĀ-expand =
          AGx._+_ x (AGx._-_ x (ő≤ x u v) (ő≤ x v v)) (ő≤ x v u)
            ‚Č°‚ü® cong (őĽ z ‚Üí AGx._+_ x (AGx._-_ x (ő≤ x u v) z) (ő≤ x v u))
                 (cocycle-diag x v) ‚ü©
          AGx._+_ x (AGx._-_ x (ő≤ x u v) (AGx.0g x)) (ő≤ x v u)
            ‚Č°‚ü® cong (őĽ z ‚Üí AGx._+_ x (AGx._+_ x (ő≤ x u v) z) (ő≤ x v u))
                 (Gx.inv1g x) ‚ü©
          AGx._+_ x (AGx._+_ x (ő≤ x u v) (AGx.0g x)) (ő≤ x v u)
            ‚Č°‚ü® cong (őĽ z ‚Üí AGx._+_ x z (ő≤ x v u)) (AGx.+IdR x (ő≤ x u v)) ‚ü©
          AGx._+_ x (ő≤ x u v) (ő≤ x v u)
            ‚Č°‚ü® AGx.+Comm x (ő≤ x u v) (ő≤ x v u) ‚ü©
          AGx._+_ x (ő≤ x v u) (ő≤ x u v) ‚ąé

      -- ő≤(x)(u)(v) + ő≤(x)(v)(w) = ő≤(x)(u)(w) (cocycle additivity / transitivity)
      cocycle-add : (x : S) (u v w : T x) ‚Üí AGx._+_ x (ő≤ x u v) (ő≤ x v w) ‚Č° ő≤ x u w
      cocycle-add x u v w = Gx.¬∑CancelR x (AGx.-_ x (ő≤ x u w)) add-step
        where
        -- d‚āĀ ő≤ x u v w = (ő≤(v)(w) - ő≤(u)(w)) + ő≤(u)(v) = 0
        -- Rearranging: ő≤(u)(v) + (ő≤(v)(w) - ő≤(u)(w)) = 0
        -- i.e. ő≤(u)(v) + ő≤(v)(w) + (-ő≤(u)(w)) = 0
        -- i.e. (ő≤(u)(v) + ő≤(v)(w)) + (-ő≤(u)(w)) = ő≤(u)(w) + (-ő≤(u)(w))
        add-step : AGx._+_ x (AGx._+_ x (ő≤ x u v) (ő≤ x v w)) (AGx.-_ x (ő≤ x u w))
                 ‚Č° AGx._+_ x (ő≤ x u w) (AGx.-_ x (ő≤ x u w))
        add-step =
          AGx._+_ x (AGx._+_ x (ő≤ x u v) (ő≤ x v w)) (AGx.-_ x (ő≤ x u w))
            ‚Č°‚ü® sym (AGx.+Assoc x (ő≤ x u v) (ő≤ x v w) (AGx.-_ x (ő≤ x u w))) ‚ü©
          AGx._+_ x (ő≤ x u v) (AGx._+_ x (ő≤ x v w) (AGx.-_ x (ő≤ x u w)))
            ‚Č°‚ü® AGx.+Comm x (ő≤ x u v) (AGx._-_ x (ő≤ x v w) (ő≤ x u w)) ‚ü©
          AGx._+_ x (AGx._-_ x (ő≤ x v w) (ő≤ x u w)) (ő≤ x u v)
            ‚Č°‚ü® cocyc x u v w ‚ü©
          AGx.0g x
            ‚Č°‚ü® sym (AGx.+InvR x (ő≤ x u w)) ‚ü©
          AGx._+_ x (ő≤ x u w) (AGx.-_ x (ő≤ x u w)) ‚ąé

  -- Group lemma: if a - b ‚Č° -c then a ‚Č° b - c
  private
    grp-sub-rearrange : {‚Ąď : Level} (G : AbGroup ‚Ąď) (a b c : fst G)
      ‚Üí let module Ax = AbGroupStr (snd G)
        in Ax._-_ a b ‚Č° Ax.-_ c ‚Üí a ‚Č° Ax._-_ b c
    grp-sub-rearrange G a b c step1 =
      a
        ‚Č°‚ü® sym (Ax.+IdR a) ‚ü©
      Ax._+_ a Ax.0g
        ‚Č°‚ü® cong (Ax._+_ a) (sym (Ax.+InvL b)) ‚ü©
      Ax._+_ a (Ax._+_ (Ax.-_ b) b)
        ‚Č°‚ü® Ax.+Assoc a (Ax.-_ b) b ‚ü©
      Ax._+_ (Ax._-_ a b) b
        ‚Č°‚ü® cong (őĽ z ‚Üí Ax._+_ z b) step1 ‚ü©
      Ax._+_ (Ax.-_ c) b
        ‚Č°‚ü® Ax.+Comm (Ax.-_ c) b ‚ü©
      Ax._-_ b c ‚ąé
      where module Ax = AbGroupStr (snd G)

  -- Lemma: section-exact-cech-complex (tex Lemma 2807)

  module SectionExactCechComplex {‚Ąď : Level} (S : Type ‚Ąď) (T : S ‚Üí Type ‚Ąď) (A : S ‚Üí AbGroup ‚Ąď) where
    open CechComplex S T A

    section-exact : ((x : S) ‚Üí T x) ‚Üí »ě¬Ļ-vanishes
    section-exact t ő≤ cocycle-cond = ‚ą£ őĪ , funExt (őĽ x ‚Üí funExt őĽ u ‚Üí funExt őĽ v ‚Üí prove-at x u v) ‚ą£‚āĀ
      where
        őĪ : C‚Āį
        őĪ x u = ő≤ x (t x) u

        prove-at : (x : S) (u v : T x) ‚Üí d‚āÄ őĪ x u v ‚Č° ő≤ x u v
        prove-at x u v = sym step2
          where
            module Ax = AbGroupStr (snd (A x))
            module Gx = GrpProps.GroupTheory (AbGroup‚ÜíGroup (A x))

            a = ő≤ x u v
            b = ő≤ x (t x) v
            c = ő≤ x (t x) u

            step1 : Ax._-_ a b ‚Č° Ax.-_ c
            step1 = Gx.invUniqueL (cocycle-cond x (t x) u v)

            step2 : a ‚Č° Ax._-_ b c
            step2 = grp-sub-rearrange (A x) a b c step1

  -- Lemma: canonical-exact-cech-complex (tex Lemma 2815)

  module CanonicalExactCechComplex {‚Ąď : Level} (S : Type ‚Ąď) (T : S ‚Üí Type ‚Ąď) (A : S ‚Üí AbGroup ‚Ąď) where

    A^T : S ‚Üí AbGroup ‚Ąď
    A^T x = ő†AbGroup {X = T x} (őĽ _ ‚Üí A x)

    open CechComplex S T A^T public

    canonical-exact : »ě¬Ļ-vanishes
    canonical-exact ő≤ cocycle-cond = ‚ą£ őĪ , funExt (őĽ x ‚Üí funExt őĽ u ‚Üí funExt őĽ v ‚Üí funExt őĽ t ‚Üí prove-at x u v t) ‚ą£‚āĀ
      where
        őĪ : C‚Āį
        őĪ x u t = ő≤ x t u t

        prove-at : (x : S) (u v : T x) (t : T x) ‚Üí d‚āÄ őĪ x u v t ‚Č° ő≤ x u v t
        prove-at x u v t = sym step2
          where
            module Ax = AbGroupStr (snd (A x))
            module Gx = GrpProps.GroupTheory (AbGroup‚ÜíGroup (A x))

            a = ő≤ x u v t
            b = ő≤ x t v t
            c = ő≤ x t u t

            step1 : Ax._-_ a b ‚Č° Ax.-_ c
            step1 = Gx.invUniqueL (cong (őĽ f ‚Üí f t) (cocycle-cond x t u v))

            step2 : a ‚Č° Ax._-_ b c
            step2 = grp-sub-rearrange (A x) a b c step1

  -- tex Lemma 2823
  module ExactCechComplexVanishingProof {‚Ąď : Level} (S : Type ‚Ąď) (T : S ‚Üí Type ‚Ąď)
      (A : S ‚Üí AbGroup ‚Ąď)
      (inhabited : (x : S) ‚Üí ‚ą• T x ‚ą•‚āĀ)
      (exact : CechComplex.»ě¬Ļ-vanishes S T A) where

    open CechComplex S T A

    open import Cubical.HITs.PropositionalTruncation.Properties as PT-Props
    open import Cubical.Foundations.Isomorphism using (Iso)
    open import Cubical.Foundations.GroupoidLaws using (symDistr; rCancel; lCancel; lUnit) renaming (assoc to assoc-path)

    EM-iso : (x : S) ‚Üí Iso (EM (A x) 0) (0‚āĖ {G = A x} 1 ‚Č° 0‚āĖ {G = A x} 1)
    EM-iso x = EMProp.Iso-EM-ő©EM+1 {G = A x} 0

    path-to-EM0 : (őĪ : (x : S) ‚Üí EM (A x) 1)
      ‚Üí (ő≤ : (x : S) (t : T x) ‚Üí őĪ x ‚Č° 0‚āĖ {G = A x} 1)
      ‚Üí (x : S) ‚Üí T x ‚Üí T x ‚Üí EM (A x) 0
    path-to-EM0 őĪ ő≤ x u v = Iso.inv (EM-iso x) (sym (ő≤ x u) ‚ąô ő≤ x v)

    path-to-EM0-is-cocycle : (őĪ : (x : S) ‚Üí EM (A x) 1)
      ‚Üí (ő≤ : (x : S) (t : T x) ‚Üí őĪ x ‚Č° 0‚āĖ {G = A x} 1)
      ‚Üí CechComplex.is1Cocycle S T A (path-to-EM0 őĪ ő≤)
    path-to-EM0-is-cocycle őĪ ő≤ x u v w = goal
      where

        module Ax = AbGroupStr (snd (A x))
        module Gx = GrpProps.GroupTheory (AbGroup‚ÜíGroup (A x))

        g : (s t : T x) ‚Üí EM (A x) 0
        g s t = path-to-EM0 őĪ ő≤ x s t

        Ōē : 0‚āĖ {G = A x} 1 ‚Č° 0‚āĖ {G = A x} 1 ‚Üí EM (A x) 0
        Ōē = Iso.inv (EM-iso x)

        pu = ő≤ x u
        pv = ő≤ x v
        pw = ő≤ x w

        guv = g u v
        guw = g u w
        gvw = g v w

        p-uv : 0‚āĖ {G = A x} 1 ‚Č° 0‚āĖ {G = A x} 1
        p-uv = sym pu ‚ąô pv

        p-uw : 0‚āĖ {G = A x} 1 ‚Č° 0‚āĖ {G = A x} 1
        p-uw = sym pu ‚ąô pw

        p-vw : 0‚āĖ {G = A x} 1 ‚Č° 0‚āĖ {G = A x} 1
        p-vw = sym pv ‚ąô pw

        combined-path : 0‚āĖ {G = A x} 1 ‚Č° 0‚āĖ {G = A x} 1
        combined-path = p-vw ‚ąô sym p-uw ‚ąô p-uv

        sym-p-uw : sym p-uw ‚Č° sym pw ‚ąô pu
        sym-p-uw =
          sym p-uw
            ‚Č°‚ü® symDistr (sym pu) pw ‚ü©
          sym pw ‚ąô pu ‚ąé

        combined-is-refl : combined-path ‚Č° refl
        combined-is-refl =
          p-vw ‚ąô sym p-uw ‚ąô p-uv
            ‚Č°‚ü® cong (őĽ z ‚Üí p-vw ‚ąô z ‚ąô p-uv) sym-p-uw ‚ü©
          p-vw ‚ąô (sym pw ‚ąô pu) ‚ąô p-uv
            ‚Č°‚ü® cong (p-vw ‚ąô_) (sym (assoc-path (sym pw) pu p-uv)) ‚ü©
          p-vw ‚ąô (sym pw ‚ąô (pu ‚ąô (sym pu ‚ąô pv)))
            ‚Č°‚ü® cong (őĽ z ‚Üí p-vw ‚ąô (sym pw ‚ąô z)) (assoc-path pu (sym pu) pv) ‚ü©
          p-vw ‚ąô (sym pw ‚ąô ((pu ‚ąô sym pu) ‚ąô pv))
            ‚Č°‚ü® cong (őĽ z ‚Üí p-vw ‚ąô (sym pw ‚ąô z)) (cong (_‚ąô pv) (rCancel pu) ‚ąô sym (lUnit pv)) ‚ü©
          (sym pv ‚ąô pw) ‚ąô (sym pw ‚ąô pv)
            ‚Č°‚ü® sym (assoc-path (sym pv) pw (sym pw ‚ąô pv)) ‚ü©
          sym pv ‚ąô (pw ‚ąô (sym pw ‚ąô pv))
            ‚Č°‚ü® cong (sym pv ‚ąô_) (assoc-path pw (sym pw) pv) ‚ü©
          sym pv ‚ąô ((pw ‚ąô sym pw) ‚ąô pv)
            ‚Č°‚ü® cong (sym pv ‚ąô_) (cong (_‚ąô pv) (rCancel pw) ‚ąô sym (lUnit pv)) ‚ü©
          sym pv ‚ąô pv
            ‚Č°‚ü® lCancel pv ‚ü©
          refl ‚ąé

        Ōē-hom : (p q : 0‚āĖ {G = A x} 1 ‚Č° 0‚āĖ {G = A x} 1) ‚Üí Ōē (p ‚ąô q) ‚Č° Ax._+_ (Ōē p) (Ōē q)
        Ōē-hom p q = EMProp.ő©EM+1‚ÜíEM-hom {G = A x} 0 p q

        Ōē-sym : (p : 0‚āĖ {G = A x} 1 ‚Č° 0‚āĖ {G = A x} 1) ‚Üí Ōē (sym p) ‚Č° Ax.-_ (Ōē p)
        Ōē-sym p = EMProp.ő©EM+1‚ÜíEM-sym {G = A x} 0 p

        Ōē-refl : Ōē refl ‚Č° Ax.0g
        Ōē-refl = EMProp.ő©EM+1‚ÜíEM-refl {G = A x} 0

        combined-gives-0g : Ōē combined-path ‚Č° Ax.0g
        combined-gives-0g =
          Ōē combined-path
            ‚Č°‚ü® cong Ōē combined-is-refl ‚ü©
          Ōē refl
            ‚Č°‚ü® Ōē-refl ‚ü©
          Ax.0g ‚ąé

        expand-combined : Ōē combined-path ‚Č° Ax._+_ (Ax._+_ gvw (Ax.-_ guw)) guv
        expand-combined =
          Ōē (p-vw ‚ąô sym p-uw ‚ąô p-uv)
            ‚Č°‚ü® Ōē-hom p-vw (sym p-uw ‚ąô p-uv) ‚ü©
          Ax._+_ (Ōē p-vw) (Ōē (sym p-uw ‚ąô p-uv))
            ‚Č°‚ü® cong (Ax._+_ (Ōē p-vw)) (Ōē-hom (sym p-uw) p-uv) ‚ü©
          Ax._+_ (Ōē p-vw) (Ax._+_ (Ōē (sym p-uw)) (Ōē p-uv))
            ‚Č°‚ü® cong (őĽ z ‚Üí Ax._+_ (Ōē p-vw) (Ax._+_ z (Ōē p-uv))) (Ōē-sym p-uw) ‚ü©
          Ax._+_ gvw (Ax._+_ (Ax.-_ guw) guv)
            ‚Č°‚ü® Ax.+Assoc gvw (Ax.-_ guw) guv ‚ü©
          Ax._+_ (Ax._+_ gvw (Ax.-_ guw)) guv ‚ąé

        goal : d‚āĀ (path-to-EM0 őĪ ő≤) x u v w ‚Č° AGx.0g x
