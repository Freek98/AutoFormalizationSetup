      cong-canonicalMap-isEquiv : (X : Type‚āÄ)
        ‚Üí isEquiv (cong {x = 0‚āĖ {G = G X} 1} {y = 0‚āĖ {G = G X} 1} (canonicalMap X))
      cong-canonicalMap-isEquiv X = subst isEquiv
        (sym (funExt (cong-canonicalMap-is-ő©-iso X)))
        (isoToIsEquiv (ő©-iso X))

      -- ő©‚Üí(canonicalMap, refl) is equiv at basepoint
      ő©‚Üí-isEquiv-at-base : (X : Type‚āÄ)
        ‚Üí isEquiv (fst (ő©‚Üí {A = EM (G X) 1 , 0‚āĖ {G = G X} 1} {B = (X ‚Üí BZ) , (őĽ _ ‚Üí 0‚āĖ {G = ‚Ą§AbGroup} 1)}
