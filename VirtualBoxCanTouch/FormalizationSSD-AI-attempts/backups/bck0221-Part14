    fst (evHom X s) f = f s
    snd (evHom X s) = record { pres¬∑ = őĽ _ _ ‚Üí refl
                              ; pres1 = refl
                              ; presinv = őĽ _ ‚Üí refl }

    -- The canonical map: B(‚Ą§^S) ‚Üí (S ‚Üí BZ)
