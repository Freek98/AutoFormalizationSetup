        (source-set-trunc-contr (fst S) (BZX-connected (fst S)))
        (BZ-funspace-set-trunc-contr S)

      -- At basepoint, ő©‚Üí(canonicalMap, refl) is propositionally cong(canonicalMap)
      -- By doubleCompPath-elim: refl ‚ąô‚ąô cong f q ‚ąô‚ąô refl = (refl ‚ąô cong f q) ‚ąô refl = cong f q
      open import Cubical.Foundations.GroupoidLaws using (doubleCompPath-elim)

      ő©‚Üí-at-base-is-cong : (X : Type‚āÄ) (q : 0‚āĖ {G = G X} 1 ‚Č° 0‚āĖ {G = G X} 1)
        ‚Üí fst (ő©‚Üí {A = EM (G X) 1 , 0‚āĖ {G = G X} 1} {B = (X ‚Üí BZ) , (őĽ _ ‚Üí 0‚āĖ {G = ‚Ą§AbGroup} 1)}
               (canonicalMap X , refl)) q
        ‚Č° cong (canonicalMap X) q
      ő©‚Üí-at-base-is-cong X q =
        fst (ő©‚Üí (canonicalMap X , refl)) q
          ‚Č°‚ü® doubleCompPath-elim refl (cong (canonicalMap X) q) refl ‚ü©
        (refl ‚ąô cong (canonicalMap X) q) ‚ąô refl
          ‚Č°‚ü® sym (rUnit _) ‚ü©
        refl ‚ąô cong (canonicalMap X) q
          ‚Č°‚ü® sym (lUnit _) ‚ü©
        cong (canonicalMap X) q ‚ąé

      -- canonicalMap is an equiv on loop spaces at base:
      -- cong(canonicalMap) : (emloop g ‚Ü¶ funExt(őĽ s ‚Üí emloop(g s)))
      -- which is exactly the composite ő©EM‚āĀIso on each component
      open import Cubical.Homotopy.EilenbergMacLane.Properties using (Iso-EM-ő©EM+1)
      open import Cubical.Foundations.Isomorphism using (isoToIsEquiv; compIso; invIso; Iso)
      open import Cubical.HITs.EilenbergMacLane1.Base using (emloop)

      -- The EM loop iso: G ‚ČÖ ő©(EM G 1)
      ő©EM‚āĀ : (H : AbGroup ‚Ąď-zero) ‚Üí Iso (fst H) (0‚āĖ {G = H} 1 ‚Č° 0‚āĖ {G = H} 1)
      ő©EM‚āĀ H = Iso-EM-ő©EM+1 {G = H} 0

      -- canonicalMap commutes: on EM‚Üíő©EM+1 g, gives funExt(őĽ s ‚Üí EM‚Üíő©EM+1 (g s))
      -- Because inducedFun-EM at n=1 is inducedFun-EM‚āĀ which on emloop g gives emloop(f g)
      -- cong(canonicalMap X) (Iso.fun(ő©EM‚āĀ (G X)) g) = funExt(őĽ s ‚Üí Iso.fun(ő©EM‚āĀ ‚Ą§AbGroup) (g s))

      -- The target loop space iso: (X ‚Üí ‚Ą§) ‚ČÖ ő©(X ‚Üí BZ, const 0)
      -- via funExt + pointwise ő©EM‚āĀ
      target-loop-iso : (X : Type‚āÄ) ‚Üí Iso ((x : X) ‚Üí ‚Ą§) ((őĽ (_ : X) ‚Üí 0‚āĖ {G = ‚Ą§AbGroup} 1) ‚Č° (őĽ _ ‚Üí 0‚āĖ {G = ‚Ą§AbGroup} 1))
      Iso.fun (target-loop-iso X) g = funExt (őĽ s ‚Üí Iso.fun (ő©EM‚āĀ ‚Ą§AbGroup) (g s))
      Iso.inv (target-loop-iso X) p s = Iso.inv (ő©EM‚āĀ ‚Ą§AbGroup) (funExt‚ĀĽ p s)
      Iso.sec (target-loop-iso X) p =
        funExt (őĽ s ‚Üí Iso.fun (ő©EM‚āĀ ‚Ą§AbGroup) (Iso.inv (ő©EM‚āĀ ‚Ą§AbGroup) (funExt‚ĀĽ p s)))
          ‚Č°‚ü® cong funExt (funExt (őĽ s ‚Üí Iso.sec (ő©EM‚āĀ ‚Ą§AbGroup) (funExt‚ĀĽ p s))) ‚ü©
        funExt (funExt‚ĀĽ p)
          ‚Č°‚ü® refl ‚ü©
        p ‚ąé
      Iso.ret (target-loop-iso X) g = funExt (őĽ s ‚Üí Iso.ret (ő©EM‚āĀ ‚Ą§AbGroup) (g s))

      -- cong(canonicalMap X) ‚ąė emloop = funExt ‚ąė (őĽ g s ‚Üí emloop(g s))
      -- by EMFun-EM‚Üíő©EM+1 at n=0 (which is refl), for each s:
      -- emloop (g s) = cong (inducedFun-EM (evHom X s) 1) (emloop g) definitionally.
      -- Build the ő©-equivalence directly as an Iso
      ő©-iso : (X : Type‚āÄ) ‚Üí Iso (0‚āĖ {G = G X} 1 ‚Č° 0‚āĖ {G = G X} 1) ((őĽ _ ‚Üí 0‚āĖ {G = ‚Ą§AbGroup} 1) ‚Č° (őĽ _ ‚Üí 0‚āĖ {G = ‚Ą§AbGroup} 1))
      ő©-iso X = compIso (invIso (ő©EM‚āĀ (G X))) (target-loop-iso X)

