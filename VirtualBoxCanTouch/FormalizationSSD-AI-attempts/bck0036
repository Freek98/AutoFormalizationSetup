    div2-neq : ¬ (div2 m ≡ div2 n)
    div2-neq = λ eq → m≠n (div2-injective-odd m n pm pn eq)
... | true | false = inl-inr-mult-zero (g∞ (div2 m)) (g∞ (div2 n))
... | false | true = inr-inl-mult-zero (g∞ (div2 m)) (g∞ (div2 n))

