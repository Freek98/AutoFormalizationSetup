    step1-equiv-fun = isoToEquiv step1-iso

    step1-equiv : BooleanRingEquiv (BoolBR QB./Im α) ((freeBA ℕ QB./Im f₀) QB./Im α')
    step1-equiv = step1-equiv-fun , snd forward-hom

    open IsCommRingHom

