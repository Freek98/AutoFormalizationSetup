  div2 (suc (suc (k +ℕ suc k)))     ≡⟨ cong (div2 ∘ suc ∘ suc) (+-suc k k) ⟩
  div2 (suc (suc (suc (k +ℕ k))))   ≡⟨ refl ⟩
  suc (div2 (suc (k +ℕ k)))         ≡⟨ cong suc (div2-double-suc k) ⟩
  suc k ∎

