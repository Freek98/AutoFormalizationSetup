        cong₂ _+Bool_ (pres1 (snd y')) (pres- (snd y') b) ∙
        cong (λ z → true +Bool (negBool z)) eq'

      contra : false ≡ true
      contra = sym y'-¬b-false ∙ y'-¬b-true

