      → (C : ℕ → (fst X → hProp ℓ-zero))
      → ((n : ℕ) → (x : fst X) → isClosedProp (C n x))
      → ((x : fst X) → ¬ fst (countableIntersectionClosed C x))
      → ∥ Σ[ k ∈ ℕ ] ((x : fst X) → ¬ fst (finiteIntersectionClosed C k x)) ∥₁

