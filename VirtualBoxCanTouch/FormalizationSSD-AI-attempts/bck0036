  ClosedSubsetOfStone : Stone → Type₁
  ClosedSubsetOfStone S = Σ[ A ∈ (fst S → hProp ℓ-zero) ] ((x : fst S) → isClosedProp (A x))

  DecSubsetOfStone : Stone → Type₀
  DecSubsetOfStone S = fst S → Bool

