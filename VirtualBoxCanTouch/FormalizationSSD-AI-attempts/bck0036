  <I-trans : (x y z : UnitInterval) → x <I y → y <I z → x <I z
  <I-trans x y z x<y y<z =
    let x≤y : x ≤I y
        x≤y = ≤-from-<I x y x<y
        y≤z : y ≤I z
        y≤z = ≤-from-<I y z y<z
        x≤z : x ≤I z
        x≤z = ≤I-trans x y z x≤y y≤z
        x≢z : x ≡ z → ⊥
