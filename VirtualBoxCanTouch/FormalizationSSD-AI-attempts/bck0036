    invStep2 = invBooleanRingEquiv (freeBA ℕ QB./Im (⊎.rec f₀ g)) ((freeBA ℕ QB./Im f₀) QB./Im (π₀ ∘ g)) step2-equiv

    invStep3 : BooleanRingEquiv C' D'
    invStep3 = invBooleanRingEquiv (freeBA ℕ QB./Im h) (freeBA ℕ QB./Im (⊎.rec f₀ g)) step3-equiv

