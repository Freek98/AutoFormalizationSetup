allFalseProp : binarySequence → hProp ℓ-zero
allFalseProp α = ((n : ℕ) → α n ≡ false) , isPropΠ (λ n → isSetBool (α n) false)

binarySeqToClosed : binarySequence → Closed
binarySeqToClosed α = allFalseProp α , allFalseIsClosed α

