mp-from-SD SD ╬▒ ╬▒тЙа0 = MarkovLib.extract' ╬▒ (MarkovLib.тИГ╬▒n ╬▒ (trivialQuotientтЖТ1тИИI BoolCR (IQ.genIdeal BoolCR ╬▒) (sym 0тЙб1-CR)))
