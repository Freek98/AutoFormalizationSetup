DependentChoiceAxiom : Type (тДУ-suc тДУ-zero)
DependentChoiceAxiom = (E : тДХ тЖТ Type тДУ-zero) (p : (n : тДХ) тЖТ E (suc n) тЖТ E n)
  тЖТ ((n : тДХ) тЖТ (y : E n) тЖТ тИе ╬г[ x тИИ E (suc n) ] p n x тЙб y тИетВБ)
  тЖТ (eтВА : E 0) тЖТ тИе ╬г[ s тИИ SeqLimit E p ] seqLim-projтВА E p s тЙб eтВА тИетВБ

postulate
  dependentChoice-axiom : DependentChoiceAxiom

CountableChoiceAxiom : Type (тДУ-suc тДУ-zero)
CountableChoiceAxiom = (A : тДХ тЖТ Type тДУ-zero)
  тЖТ ((n : тДХ) тЖТ тИе A n тИетВБ)
  тЖТ тИе ((n : тДХ) тЖТ A n) тИетВБ

countableChoice : CountableChoiceAxiom
countableChoice A witnesses = PT.map (╬╗ { ((f , _) , _) n тЖТ snd (f (suc n)) })
    (dependentChoice-axiom E p p-surj tt)
  where
  E : тДХ тЖТ Type тДУ-zero
  E zero = Unit
  E (suc n) = E n ├Ч A n

  p : (n : тДХ) тЖТ E (suc n) тЖТ E n
  p n (e , _) = e

  p-surj : (n : тДХ) тЖТ (y : E n) тЖТ тИе ╬г[ x тИИ E (suc n) ] p n x тЙб y тИетВБ
  p-surj n y = PT.map (╬╗ a тЖТ (y , a) , refl) (witnesses n)

-- If B is Boole╧Й, then B/d is Boole╧Й for any sequence d (tex: Rule 2 separation)

quotientBySeqHasBoole╧Й : (B : Boole╧Й) (d : тДХ тЖТ тЯи fst B тЯй)
  тЖТ тИе has-Boole-╧Й' (fst B QB./Im d) тИетВБ
quotientBySeqHasBoole╧Й B d = PT.rec squashтВБ construct (snd B)
  where
  B/d : BooleanRing тДУ-zero
  B/d = fst B QB./Im d

  construct : has-Boole-╧Й' (fst B) тЖТ тИе has-Boole-╧Й' B/d тИетВБ
  construct (f , equiv) = PT.rec squashтВБ (╬╗ lifts тЖТ тИг constructFromLifts lifts тИгтВБ)
      (countableChoice LiftType (╬╗ n тЖТ QB.quotientImageHomSurjective (d' n)))
    where
    d' : тДХ тЖТ тЯи freeBA тДХ QB./Im f тЯй
    d' n = fst (fst equiv) (d n)

    LiftType : тДХ тЖТ Type тДУ-zero
    LiftType n = ╬г[ x тИИ тЯи freeBA тДХ тЯй ] fst QB.quotientImageHom x тЙб d' n

    constructFromLifts : ((n : тДХ) тЖТ LiftType n) тЖТ has-Boole-╧Й' B/d
    constructFromLifts lifts = h , B/d-equiv
      where
      g : тДХ тЖТ тЯи freeBA тДХ тЯй
      g n = fst (lifts n)

      g-is-section : (n : тДХ) тЖТ fst QB.quotientImageHom (g n) тЙб d' n
      g-is-section n = snd (lifts n)

      encode : тДХ тКО тДХ тЖТ тДХ
      encode = Iso.fun тДХтКОтДХтЙЕтДХ

      decode : тДХ тЖТ тДХ тКО тДХ
      decode = Iso.inv тДХтКОтДХтЙЕтДХ

      h : тДХ тЖТ тЯи freeBA тДХ тЯй
      h n with decode n
      ... | inl m = f m
      ... | inr m = g m

      step2-equiv : BooleanRingEquiv (freeBA тДХ QB./Im (тКО.rec f g))
                                     ((freeBA тДХ QB./Im f) QB./Im (fst QB.quotientImageHom тИШ g))
      step2-equiv = commRingPathтЖТboolRingEquiv
                      (freeBA тДХ QB./Im (тКО.rec f g))
                      ((freeBA тДХ QB./Im f) QB./Im (fst QB.quotientImageHom тИШ g))
                      (BoolQuotientEquiv (freeBA тДХ) f g)

      hтЙбrecтИШdecode-pointwise : (n : тДХ) тЖТ h n тЙб тКО.rec f g (decode n)
      hтЙбrecтИШdecode-pointwise n with decode n
      ... | inl m = refl
      ... | inr m = refl

      rec-quotient : BooleanRing тДУ-zero
      rec-quotient = freeBA тДХ QB./Im (тКО.rec f g)

      h-quotient : BooleanRing тДУ-zero
      h-quotient = freeBA тДХ QB./Im h

      ╧А-rec : BoolHom (freeBA тДХ) rec-quotient
      ╧А-rec = QB.quotientImageHom

      ╧А-h : BoolHom (freeBA тДХ) h-quotient
      ╧А-h = QB.quotientImageHom

      ╧А-rec-sends-h-to-0 : (n : тДХ) тЖТ ╧А-rec $cr (h n) тЙб BooleanRingStr.ЁЭЯШ (snd rec-quotient)
      ╧А-rec-sends-h-to-0 n =
        ╧А-rec $cr (h n)
          тЙбтЯи cong (╧А-rec $cr_) (hтЙбrecтИШdecode-pointwise n) тЯй
        ╧А-rec $cr ((тКО.rec f g) (decode n))
          тЙбтЯи QB.zeroOnImage {B = freeBA тДХ} {f = тКО.rec f g} (decode n) тЯй
        BooleanRingStr.ЁЭЯШ (snd rec-quotient) тИО

      step3-forward-hom : BoolHom h-quotient rec-quotient
      step3-forward-hom = QB.inducedHom {B = freeBA тДХ} {f = h} rec-quotient ╧А-rec ╧А-rec-sends-h-to-0

      rec-eq-h-encode : (x : тДХ тКО тДХ) тЖТ (тКО.rec f g) x тЙб h (encode x)
      rec-eq-h-encode x =
        (тКО.rec f g) x
          тЙбтЯи cong (тКО.rec f g) (sym (Iso.ret тДХтКОтДХтЙЕтДХ x)) тЯй
        (тКО.rec f g) (decode (encode x))
          тЙбтЯи sym (hтЙбrecтИШdecode-pointwise (encode x)) тЯй
        h (encode x) тИО

      ╧А-h-sends-rec-to-0 : (x : тДХ тКО тДХ) тЖТ ╧А-h $cr ((тКО.rec f g) x) тЙб BooleanRingStr.ЁЭЯШ (snd h-quotient)
      ╧А-h-sends-rec-to-0 x =
        ╧А-h $cr ((тКО.rec f g) x)
          тЙбтЯи cong (╧А-h $cr_) (rec-eq-h-encode x) тЯй
        ╧А-h $cr (h (encode x))
          тЙбтЯи QB.zeroOnImage {B = freeBA тДХ} {f = h} (encode x) тЯй
        BooleanRingStr.ЁЭЯШ (snd h-quotient) тИО

      step3-backward-hom : BoolHom rec-quotient h-quotient
      step3-backward-hom = QB.inducedHom {B = freeBA тДХ} {f = тКО.rec f g} h-quotient ╧А-h ╧А-h-sends-rec-to-0

      step3-forward : тЯи h-quotient тЯй тЖТ тЯи rec-quotient тЯй
      step3-forward = fst step3-forward-hom

      step3-backward : тЯи rec-quotient тЯй тЖТ тЯи h-quotient тЯй
      step3-backward = fst step3-backward-hom

      step3-forward-eval : step3-forward-hom тИШcr ╧А-h тЙб ╧А-rec
      step3-forward-eval = QB.evalInduce {B = freeBA тДХ} {f = h} rec-quotient

      step3-backward-eval : step3-backward-hom тИШcr ╧А-rec тЙб ╧А-h
      step3-backward-eval = QB.evalInduce {B = freeBA тДХ} {f = тКО.rec f g} h-quotient

      step3-backwardтИШforward-on-╧А : (x : тЯи freeBA тДХ тЯй) тЖТ step3-backward (step3-forward (fst ╧А-h x)) тЙб fst ╧А-h x
      step3-backwardтИШforward-on-╧А x =
        step3-backward (step3-forward (fst ╧А-h x))
          тЙбтЯи cong step3-backward (cong (╬╗ hom тЖТ fst hom x) step3-forward-eval) тЯй
        step3-backward (fst ╧А-rec x)
          тЙбтЯи cong (╬╗ hom тЖТ fst hom x) step3-backward-eval тЯй
        fst ╧А-h x тИО

      step3-forwardтИШbackward-on-╧А : (y : тЯи freeBA тДХ тЯй) тЖТ step3-forward (step3-backward (fst ╧А-rec y)) тЙб fst ╧А-rec y
      step3-forwardтИШbackward-on-╧А y =
        step3-forward (step3-backward (fst ╧А-rec y))
          тЙбтЯи cong step3-forward (cong (╬╗ hom тЖТ fst hom y) step3-backward-eval) тЯй
        step3-forward (fst ╧А-h y)
          тЙбтЯи cong (╬╗ hom тЖТ fst hom y) step3-forward-eval тЯй
        fst ╧А-rec y тИО

      step3-iso : Iso тЯи h-quotient тЯй тЯи rec-quotient тЯй
      Iso.fun step3-iso = step3-forward
      Iso.inv step3-iso = step3-backward
      Iso.sec step3-iso = funExtтБ╗ (QB.quotientImageHomEpi {B = freeBA тДХ} {f = тКО.rec f g}
        (тЯи rec-quotient тЯй , BooleanRingStr.is-set (snd rec-quotient)) (funExt step3-forwardтИШbackward-on-╧А))
      Iso.ret step3-iso = funExtтБ╗ (QB.quotientImageHomEpi {B = freeBA тДХ} {f = h}
        (тЯи h-quotient тЯй , BooleanRingStr.is-set (snd h-quotient)) (funExt step3-backwardтИШforward-on-╧А))

      step3-equiv' : BooleanRingEquiv h-quotient rec-quotient
      step3-equiv' = isoToEquiv step3-iso , snd step3-forward-hom

      target-ring : BooleanRing тДУ-zero
      target-ring = (freeBA тДХ QB./Im f) QB./Im d'

      equiv-hom : BoolHom (fst B) (freeBA тДХ QB./Im f)
      equiv-hom = fst (fst equiv) , snd equiv

      ╧А-d' : BoolHom (freeBA тДХ QB./Im f) target-ring
      ╧А-d' = QB.quotientImageHom

      composite-hom-1 : BoolHom (fst B) target-ring
      composite-hom-1 = ╧А-d' тИШcr equiv-hom

      composite-sends-d-to-0 : (n : тДХ) тЖТ composite-hom-1 $cr (d n) тЙб BooleanRingStr.ЁЭЯШ (snd target-ring)
      composite-sends-d-to-0 n = QB.zeroOnImage {f = d'} n

      step1-forward-hom : BoolHom B/d target-ring
      step1-forward-hom = QB.inducedHom target-ring composite-hom-1 composite-sends-d-to-0

      ╧А-d : BoolHom (fst B) B/d
      ╧А-d = QB.quotientImageHom

      equivтБ╗┬╣-hom : BoolHom (freeBA тДХ QB./Im f) (fst B)
      equivтБ╗┬╣-hom = fst (fst (invBooleanRingEquiv (fst B) (freeBA тДХ QB./Im f) equiv)) ,
                    snd (invBooleanRingEquiv (fst B) (freeBA тДХ QB./Im f) equiv)

      backward-composite-1 : BoolHom (freeBA тДХ QB./Im f) B/d
      backward-composite-1 = ╧А-d тИШcr equivтБ╗┬╣-hom

      backward-composite-sends-d'-to-0 : (n : тДХ) тЖТ backward-composite-1 $cr (d' n) тЙб BooleanRingStr.ЁЭЯШ (snd B/d)
      backward-composite-sends-d'-to-0 n =
        ╧А-d $cr (equivтБ╗┬╣-hom $cr (fst (fst equiv) (d n)))
          тЙбтЯи cong (╧А-d $cr_) (Iso.ret (equivToIso (fst equiv)) (d n)) тЯй
        ╧А-d $cr (d n)
          тЙбтЯи QB.zeroOnImage {f = d} n тЯй
        BooleanRingStr.ЁЭЯШ (snd B/d) тИО

      step1-backward-hom : BoolHom target-ring B/d
      step1-backward-hom = QB.inducedHom B/d backward-composite-1 backward-composite-sends-d'-to-0

      step1-forward-fun : тЯи B/d тЯй тЖТ тЯи target-ring тЯй
      step1-forward-fun = fst step1-forward-hom

      step1-backward-fun : тЯи target-ring тЯй тЖТ тЯи B/d тЯй
      step1-backward-fun = fst step1-backward-hom

      step1-forward-eval : step1-forward-hom тИШcr ╧А-d тЙб composite-hom-1
      step1-forward-eval = QB.evalInduce {B = fst B} {f = d} target-ring

      step1-backward-eval : step1-backward-hom тИШcr ╧А-d' тЙб backward-composite-1
      step1-backward-eval = QB.evalInduce {B = freeBA тДХ QB./Im f} {f = d'} B/d

      equivтБ╗┬╣тИШequivтЙбid : (x : тЯи fst B тЯй) тЖТ fst equivтБ╗┬╣-hom (fst (fst equiv) x) тЙб x
      equivтБ╗┬╣тИШequivтЙбid = Iso.ret (equivToIso (fst equiv))

      equivтИШequivтБ╗┬╣тЙбid : (y : тЯи freeBA тДХ QB./Im f тЯй) тЖТ fst (fst equiv) (fst equivтБ╗┬╣-hom y) тЙб y
      equivтИШequivтБ╗┬╣тЙбid = Iso.sec (equivToIso (fst equiv))

      step1-backwardтИШforward-on-╧А : (x : тЯи fst B тЯй) тЖТ step1-backward-fun (step1-forward-fun (fst ╧А-d x)) тЙб fst ╧А-d x
      step1-backwardтИШforward-on-╧А x =
        step1-backward-fun (step1-forward-fun (fst ╧А-d x))
          тЙбтЯи cong step1-backward-fun (cong (╬╗ hom тЖТ fst hom x) step1-forward-eval) тЯй
        step1-backward-fun (fst composite-hom-1 x)
          тЙбтЯи cong (╬╗ hom тЖТ fst hom (fst (fst equiv) x)) step1-backward-eval тЯй
        fst ╧А-d (fst equivтБ╗┬╣-hom (fst (fst equiv) x))
          тЙбтЯи cong (fst ╧А-d) (equivтБ╗┬╣тИШequivтЙбid x) тЯй
        fst ╧А-d x тИО

      step1-forwardтИШbackward-on-╧А : (y : тЯи freeBA тДХ QB./Im f тЯй) тЖТ
                                     step1-forward-fun (step1-backward-fun (fst ╧А-d' y)) тЙб fst ╧А-d' y
      step1-forwardтИШbackward-on-╧А y =
        step1-forward-fun (step1-backward-fun (fst ╧А-d' y))
          тЙбтЯи cong step1-forward-fun (cong (╬╗ hom тЖТ fst hom y) step1-backward-eval) тЯй
        step1-forward-fun (fst backward-composite-1 y)
          тЙбтЯи cong (╬╗ hom тЖТ fst hom (fst equivтБ╗┬╣-hom y)) step1-forward-eval тЯй
        fst ╧А-d' (fst (fst equiv) (fst equivтБ╗┬╣-hom y))
          тЙбтЯи cong (fst ╧А-d') (equivтИШequivтБ╗┬╣тЙбid y) тЯй
        fst ╧А-d' y тИО

      step1-iso : Iso тЯи B/d тЯй тЯи target-ring тЯй
      Iso.fun step1-iso = step1-forward-fun
      Iso.inv step1-iso = step1-backward-fun
      Iso.sec step1-iso = funExtтБ╗ (QB.quotientImageHomEpi {B = freeBA тДХ QB./Im f} {f = d'}
        (тЯи target-ring тЯй , BooleanRingStr.is-set (snd target-ring)) (funExt step1-forwardтИШbackward-on-╧А))
      Iso.ret step1-iso = funExtтБ╗ (QB.quotientImageHomEpi {B = fst B} {f = d}
        (тЯи B/d тЯй , BooleanRingStr.is-set (snd B/d)) (funExt step1-backwardтИШforward-on-╧А))

      step1-equiv : BooleanRingEquiv B/d target-ring
      step1-equiv = isoToEquiv step1-iso , snd step1-forward-hom

      step1-equiv' : BooleanRingEquiv B/d ((freeBA тДХ QB./Im f) QB./Im (fst QB.quotientImageHom тИШ g))
      step1-equiv' = subst (╬╗ seq тЖТ BooleanRingEquiv B/d ((freeBA тДХ QB./Im f) QB./Im seq))
                       (funExt (╬╗ n тЖТ sym (g-is-section n))) step1-equiv

      B'-seq : BooleanRing тДУ-zero
      B'-seq = (freeBA тДХ QB./Im f) QB./Im (fst QB.quotientImageHom тИШ g)

      invStep2-seq : BooleanRingEquiv B'-seq rec-quotient
      invStep2-seq = invBooleanRingEquiv rec-quotient B'-seq step2-equiv

      invStep3-seq : BooleanRingEquiv rec-quotient h-quotient
      invStep3-seq = invBooleanRingEquiv h-quotient rec-quotient step3-equiv'

      step12-seq : BooleanRingEquiv B/d rec-quotient
      step12-seq = compBoolRingEquiv B/d B'-seq rec-quotient step1-equiv' invStep2-seq

      B/d-equiv : BooleanRingEquiv B/d (freeBA тДХ QB./Im h)
      B/d-equiv = compBoolRingEquiv B/d rec-quotient h-quotient step12-seq invStep3-seq

