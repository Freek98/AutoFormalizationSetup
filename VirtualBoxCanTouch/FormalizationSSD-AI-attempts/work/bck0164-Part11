        bwd ex = openIsStable mp (A y) (A-open y)
          (╬╗ ┬мay тЖТ snd (markov y) ex (transport (char y) ┬мay))

-- CHausSeperationOfClosedByOpens (tex Lemma 2058)

module CHausSeperationOfClosedByOpensModule where
  open CompactHausdorffModule
  open CompactHausdorffClosedModule
  open StoneSeparatedModule
  open import Cubical.Functions.Surjection using (isSurjection)
  open import Axioms.StoneDuality using (Stone; hasStoneStr)

  areDisjoint : {X : TypeтВА}
    тЖТ (A B : X тЖТ hProp тДУ-zero) тЖТ TypeтВА
  areDisjoint {X} A B = (x : X) тЖТ ┬м (fst (A x) ├Ч fst (B x))

  subsetOf : {X : TypeтВА}
    тЖТ (A B : X тЖТ hProp тДУ-zero) тЖТ TypeтВА
  subsetOf {X} A B = (x : X) тЖТ fst (A x) тЖТ fst (B x)

  CHausSeperationOfClosedByOpens : (X : CHaus)
    тЖТ (A B : fst X тЖТ hProp тДУ-zero)
    тЖТ ((x : fst X) тЖТ isClosedProp (A x))
    тЖТ ((x : fst X) тЖТ isClosedProp (B x))
    тЖТ areDisjoint A B
    тЖТ тИе ╬г[ U тИИ (fst X тЖТ hProp тДУ-zero) ] ╬г[ V тИИ (fst X тЖТ hProp тДУ-zero) ]
        ((x : fst X) тЖТ isOpenProp (U x)) ├Ч
        ((x : fst X) тЖТ isOpenProp (V x)) ├Ч
        subsetOf A U ├Ч subsetOf B V ├Ч areDisjoint U V тИетВБ
  CHausSeperationOfClosedByOpens X A B A-closed B-closed AB-disjoint =
    PT.rec squashтВБ fromCover (hasCHausStr.stoneCover (snd X))
    where
    open hasCHausStr (snd X)

    fromCover : ╬г[ S тИИ Stone ] ╬г[ q тИИ (fst S тЖТ fst X) ] isSurjection q
              тЖТ тИе ╬г[ U тИИ (fst X тЖТ hProp тДУ-zero) ] ╬г[ V тИИ (fst X тЖТ hProp тДУ-zero) ]
                  ((x : fst X) тЖТ isOpenProp (U x)) ├Ч
                  ((x : fst X) тЖТ isOpenProp (V x)) ├Ч
                  subsetOf A U ├Ч subsetOf B V ├Ч areDisjoint U V тИетВБ
    fromCover (S , q , q-surj) = PT.rec squashтВБ fromSeparator separated
      where
      -- Pull back A and B to S
      A' : fst S тЖТ hProp тДУ-zero
      A' s = A (q s)

      B' : fst S тЖТ hProp тДУ-zero
      B' s = B (q s)

      A'-closed : (s : fst S) тЖТ isClosedProp (A' s)
      A'-closed s = A-closed (q s)

      B'-closed : (s : fst S) тЖТ isClosedProp (B' s)
      B'-closed s = B-closed (q s)

      A'B'-disjoint : ClosedSubsetsDisjoint S (A' , A'-closed) (B' , B'-closed)
      A'B'-disjoint s a'x b'x = AB-disjoint (q s) (a'x , b'x)

      separated : тИе ╬г[ D тИИ DecSubsetOfStone S ] (ClosedSubDec S (A' , A'-closed) D) ├Ч (ClosedSubNotDec S (B' , B'-closed) D) тИетВБ
      separated = StoneSeparated S (A' , A'-closed) (B' , B'-closed) A'B'-disjoint

      fromSeparator : ╬г[ D тИИ DecSubsetOfStone S ] (ClosedSubDec S (A' , A'-closed) D) ├Ч (ClosedSubNotDec S (B' , B'-closed) D)
                    тЖТ тИе ╬г[ U тИИ (fst X тЖТ hProp тДУ-zero) ] ╬г[ V тИИ (fst X тЖТ hProp тДУ-zero) ]
                        ((x : fst X) тЖТ isOpenProp (U x)) ├Ч
                        ((x : fst X) тЖТ isOpenProp (V x)) ├Ч
                        subsetOf A U ├Ч subsetOf B V ├Ч areDisjoint U V тИетВБ
      fromSeparator (D , D-sep-A , D-sep-B) = тИг U , V , U-open , V-open , AтКЖU , BтКЖV , UV-disjoint тИгтВБ
        where
        -- D-subset: {s : S | D s = true}
        D-true : fst S тЖТ hProp тДУ-zero
        D-true s = (D s тЙб true) , isSetBool (D s) true

        D-false : fst S тЖТ hProp тДУ-zero
        D-false s = (D s тЙб false) , isSetBool (D s) false

        D-true-closed : (s : fst S) тЖТ isClosedProp (D-true s)
        D-true-closed s = Bool-equality-closed (D s) true

        D-false-closed : (s : fst S) тЖТ isClosedProp (D-false s)
        D-false-closed s = Bool-equality-closed (D s) false

        -- q(D) and q(┬мD) as closed subsets of X
        qD : fst X тЖТ hProp тДУ-zero
        qD x = тИе ╬г[ s тИИ fst S ] (D s тЙб true) ├Ч (q s тЙб x) тИетВБ , squashтВБ

        q┬мD : fst X тЖТ hProp тДУ-zero
        q┬мD x = тИе ╬г[ s тИИ fst S ] (D s тЙб false) ├Ч (q s тЙб x) тИетВБ , squashтВБ

        qD-closed : (x : fst X) тЖТ isClosedProp (qD x)
        qD-closed = CompactHausdorffClosed-backward X S q q-surj D-true D-true-closed

        q┬мD-closed : (x : fst X) тЖТ isClosedProp (q┬мD x)
        q┬мD-closed = CompactHausdorffClosed-backward X S q q-surj D-false D-false-closed

        -- U = ┬мq(┬мD), V = ┬мq(D)
        U : fst X тЖТ hProp тДУ-zero
        U x = ┬мhProp (q┬мD x)

        V : fst X тЖТ hProp тДУ-zero
        V x = ┬мhProp (qD x)

        U-open : (x : fst X) тЖТ isOpenProp (U x)
        U-open x = PT.rec squashтВБ
          (╬╗ (╬▓ , fwd , bwd) тЖТ negClosedIsOpen mp (q┬мD x) ╬▓ (fwd , bwd))
          (q┬мD-closed x)

        V-open : (x : fst X) тЖТ isOpenProp (V x)
        V-open x = PT.rec squashтВБ
          (╬╗ (╬▓ , fwd , bwd) тЖТ negClosedIsOpen mp (qD x) ╬▓ (fwd , bwd))
          (qD-closed x)

        -- A тКЖ U: if x тИИ A, then ┬мтИГs, D(s)=false тИз q(s)=x
        AтКЖU : subsetOf A U
        AтКЖU x ax = PT.rec isPropтКе ╬╗ { (s , dsтЙбfalse , qsтЙбx) тЖТ
          trueтЙвfalse (sym (D-sep-A s (subst (╬╗ y тЖТ fst (A y)) (sym qsтЙбx) ax)) тИЩ dsтЙбfalse) }

        -- B тКЖ V: if x тИИ B, then ┬мтИГs, D(s)=true тИз q(s)=x
        BтКЖV : subsetOf B V
        BтКЖV x bx = PT.rec isPropтКе ╬╗ { (s , dsтЙбtrue , qsтЙбx) тЖТ
          trueтЙвfalse (sym dsтЙбtrue тИЩ D-sep-B s (subst (╬╗ y тЖТ fst (B y)) (sym qsтЙбx) bx)) }

        -- U тИй V = тИЕ: ┬мq(┬мD)(x) тИз ┬мq(D)(x) тЖТ тКе
        UV-disjoint : areDisjoint U V
        UV-disjoint x (ux , vx) = PT.rec isPropтКе helper (q-surj x)
          where
          helper : ╬г[ s тИИ fst S ] q s тЙб x тЖТ тКе
          helper (s , qsтЙбx) = case-bool (D s) refl
            where
            case-bool : (b : Bool) тЖТ D s тЙб b тЖТ тКе
            case-bool true  eq = vx тИг s , eq , qsтЙбx тИгтВБ
            case-bool false eq = ux тИг s , eq , qsтЙбx тИгтВБ

