          (╬╗ (q1 , eq1) (q2 , eq2) тЖТ selfтЙвnot fval
            (fval тЙбтЯи sym eq1 тЯй
             f (w , q1) тЙбтЯи cong (╬╗ q тЖТ f (w , q)) (snd (ConnectedComponent X x w) q1 q2) тЯй
             f (w , q2) тЙбтЯи eq2 тЯй
             not fval тИО))
          aw bw
        step2 : ╬г[ U тИИ (fst X тЖТ hProp тДУ-zero) ] ╬г[ V тИИ (fst X тЖТ hProp тДУ-zero) ]
                ((w : fst X) тЖТ isOpenProp (U w)) ├Ч
                ((w : fst X) тЖТ isOpenProp (V w)) ├Ч
                subsetOf A_X U ├Ч subsetOf B_X V ├Ч areDisjoint U V
              тЖТ fval тЙб f (a , qa)
        step2 (U , V , Uopen , Vopen , AтКЖU , BтКЖV , UV-disj) =
