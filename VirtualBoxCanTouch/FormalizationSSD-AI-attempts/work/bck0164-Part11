            x-in-U = AтКЖU x тИг (╬╗ D p тЖТ p) , refl тИгтВБ
            x-not-in-V : ┬м fst (V x)
            x-not-in-V vx = UV-disj x (x-in-U , vx)
            E'-prop : fst X тЖТ hProp тДУ-zero
            E'-prop w = (E w тЙб true) ├Ч (┬м fst (V w)) ,
                        isProp├Ч (isSetBool _ _) (snd (┬мhProp (V w)))
            E'-closed : (w : fst X) тЖТ isClosedProp (E'-prop w)
            E'-closed w = closedAnd ((E w тЙб true) , isSetBool _ _) (┬мhProp (V w))
                          (Bool-equality-closed (E w) true) (negOpenIsClosed (V w) (Vopen w))
            E'-open : (w : fst X) тЖТ isOpenProp (E'-prop w)
            E'-open w = openEquiv
              ((E w тЙб true) ├Ч fst (U w) , isProp├Ч (isSetBool _ _) (snd (U w)))
              (E'-prop w)
              (╬╗ (ew , uw) тЖТ ew , ╬╗ vw тЖТ UV-disj w (uw , vw))
              (╬╗ (ew , ┬мvw) тЖТ ew , openIsStable mp (U w) (Uopen w)
                (╬╗ ┬мuw тЖТ PT.rec isPropтКе
                  (╬╗ { (тКО.inl uw) тЖТ ┬мuw uw ; (тКО.inr vw) тЖТ ┬мvw vw })
                  (EтКЖUV w ew)))
              (openAnd ((E w тЙб true) , isSetBool _ _) (U w)
                (decIsOpen ((E w тЙб true) , isSetBool _ _) (E w тЙЯ true)) (Uopen w))
