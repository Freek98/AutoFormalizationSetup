-- ChausMapsPreserveIntersectionOfClosed (tex Corollary 2003)

module ChausMapsPreserveIntersectionOfClosedModule where
  open CompactHausdorffModule
  open CHausFiniteIntersectionPropertyModule
  open InhabitedClosedSubSpaceClosedCHausModule
  open import Cubical.Foundations.Univalence using (hPropExt)

  imageSubset : {X Y : TypeтВА} тЖТ (f : X тЖТ Y)
    тЖТ (A : X тЖТ hProp тДУ-zero) тЖТ Y тЖТ hProp тДУ-zero
  imageSubset f A y = тИе ╬г[ x тИИ _ ] fst (A x) ├Ч (f x тЙб y) тИетВБ , squashтВБ

  isDecreasingSeq : {X : TypeтВА}
    тЖТ (G : тДХ тЖТ (X тЖТ hProp тДУ-zero)) тЖТ TypeтВА
  isDecreasingSeq {X} G = (n : тДХ) тЖТ (x : X) тЖТ fst (G (suc n) x) тЖТ fst (G n x)

  ChausMapsPreserveIntersectionOfClosed : (X Y : CHaus)
    тЖТ (f : fst X тЖТ fst Y)
    тЖТ (G : тДХ тЖТ (fst X тЖТ hProp тДУ-zero))
    тЖТ ((n : тДХ) тЖТ (x : fst X) тЖТ isClosedProp (G n x))
    тЖТ isDecreasingSeq G
    тЖТ (y : fst Y)
    тЖТ fst (imageSubset f (countableIntersectionClosed G) y)
      тЙб fst (countableIntersectionClosed (╬╗ n тЖТ imageSubset f (G n)) y)
  ChausMapsPreserveIntersectionOfClosed X Y f G G-closed G-decr y =
    hPropExt squashтВБ (isProp╬а (╬╗ _ тЖТ squashтВБ)) forward backward
    where
    isSetY : isSet (fst Y)
    isSetY = hasCHausStr.isSetX (snd Y)

    forward : fst (imageSubset f (countableIntersectionClosed G) y)
            тЖТ fst (countableIntersectionClosed (╬╗ n тЖТ imageSubset f (G n)) y)
    forward = PT.rec (isProp╬а (╬╗ _ тЖТ squashтВБ))
      ╬╗ { (x , allG , fxтЙбy) n тЖТ тИг x , allG n , fxтЙбy тИгтВБ }

    backward : fst (countableIntersectionClosed (╬╗ n тЖТ imageSubset f (G n)) y)
             тЖТ fst (imageSubset f (countableIntersectionClosed G) y)
    backward hyp = closedIsStable target-prop target-closed ┬м┬мtarget
      where
      -- C_n(x) = G_n(x) тИз (f x тЙб y)
      C : тДХ тЖТ (fst X тЖТ hProp тДУ-zero)
      C n x = (fst (G n x) ├Ч (f x тЙб y)) , isProp├Ч (snd (G n x)) (isSetY (f x) y)

      C-closed : (n : тДХ) тЖТ (x : fst X) тЖТ isClosedProp (C n x)
      C-closed n x = closedAnd (G n x) ((f x тЙб y) , isSetY (f x) y)
                       (G-closed n x) (hasCHausStr.equalityClosed (snd Y) (f x) y)

      -- Build finite intersection witness from G_k witness + decreasingness
      buildFinInt : (k : тДХ) (x : fst X)
                  тЖТ fst (G k x) тЖТ f x тЙб y
                  тЖТ fst (finiteIntersectionClosed C k x)
      buildFinInt zero x gkx fxтЙбy = gkx , fxтЙбy
      buildFinInt (suc k) x gkx fxтЙбy =
        (gkx , fxтЙбy) , buildFinInt k x (G-decr k x gkx) fxтЙбy

      -- Each finite intersection is nonempty
      finInt-nonempty : (k : тДХ) тЖТ ┬м ((x : fst X) тЖТ ┬м fst (finiteIntersectionClosed C k x))
      finInt-nonempty k allEmpty-k =
        PT.rec isPropтКе
          (╬╗ { (x , gkx , fxтЙбy) тЖТ allEmpty-k x (buildFinInt k x gkx fxтЙбy) })
          (hyp k)

      -- Countable intersection is nonempty (contrapositive of CHausFIP)
      ┬мcountInt-empty : ┬м ((x : fst X) тЖТ ┬м fst (countableIntersectionClosed C x))
      ┬мcountInt-empty allEmpty =
        PT.rec isPropтКе
          (╬╗ { (k , finEmpty-k) тЖТ finInt-nonempty k finEmpty-k })
          (CHausFiniteIntersectionProperty X C C-closed allEmpty)

      target-prop : hProp тДУ-zero
      target-prop = imageSubset f (countableIntersectionClosed G) y

      -- тИе ╬г x. (тИАn. G_n x) ├Ч (f x тЙб y) тИетВБ is closed
      A-bwd : fst X тЖТ hProp тДУ-zero
      A-bwd x = (((n : тДХ) тЖТ fst (G n x)) ├Ч (f x тЙб y)) ,
                isProp├Ч (isProp╬а (╬╗ n тЖТ snd (G n x))) (isSetY (f x) y)

      A-bwd-closed : (x : fst X) тЖТ isClosedProp (A-bwd x)
      A-bwd-closed x = closedAnd
        (countableIntersectionClosed G x)
        ((f x тЙб y) , isSetY (f x) y)
        (closedCountableIntersection (╬╗ n тЖТ G n x) (╬╗ n тЖТ G-closed n x))
        (hasCHausStr.equalityClosed (snd Y) (f x) y)

      target-closed : isClosedProp target-prop
      target-closed = InhabitedClosedSubSpaceClosedCHaus X A-bwd A-bwd-closed

      ┬м┬мtarget : ┬м ┬м fst target-prop
      ┬м┬мtarget ┬мtgt = ┬мcountInt-empty ╬╗ x countInt-C-x тЖТ
        ┬мtgt тИг x , (╬╗ n тЖТ fst (countInt-C-x n)) , snd (countInt-C-x 0) тИгтВБ

