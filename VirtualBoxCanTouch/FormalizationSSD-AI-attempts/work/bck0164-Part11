               isProp╬а ╬╗ t тЖТ isProp╬а ╬╗ _ тЖТ isSetBool (b s) (b t))
        (╬╗ s тЖТ AllOpenSubspaceOpen S-CHaus
          (╬╗ t тЖТ (q s тЙб q t тЖТ b s тЙб b t) ,
                 isProp╬а (╬╗ _ тЖТ isSetBool (b s) (b t)))
          (╬╗ t тЖТ impl-open b s t))

      -- (fst X тЖТ Bool) тЙГ ╬г (fst S тЖТ Bool) compatible
      fwd : (fst X тЖТ Bool) тЖТ ╬г[ b тИИ (fst S тЖТ Bool) ] compatible b
      fwd a = (╬╗ s тЖТ a (q s)) , (╬╗ s t e тЖТ cong a e)

      bwd : (╬г[ b тИИ (fst S тЖТ Bool) ] compatible b) тЖТ fst X тЖТ Bool
      bwd (b , comp) x = recтЖТSet isSetBool
        (╬╗ { (s , _) тЖТ b s })
        (╬╗ { (sтВБ , pтВБ) (sтВВ , pтВВ) тЖТ comp sтВБ sтВВ (pтВБ тИЩ sym pтВВ) })
        (q-surj x)

      fwd-bwd : (bc : ╬г[ b тИИ (fst S тЖТ Bool) ] compatible b) тЖТ fwd (bwd bc) тЙб bc
      fwd-bwd (b , comp) = ╬гтЙбProp isProp-compatible (funExt ╬╗ s тЖТ
        PT.elim
          {P = ╬╗ w тЖТ recтЖТSet isSetBool
                       (╬╗ { (s' , _) тЖТ b s' })
                       (╬╗ { (sтВБ , pтВБ) (sтВВ , pтВВ) тЖТ comp sтВБ sтВВ (pтВБ тИЩ sym pтВВ) })
                       w
                     тЙб b s}
          (╬╗ _ тЖТ isSetBool _ _)
          (╬╗ { (s' , p') тЖТ comp s' s p' }) (q-surj (q s)))

      bwd-fwd : (a : fst X тЖТ Bool) тЖТ bwd (fwd a) тЙб a
      bwd-fwd a = funExt ╬╗ x тЖТ
        PT.elim
          {P = ╬╗ w тЖТ recтЖТSet isSetBool
                       (╬╗ { (s , _) тЖТ a (q s) })
                       (╬╗ { (sтВБ , pтВБ) (sтВВ , pтВВ) тЖТ cong a (pтВБ тИЩ sym pтВВ) })
                       w
                     тЙб a x}
          (╬╗ _ тЖТ isSetBool _ _)
          (╬╗ { (s , e) тЖТ cong a e }) (q-surj x)

      2^XтЙГ╬г : (fst X тЖТ Bool) тЙГ (╬г[ b тИИ (fst S тЖТ Bool) ] compatible b)
      2^XтЙГ╬г = isoToEquiv (iso fwd bwd fwd-bwd bwd-fwd)

      -- ╬г (fst S тЖТ Bool) compatible is ODisc
      ╬г-isODisc : isODisc (╬г[ b тИИ (fst S тЖТ Bool) ] (compatible b))
      ╬г-isODisc = OdiscSigma 2^S-isODisc
        (╬╗ b тЖТ PropOpenIffOdisc (compatible b , isProp-compatible b) (compatible-open b))

      -- (fst X тЖТ Bool) is ODisc
