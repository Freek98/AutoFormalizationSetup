    ((n : тДХ) тЖТ fst (C n x)) , isProp╬а (╬╗ n тЖТ snd (C n x))

  -- Extract C n x from the finite intersection CтВА тИй ... тИй C_k
  allC : {X : TypeтВА} (C : тДХ тЖТ (X тЖТ hProp тДУ-zero))
       тЖТ (k : тДХ) (x : X) тЖТ fst (finiteIntersectionClosed C k x) тЖТ (n : тДХ) тЖТ n тЙд k тЖТ fst (C n x)
