              (clopenIsDecidable (E'-prop x) (E'-open x) (E'-closed x))
            a-in-E' : E'bool a тЙб true
            a-in-E' = qa E'bool x-in-E'
            a-not-in-V : ┬м fst (V a)
            a-not-in-V = snd (DecтЖТBool-extract
              (clopenIsDecidable (E'-prop a) (E'-open a) (E'-closed a)) a-in-E')
