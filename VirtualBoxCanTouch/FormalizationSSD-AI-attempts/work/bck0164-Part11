    тЖТ (U : fst X тЖТ hProp тДУ-zero) тЖТ ((x : fst X) тЖТ isOpenProp (U x))
    тЖТ isOpenProp (((x : fst X) тЖТ fst (U x)) , isProp╬а (╬╗ x тЖТ snd (U x)))
  AllOpenSubspaceOpen X U Uopen = PT.rec squashтВБ go exists-┬мU-closed
    where
    ┬мU : fst X тЖТ hProp тДУ-zero
    ┬мU x = ┬мhProp (U x)

    ┬мUclosed : (x : fst X) тЖТ isClosedProp (┬мU x)
    ┬мUclosed x = negOpenIsClosed (U x) (Uopen x)

    exists-┬мU : hProp тДУ-zero
    exists-┬мU = тИе ╬г[ x тИИ fst X ] (┬м fst (U x)) тИетВБ , squashтВБ

    exists-┬мU-closed : isClosedProp exists-┬мU
    exists-┬мU-closed = InhabitedClosedSubSpaceClosedCHaus X ┬мU ┬мUclosed

    ┬мexists-┬мU : hProp тДУ-zero
    ┬мexists-┬мU = ┬мhProp exists-┬мU

    forward : ((x : fst X) тЖТ fst (U x)) тЖТ fst ┬мexists-┬мU
    forward all-U exists-┬мU' = PT.rec isPropтКе (╬╗ { (x , ┬мUx) тЖТ ┬мUx (all-U x) }) exists-┬мU'

    backward : fst ┬мexists-┬мU тЖТ (x : fst X) тЖТ fst (U x)
    backward ┬мтИГ┬мU x = openIsStable mp (U x) (Uopen x) (╬╗ ┬мUx тЖТ ┬мтИГ┬мU тИг x , ┬мUx тИгтВБ)

    go : ╬г[ ╬▓ тИИ binarySequence ] тЯи exists-┬мU тЯй тЖФ ((n : тДХ) тЖТ ╬▓ n тЙб false)
       тЖТ isOpenProp (((x : fst X) тЖТ fst (U x)) , isProp╬а (╬╗ x тЖТ snd (U x)))
    go (╬▓ , ╬▓-fwd , ╬▓-bwd) = openEquiv ┬мexists-┬мU (((x : fst X) тЖТ fst (U x)) , isProp╬а (╬╗ x тЖТ snd (U x)))
              backward forward (negClosedIsOpen mp exists-┬мU ╬▓ (╬▓-fwd , ╬▓-bwd))

