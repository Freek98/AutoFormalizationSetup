            (╬╗ n тЖТ (enc-of t ╬│ n тЙб false) , isSetBool _ _)
            (╬╗ n тЖТ Bool-equality-closed (enc-of t ╬│ n) false)

          total-Stone : Stone
          total-Stone = ╬г (Sp Dlc ├Ч CantorSpace) (╬╗ p тЖТ fst (C-pred p)) ,
                        ClosedInStoneIsStone product-Stone C-pred C-closed

          total-map : fst total-Stone тЖТ SigmaCHausType X Y
          total-map ((t , ╬│) , prf) = q_X (qT t) , f-of t (╬│ , prf)

          total-surj : isSurjection total-map
          total-surj (x , y) = PT.rec squashтВБ
            (╬╗ { (s , qsтЙбx) тЖТ PT.rec squashтВБ
              (╬╗ { (t , ╧ЖtтЙбh) тЖТ
                let qtтЙбs : qT t тЙб s
                    qtтЙбs = cong (transport p_X) ╧ЖtтЙбh тИЩ transportTransportтБ╗ p_X s
                    path-to-x : q_X (qT t) тЙб x
                    path-to-x = cong q_X qtтЙбs тИЩ qsтЙбx
                    y' : fst (Y (q_X (qT t)))
