-- StoneCompactHausdorffTotallyDisconnectedModule (tex Lemma 2186)

module StoneCompactHausdorffTotallyDisconnectedModule where
  open CompactHausdorffModule
  open ConnectedComponentModule
  open import Axioms.StoneDuality using (Stone; hasStoneStr; Sp; Boole╧Й; evaluationMap; isPropHasStoneStr; 2^; SDHomVersion; isSetBoolHom)

  isTotallyDisconnected : CHaus тЖТ TypeтВА
  isTotallyDisconnected X =
    (x : fst X) тЖТ (y : fst X) тЖТ fst (ConnectedComponent X x y) тЖТ x тЙб y
  open import Cubical.Algebra.CommRing using (_$cr_; CommRingStr; IsCommRingHom; CommRingHomтЙб)
  open import Cubical.Algebra.BooleanRing using (BooleanRingStr; BooleanRingтЖТCommRing)
  open import Cubical.Algebra.BooleanRing.Instances.Bool using (BoolBR)
  open import Cubical.Data.Bool using (true; false; falseтЙвtrue)
  open import Cubical.Data.Empty as тКе using (тКе)
  open AlgebraCompactHausdorffCountablyPresentedModule
  open import Cubical.Foundations.Function using (_тИШ_)
  open import Cubical.Functions.Surjection using (isSurjection; isEmbedding├ЧisSurjectionтЖТisEquiv)
  open import Cubical.Functions.Embedding using (injEmbedding)
  open import Cubical.Foundations.Equiv using (invEq; secEq)

  StoneCompactHausdorffTotallyDisconnected-forward : (S : Stone)
    тЖТ isTotallyDisconnected (StoneтЖТCHaus S)
  StoneCompactHausdorffTotallyDisconnected-forward S x y qxy = goal
    where
    B : Boole╧Й
    B = snd S .fst

    p : Sp B тЙб fst S
    p = snd S .snd

    x' : Sp B
    x' = transport (sym p) x

    y' : Sp B
    y' = transport (sym p) y

    D_b : тЯи fst B тЯй тЖТ DecSubsetCHaus (StoneтЖТCHaus S)
    D_b b z = evaluationMap B b (transport (sym p) z)

    agree-on-true : (b : тЯи fst B тЯй) тЖТ x' $cr b тЙб true тЖТ y' $cr b тЙб true
    agree-on-true b x'bтЙбtrue = qxy (D_b b) x'bтЙбtrue

    open BooleanRingStr (snd (fst B)) renaming (ЁЭЯЩ to 1B; _-_ to _-B_)
    open CommRingStr (snd (BooleanRingтЖТCommRing BoolBR)) renaming (1r to 1Bool; _-_ to _-Bool_)
    open IsCommRingHom

    agree-on-all : (b : тЯи fst B тЯй) тЖТ x' $cr b тЙб y' $cr b
    agree-on-all b with x' $cr b | inspect (x' $cr_) b
    ... | true  | [ eq ] = sym (agree-on-true b eq)
    ... | false | [ eq ] with y' $cr b | inspect (y' $cr_) b
    ...   | false | [ eq' ] = refl
    ...   | true  | [ eq' ] = тКе.rec (falseтЙвtrue contra)
      where
      open BooleanRingStr (snd (fst B)) using (_+_) renaming (-_ to negB)
      open CommRingStr (snd (BooleanRingтЖТCommRing BoolBR)) using () renaming (_+_ to _+Bool_; -_ to negBool)

      ┬мb : тЯи fst B тЯй
      ┬мb = 1B -B b

      neg-eval : тИА h тЖТ h $cr ┬мb тЙб true +Bool (negBool (h $cr b))
      neg-eval h =
        h $cr ┬мb
          тЙбтЯи pres+ (snd h) 1B (negB b) тЯй
        (h $cr 1B) +Bool (h $cr (negB b))
          тЙбтЯи congтВВ _+Bool_ (pres1 (snd h)) (pres- (snd h) b) тЯй
        true +Bool (negBool (h $cr b)) тИО

      x'-┬мb-true : x' $cr ┬мb тЙб true
      x'-┬мb-true =
        x' $cr ┬мb
          тЙбтЯи neg-eval x' тЯй
        true +Bool (negBool (x' $cr b))
          тЙбтЯи cong (╬╗ z тЖТ true +Bool (negBool z)) eq тЯй
        true тИО

      y'-┬мb-false : y' $cr ┬мb тЙб false
      y'-┬мb-false =
        y' $cr ┬мb
          тЙбтЯи neg-eval y' тЯй
        true +Bool (negBool (y' $cr b))
          тЙбтЯи cong (╬╗ z тЖТ true +Bool (negBool z)) eq' тЯй
        false тИО

      contra : false тЙб true
      contra =
        false
          тЙбтЯи sym y'-┬мb-false тЯй
        y' $cr ┬мb
          тЙбтЯи agree-on-true ┬мb x'-┬мb-true тЯй
        true тИО

    x'тЙбy' : x' тЙб y'
    x'тЙбy' = CommRingHomтЙб (funExt agree-on-all)

    goal : x тЙб y
    goal =
      x
        тЙбтЯи sym (transportTransportтБ╗ p x) тЯй
      transport p (transport (sym p) x)
        тЙбтЯи cong (transport p) x'тЙбy' тЯй
      transport p (transport (sym p) y)
        тЙбтЯи transportTransportтБ╗ p y тЯй
      y тИО

  -- tex Lemma 2186 backward direction, depends on tex Lemma 2112
  StoneCompactHausdorffTotallyDisconnected-backward : (X : CHaus)
    тЖТ isTotallyDisconnected X
    тЖТ hasStoneStr (fst X)
  StoneCompactHausdorffTotallyDisconnected-backward X td =
    PT.rec (isPropHasStoneStr sd-axiom _) mainConstruct
      (AlgebraCompactHausdorffCountablyPresented X)
    where
    mainConstruct : has-Boole-╧Й' (2^ (fst X)) тЖТ hasStoneStr (fst X)
    mainConstruct countPresX = BX , sym (ua ev-equiv)
      where
      BX : Boole╧Й
      BX = 2^ (fst X) , тИг countPresX тИгтВБ

      open IsCommRingHom

      ev : fst X тЖТ Sp BX
      fst (ev z) D = D z
      pres0 (snd (ev z)) = refl
      pres1 (snd (ev z)) = refl
      pres+ (snd (ev z)) _ _ = refl
      pres┬╖ (snd (ev z)) _ _ = refl
      pres- (snd (ev z)) _ = refl

      ev-inj : (x y : fst X) тЖТ ev x тЙб ev y тЖТ x тЙб y
      ev-inj x y p = td x y (╬╗ D xInD тЖТ
        subst (_тЙб true) (funExtтБ╗ (cong fst p) D) xInD)

      ev-surj : isSurjection ev
      ev-surj h = PT.rec squashтВБ withCover (hasCHausStr.stoneCover (snd X))
        where
        withCover : ╬г[ S тИИ Stone ] ╬г[ q тИИ (fst S тЖТ fst X) ] isSurjection q
          тЖТ тИе ╬г[ x тИИ fst X ] ev x тЙб h тИетВБ
        withCover (S , q , q-surj) = PT.rec squashтВБ withCountPresS
          (AlgebraCompactHausdorffCountablyPresented (StoneтЖТCHaus S))
          where
          withCountPresS : has-Boole-╧Й' (2^ (fst S)) тЖТ тИе ╬г[ x тИИ fst X ] ev x тЙб h тИетВБ
          withCountPresS countPresS = PT.rec squashтВБ withH'
            (injectiveтЖТSp-surjective BX BSo q* q*-inj h)
            where
            BSo : Boole╧Й
            BSo = 2^ (fst S) , тИг countPresS тИгтВБ

            q* : BoolHom (fst BX) (fst BSo)
            fst q* D s' = D (q s')
            pres0 (snd q*) = refl
            pres1 (snd q*) = refl
            pres+ (snd q*) _ _ = refl
            pres┬╖ (snd q*) _ _ = refl
            pres- (snd q*) _ = refl

            q*-inj : isInjectiveBoolHom BX BSo q*
            q*-inj D1 D2 eq = funExt (╬╗ x тЖТ
              PT.rec (isSetBool _ _)
                (╬╗ { (s' , qs'тЙбx) тЖТ
                  D1 x       тЙбтЯи cong D1 (sym qs'тЙбx) тЯй
                  D1 (q s')  тЙбтЯи funExtтБ╗ eq s' тЯй
                  D2 (q s')  тЙбтЯи cong D2 qs'тЙбx тЯй
                  D2 x тИО })
                (q-surj x))

            B_S : Boole╧Й
            B_S = snd S .fst

            p_S : Sp B_S тЙб fst S
            p_S = snd S .snd

            coord : BoolHom (fst B_S) (fst BSo)
            fst coord b s' = evaluationMap B_S b (transport (sym p_S) s')
            pres0 (snd coord) = funExt (╬╗ s' тЖТ pres0 (snd (transport (sym p_S) s')))
            pres1 (snd coord) = funExt (╬╗ s' тЖТ pres1 (snd (transport (sym p_S) s')))
            pres+ (snd coord) a b = funExt (╬╗ s' тЖТ pres+ (snd (transport (sym p_S) s')) a b)
            pres┬╖ (snd coord) a b = funExt (╬╗ s' тЖТ pres┬╖ (snd (transport (sym p_S) s')) a b)
            pres- (snd coord) a = funExt (╬╗ s' тЖТ pres- (snd (transport (sym p_S) s')) a)

            sdEquiv : тЯи fst B_S тЯй тЙГ (Sp B_S тЖТ Bool)
            sdEquiv = fst (SDHomVersion sd-axiom B_S)

            withH' : ╬г[ h' тИИ Sp BSo ] h' тИШcr q* тЙб h тЖТ тИе ╬г[ x тИИ fst X ] ev x тЙб h тИетВБ
            withH' (h' , h'q*тЙбh) = тИг q s , CommRingHomтЙб (funExt pointwise) тИгтВБ
              where
              ╧И : Sp B_S
              ╧И = h' тИШcr coord

              s : fst S
              s = transport p_S ╧И

              bE : (E : fst S тЖТ Bool) тЖТ тЯи fst B_S тЯй
              bE E = invEq sdEquiv (E тИШ transport p_S)

              coordbтЙб : (E : fst S тЖТ Bool) тЖТ fst coord (bE E) тЙб E
              coordbтЙб E = funExt (╬╗ s' тЖТ
                fst coord (bE E) s'
                  тЙбтЯи funExtтБ╗ (secEq sdEquiv (E тИШ transport p_S)) (transport (sym p_S) s') тЯй
                E (transport p_S (transport (sym p_S) s'))
                  тЙбтЯи cong E (transportTransportтБ╗ p_S s') тЯй
                E s' тИО)

              pointwise : (D : fst X тЖТ Bool) тЖТ D (q s) тЙб fst h D
              pointwise D =
                D (q s)
                  тЙбтЯи sym (funExtтБ╗ (secEq sdEquiv ((D тИШ q) тИШ transport p_S)) ╧И) тЯй
                fst h' (fst coord (bE (D тИШ q)))
                  тЙбтЯи cong (fst h') (coordbтЙб (D тИШ q)) тЯй
                fst h' (D тИШ q)
                  тЙбтЯи funExtтБ╗ (cong fst h'q*тЙбh) D тЯй
                fst h D тИО

      ev-emb = injEmbedding (isSetBoolHom (fst BX) BoolBR) (╬╗ {x} {y} тЖТ ev-inj x y)

      ev-equiv : fst X тЙГ Sp BX
      ev-equiv = ev , isEmbedding├ЧisSurjectionтЖТisEquiv (ev-emb , ev-surj)

