  allC C zero x p n (suc j , q) = тКе.rec (snotz q)
  allC C (suc k) x (csk , fink) n (zero , q) = subst (╬╗ m тЖТ fst (C m x)) (sym q) csk
  allC C (suc k) x (csk , fink) n (suc j , q) = allC C k x fink n (j , injSuc q)

  CHausFiniteIntersectionProperty : (X : CHaus)
    тЖТ (C : тДХ тЖТ (fst X тЖТ hProp тДУ-zero))
    тЖТ ((n : тДХ) тЖТ (x : fst X) тЖТ isClosedProp (C n x))
    тЖТ ((x : fst X) тЖТ ┬м fst (countableIntersectionClosed C x))
    тЖТ тИе ╬г[ k тИИ тДХ ] ((x : fst X) тЖТ ┬м fst (finiteIntersectionClosed C k x)) тИетВБ
  CHausFiniteIntersectionProperty X C C-closed allEmpty =
    PT.rec squashтВБ fromCover (hasCHausStr.stoneCover (snd X))
    where
    open hasCHausStr (snd X)

    fromCover : ╬г[ S тИИ Stone ] ╬г[ q тИИ (fst S тЖТ fst X) ] isSurjection q
              тЖТ тИе ╬г[ k тИИ тДХ ] ((x : fst X) тЖТ ┬м fst (finiteIntersectionClosed C k x)) тИетВБ
    fromCover (S , q , q-surj) =
      PT.rec squashтВБ fromWitnesses combined
      where
      C' : тДХ тЖТ fst S тЖТ hProp тДУ-zero
      C' n s = C n (q s)

      C'-closed : (n : тДХ) (s : fst S) тЖТ isClosedProp (C' n s)
      C'-closed n s = C-closed n (q s)

      combined : тИе ((n : тДХ) тЖТ (s : fst S) тЖТ ╬г[ ╬▒ тИИ binarySequence ] fst (C' n s) тЖФ ((m : тДХ) тЖТ ╬▒ m тЙб false)) тИетВБ
      combined = countableChoice _ (╬╗ n тЖТ closedFamilyChoice S (C' n) (C'-closed n))

      fromWitnesses : ((n : тДХ) тЖТ (s : fst S) тЖТ ╬г[ ╬▒ тИИ binarySequence ] fst (C' n s) тЖФ ((m : тДХ) тЖТ ╬▒ m тЙб false))
                    тЖТ тИе ╬г[ k тИИ тДХ ] ((x : fst X) тЖТ ┬м fst (finiteIntersectionClosed C k x)) тИетВБ
      fromWitnesses wit = PT.rec squashтВБ fromIdealMem idealMem
        where
        -- Stone duality data
