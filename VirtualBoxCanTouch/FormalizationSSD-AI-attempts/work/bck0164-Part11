      stoneCover : тИе ╬г[ S тИИ Stone ] ╬г[ q тИИ (fst S тЖТ X) ] isSurjection q тИетВБ

  CHaus : TypeтВБ
  CHaus = ╬г[ X тИИ TypeтВА ] hasCHausStr X

  StoneтЖТCHaus : Stone тЖТ CHaus
  StoneтЖТCHaus S = fst S , record
    { isSetX = hasStoneStrтЖТisSet S
    ; equalityClosed = StoneEqualityClosed S
    ; stoneCover = тИг S , (╬╗ x тЖТ x) , (╬╗ x тЖТ тИг x , refl тИгтВБ) тИгтВБ
    }
    where
    open StoneEqualityClosedModule

