    (fst (C (suc n) x) ├Ч fst (finiteIntersectionClosed C n x)) ,
    isProp├Ч (snd (C (suc n) x)) (snd (finiteIntersectionClosed C n x))

  countableIntersectionClosed : {X : TypeтВА}
    тЖТ (C : тДХ тЖТ (X тЖТ hProp тДУ-zero))
