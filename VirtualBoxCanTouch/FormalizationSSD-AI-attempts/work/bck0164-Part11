  open import Cubical.Data.Bool using (_тЙЯ_)
  open import Cubical.HITs.PropositionalTruncation.Properties using (recтЖТSet)

  -- Helper: if P is closed and Q is decidable, (P тЖТ Q) is open
  closedImplDecIsOpen : (P Q : hProp тДУ-zero) тЖТ isClosedProp P тЖТ Dec тЯи Q тЯй
    тЖТ isOpenProp ((тЯи P тЯй тЖТ тЯи Q тЯй) , isProp╬а (╬╗ _ тЖТ snd Q))
  closedImplDecIsOpen P Q Pclosed (yes q) =
    тИг (╬╗ _ тЖТ true) , (╬╗ _ тЖТ 0 , refl) , (╬╗ _ _ тЖТ q) тИгтВБ
  closedImplDecIsOpen P Q Pclosed (no ┬мq) = PT.rec squashтВБ go Pclosed
    where
    go : ╬г[ ╬▒ тИИ binarySequence ] тЯи P тЯй тЖФ ((n : тДХ) тЖТ ╬▒ n тЙб false)
       тЖТ isOpenProp ((тЯи P тЯй тЖТ тЯи Q тЯй) , isProp╬а (╬╗ _ тЖТ snd Q))
    go (╬▒ , PтЖТтИА , тИАтЖТP) = openEquiv (┬мhProp P)
      ((тЯи P тЯй тЖТ тЯи Q тЯй) , isProp╬а (╬╗ _ тЖТ snd Q))
      (╬╗ ┬мp p тЖТ ex-falso (┬мp p))
