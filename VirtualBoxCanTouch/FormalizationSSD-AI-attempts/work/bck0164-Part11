        (ua (fst (SDHomVersion sd-axiom B)) тИЩ cong (╬╗ T тЖТ T тЖТ Bool) p)
        (BooleIsODisc B)

      -- compatibility predicate
      compatible : (fst S тЖТ Bool) тЖТ Type тДУ-zero
