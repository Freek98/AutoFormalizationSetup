  ConnectedComponentClosedInCompactHausdorff : (X : CHaus) (x : fst X)
    тЖТ тИе ╬г[ D тИИ (тДХ тЖТ DecSubsetCHaus X) ]
        ((y : fst X) тЖТ fst (ConnectedComponent X x y)
          тЙб ((n : тДХ) тЖТ inDec X y (D n))) тИетВБ
  ConnectedComponentClosedInCompactHausdorff X x =
    PT.rec squashтВБ construct (AlgebraCompactHausdorffCountablyPresented X)
    where
    construct : has-Boole-╧Й' (2^ (fst X))
      тЖТ тИе ╬г[ D тИИ (тДХ тЖТ DecSubsetCHaus X) ]
          ((y : fst X) тЖТ fst (ConnectedComponent X x y)
            тЙб ((n : тДХ) тЖТ inDec X y (D n))) тИетВБ
    construct (rel , equiv) = тИг D , proof тИгтВБ
      where
      Q = freeBA тДХ /Im rel

      inv-hom : BoolHom Q (2^ (fst X))
      inv-hom = BooleanEquivToHomInv (2^ (fst X)) Q equiv

      ╬ж : BoolHom (freeBA тДХ) (2^ (fst X))
      ╬ж = inv-hom тИШcr quotientImageHom

      g : тДХ тЖТ DecSubsetCHaus X
      g n = fst ╬ж (generator n)

      D : тДХ тЖТ DecSubsetCHaus X
      D n y = bool-eq (g n x) (g n y)

      open IsCommRingHom

      ev : fst X тЖТ BoolHom (2^ (fst X)) BoolBR
      fst (ev z) h = h z
      pres0 (snd (ev z)) = refl
      pres1 (snd (ev z)) = refl
      pres+ (snd (ev z)) _ _ = refl
      pres┬╖ (snd (ev z)) _ _ = refl
      pres- (snd (ev z)) _ = refl

      proof : (y : fst X) тЖТ fst (ConnectedComponent X x y)
            тЙб ((n : тДХ) тЖТ inDec X y (D n))
      proof y = hPropExt
        (isProp╬а (╬╗ _ тЖТ isProp╬а (╬╗ _ тЖТ isSetBool _ _)))
        (isProp╬а (╬╗ _ тЖТ isSetBool _ _))
        forward backward
        where
        forward : fst (ConnectedComponent X x y) тЖТ (n : тДХ) тЖТ inDec X y (D n)
        forward qxy n = qxy (D n) (bool-eq-refl (g n x))

        backward : ((n : тДХ) тЖТ inDec X y (D n)) тЖТ fst (ConnectedComponent X x y)
        backward allDn E ExтЙбtrue =
          PT.rec (isSetBool _ _) step (quotientImageHomSurjective (equivFun (fst equiv) E))
          where
          gn-eq : (n : тДХ) тЖТ g n x тЙб g n y
          gn-eq n = bool-eq-eq (g n x) (g n y) (allDn n)

          hom-eq : ev x тИШcr ╬ж тЙб ev y тИШcr ╬ж
          hom-eq = equalityFromEqualityOnGenerators BoolBR (ev x тИШcr ╬ж) (ev y тИШcr ╬ж) gn-eq

          step : ╬г[ t тИИ тЯи freeBA тДХ тЯй ] fst quotientImageHom t тЙб equivFun (fst equiv) E
               тЖТ E y тЙб true
          step (t , qtтЙбq) =
            E y
              тЙбтЯи cong (╬╗ h тЖТ h y) (sym ╬жtтЙбE) тЯй
            fst ╬ж t y
              тЙбтЯи sym (funExtтБ╗ (cong fst hom-eq) t) тЯй
            fst ╬ж t x
              тЙбтЯи cong (╬╗ h тЖТ h x) ╬жtтЙбE тЯй
            E x
              тЙбтЯи ExтЙбtrue тЯй
            true тИО
            where
            ╬жtтЙбE : fst ╬ж t тЙб E
            ╬жtтЙбE = cong (invEq (fst equiv)) qtтЙбq тИЩ retEq (fst equiv) E

  ConnectedComponentSubOpenHasDecidableInbetween : (X : CHaus) (x : fst X)
    тЖТ (U : fst X тЖТ hProp тДУ-zero) тЖТ ((y : fst X) тЖТ isOpenProp (U y))
    тЖТ ((y : fst X) тЖТ fst (ConnectedComponent X x y) тЖТ fst (U y))
    тЖТ тИе ╬г[ E тИИ DecSubsetCHaus X ] inDec X x E ├Ч ((y : fst X) тЖТ inDec X y E тЖТ fst (U y)) тИетВБ
  ConnectedComponentSubOpenHasDecidableInbetween X x U Uopen QxтКЖU =
    PT.rec squashтВБ construct (ConnectedComponentClosedInCompactHausdorff X x)
    where
    construct : ╬г[ D тИИ (тДХ тЖТ DecSubsetCHaus X) ]
        ((y : fst X) тЖТ fst (ConnectedComponent X x y) тЙб ((n : тДХ) тЖТ inDec X y (D n)))
      тЖТ тИе ╬г[ E тИИ DecSubsetCHaus X ] inDec X x E ├Ч ((y : fst X) тЖТ inDec X y E тЖТ fst (U y)) тИетВБ
    construct (D , Deq) = PT.rec squashтВБ fromK getK
      where
      C : тДХ тЖТ (fst X тЖТ hProp тДУ-zero)
      C n y = ((D n y тЙб true) ├Ч (┬м fst (U y))) ,
              isProp├Ч (isSetBool _ _) (isProp╬а (╬╗ _ тЖТ isPropтКе))

      C-closed : (n : тДХ) тЖТ (y : fst X) тЖТ isClosedProp (C n y)
      C-closed n y = closedAnd ((D n y тЙб true) , isSetBool _ _) (┬мhProp (U y))
                     (Bool-equality-closed (D n y) true) (negOpenIsClosed (U y) (Uopen y))

      countInt-empty : (y : fst X) тЖТ ┬м fst (countableIntersectionClosed C y)
      countInt-empty y allCn = snd (allCn 0) (QxтКЖU y qxy)
        where
        qxy : fst (ConnectedComponent X x y)
        qxy = transport (sym (Deq y)) (╬╗ n тЖТ fst (allCn n))

      getK : тИе ╬г[ k тИИ тДХ ] ((y : fst X) тЖТ ┬м fst (finiteIntersectionClosed C k y)) тИетВБ
      getK = CHausFiniteIntersectionProperty X C C-closed countInt-empty

      finBoolAnd : тДХ тЖТ fst X тЖТ Bool
      finBoolAnd zero y = D zero y
      finBoolAnd (suc j) y = D (suc j) y and finBoolAnd j y

      and-true-l : (a b : Bool) тЖТ a and b тЙб true тЖТ a тЙб true
      and-true-l true  _ _ = refl
      and-true-l false _ p = p

      and-true-r : (a b : Bool) тЖТ a and b тЙб true тЖТ b тЙб true
      and-true-r true  _ p = p
      and-true-r false _ p = ex-falso (falseтЙвtrue p)

      build-finInt : (j : тДХ) (y : fst X)
        тЖТ finBoolAnd j y тЙб true тЖТ ┬м fst (U y) тЖТ fst (finiteIntersectionClosed C j y)
      build-finInt zero y p ┬мUy = p , ┬мUy
      build-finInt (suc j) y p ┬мUy =
        (and-true-l (D (suc j) y) (finBoolAnd j y) p , ┬мUy) ,
        build-finInt j y (and-true-r (D (suc j) y) (finBoolAnd j y) p) ┬мUy

      fromK : ╬г[ k тИИ тДХ ] ((y : fst X) тЖТ ┬м fst (finiteIntersectionClosed C k y))
        тЖТ тИе ╬г[ E тИИ DecSubsetCHaus X ] inDec X x E ├Ч ((y : fst X) тЖТ inDec X y E тЖТ fst (U y)) тИетВБ
      fromK (k , kEmpty) = тИг finBoolAnd k , x-in-E , E-sub-U тИгтВБ
        where
        x-in-all-D : (n : тДХ) тЖТ D n x тЙб true
        x-in-all-D = transport (Deq x) (╬╗ _ xInD тЖТ xInD)

        x-in-E : inDec X x (finBoolAnd k)
        x-in-E = go k
          where
          go : (j : тДХ) тЖТ finBoolAnd j x тЙб true
          go zero = x-in-all-D 0
          go (suc j) = congтВВ _and_ (x-in-all-D (suc j)) (go j)

        E-sub-U : (y : fst X) тЖТ inDec X y (finBoolAnd k) тЖТ fst (U y)
        E-sub-U y Ey = openIsStable mp (U y) (Uopen y) ┬м┬мUy
          where
          ┬м┬мUy : ┬м ┬м fst (U y)
          ┬м┬мUy ┬мUy = kEmpty y (build-finInt k y Ey ┬мUy)

