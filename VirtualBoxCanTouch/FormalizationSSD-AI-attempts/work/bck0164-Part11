  CompactHausdorffClosed-backward : (X : CHaus) (S : Stone)
    тЖТ (q : fst S тЖТ fst X) тЖТ isSurjection q
    тЖТ (B : fst S тЖТ hProp тДУ-zero) тЖТ ((s : fst S) тЖТ isClosedProp (B s))
    тЖТ (x : fst X) тЖТ isClosedProp (тИе ╬г[ s тИИ fst S ] fst (B s) ├Ч (q s тЙб x) тИетВБ , squashтВБ)
  CompactHausdorffClosed-backward X S q q-surj B B-closed x = InhabitedClosedSubSpaceClosed S AтВУ AтВУ-closed
    where
    open hasCHausStr (snd X)
    AтВУ : fst S тЖТ hProp тДУ-zero
    AтВУ s = (fst (B s) ├Ч (q s тЙб x)) , isProp├Ч (snd (B s)) (isSetX (q s) x)

    AтВУ-closed : (s : fst S) тЖТ isClosedProp (AтВУ s)
    AтВУ-closed s = closedAnd (B s) ((q s тЙб x) , isSetX (q s) x) (B-closed s) (equalityClosed (q s) x)

-- InhabitedClosedSubSpaceClosedCHaus (tex Corollary 1930)

module InhabitedClosedSubSpaceClosedCHausModule where
  open import Axioms.StoneDuality using (Stone; hasStoneStr)
  open import Cubical.Functions.Surjection using (isSurjection)
  open CompactHausdorffModule
  open InhabitedClosedSubSpaceClosedModule
  open StoneEqualityClosedModule

  InhabitedClosedSubSpaceClosedCHaus : (X : CHaus)
    тЖТ (A : fst X тЖТ hProp тДУ-zero) тЖТ ((x : fst X) тЖТ isClosedProp (A x))
    тЖТ isClosedProp (тИе ╬г[ x тИИ fst X ] fst (A x) тИетВБ , squashтВБ)
  InhabitedClosedSubSpaceClosedCHaus X A A-closed =
    PT.rec (isPropIsClosedProp {тИе ╬г[ x тИИ fst X ] fst (A x) тИетВБ , squashтВБ}) construct (hasCHausStr.stoneCover (snd X))
    where
    open hasCHausStr (snd X)

    construct : ╬г[ S тИИ Stone ] ╬г[ q тИИ (fst S тЖТ fst X) ] isSurjection q
              тЖТ isClosedProp (тИе ╬г[ x тИИ fst X ] fst (A x) тИетВБ , squashтВБ)
    construct (S , q , q-surj) = closedEquiv тИе╬гSBтИетВБ тИе╬гXAтИетВБ forward backward тИе╬гSBтИетВБ-closed
      where
      B : fst S тЖТ hProp тДУ-zero
      B s = A (q s)

      B-closed : (s : fst S) тЖТ isClosedProp (B s)
      B-closed s = A-closed (q s)

      тИе╬гSBтИетВБ : hProp тДУ-zero
      тИе╬гSBтИетВБ = тИе ╬г[ s тИИ fst S ] fst (B s) тИетВБ , squashтВБ

      тИе╬гSBтИетВБ-closed : isClosedProp тИе╬гSBтИетВБ
      тИе╬гSBтИетВБ-closed = InhabitedClosedSubSpaceClosed S B B-closed

      тИе╬гXAтИетВБ : hProp тДУ-zero
      тИе╬гXAтИетВБ = тИе ╬г[ x тИИ fst X ] fst (A x) тИетВБ , squashтВБ

      forward : fst тИе╬гSBтИетВБ тЖТ fst тИе╬гXAтИетВБ
      forward = PT.map (╬╗ { (s , Bs) тЖТ q s , Bs })

      backward : fst тИе╬гXAтИетВБ тЖТ fst тИе╬гSBтИетВБ
      backward = PT.rec squashтВБ (╬╗ { (x , Ax) тЖТ
        PT.map (╬╗ { (s , qsтЙбx) тЖТ s , subst (╬╗ y тЖТ fst (A y)) (sym qsтЙбx) Ax }) (q-surj x) })

