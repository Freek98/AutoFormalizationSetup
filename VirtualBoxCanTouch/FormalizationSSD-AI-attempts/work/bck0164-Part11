    isProp╬а (╬╗ D тЖТ isProp╬а (╬╗ _ тЖТ isSetBool (D y) true))

  private
    bool-eq : Bool тЖТ Bool тЖТ Bool
    bool-eq true  true  = true
    bool-eq true  false = false
    bool-eq false true  = false
    bool-eq false false = true

    bool-eq-refl : (b : Bool) тЖТ bool-eq b b тЙб true
    bool-eq-refl true  = refl
    bool-eq-refl false = refl

    bool-eq-eq : (a b : Bool) тЖТ bool-eq a b тЙб true тЖТ a тЙб b
