        (╬╗ s тЖТ (E n s тЙб true) , isSetBool _ _) (╬╗ s тЖТ Bool-equality-closed (E n s) true) y

      markov : (y : fst X) тЖТ (┬м ((n : тДХ) тЖТ fst (qE n y))) тЖФ тИе ╬г[ n тИИ тДХ ] (┬м fst (qE n y)) тИетВБ
      markov y = closedMarkovTex (╬╗ n тЖТ qE n y) (╬╗ n тЖТ qE-closed n y)

      open-char : (y : fst X) тЖТ fst (A y) тЙб тИе ╬г[ n тИИ тДХ ] (┬м fst (qE n y)) тИетВБ
      open-char y = hPropExt (snd (A y)) squashтВБ fwd bwd
        where
        fwd : fst (A y) тЖТ тИе ╬г[ n тИИ тДХ ] (┬м fst (qE n y)) тИетВБ
        fwd ay = fst (markov y) (╬╗ allqE тЖТ transport (sym (char y)) allqE ay)

