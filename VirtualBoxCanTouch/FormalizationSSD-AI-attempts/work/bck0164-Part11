module CompactHausdorffTopologyModule where
  open CompactHausdorffModule
  open CompactHausdorffClosedModule
  open ChausMapsPreserveIntersectionOfClosedModule
  open CHausFiniteIntersectionPropertyModule using (countableIntersectionClosed)
  open ClosedInStoneIsStoneModule using (closedFamilyChoice)
  open import Cubical.Functions.Surjection using (isSurjection)
  open import Axioms.StoneDuality using (Stone)
  open import Cubical.Data.Bool using (not; _and_)
  open import Cubical.Foundations.Function using (_тИШ_)
  open import Cubical.Foundations.Univalence using (hPropExt)
  open import Cubical.Data.Empty as тКе using (тКе)
  import Cubical.HITs.PropositionalTruncation as PT

  private
    -- Cumulative conjunction: DтВА тИз DтВБ тИз ... тИз D_n
    cumAnd : {A : TypeтВА} (D : тДХ тЖТ A тЖТ Bool) тЖТ тДХ тЖТ A тЖТ Bool
    cumAnd D zero s = D zero s
    cumAnd D (suc n) s = D (suc n) s and cumAnd D n s

    cumAnd-decr : {A : TypeтВА} (D : тДХ тЖТ A тЖТ Bool) (n : тДХ) (s : A)
      тЖТ cumAnd D (suc n) s тЙб true тЖТ cumAnd D n s тЙб true
    cumAnd-decr D n s eq with D (suc n) s
    ... | true = eq
    ... | false = тКе.rec (trueтЙвfalse (sym eq))

    cumAnd-extract : {A : TypeтВА} (D : тДХ тЖТ A тЖТ Bool) (n : тДХ) (s : A)
      тЖТ cumAnd D n s тЙб true тЖТ D n s тЙб true
    cumAnd-extract D zero s eq = eq
    cumAnd-extract D (suc n) s eq with D (suc n) s
    ... | true = refl
    ... | false = тКе.rec (trueтЙвfalse (sym eq))

    all-to-cumAnd : {A : TypeтВА} (D : тДХ тЖТ A тЖТ Bool) (n : тДХ) (s : A)
      тЖТ ((k : тДХ) тЖТ D k s тЙб true) тЖТ cumAnd D n s тЙб true
    all-to-cumAnd D zero s hyp = hyp zero
    all-to-cumAnd D (suc n) s hyp =
      subst (╬╗ b тЖТ b and cumAnd D n s тЙб true) (sym (hyp (suc n)))
        (all-to-cumAnd D n s hyp)

  -- Closed characterization: backward direction
  -- If A = тИй_n q(D_n) for decidable D_n, then A is closed
  CHTopClosed-backward : (X : CHaus) (S : Stone)
    тЖТ (q : fst S тЖТ fst X) тЖТ isSurjection q
    тЖТ (D : тДХ тЖТ fst S тЖТ Bool) тЖТ (y : fst X)
    тЖТ isClosedProp (((n : тДХ) тЖТ тИе ╬г[ s тИИ fst S ] (D n s тЙб true) ├Ч (q s тЙб y) тИетВБ) ,
                    isProp╬а (╬╗ _ тЖТ squashтВБ))
  CHTopClosed-backward X S q q-surj D y = closedCountableIntersection
    (╬╗ n тЖТ тИе ╬г[ s тИИ fst S ] (D n s тЙб true) ├Ч (q s тЙб y) тИетВБ , squashтВБ)
    (╬╗ n тЖТ CompactHausdorffClosed-backward X S q q-surj
      (╬╗ s тЖТ (D n s тЙб true) , isSetBool _ _) (╬╗ s тЖТ Bool-equality-closed (D n s) true) y)

  -- Closed characterization: forward direction
  -- If A is closed, then тИГ D_n decidable with A(y) тЙб тИй_n q(D_n)(y)
  CHTopClosed-forward : (X : CHaus) (S : Stone)
    тЖТ (q : fst S тЖТ fst X) тЖТ isSurjection q
    тЖТ (A : fst X тЖТ hProp тДУ-zero) тЖТ ((x : fst X) тЖТ isClosedProp (A x))
    тЖТ тИе ╬г[ D тИИ (тДХ тЖТ fst S тЖТ Bool) ]
         ((y : fst X) тЖТ fst (A y) тЙб ((n : тДХ) тЖТ тИе ╬г[ s тИИ fst S ] (D n s тЙб true) ├Ч (q s тЙб y) тИетВБ)) тИетВБ
  CHTopClosed-forward X S q q-surj A A-closed =
    PT.rec squashтВБ (╬╗ w тЖТ тИг construct w тИгтВБ) (closedFamilyChoice S A' A'-closed)
    where
    A' : fst S тЖТ hProp тДУ-zero
    A' s = A (q s)

    A'-closed : (s : fst S) тЖТ isClosedProp (A' s)
    A'-closed s = A-closed (q s)

    construct : ((s : fst S) тЖТ ╬г[ ╬▒ тИИ binarySequence ] fst (A' s) тЖФ ((n : тДХ) тЖТ ╬▒ n тЙб false))
              тЖТ ╬г[ D тИИ (тДХ тЖТ fst S тЖТ Bool) ]
                  ((y : fst X) тЖТ fst (A y) тЙб ((n : тДХ) тЖТ тИе ╬г[ s тИИ fst S ] (D n s тЙб true) ├Ч (q s тЙб y) тИетВБ))
    construct witness = E , characterization
      where
      ╬▒ : fst S тЖТ binarySequence
      ╬▒ s = fst (witness s)

      ╬▒-fwd : (s : fst S) тЖТ fst (A (q s)) тЖТ (n : тДХ) тЖТ ╬▒ s n тЙб false
      ╬▒-fwd s = fst (snd (witness s))

      ╬▒-bwd : (s : fst S) тЖТ ((n : тДХ) тЖТ ╬▒ s n тЙб false) тЖТ fst (A (q s))
      ╬▒-bwd s = snd (snd (witness s))

      -- D_n(s) = not(╬▒(s,n)), so D_n(s) = true тЖФ ╬▒(s,n) = false
      D : тДХ тЖТ fst S тЖТ Bool
      D n s = not (╬▒ s n)

      D-trueтЖТ╬▒-false : (n : тДХ) (s : fst S) тЖТ D n s тЙб true тЖТ ╬▒ s n тЙб false
      D-trueтЖТ╬▒-false n s eq with ╬▒ s n
      ... | false = refl
      ... | true = тКе.rec (trueтЙвfalse (sym eq))

      ╬▒-falseтЖТD-true : (n : тДХ) (s : fst S) тЖТ ╬▒ s n тЙб false тЖТ D n s тЙб true
      ╬▒-falseтЖТD-true n s eq with ╬▒ s n
      ... | false = refl
      ... | true = тКе.rec (trueтЙвfalse eq)

      -- Output: cumulative intersection (decreasing and decidable)
      E : тДХ тЖТ fst S тЖТ Bool
      E = cumAnd D

      -- hProp version for CMPIC
      G : тДХ тЖТ (fst S тЖТ hProp тДУ-zero)
      G n s = (E n s тЙб true) , isSetBool _ _

      G-closed : (n : тДХ) тЖТ (s : fst S) тЖТ isClosedProp (G n s)
      G-closed n s = Bool-equality-closed (E n s) true

      G-decr : isDecreasingSeq G
      G-decr n s = cumAnd-decr D n s

      -- тИй_n G_n(s) тЖФ A'(s)
      countGтЖТA' : (s : fst S) тЖТ ((n : тДХ) тЖТ fst (G n s)) тЖТ fst (A' s)
      countGтЖТA' s hyp = ╬▒-bwd s (╬╗ n тЖТ D-trueтЖТ╬▒-false n s (cumAnd-extract D n s (hyp n)))

      A'тЖТcountG : (s : fst S) тЖТ fst (A' s) тЖТ (n : тДХ) тЖТ fst (G n s)
      A'тЖТcountG s a's n = all-to-cumAnd D n s (╬╗ k тЖТ ╬▒-falseтЖТD-true k s (╬▒-fwd s a's k))

      -- A(y) тЖТ imageSubset q (тИй_n G) y
      AтЖТimg : (y : fst X) тЖТ fst (A y)
        тЖТ fst (imageSubset q (countableIntersectionClosed G) y)
      AтЖТimg y ay = PT.rec squashтВБ
        (╬╗ (s , qsтЙбy) тЖТ тИг s , A'тЖТcountG s (subst (fst тИШ A) (sym qsтЙбy) ay) , qsтЙбy тИгтВБ)
        (q-surj y)

      -- imageSubset q (тИй_n G) y тЖТ A(y)
      imgтЖТA : (y : fst X) тЖТ fst (imageSubset q (countableIntersectionClosed G) y) тЖТ fst (A y)
      imgтЖТA y = PT.rec (snd (A y))
        (╬╗ (s , allG , qsтЙбy) тЖТ subst (fst тИШ A) qsтЙбy (countGтЖТA' s allG))

      -- CMPIC: q(тИй_n G) = тИй_n q(G_n)
      cmpic : (y : fst X)
        тЖТ fst (imageSubset q (countableIntersectionClosed G) y)
          тЙб fst (countableIntersectionClosed (╬╗ n тЖТ imageSubset q (G n)) y)
      cmpic = ChausMapsPreserveIntersectionOfClosed (StoneтЖТCHaus S) X q G G-closed G-decr

      characterization : (y : fst X) тЖТ fst (A y)
        тЙб ((n : тДХ) тЖТ тИе ╬г[ s тИИ fst S ] (E n s тЙб true) ├Ч (q s тЙб y) тИетВБ)
      characterization y = hPropExt (snd (A y)) (isProp╬а (╬╗ _ тЖТ squashтВБ))
        (╬╗ ay тЖТ transport (cmpic y) (AтЖТimg y ay))
        (╬╗ hyp тЖТ imgтЖТA y (transport (sym (cmpic y)) hyp))

  -- Open characterization: backward direction
  -- If A = тИк_n ┬мq(D_n) for decidable D_n, then A is open
  CHTopOpen-backward : (X : CHaus) (S : Stone)
    тЖТ (q : fst S тЖТ fst X) тЖТ isSurjection q
    тЖТ (D : тДХ тЖТ fst S тЖТ Bool) тЖТ (y : fst X)
    тЖТ isOpenProp (тИе ╬г[ n тИИ тДХ ] (┬м тИе ╬г[ s тИИ fst S ] (D n s тЙб true) ├Ч (q s тЙб y) тИетВБ) тИетВБ , squashтВБ)
  CHTopOpen-backward X S q q-surj D y = openCountableUnion
    (╬╗ n тЖТ (┬м тИе ╬г[ s тИИ fst S ] (D n s тЙб true) ├Ч (q s тЙб y) тИетВБ) , isProp╬а (╬╗ _ тЖТ isPropтКе))
    (╬╗ n тЖТ PT.rec squashтВБ
      (╬╗ (╬▓ , fwd , bwd) тЖТ negClosedIsOpen mp
        (тИе ╬г[ s тИИ fst S ] (D n s тЙб true) ├Ч (q s тЙб y) тИетВБ , squashтВБ) ╬▓ (fwd , bwd))
      (CompactHausdorffClosed-backward X S q q-surj
        (╬╗ s тЖТ (D n s тЙб true) , isSetBool _ _) (╬╗ s тЖТ Bool-equality-closed (D n s) true) y))

  -- Open characterization: forward direction
  -- If A is open, then тИГ D_n decidable with A(y) тЙб тИк_n ┬мq(D_n)(y)
  CHTopOpen-forward : (X : CHaus) (S : Stone)
    тЖТ (q : fst S тЖТ fst X) тЖТ isSurjection q
    тЖТ (A : fst X тЖТ hProp тДУ-zero) тЖТ ((x : fst X) тЖТ isOpenProp (A x))
    тЖТ тИе ╬г[ D тИИ (тДХ тЖТ fst S тЖТ Bool) ]
         ((y : fst X) тЖТ fst (A y) тЙб тИе ╬г[ n тИИ тДХ ] (┬м тИе ╬г[ s тИИ fst S ] (D n s тЙб true) ├Ч (q s тЙб y) тИетВБ) тИетВБ) тИетВБ
  CHTopOpen-forward X S q q-surj A A-open =
    PT.rec squashтВБ open-construct (CHTopClosed-forward X S q q-surj ┬мA ┬мA-closed)
    where
    ┬мA : fst X тЖТ hProp тДУ-zero
    ┬мA x = ┬мhProp (A x)

    ┬мA-closed : (x : fst X) тЖТ isClosedProp (┬мA x)
    ┬мA-closed x = negOpenIsClosed (A x) (A-open x)

    open-construct : ╬г[ E тИИ (тДХ тЖТ fst S тЖТ Bool) ]
                       ((y : fst X) тЖТ (┬м fst (A y)) тЙб ((n : тДХ) тЖТ тИе ╬г[ s тИИ fst S ] (E n s тЙб true) ├Ч (q s тЙб y) тИетВБ))
                   тЖТ тИе ╬г[ D тИИ (тДХ тЖТ fst S тЖТ Bool) ]
                       ((y : fst X) тЖТ fst (A y) тЙб тИе ╬г[ n тИИ тДХ ] (┬м тИе ╬г[ s тИИ fst S ] (D n s тЙб true) ├Ч (q s тЙб y) тИетВБ) тИетВБ) тИетВБ
