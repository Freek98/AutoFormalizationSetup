module StoneSigmaClosedModule where
  open import Axioms.StoneDuality using (Stone; hasStoneStr)
  open CompactHausdorffModule
  open SigmaCompactHausdorffModule
  open StoneCompactHausdorffTotallyDisconnectedModule
  open ConnectedComponentModule
  open ConnectedComponentConnectedModule

  SigmaStoneType : (S : Stone) тЖТ (T : fst S тЖТ Stone) тЖТ TypeтВА
  SigmaStoneType S T = ╬г[ x тИИ fst S ] fst (T x)

  ╬гStoneCHaus : (S : Stone) тЖТ (T : fst S тЖТ Stone) тЖТ CHaus
  ╬гStoneCHaus S T = CHaus╬г (StoneтЖТCHaus S) (╬╗ x тЖТ StoneтЖТCHaus (T x))

  projтВБ-preserves-CC : (S : Stone) (T : fst S тЖТ Stone)
    тЖТ (x : fst S) (y : fst (T x)) (x' : fst S) (y' : fst (T x'))
    тЖТ fst (ConnectedComponent (╬гStoneCHaus S T) (x , y) (x' , y'))
    тЖТ fst (ConnectedComponent (StoneтЖТCHaus S) x x')
  projтВБ-preserves-CC S T x y x' y' cc╧Г D xInD = cc╧Г (╬╗ (a , b) тЖТ D a) xInD

  -- Proof of ╬гStone-isTotallyDisconnected following tex Theorem 2214
  ╬гStone-isTotallyDisconnected : (S : Stone) (T : fst S тЖТ Stone)
    тЖТ isTotallyDisconnected (╬гStoneCHaus S T)
  ╬гStone-isTotallyDisconnected S T (x , y) (x' , y') cc╧Г = goal
    where
    x'InQx : fst (ConnectedComponent (StoneтЖТCHaus S) x x')
    x'InQx = projтВБ-preserves-CC S T x y x' y' cc╧Г

    xтЙбx' : x тЙб x'
    xтЙбx' = StoneCompactHausdorffTotallyDisconnected-forward S x x' x'InQx

    y'-in-Tx : fst (T x)
    y'-in-Tx = subst (╬╗ z тЖТ fst (T z)) (sym xтЙбx') y'

    Q╧Г : TypeтВА
    Q╧Г = ╬г[ p тИИ SigmaStoneType S T ] fst (ConnectedComponent (╬гStoneCHaus S T) (x , y) p)

    xy-in-Q╧Г : Q╧Г
    xy-in-Q╧Г = (x , y) , ╬╗ D xInD тЖТ xInD

    x'y'-in-Q╧Г : Q╧Г
    x'y'-in-Q╧Г = (x' , y') , cc╧Г

    make-f : (g : fst (T x) тЖТ Bool) тЖТ Q╧Г тЖТ Bool
    make-f g ((a , b) , cc) = g (subst (╬╗ z тЖТ fst (T z))
      (sym (StoneCompactHausdorffTotallyDisconnected-forward S x a
            (projтВБ-preserves-CC S T x y a b cc))) b)

    f-constant : (g : fst (T x) тЖТ Bool) тЖТ make-f g xy-in-Q╧Г тЙб make-f g x'y'-in-Q╧Г
    f-constant g = ConnectedComponentConnected (╬гStoneCHaus S T) (x , y) (make-f g) xy-in-Q╧Г x'y'-in-Q╧Г

    isSetS : isSet (fst S)
    isSetS = StoneEqualityClosedModule.hasStoneStrтЖТisSet S

    p_x : x тЙб x
    p_x = StoneCompactHausdorffTotallyDisconnected-forward S x x
          (projтВБ-preserves-CC S T x y x y (╬╗ D xInD тЖТ xInD))

    p_x' : x тЙб x'
    p_x' = StoneCompactHausdorffTotallyDisconnected-forward S x x'
           (projтВБ-preserves-CC S T x y x' y' cc╧Г)

    make-f-xy : (g : fst (T x) тЖТ Bool) тЖТ make-f g xy-in-Q╧Г тЙб g y
    make-f-xy g =
      make-f g xy-in-Q╧Г
        тЙбтЯи cong (╬╗ p тЖТ g (subst (╬╗ z тЖТ fst (T z)) (sym p) y)) (isSetS x x p_x refl) тЯй
      g (transport refl y)
        тЙбтЯи cong g (transportRefl y) тЯй
      g y тИО

    make-f-x'y' : (g : fst (T x) тЖТ Bool) тЖТ make-f g x'y'-in-Q╧Г тЙб g y'-in-Tx
    make-f-x'y' g = cong (╬╗ p тЖТ g (subst (╬╗ z тЖТ fst (T z)) (sym p) y')) (isSetS x x' p_x' xтЙбx')

    g-agrees : (g : fst (T x) тЖТ Bool) тЖТ g y тЙб g y'-in-Tx
    g-agrees g =
      g y
        тЙбтЯи sym (make-f-xy g) тЯй
      make-f g xy-in-Q╧Г
        тЙбтЯи f-constant g тЯй
      make-f g x'y'-in-Q╧Г
        тЙбтЯи make-f-x'y' g тЯй
      g y'-in-Tx тИО

    yтЙбy'-in-Tx : y тЙб y'-in-Tx
    yтЙбy'-in-Tx = StoneCompactHausdorffTotallyDisconnected-forward (T x) y y'-in-Tx
      (╬╗ D yInD тЖТ sym (g-agrees D) тИЩ yInD)

    goal : (x , y) тЙб (x' , y')
    goal = ╬гPathP (xтЙбx' , toPathP (cong (subst (╬╗ z тЖТ fst (T z)) xтЙбx') yтЙбy'-in-Tx
              тИЩ transportTransportтБ╗ (cong (╬╗ z тЖТ fst (T z)) xтЙбx') y'))

  StoneSigmaClosed : (S : Stone) (T : fst S тЖТ Stone)
    тЖТ hasStoneStr (SigmaStoneType S T)
