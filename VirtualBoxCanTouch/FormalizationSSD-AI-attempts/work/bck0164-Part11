              ((w : fst X) тЖТ fst (ConnectedComponent X x w) тЙб ((n : тДХ) тЖТ inDec X w (D n)))
            тЖТ fval тЙб f (a , qa)
      step1 (D , Deq) = PT.rec (isSetBool fval (f (a , qa))) step2
        (CHausSeperationOfClosedByOpens X A_X B_X A-closed B-closed AB-disjoint)
        where
        Qx-closed : (w : fst X) тЖТ isClosedProp (ConnectedComponent X x w)
        Qx-closed w = closedEquiv
          (((n : тДХ) тЖТ D n w тЙб true) , isProp╬а (╬╗ n тЖТ isSetBool (D n w) true))
          (ConnectedComponent X x w)
          (transport (sym (Deq w)))
          (transport (Deq w))
          (closedCountableIntersection (╬╗ n тЖТ (D n w тЙб true) , isSetBool (D n w) true)
            (╬╗ n тЖТ Bool-equality-closed (D n w) true))
        A_X : fst X тЖТ hProp тДУ-zero
        A_X w = тИе ╬г[ q тИИ fst (ConnectedComponent X x w) ] (f (w , q) тЙб fval) тИетВБ , squashтВБ
        A-closed : (w : fst X) тЖТ isClosedProp (A_X w)
        A-closed w = closedSigmaClosed-derived (ConnectedComponent X x w) (Qx-closed w)
          (╬╗ q тЖТ (f (w , q) тЙб fval) , isSetBool (f (w , q)) fval)
          (╬╗ q тЖТ Bool-equality-closed (f (w , q)) fval)
        B_X : fst X тЖТ hProp тДУ-zero
        B_X w = тИе ╬г[ q тИИ fst (ConnectedComponent X x w) ] (f (w , q) тЙб not fval) тИетВБ , squashтВБ
        B-closed : (w : fst X) тЖТ isClosedProp (B_X w)
        B-closed w = closedSigmaClosed-derived (ConnectedComponent X x w) (Qx-closed w)
          (╬╗ q тЖТ (f (w , q) тЙб not fval) , isSetBool (f (w , q)) (not fval))
