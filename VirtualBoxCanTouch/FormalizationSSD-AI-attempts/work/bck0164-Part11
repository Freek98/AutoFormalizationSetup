              тЙбтЯи sym (CRS.┬╖Assoc s t (fJ d N)) тЯй
            s ┬╖B (t ┬╖B fJ d N)
              тЙбтЯи cong (s ┬╖B_) p тЯй
            s ┬╖B t
              тЙбтЯи sym r=st тЯй
            r тИО)

        -- BoolHom preserves тИи
        boolhom-тИи : (x : Sp B╧Й) (a b : тЯи B тЯй) тЖТ fst x (a тИиB b) тЙб fst x a тИиBool fst x b
        boolhom-тИи x a b =
          let _+S_ = CommRingStr._+_ (snd (BooleanRingтЖТCommRing BoolBR))
          in fst x (a тИиB b)
            тЙбтЯи IsCommRingHom.pres+ (snd x) (a +B b) (a ┬╖B b) тЯй
          fst x (a +B b) +S fst x (a ┬╖B b)
            тЙбтЯи congтВВ _+S_ (IsCommRingHom.pres+ (snd x) a b) (IsCommRingHom.pres┬╖ (snd x) a b) тЯй
          fst x a тИиBool fst x b тИО

        -- If all d(k) for k<N map to false, then fJ d N maps to false
        finJoin-false : (x : Sp B╧Й) (N : тДХ) тЖТ ((k : тДХ) тЖТ k < N тЖТ fst x (d k) тЙб false)
                      тЖТ fst x (fJ d N) тЙб false
        finJoin-false x zero _ = IsCommRingHom.pres0 (snd x)
        finJoin-false x (suc n) h =
          fst x (d n тИиB fJ d n)
            тЙбтЯи boolhom-тИи x (d n) (fJ d n) тЯй
          fst x (d n) тИиBool fst x (fJ d n)
            тЙбтЯи congтВВ _тИиBool_ (h n тЙд-refl) (finJoin-false x n (╬╗ k k<n тЖТ h k (тЙд-suc k<n))) тЯй
          false тИО

        -- Max of first coordinates of dec(0),...,dec(N-1)
        maxFst : тДХ тЖТ тДХ
        maxFst zero = 0
        maxFst (suc k) = max (fst (dec k)) (maxFst k)

        open import Cubical.Data.Nat.Properties using (+-suc)

        maxFst-bound : (N k : тДХ) тЖТ k < N тЖТ fst (dec k) тЙд maxFst N
        maxFst-bound zero k (j , p) = тКе.rec (snotz (sym (+-suc j k) тИЩ p))
        maxFst-bound (suc N) k k<sN with pred-тЙд-pred k<sN
        ... | (zero , p) = subst (╬╗ j тЖТ fst (dec j) тЙд maxFst (suc N)) (sym p) (left-тЙд-max {fst (dec N)} {maxFst N})
        ... | (suc j , p) = тЙд-trans (maxFst-bound N k (j , +-suc j k тИЩ p)) (right-тЙд-max {maxFst N} {fst (dec N)})

        -- From isInIdeal 1, construct the finite bound
        fromIdealMem : isInIdeal R d CRS.1r
                     тЖТ тИе ╬г[ k тИИ тДХ ] ((x : fst X) тЖТ ┬м fst (finiteIntersectionClosed C k x)) тИетВБ
        fromIdealMem iI = тИг K , conclusion тИгтВБ
          where
          N = fst (idealBound iI)
          fJ-eq : fJ d N тЙб ЁЭЯЩB
          fJ-eq =
            fJ d N        тЙбтЯи sym (CRS.┬╖IdL (fJ d N)) тЯй
            ЁЭЯЩB ┬╖B fJ d N тЙбтЯи snd (idealBound iI) тЯй
            ЁЭЯЩB тИО

          K : тДХ
          K = maxFst N

          conclusion : (x : fst X) тЖТ ┬м fst (finiteIntersectionClosed C K x)
          conclusion x finK =
            PT.rec isPropтКе (╬╗ { (s , qsтЙбx) тЖТ contradiction s qsтЙбx }) (q-surj x)
            where
            contradiction : (s : fst S) тЖТ q s тЙб x тЖТ тКе
            contradiction s qsтЙбx = trueтЙвfalse contra
              where
              x' : Sp B╧Й
              x' = transport (sym SpBтЙбS) s

              x'-has-Cn : (n : тДХ) тЖТ n тЙд K тЖТ fst (C n (q s))
              x'-has-Cn n nтЙдK = allC C K (q s) (subst (╬╗ y тЖТ fst (finiteIntersectionClosed C K y)) (sym qsтЙбx) finK) n nтЙдK

              x'-d-false : (k : тДХ) тЖТ k < N тЖТ fst x' (d k) тЙб false
              x'-d-false k k<N =
                let nтВА = fst (dec k)
                    mтВА = snd (dec k)
                    nтВАтЙдK : nтВА тЙд K
                    nтВАтЙдK = maxFst-bound N k k<N
                    cnтВА : fst (C nтВА (q s))
                    cnтВА = x'-has-Cn nтВА nтВАтЙдK
                    all-false : (m : тДХ) тЖТ fst (wit nтВА s) m тЙб false
                    all-false = fst (snd (wit nтВА s)) cnтВА
                in fst x' (d k)
                  тЙбтЯи elem-prop nтВА mтВА x' тЯй
                ╬▒-pred nтВА mтВА x'
                  тЙбтЯи cong (╬╗ z тЖТ fst (wit nтВА z) mтВА) (transportTransportтБ╗ SpBтЙбS s) тЯй
                fst (wit nтВА s) mтВА
                  тЙбтЯи all-false mтВА тЯй
