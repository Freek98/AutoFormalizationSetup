      impl-open : (b : fst S тЖТ Bool) (s t : fst S)
        тЖТ isOpenProp ((q s тЙб q t тЖТ b s тЙб b t) , isProp╬а (╬╗ _ тЖТ isSetBool (b s) (b t)))
      impl-open b s t = closedImplDecIsOpen
