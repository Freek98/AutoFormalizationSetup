    where
    open hasCHausStr (snd X) renaming (isSetX to isSetXbase; equalityClosed to X-eq-cl; stoneCover to X-sc)

    isSet╬гXY : isSet (SigmaCHausType X Y)
    isSet╬гXY = isSet╬г isSetXbase (╬╗ x тЖТ hasCHausStr.isSetX (snd (Y x)))

    -- Equality in ╬г X Y is closed (tex ClosedDependentSums 1785)
    ╧Г-eq-closed : (╧ГтВБ ╧ГтВВ : SigmaCHausType X Y)
      тЖТ isClosedProp ((╧ГтВБ тЙб ╧ГтВВ) , isSet╬гXY ╧ГтВБ ╧ГтВВ)
    ╧Г-eq-closed (xтВБ , yтВБ) (xтВВ , yтВВ) =
      closedEquiv
        (тИе ╬г[ p тИИ xтВБ тЙб xтВВ ] PathP (╬╗ i тЖТ fst (Y (p i))) yтВБ yтВВ тИетВБ , squashтВБ)
        (((xтВБ , yтВБ) тЙб (xтВВ , yтВВ)) , isSet╬гXY (xтВБ , yтВБ) (xтВВ , yтВВ))
        (PT.rec (isSet╬гXY _ _) (╬╗ { (p , q) тЖТ ╬гPathP (p , q) }))
        (╬╗ eq тЖТ тИг cong fst eq , cong snd eq тИгтВБ)
        trunc-sigma-closed
      where
      eq-x-closed : isClosedProp ((xтВБ тЙб xтВВ) , isSetXbase xтВБ xтВВ)
      eq-x-closed = X-eq-cl xтВБ xтВВ

      pathP-closed : (p : xтВБ тЙб xтВВ) тЖТ isClosedProp (PathP (╬╗ i тЖТ fst (Y (p i))) yтВБ yтВВ ,
                       isOfHLevelPathP' 1 (hasCHausStr.isSetX (snd (Y xтВВ))) yтВБ yтВВ)
      pathP-closed p = closedEquiv
        ((subst (╬╗ z тЖТ fst (Y z)) p yтВБ тЙб yтВВ) , hasCHausStr.isSetX (snd (Y xтВВ)) _ _)
        (PathP (╬╗ i тЖТ fst (Y (p i))) yтВБ yтВВ ,
         isOfHLevelPathP' 1 (hasCHausStr.isSetX (snd (Y xтВВ))) yтВБ yтВВ)
        toPathP fromPathP
        (hasCHausStr.equalityClosed (snd (Y xтВВ)) (subst (╬╗ z тЖТ fst (Y z)) p yтВБ) yтВВ)

      trunc-sigma-closed : isClosedProp (тИе ╬г[ p тИИ xтВБ тЙб xтВВ ] PathP (╬╗ i тЖТ fst (Y (p i))) yтВБ yтВВ тИетВБ , squashтВБ)
      trunc-sigma-closed = closedSigmaClosed-derived
        ((xтВБ тЙб xтВВ) , isSetXbase xтВБ xтВВ) eq-x-closed
        (╬╗ p тЖТ PathP (╬╗ i тЖТ fst (Y (p i))) yтВБ yтВВ ,
               isOfHLevelPathP' 1 (hasCHausStr.isSetX (snd (Y xтВВ))) yтВБ yтВВ)
        pathP-closed

    -- Stone cover of ╬г X Y (tex proof of Lemma 2098)
    -- Uses localChoice with TypeтВА encoding of closed subsets (binary sequences)
    ╧Г-stoneCover : тИе ╬г[ S тИИ Stone ] ╬г[ q тИИ (fst S тЖТ SigmaCHausType X Y) ] isSurjection q тИетВБ
    ╧Г-stoneCover = PT.rec squashтВБ build-cover X-sc
      where
      build-cover : ╬г[ S тИИ Stone ] ╬г[ q тИИ (fst S тЖТ fst X) ] isSurjection q
        тЖТ тИе ╬г[ S' тИИ Stone ] ╬г[ q' тИИ (fst S' тЖТ SigmaCHausType X Y) ] isSurjection q' тИетВБ
      build-cover (S_X , q_X , surj_X) =
        PT.rec squashтВБ build-from-lc
          (localChoice-axiom (fst (snd S_X)) P' P'-all)
        where
        p_X : Sp (fst (snd S_X)) тЙб fst S_X
        p_X = snd (snd S_X)

        -- TypeтВА encoding: binary sequence per Cantor point + surjection to Y(q_X s)
        FiberData : fst S_X тЖТ TypeтВА
        FiberData s = ╬г[ enc тИИ (CantorSpace тЖТ binarySequence) ]
                      ╬г[ f тИИ ((╬г[ ╬│ тИИ CantorSpace ] ((n : тДХ) тЖТ enc ╬│ n тЙб false)) тЖТ fst (Y (q_X s))) ]
                      isSurjection f

        FiberData-all : (s : fst S_X) тЖТ тИе FiberData s тИетВБ
        FiberData-all s = PT.rec squashтВБ step1 (hasCHausStr.stoneCover (snd (Y (q_X s))))
          where
          step1 : ╬г[ T тИИ Stone ] ╬г[ r тИИ (fst T тЖТ fst (Y (q_X s))) ] isSurjection r
                тЖТ тИе FiberData s тИетВБ
          step1 (T_s , r_s , surj_s) = PT.rec squashтВБ step2 (StoneтЖТClosedInCantor T_s)
            where
            step2 : ╬г[ A тИИ ClosedSubsetOfCantor ] (fst T_s тЙГ (╬г[ ╬│ тИИ CantorSpace ] fst (fst A ╬│)))
                  тЖТ тИе FiberData s тИетВБ
            step2 (A , equiv) = PT.map step3
              (closedFamilyChoice (CantorSpace , CantorIsStone) (fst A) (snd A))
              where
              step3 : ((╬│ : CantorSpace) тЖТ ╬г[ ╬▓ тИИ binarySequence ] fst (fst A ╬│) тЖФ ((n : тДХ) тЖТ ╬▓ n тЙб false))
                    тЖТ FiberData s
              step3 witness = enc , g , g-surj
                where
                enc : CantorSpace тЖТ binarySequence
                enc ╬│ = fst (witness ╬│)
                toA : (╬│ : CantorSpace) тЖТ ((n : тДХ) тЖТ enc ╬│ n тЙб false) тЖТ fst (fst A ╬│)
                toA ╬│ = snd (snd (witness ╬│))
                fromA : (╬│ : CantorSpace) тЖТ fst (fst A ╬│) тЖТ ((n : тДХ) тЖТ enc ╬│ n тЙб false)
                fromA ╬│ = fst (snd (witness ╬│))
                g : (╬г[ ╬│ тИИ CantorSpace ] ((n : тДХ) тЖТ enc ╬│ n тЙб false)) тЖТ fst (Y (q_X s))
                g (╬│ , prf) = r_s (invEq equiv (╬│ , toA ╬│ prf))
                g-surj : isSurjection g
                g-surj y = PT.map (╬╗ { (t , rtтЙбy) тЖТ
                  let ╬│' = fst (equivFun equiv t)
                      a = snd (equivFun equiv t)
                  in (╬│' , fromA ╬│' a) ,
                    (r_s (invEq equiv (╬│' , toA ╬│' (fromA ╬│' a)))
                      тЙбтЯи cong (╬╗ z тЖТ r_s (invEq equiv (╬│' , z))) (snd (fst A ╬│') _ _) тЯй
                     r_s (invEq equiv (equivFun equiv t))
                      тЙбтЯи cong r_s (retEq equiv t) тЯй
                     r_s t
                      тЙбтЯи rtтЙбy тЯй
                     y тИО)
                  }) (surj_s y)

        P' : Sp (fst (snd S_X)) тЖТ TypeтВА
        P' h = FiberData (transport p_X h)

        P'-all : (h : Sp (fst (snd S_X))) тЖТ тИе P' h тИетВБ
        P'-all h = FiberData-all (transport p_X h)

        build-from-lc :
          ╬г[ Dlc тИИ Boole╧Й ] ╬г[ ╧Ж тИИ (Sp Dlc тЖТ Sp (fst (snd S_X))) ]
            (isSurjectiveSpMap {fst (snd S_X)} {Dlc} ╧Ж ├Ч ((t : Sp Dlc) тЖТ P' (╧Ж t)))
          тЖТ тИе ╬г[ S' тИИ Stone ] ╬г[ q' тИИ (fst S' тЖТ SigmaCHausType X Y) ] isSurjection q' тИетВБ
        build-from-lc (Dlc , ╧Ж , surj╧Ж , datT) =
          тИг total-Stone , total-map , total-surj тИгтВБ
          where
          qT : Sp Dlc тЖТ fst S_X
          qT t = transport p_X (╧Ж t)

          enc-of : (t : Sp Dlc) тЖТ CantorSpace тЖТ binarySequence
          enc-of t = fst (datT t)

          f-of : (t : Sp Dlc) тЖТ (╬г[ ╬│ тИИ CantorSpace ] ((n : тДХ) тЖТ enc-of t ╬│ n тЙб false))
               тЖТ fst (Y (q_X (qT t)))
          f-of t = fst (snd (datT t))

          surj-f : (t : Sp Dlc) тЖТ isSurjection (f-of t)
          surj-f t = snd (snd (datT t))

          SpDlc-Stone : Stone
          SpDlc-Stone = Sp Dlc , Dlc , refl

          product-Stone : Stone
          product-Stone = Sp Dlc ├Ч CantorSpace , StoneProduct SpDlc-Stone (CantorSpace , CantorIsStone)

          C-pred : Sp Dlc ├Ч CantorSpace тЖТ hProp тДУ-zero
          C-pred (t , ╬│) = ((n : тДХ) тЖТ enc-of t ╬│ n тЙб false) , isProp╬а (╬╗ _ тЖТ isSetBool _ _)

          C-closed : (p : Sp Dlc ├Ч CantorSpace) тЖТ isClosedProp (C-pred p)
