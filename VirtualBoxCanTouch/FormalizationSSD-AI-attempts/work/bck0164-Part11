          where
          UV : fst X тЖТ hProp тДУ-zero
          UV w = тИе fst (U w) тКО fst (V w) тИетВБ , squashтВБ
          UV-open : (w : fst X) тЖТ isOpenProp (UV w)
          UV-open w = openOrMP mp (U w) (V w) (Uopen w) (Vopen w)
          QxтКЖUV : (w : fst X) тЖТ fst (ConnectedComponent X x w) тЖТ fst (UV w)
          QxтКЖUV w qw with Bool-dichotomy (f (w , qw)) fval
          ... | тКО.inl p = тИг тКО.inl (AтКЖU w тИг qw , p тИгтВБ) тИгтВБ
          ... | тКО.inr p = тИг тКО.inr (BтКЖV w тИг qw , p тИгтВБ) тИгтВБ
          step3 : ╬г[ E тИИ DecSubsetCHaus X ] inDec X x E ├Ч
                  ((w : fst X) тЖТ inDec X w E тЖТ fst (UV w))
                тЖТ fval тЙб f (a , qa)
          step3 (E , x-in-E , EтКЖUV) = conclusion
            where
