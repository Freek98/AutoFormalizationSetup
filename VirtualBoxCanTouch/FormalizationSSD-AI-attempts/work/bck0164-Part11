    тЖТ тИе has-Boole-╧Й' (2^ (fst X)) тИетВБ
  AlgebraCompactHausdorffCountablyPresented X =
    PT.rec squashтВБ go (hasCHausStr.stoneCover (snd X))
    where
    go : ╬г[ S тИИ Stone ] ╬г[ q тИИ (fst S тЖТ fst X) ] isSurjection q
       тЖТ тИе has-Boole-╧Й' (2^ (fst X)) тИетВБ
    go (S , q , q-surj) = ODiscBAareBoole (2^ (fst X)) 2^X-isODisc
      where
