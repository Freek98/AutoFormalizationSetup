        Iso.sec step3-iso = step3-forwardтИШbackward
        Iso.ret step3-iso = step3-backwardтИШforward

        step3-equiv-fun : тЯи h-quotient тЯй тЙГ тЯи rec-quotient тЯй
        step3-equiv-fun = isoToEquiv step3-iso

        step3-equiv' : BooleanRingEquiv h-quotient rec-quotient
        step3-equiv' = step3-equiv-fun , snd step3-forward-hom

        step3-h-eq : freeBA тДХ QB./Im h тЙб freeBA тДХ QB./Im (тКО.rec f g)
        step3-h-eq = equivFun (BoolRingPath h-quotient rec-quotient) step3-equiv'

        step3-equiv : BooleanRingEquiv (freeBA тДХ QB./Im h) (freeBA тДХ QB./Im (тКО.rec f g))
        step3-equiv = invEq (BoolRingPath _ _) step3-h-eq

        target-ring : BooleanRing тДУ-zero
        target-ring = (freeBA тДХ QB./Im f) QB./Im d'

        equiv-hom : BoolHom (fst B) (freeBA тДХ QB./Im f)
        equiv-hom = fst (fst equiv) , snd equiv

        ╧А-d' : BoolHom (freeBA тДХ QB./Im f) target-ring
        ╧А-d' = QB.quotientImageHom

        composite-hom-1 : BoolHom (fst B) target-ring
        composite-hom-1 = ╧А-d' тИШcr equiv-hom

        composite-sends-d-to-0 : (n : тДХ) тЖТ composite-hom-1 $cr (d n) тЙб BooleanRingStr.ЁЭЯШ (snd target-ring)
        composite-sends-d-to-0 n = QB.zeroOnImage {f = d'} n

        step1-forward-hom : BoolHom B/d-ring target-ring
        step1-forward-hom = QB.inducedHom target-ring composite-hom-1 composite-sends-d-to-0

        ╧А-d : BoolHom (fst B) B/d-ring
        ╧А-d = QB.quotientImageHom

        equivтБ╗┬╣-hom : BoolHom (freeBA тДХ QB./Im f) (fst B)
        equivтБ╗┬╣-hom = fst (fst (invBooleanRingEquiv (fst B) (freeBA тДХ QB./Im f) equiv)) ,
                      snd (invBooleanRingEquiv (fst B) (freeBA тДХ QB./Im f) equiv)

        backward-composite-1 : BoolHom (freeBA тДХ QB./Im f) B/d-ring
        backward-composite-1 = ╧А-d тИШcr equivтБ╗┬╣-hom

        backward-composite-sends-d'-to-0 : (n : тДХ) тЖТ backward-composite-1 $cr (d' n) тЙб BooleanRingStr.ЁЭЯШ (snd B/d-ring)
        backward-composite-sends-d'-to-0 n =
          backward-composite-1 $cr (d' n)
            тЙбтЯи refl тЯй
          ╧А-d $cr (equivтБ╗┬╣-hom $cr (fst (fst equiv) (d n)))
            тЙбтЯи cong (╧А-d $cr_) (Iso.ret (equivToIso (fst equiv)) (d n)) тЯй
          ╧А-d $cr (d n)
            тЙбтЯи QB.zeroOnImage {f = d} n тЯй
          BooleanRingStr.ЁЭЯШ (snd B/d-ring) тИО

        step1-backward-hom : BoolHom target-ring B/d-ring
        step1-backward-hom = QB.inducedHom B/d-ring backward-composite-1 backward-composite-sends-d'-to-0

        step1-forward-fun : тЯи B/d-ring тЯй тЖТ тЯи target-ring тЯй
        step1-forward-fun = fst step1-forward-hom

        step1-backward-fun : тЯи target-ring тЯй тЖТ тЯи B/d-ring тЯй
        step1-backward-fun = fst step1-backward-hom

        step1-forward-eval : step1-forward-hom тИШcr ╧А-d тЙб composite-hom-1
        step1-forward-eval = QB.evalInduce {B = fst B} {f = d} target-ring composite-hom-1 composite-sends-d-to-0

        step1-backward-eval : step1-backward-hom тИШcr ╧А-d' тЙб backward-composite-1
        step1-backward-eval = QB.evalInduce {B = freeBA тДХ QB./Im f} {f = d'} B/d-ring
                                backward-composite-1 backward-composite-sends-d'-to-0

        equivтБ╗┬╣тИШequivтЙбid : (x : тЯи fst B тЯй) тЖТ fst equivтБ╗┬╣-hom (fst (fst equiv) x) тЙб x
        equivтБ╗┬╣тИШequivтЙбid = Iso.ret (equivToIso (fst equiv))

        equivтИШequivтБ╗┬╣тЙбid : (y : тЯи freeBA тДХ QB./Im f тЯй) тЖТ fst (fst equiv) (fst equivтБ╗┬╣-hom y) тЙб y
        equivтИШequivтБ╗┬╣тЙбid = Iso.sec (equivToIso (fst equiv))

        B/d-ring-isSet : isSet тЯи B/d-ring тЯй
        B/d-ring-isSet = BooleanRingStr.is-set (snd B/d-ring)

        target-ring-isSet : isSet тЯи target-ring тЯй
        target-ring-isSet = BooleanRingStr.is-set (snd target-ring)

        step1-backwardтИШforward-on-╧А : (x : тЯи fst B тЯй) тЖТ step1-backward-fun (step1-forward-fun (fst ╧А-d x)) тЙб fst ╧А-d x
        step1-backwardтИШforward-on-╧А x =
