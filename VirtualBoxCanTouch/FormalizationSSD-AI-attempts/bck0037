  g├Ч-left-orthog : (m n : тДХ) тЖТ ┬м (m тЙб n) тЖТ
    BooleanRingStr._┬╖_ (snd BтИЮ├ЧBтИЮ-quotient) (g├Ч-left-gen m) (g├Ч-left-gen n) тЙб
    BooleanRingStr.ЁЭЯШ (snd BтИЮ├ЧBтИЮ-quotient)
  g├Ч-left-orthog m n mтЙаn =
    let i = encode├Ч (тКО.inl m)
