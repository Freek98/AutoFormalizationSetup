        (fst f x) +├Ч (fst f y)
          тЙбтЯи cong (_+├Ч (fst f y)) fx=fy тЯй
        (fst f y) +├Ч (fst f y)
          тЙбтЯи char2-BтИЮ├ЧBтИЮ (fst f y) тЯй
        (ЁЭЯШтИЮ , ЁЭЯШтИЮ) тИО

      xy=0 : xy-diff тЙб ЁЭЯШтИЮ
      xy=0 = f-kernel-from-trunc-05a xy-diff f-xy-diff

      x=y : x тЙб y
