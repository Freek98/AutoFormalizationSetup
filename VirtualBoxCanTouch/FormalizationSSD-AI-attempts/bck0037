  mтЙаm+suc-d (suc m) d meq = mтЙаm+suc-d m d (injSuc meq)

  i+suc[jтИ╕suc-i]тЙбj : (i j : тДХ) тЖТ i < j тЖТ i +тДХ suc (j тИ╕ suc i) тЙб j
  i+suc[jтИ╕suc-i]тЙбj i zero (k , p) = ex-falso (┬м-<-zero (k , p))
  i+suc[jтИ╕suc-i]тЙбj i (suc j) (k , p) =
