  module SpOfQuotientBySeq (B : BooleanRing тДУ-zero) (d : тДХ тЖТ тЯи B тЯй) where
    B/d : BooleanRing тДУ-zero
    B/d = B QB./Im d

    ╧А : BoolHom B B/d
    ╧А = QB.quotientImageHom

    ClosedSubset : Type тДУ-zero
    ClosedSubset = ╬г[ x тИИ BoolHom B BoolBR ] ((n : тДХ) тЖТ fst x (d n) тЙб false)

    Sp-quotientтЖТClosedSubset : BoolHom B/d BoolBR тЖТ ClosedSubset
    Sp-quotientтЖТClosedSubset h = h тИШcr ╧А , ╬╗ n тЖТ zeroOnImage-applied n
      where
      zeroOnImage-applied : (n : тДХ) тЖТ fst (h тИШcr ╧А) (d n) тЙб false
      zeroOnImage-applied n =
        fst (h тИШcr ╧А) (d n)     тЙбтЯи refl тЯй
        fst h (fst ╧А (d n))     тЙбтЯи cong (fst h) (QB.zeroOnImage {B = B} {f = d} n) тЯй
        fst h (BooleanRingStr.ЁЭЯШ (snd B/d))  тЙбтЯи IsCommRingHom.pres0 (snd h) тЯй
        false тИО

    ClosedSubsetтЖТSp-quotient : ClosedSubset тЖТ BoolHom B/d BoolBR
    ClosedSubsetтЖТSp-quotient (x , allZero) = QB.inducedHom {B = B} {f = d} BoolBR x allZero

    forwardтИШbackward : (cs : ClosedSubset) тЖТ Sp-quotientтЖТClosedSubset (ClosedSubsetтЖТSp-quotient cs) тЙб cs
    forwardтИШbackward (x , allZero) = ╬гтЙбProp (╬╗ _ тЖТ isProp╬а (╬╗ _ тЖТ isSetBool _ _)) path
      where
