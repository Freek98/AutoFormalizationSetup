         тЙбтЯи congтВВ (BooleanRingStr._┬╖_ (snd BтИЮ├ЧBтИЮ-quotient))
                  (funExtтБ╗ ╧И-right-free-on-gen m) (funExtтБ╗ ╧И-right-free-on-gen n) тЯй
       BooleanRingStr._┬╖_ (snd BтИЮ├ЧBтИЮ-quotient) (g├Ч-right-gen m) (g├Ч-right-gen n)
