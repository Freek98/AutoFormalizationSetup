       BooleanRingStr.ЁЭЯШ (snd BтИЮ├ЧBтИЮ-quotient) тИО

  ╧И-right : BoolHom BтИЮ BтИЮ├ЧBтИЮ-quotient
  ╧И-right = QB.inducedHom BтИЮ├ЧBтИЮ-quotient ╧И-right-free ╧И-right-respects-relBтИЮ

