SpBтИЮ-seq-atMostOnce h m n hm=true hn=true = m=n
  where
  open IsCommRingHom (snd h)

  h-pres┬╖ : (a b : тЯи BтИЮ тЯй) тЖТ h $cr (a ┬╖тИЮ b) тЙб (h $cr a) and (h $cr b)
  h-pres┬╖ = pres┬╖

  m=n : m тЙб n
  m=n with discreteтДХ m n
  ... | yes p = p
  ... | no mтЙаn =
    let
      mult-zero : gтИЮ m ┬╖тИЮ gтИЮ n тЙб ЁЭЯШтИЮ
