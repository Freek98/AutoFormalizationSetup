openAnd : (P Q : hProp тДУ-zero) тЖТ isOpenProp P тЖТ isOpenProp Q
        тЖТ isOpenProp ((тЯи P тЯй ├Ч тЯи Q тЯй) , isProp├Ч (snd P) (snd Q))
openAnd P Q (╬▒ , PтЖТтИГ╬▒ , тИГ╬▒тЖТP) (╬▓ , QтЖТтИГ╬▓ , тИГ╬▓тЖТQ) = ╬│ , forward , backward
  where
  ╬│ : binarySequence
  ╬│ k = let (n , m) = cantorUnpair k in ╬▒ n and ╬▓ m

  forward : тЯи P тЯй ├Ч тЯи Q тЯй тЖТ ╬г[ k тИИ тДХ ] ╬│ k тЙб true
  forward (p , q) =
    let (n , ╬▒n=t) = PтЖТтИГ╬▒ p
        (m , ╬▓m=t) = QтЖТтИГ╬▓ q
        k = cantorPair n m
        ╬│k=t : ╬│ k тЙб true
        ╬│k=t =
          ╬│ k
            тЙбтЯи cong (╬╗ p тЖТ ╬▒ (fst p) and ╬▓ (snd p)) (cantorUnpair-pair n m) тЯй
          ╬▒ n and ╬▓ m
            тЙбтЯи cong (╬╗ x тЖТ x and ╬▓ m) ╬▒n=t тЯй
          true and ╬▓ m
            тЙбтЯи cong (true and_) ╬▓m=t тЯй
          true тИО
    in (k , ╬│k=t)

  backward : ╬г[ k тИИ тДХ ] ╬│ k тЙб true тЖТ тЯи P тЯй ├Ч тЯи Q тЯй
  backward (k , ╬│k=t) =
    let (n , m) = cantorUnpair k
        ╬▒nтИз╬▓m=t : ╬▒ n and ╬▓ m тЙб true
        ╬▒nтИз╬▓m=t = ╬│k=t
        ╬▒n=t : ╬▒ n тЙб true
        ╬▒n=t = and-true-left (╬▒ n) (╬▓ m) ╬▒nтИз╬▓m=t
        ╬▓m=t : ╬▓ m тЙб true
        ╬▓m=t = and-true-right (╬▒ n) (╬▓ m) ╬▒nтИз╬▓m=t
    in (тИГ╬▒тЖТP (n , ╬▒n=t)) , (тИГ╬▓тЖТQ (m , ╬▓m=t))
    where
    and-true-left : (a b : Bool) тЖТ a and b тЙб true тЖТ a тЙб true
    and-true-left true true _ = refl
    and-true-left true false p = ex-falso (falseтЙвtrue p)
    and-true-left false true p = ex-falso (falseтЙвtrue p)
    and-true-left false false p = ex-falso (falseтЙвtrue p)

    and-true-right : (a b : Bool) тЖТ a and b тЙб true тЖТ b тЙб true
    and-true-right true true _ = refl
    and-true-right true false p = ex-falso (falseтЙвtrue p)
    and-true-right false true p = ex-falso (falseтЙвtrue p)
    and-true-right false false p = ex-falso (falseтЙвtrue p)

