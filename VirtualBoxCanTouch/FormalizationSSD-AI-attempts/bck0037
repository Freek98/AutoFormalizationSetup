  encode├Ч-inr-injective : (m n : тДХ) тЖТ encode├Ч (тКО.inr m) тЙб encode├Ч (тКО.inr n) тЖТ m тЙб n
  encode├Ч-inr-injective m n = ╬╗ eq тЖТ isEmbeddingтЖТInj isEmbedding-inr m n (
    тКО.inr m            тЙбтЯи sym (decode├ЧтИШencode├Ч (тКО.inr m)) тЯй
    decode├Ч (encode├Ч (тКО.inr m))  тЙбтЯи cong decode├Ч eq тЯй
