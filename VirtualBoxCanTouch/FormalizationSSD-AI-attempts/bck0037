module StoneCompactHausdorffTotallyDisconnectedModule where
  open CompactHausdorffModule
  open ConnectedComponentModule
  open AlgebraCompactHausdorffCountablyPresentedModule
  open import Axioms.StoneDuality using (Stone; hasStoneStr)

  isTotallyDisconnected : CHaus тЖТ TypeтВА
  isTotallyDisconnected X =
    (x : fst X) тЖТ (y : fst X) тЖТ fst (ConnectedComponent X x y) тЖТ x тЙб y

  open import Axioms.StoneDuality using (Sp; Boole╧Й; evaluationMap)
  open import Cubical.Algebra.CommRing using (_$cr_; CommRingStr; IsCommRingHom; CommRingHomтЙб)
  open import Cubical.Algebra.BooleanRing using (BooleanRingStr; BooleanRingтЖТCommRing)
  open import Cubical.Algebra.BooleanRing.Instances.Bool using (BoolBR)
  open import Cubical.Data.Bool using (true; false; trueтЙвfalse; falseтЙвtrue)
  open import Cubical.Data.Empty as тКе using (тКе)

  StoneCompactHausdorffTotallyDisconnected-forward : (S : Stone)
    тЖТ isTotallyDisconnected (StoneтЖТCHaus S)
  StoneCompactHausdorffTotallyDisconnected-forward S x y qxy = goal
    where
    B : Boole╧Й
    B = snd S .fst

    p : Sp B тЙб fst S
    p = snd S .snd

    x' : Sp B
    x' = transport (sym p) x

    y' : Sp B
    y' = transport (sym p) y

    D_b : тЯи fst B тЯй тЖТ DecSubsetCHaus (StoneтЖТCHaus S)
    D_b b z = evaluationMap B b (transport (sym p) z)

    agree-on-true : (b : тЯи fst B тЯй) тЖТ x' $cr b тЙб true тЖТ y' $cr b тЙб true
    agree-on-true b x'bтЙбtrue = qxy (D_b b) x'bтЙбtrue

    open BooleanRingStr (snd (fst B)) renaming (ЁЭЯЩ to 1B; _-_ to _-B_)
    open CommRingStr (snd (BooleanRingтЖТCommRing BoolBR)) renaming (1r to 1Bool; _-_ to _-Bool_)
    open IsCommRingHom

    agree-on-all : (b : тЯи fst B тЯй) тЖТ x' $cr b тЙб y' $cr b
    agree-on-all b with x' $cr b | inspect (x' $cr_) b
    ... | true  | [ eq ] = sym (agree-on-true b eq)
    ... | false | [ eq ] with y' $cr b | inspect (y' $cr_) b
    ...   | false | [ eq' ] = refl
    ...   | true  | [ eq' ] = тКе.rec (falseтЙвtrue contra)
      where
      open BooleanRingStr (snd (fst B)) using (_+_) renaming (-_ to negB)
      open CommRingStr (snd (BooleanRingтЖТCommRing BoolBR)) using () renaming (_+_ to _+Bool_; -_ to negBool)

      ┬мb : тЯи fst B тЯй
      ┬мb = 1B -B b

      x'-┬мb-true : x' $cr ┬мb тЙб true
      x'-┬мb-true =
        pres+ (snd x') 1B (negB b) тИЩ
        congтВВ _+Bool_ (pres1 (snd x')) (pres- (snd x') b) тИЩ
        cong (╬╗ z тЖТ true +Bool (negBool z)) eq

      y'-┬мb-true : y' $cr ┬мb тЙб true
      y'-┬мb-true = agree-on-true ┬мb x'-┬мb-true

      y'-┬мb-false : y' $cr ┬мb тЙб false
      y'-┬мb-false =
        pres+ (snd y') 1B (negB b) тИЩ
        congтВВ _+Bool_ (pres1 (snd y')) (pres- (snd y') b) тИЩ
        cong (╬╗ z тЖТ true +Bool (negBool z)) eq'

      contra : false тЙб true
      contra = sym y'-┬мb-false тИЩ y'-┬мb-true

    x'тЙбy' : x' тЙб y'
    x'тЙбy' = CommRingHomтЙб (funExt agree-on-all)

    goal : x тЙб y
    goal = sym (transportTransportтБ╗ p x) тИЩ cong (transport p) x'тЙбy' тИЩ transportTransportтБ╗ p y

  open import Axioms.StoneDuality using (2^; SpGeneralBooleanRing)
  open import BooleanRing.BoolRingUnivalence using (IsBoolRingHom)
  module ICRHom = IsCommRingHom

  evalAtPointIsHom : (X : CHaus) (x : fst X)
    тЖТ IsBoolRingHom (snd (2^ (fst X))) (╬╗ f тЖТ f x) (snd BoolBR)
  evalAtPointIsHom X x .ICRHom.pres0 = refl
  evalAtPointIsHom X x .ICRHom.pres1 = refl
  evalAtPointIsHom X x .ICRHom.pres+ f g = refl
  evalAtPointIsHom X x .ICRHom.pres┬╖ f g = refl
  evalAtPointIsHom X x .ICRHom.pres- f = refl

  evalCHaus : (X : CHaus) тЖТ fst X тЖТ SpGeneralBooleanRing (2^ (fst X))
  evalCHaus X x = (╬╗ f тЖТ f x) , evalAtPointIsHom X x

  evalCHaus-injective : (X : CHaus) тЖТ isTotallyDisconnected X
    тЖТ (x y : fst X) тЖТ evalCHaus X x тЙб evalCHaus X y тЖТ x тЙб y
  evalCHaus-injective X totDisc x y exтЙбey = totDisc x y qxy
    where
    qxy : fst (ConnectedComponent X x y)
    qxy D xInD = sym (cong (╬╗ h тЖТ fst h D) exтЙбey) тИЩ xInD

  open import Cubical.Functions.Surjection using (isSurjection)

  precomp-surj-inj : {S X : TypeтВА} тЖТ (q : S тЖТ X) тЖТ isSurjection q
    тЖТ (f g : X тЖТ Bool) тЖТ (╬╗ s тЖТ f (q s)) тЙб (╬╗ s тЖТ g (q s)) тЖТ f тЙб g
  precomp-surj-inj q q-surj f g eq = funExt ╬╗ x тЖТ
    PT.rec (isSetBool (f x) (g x)) (╬╗ { (s , qsтЙбx) тЖТ
      cong f (sym qsтЙбx) тИЩ funExtтБ╗ eq s тИЩ cong g qsтЙбx
    }) (q-surj x)

  -- tex Lemma 2186 backward direction, depends on tex Lemma 2112
  postulate
    StoneCompactHausdorffTotallyDisconnected-backward : (X : CHaus)
      тЖТ isTotallyDisconnected X
      тЖТ hasStoneStr (fst X)

-- StoneSigmaClosedModule (tex Theorem 2214)

module StoneSigmaClosedModule where
  open import Axioms.StoneDuality using (Stone; hasStoneStr)
  open CompactHausdorffModule
  open SigmaCompactHausdorffModule
  open StoneCompactHausdorffTotallyDisconnectedModule
  open ConnectedComponentModule
  open ConnectedComponentConnectedModule

  SigmaStoneType : (S : Stone) тЖТ (T : fst S тЖТ Stone) тЖТ TypeтВА
  SigmaStoneType S T = ╬г[ x тИИ fst S ] fst (T x)

  ╬гStoneCHaus : (S : Stone) тЖТ (T : fst S тЖТ Stone) тЖТ CHaus
  ╬гStoneCHaus S T = CHaus╬г (StoneтЖТCHaus S) (╬╗ x тЖТ StoneтЖТCHaus (T x))

  projтВБ-preserves-CC : (S : Stone) (T : fst S тЖТ Stone)
    тЖТ (x : fst S) (y : fst (T x)) (x' : fst S) (y' : fst (T x'))
    тЖТ fst (ConnectedComponent (╬гStoneCHaus S T) (x , y) (x' , y'))
    тЖТ fst (ConnectedComponent (StoneтЖТCHaus S) x x')
  projтВБ-preserves-CC S T x y x' y' cc╧Г D xInD = goal
    where
    D╧Г : DecSubsetCHaus (╬гStoneCHaus S T)
    D╧Г (a , b) = D a
    xyInD╧Г : inDec (╬гStoneCHaus S T) (x , y) D╧Г
    xyInD╧Г = xInD
    x'y'InD╧Г : inDec (╬гStoneCHaus S T) (x' , y') D╧Г
    x'y'InD╧Г = cc╧Г D╧Г xyInD╧Г
    goal : inDec (StoneтЖТCHaus S) x' D
    goal = x'y'InD╧Г

  -- Proof of ╬гStone-isTotallyDisconnected following tex Theorem 2214
  ╬гStone-isTotallyDisconnected : (S : Stone) (T : fst S тЖТ Stone)
    тЖТ isTotallyDisconnected (╬гStoneCHaus S T)
  ╬гStone-isTotallyDisconnected S T (x , y) (x' , y') cc╧Г = goal
    where
    x'InQx : fst (ConnectedComponent (StoneтЖТCHaus S) x x')
    x'InQx = projтВБ-preserves-CC S T x y x' y' cc╧Г

    xтЙбx' : x тЙб x'
    xтЙбx' = StoneCompactHausdorffTotallyDisconnected-forward S x x' x'InQx

    y'-in-Tx : fst (T x)
    y'-in-Tx = subst (╬╗ z тЖТ fst (T z)) (sym xтЙбx') y'

    Q╧Г : TypeтВА
    Q╧Г = ╬г[ p тИИ SigmaStoneType S T ] fst (ConnectedComponent (╬гStoneCHaus S T) (x , y) p)

    xy-in-Q╧Г : Q╧Г
    xy-in-Q╧Г = (x , y) , ╬╗ D xInD тЖТ xInD  -- reflexivity of connected component

    x'y'-in-Q╧Г : Q╧Г
    x'y'-in-Q╧Г = (x' , y') , cc╧Г

    make-f : (g : fst (T x) тЖТ Bool) тЖТ Q╧Г тЖТ Bool
    make-f g ((a , b) , cc) = g (subst (╬╗ z тЖТ fst (T z)) (sym p_a) b)
      where
      p_a : x тЙб a
      p_a = StoneCompactHausdorffTotallyDisconnected-forward S x a
            (projтВБ-preserves-CC S T x y a b cc)

    f-constant : (g : fst (T x) тЖТ Bool) тЖТ make-f g xy-in-Q╧Г тЙб make-f g x'y'-in-Q╧Г
    f-constant g = ConnectedComponentConnected (╬гStoneCHaus S T) (x , y) (make-f g) xy-in-Q╧Г x'y'-in-Q╧Г

    isSetS : isSet (fst S)
    isSetS = StoneEqualityClosedModule.hasStoneStrтЖТisSet S

    p_x : x тЙб x
    p_x = StoneCompactHausdorffTotallyDisconnected-forward S x x
          (projтВБ-preserves-CC S T x y x y (╬╗ D xInD тЖТ xInD))

    p_xтЙбrefl : p_x тЙб refl
    p_xтЙбrefl = isSetS x x p_x refl

    p_x' : x тЙб x'
    p_x' = StoneCompactHausdorffTotallyDisconnected-forward S x x'
           (projтВБ-preserves-CC S T x y x' y' cc╧Г)

    make-f-xy : (g : fst (T x) тЖТ Bool) тЖТ make-f g xy-in-Q╧Г тЙб g y
    make-f-xy g = cong (╬╗ p тЖТ g (subst (╬╗ z тЖТ fst (T z)) (sym p) y)) p_xтЙбrefl
                тИЩ cong g (transportRefl y)

    p_x'тЙбxтЙбx' : p_x' тЙб xтЙбx'
    p_x'тЙбxтЙбx' = isSetS x x' p_x' xтЙбx'

    make-f-x'y' : (g : fst (T x) тЖТ Bool) тЖТ make-f g x'y'-in-Q╧Г тЙб g y'-in-Tx
    make-f-x'y' g = cong (╬╗ p тЖТ g (subst (╬╗ z тЖТ fst (T z)) (sym p) y')) p_x'тЙбxтЙбx'

    g-agrees : (g : fst (T x) тЖТ Bool) тЖТ g y тЙб g y'-in-Tx
    g-agrees g = sym (make-f-xy g) тИЩ f-constant g тИЩ make-f-x'y' g

    y'-in-Qy : fst (ConnectedComponent (StoneтЖТCHaus (T x)) y y'-in-Tx)
    y'-in-Qy D yInD = goal'
      where
      goal' : D y'-in-Tx тЙб true
      goal' = sym (g-agrees D) тИЩ yInD

    yтЙбy'-in-Tx : y тЙб y'-in-Tx
    yтЙбy'-in-Tx = StoneCompactHausdorffTotallyDisconnected-forward (T x) y y'-in-Tx y'-in-Qy

    goal : (x , y) тЙб (x' , y')
    goal = ╬гPathP (xтЙбx' , toPathP y'-path)
      where
      y'-path : transport (╬╗ i тЖТ fst (T (xтЙбx' i))) y тЙб y'
      y'-path = cong (subst (╬╗ z тЖТ fst (T z)) xтЙбx') yтЙбy'-in-Tx
              тИЩ transportTransportтБ╗ (cong (╬╗ z тЖТ fst (T z)) xтЙбx') y'

  StoneSigmaClosed : (S : Stone) (T : fst S тЖТ Stone)
    тЖТ hasStoneStr (SigmaStoneType S T)
  StoneSigmaClosed S T = StoneCompactHausdorffTotallyDisconnected-backward
    (╬гStoneCHaus S T)
    (╬гStone-isTotallyDisconnected S T)

  Stone╬г : (S : Stone) тЖТ (T : fst S тЖТ Stone) тЖТ Stone
  Stone╬г S T = SigmaStoneType S T , StoneSigmaClosed S T

