       BooleanRingStr._┬╖_ (snd BтИЮ├ЧBтИЮ-quotient) (g├Ч-left-gen m) (g├Ч-left-gen n)
         тЙбтЯи g├Ч-left-orthog m n mтЙаn тЯй
