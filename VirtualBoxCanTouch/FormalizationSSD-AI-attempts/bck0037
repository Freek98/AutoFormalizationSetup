  quotientBySeqPreservesBoole╧Й : (B : Boole╧Й) (d : тДХ тЖТ тЯи fst B тЯй)
    тЖТ тИе ╬г[ C тИИ Boole╧Й ] (Sp C тЙГ (╬г[ x тИИ Sp B ] ((n : тДХ) тЖТ fst x (d n) тЙб false))) тИетВБ
  quotientBySeqPreservesBoole╧Й B d = PT.rec squashтВБ construct (snd B)
    where
    B/d : BooleanRing тДУ-zero
    B/d = fst B QB./Im d

    construct : has-Boole-╧Й' (fst B) тЖТ
                тИе ╬г[ C тИИ Boole╧Й ] (Sp C тЙГ (╬г[ x тИИ Sp B ] ((n : тДХ) тЖТ fst x (d n) тЙб false))) тИетВБ
    construct (f , equiv) = PT.rec squashтВБ (╬╗ lifts тЖТ тИг constructFromLifts lifts тИгтВБ) lifts-exist
      where
      open SpOfQuotientBySeq (fst B) d

      B/d-ring : BooleanRing тДУ-zero
      B/d-ring = fst B QB./Im d

      d' : тДХ тЖТ тЯи freeBA тДХ QB./Im f тЯй
      d' n = fst (fst equiv) (d n)

      ╧А-f : тЯи freeBA тДХ тЯй тЖТ тЯи freeBA тДХ QB./Im f тЯй
      ╧А-f = fst QB.quotientImageHom

      d'-has-preimage : (n : тДХ) тЖТ тИе ╬г[ x тИИ тЯи freeBA тДХ тЯй ] ╧А-f x тЙб d' n тИетВБ
      d'-has-preimage n = QB.quotientImageHomSurjective (d' n)

      LiftType : тДХ тЖТ Type тДУ-zero
      LiftType n = ╬г[ x тИИ тЯи freeBA тДХ тЯй ] ╧А-f x тЙб d' n

      lifts-exist : тИе ((n : тДХ) тЖТ LiftType n) тИетВБ
      lifts-exist = countableChoice LiftType d'-has-preimage

      constructFromLifts : ((n : тДХ) тЖТ LiftType n) тЖТ
                           ╬г[ C тИИ Boole╧Й ] (Sp C тЙГ (╬г[ x тИИ Sp B ] ((n : тДХ) тЖТ fst x (d n) тЙб false)))
      constructFromLifts lifts = C , Sp-equiv
        where
        g : тДХ тЖТ тЯи freeBA тДХ тЯй
        g n = fst (lifts n)

        g-is-section : (n : тДХ) тЖТ ╧А-f (g n) тЙб d' n
        g-is-section n = snd (lifts n)

        encode : тДХ тКО тДХ тЖТ тДХ
        encode = Iso.fun тДХтКОтДХтЙЕтДХ

        decode : тДХ тЖТ тДХ тКО тДХ
        decode = Iso.inv тДХтКОтДХтЙЕтДХ

        h : тДХ тЖТ тЯи freeBA тДХ тЯй
        h n with decode n
        ... | inl m = f m    -- relations from the original presentation
        ... | inr m = g m    -- relations from d' (via lifts)

        step2-path : BooleanRingтЖТCommRing (freeBA тДХ QB./Im (тКО.rec f g)) тЙб
                     BooleanRingтЖТCommRing ((freeBA тДХ QB./Im f) QB./Im (fst QB.quotientImageHom тИШ g))
        step2-path = BoolQuotientEquiv (freeBA тДХ) f g

        step2-equiv : BooleanRingEquiv (freeBA тДХ QB./Im (тКО.rec f g))
                                       ((freeBA тДХ QB./Im f) QB./Im (fst QB.quotientImageHom тИШ g))
        step2-equiv = commRingPathтЖТboolRingEquiv
                        (freeBA тДХ QB./Im (тКО.rec f g))
                        ((freeBA тДХ QB./Im f) QB./Im (fst QB.quotientImageHom тИШ g))
                        step2-path

        hтЙбrecтИШdecode-pointwise : (n : тДХ) тЖТ h n тЙб тКО.rec f g (decode n)
        hтЙбrecтИШdecode-pointwise n with decode n
        ... | inl m = refl
        ... | inr m = refl

        hтЙбrecтИШdecode : h тЙб (тКО.rec f g) тИШ decode
        hтЙбrecтИШdecode = funExt hтЙбrecтИШdecode-pointwise

        rec-of-decode : (n : тДХ) тЖТ тКО.rec f g (decode n) тЙб h n
        rec-of-decode n = sym (hтЙбrecтИШdecode-pointwise n)

        encodeтИШdecode : (n : тДХ) тЖТ encode (decode n) тЙб n
        encodeтИШdecode = Iso.sec тДХтКОтДХтЙЕтДХ

        decodeтИШencode : (x : тДХ тКО тДХ) тЖТ decode (encode x) тЙб x
        decodeтИШencode = Iso.ret тДХтКОтДХтЙЕтДХ

        rec-quotient : BooleanRing тДУ-zero
        rec-quotient = freeBA тДХ QB./Im (тКО.rec f g)

        h-quotient : BooleanRing тДУ-zero
        h-quotient = freeBA тДХ QB./Im h

        ╧А-rec : BoolHom (freeBA тДХ) rec-quotient
        ╧А-rec = QB.quotientImageHom

        ╧А-h : BoolHom (freeBA тДХ) h-quotient
        ╧А-h = QB.quotientImageHom

        ╧А-rec-sends-h-to-0 : (n : тДХ) тЖТ ╧А-rec $cr (h n) тЙб BooleanRingStr.ЁЭЯШ (snd rec-quotient)
        ╧А-rec-sends-h-to-0 n =
          ╧А-rec $cr (h n)
            тЙбтЯи cong (╧А-rec $cr_) (sym (rec-of-decode n)) тЯй
          ╧А-rec $cr ((тКО.rec f g) (decode n))
            тЙбтЯи QB.zeroOnImage {B = freeBA тДХ} {f = тКО.rec f g} (decode n) тЯй
          BooleanRingStr.ЁЭЯШ (snd rec-quotient) тИО

        step3-forward-hom : BoolHom h-quotient rec-quotient
        step3-forward-hom = QB.inducedHom {B = freeBA тДХ} {f = h} rec-quotient ╧А-rec ╧А-rec-sends-h-to-0

        rec-eq-h-encode : (x : тДХ тКО тДХ) тЖТ (тКО.rec f g) x тЙб h (encode x)
