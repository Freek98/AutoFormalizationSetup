        step6 = cong (_+Q fst ╧А gтВБ) (sym (BooleanRingStr.+IdL (snd Bool┬▓-quotient) (fst ╧А gтВА)))
        step7 : ЁЭЯШQ +Q fst ╧А gтВА +Q fst ╧А gтВБ тЙб (ЁЭЯЩQ +Q ЁЭЯЩQ) +Q fst ╧А gтВА +Q fst ╧А gтВБ
        step7 = cong (╬╗ z тЖТ z +Q fst ╧А gтВА +Q fst ╧А gтВБ) (sym (char2Q ЁЭЯЩQ))
