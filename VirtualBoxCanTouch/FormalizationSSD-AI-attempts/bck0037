... | yes m<n = gтИЮ-lt-mult-zero m n m<n
... | no ┬мm<n with Cubical.Data.Nat.Order.<Dec n m
...   | yes n<m =
        let comm : gтИЮ m ┬╖тИЮ gтИЮ n тЙб gтИЮ n ┬╖тИЮ gтИЮ m
            comm = BooleanRingStr.┬╖Comm (snd BтИЮ) (gтИЮ m) (gтИЮ n)
