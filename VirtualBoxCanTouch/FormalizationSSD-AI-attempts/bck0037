module NotWLPOTC where
  import WLPO as WLPOmod
  open CantorIsStoneModule
  open import Axioms.StoneDuality using (evaluationMap)
  open import BooleanRing.FreeBooleanRing.FreeBool using (freeBA)
  open import Cubical.Foundations.Equiv using (invEq; secEq)
  open import Cubical.Relation.Nullary using (Dec; yes; no)
  open import Cubical.Foundations.Function using (_тИШ_)
  open import Cubical.Algebra.CommRing using (_$cr_)

  SD-freeBA-тДХ : isEquiv (evaluationMap freeBA-тДХ-Boole╧Й)
  SD-freeBA-тДХ = sd-axiom freeBA-тДХ-Boole╧Й

  decPredтЖТelem' : (Sp freeBA-тДХ-Boole╧Й тЖТ Bool) тЖТ тЯи freeBA тДХ тЯй
  decPredтЖТelem' = invEq (_ , SD-freeBA-тДХ)

  decPredтЖТelem-property' : (g : Sp freeBA-тДХ-Boole╧Й тЖТ Bool) (h : Sp freeBA-тДХ-Boole╧Й)
    тЖТ evaluationMap freeBA-тДХ-Boole╧Й (decPredтЖТelem' g) h тЙб g h
  decPredтЖТelem-property' g h = funExtтБ╗ (secEq (_ , SD-freeBA-тДХ) g) h

  ┬мWLPO : ┬м WLPO
  ┬мWLPO wlpo = contradiction'
    where
    decide-fn : binarySequence тЖТ Bool
    decide-fn ╬▒ with wlpo ╬▒
    ... | yes _ = false
    ... | no _ = true

    WLPOf : (╬▒ : binarySequence) тЖТ (decide-fn ╬▒ тЙб false) тЖФ ((n : тДХ) тЖТ ╬▒ n тЙб false)
    WLPOf ╬▒ = forward , backward
      where
      forward : decide-fn ╬▒ тЙб false тЖТ (n : тДХ) тЖТ ╬▒ n тЙб false
      forward f╬▒=false with wlpo ╬▒
      ... | yes all-zero = all-zero
      ... | no _ = ex-falso (trueтЙвfalse f╬▒=false)

      backward : ((n : тДХ) тЖТ ╬▒ n тЙб false) тЖТ decide-fn ╬▒ тЙб false
      backward all-zero with wlpo ╬▒
      ... | yes _ = refl
      ... | no ┬мall-zero = ex-falso (┬мall-zero all-zero)

    elem-c : тЯи freeBA тДХ тЯй
    elem-c = decPredтЖТelem' (decide-fn тИШ Iso.fun Sp-freeBA-тДХ-Iso)

    SD-property : (╬▒ : binarySequence) тЖТ decide-fn ╬▒ тЙб WLPOmod.evaluate ╬▒ $cr elem-c
    SD-property ╬▒ = sym (
      WLPOmod.evaluate ╬▒ $cr elem-c
        тЙбтЯи refl тЯй
      evaluationMap freeBA-тДХ-Boole╧Й elem-c (WLPOmod.evaluate ╬▒)
        тЙбтЯи cong (evaluationMap freeBA-тДХ-Boole╧Й elem-c) evaluate-is-Iso-inv тЯй
      evaluationMap freeBA-тДХ-Boole╧Й elem-c (Iso.inv Sp-freeBA-тДХ-Iso ╬▒)
        тЙбтЯи decPredтЖТelem-property' (decide-fn тИШ Iso.fun Sp-freeBA-тДХ-Iso) (Iso.inv Sp-freeBA-тДХ-Iso ╬▒) тЯй
      decide-fn (Iso.fun Sp-freeBA-тДХ-Iso (Iso.inv Sp-freeBA-тДХ-Iso ╬▒))
        тЙбтЯи cong decide-fn (Iso.sec Sp-freeBA-тДХ-Iso ╬▒) тЯй
      decide-fn ╬▒ тИО)
      where
      open import BooleanRing.FreeBooleanRing.FreeBool using (inducedBAHom; freeBA-universal-property)

      evaluate-is-Iso-inv : WLPOmod.evaluate ╬▒ тЙб Iso.inv Sp-freeBA-тДХ-Iso ╬▒
      evaluate-is-Iso-inv = refl

    open WLPOmod.PlayingWithWLPO' decide-fn WLPOf elem-c SD-property
