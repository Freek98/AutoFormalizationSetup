            nтЙбm = тЙд-antisym nтЙдm mтЙдn
            mтЙбn : m тЙб n
            mтЙбn = sym nтЙбm
        in ex-falso (mтЙаn mтЙбn)
  where
  тЙотЖТтЙе : {a b : тДХ} тЖТ ┬м (a < b) тЖТ b тЙд a
