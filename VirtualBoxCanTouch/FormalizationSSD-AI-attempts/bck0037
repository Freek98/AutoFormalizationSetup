    Iso.inv Sp-quotient-Iso = ClosedSubsetтЖТSp-quotient
    Iso.sec Sp-quotient-Iso = forwardтИШbackward
    Iso.ret Sp-quotient-Iso = backwardтИШforward

    Sp-quotient-тЙГ : BoolHom B/d BoolBR тЙГ ClosedSubset
