      path : fst (Sp-quotientтЖТClosedSubset induced) тЙб x
      path = QB.evalInduce {B = B} {f = d} BoolBR x allZero

    backwardтИШforward : (h : BoolHom B/d BoolBR) тЖТ ClosedSubsetтЖТSp-quotient (Sp-quotientтЖТClosedSubset h) тЙб h
    backwardтИШforward h = QB.inducedHomUnique BoolBR (h тИШcr ╧А) allZero h refl
      where
      allZero : (n : тДХ) тЖТ fst (h тИШcr ╧А) (d n) тЙб false
      allZero = snd (Sp-quotientтЖТClosedSubset h)

