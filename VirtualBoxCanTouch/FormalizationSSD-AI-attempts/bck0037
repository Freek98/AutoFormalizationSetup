xor-nf (joinForm ns) (meetNegForm ms) = meetNegForm (ns тЦ│L ms)
xor-nf (meetNegForm ns) (joinForm ms) = meetNegForm (ms тЦ│L ns)
xor-nf (meetNegForm ns) (meetNegForm ms) = joinForm (ns тЦ│L ms)

