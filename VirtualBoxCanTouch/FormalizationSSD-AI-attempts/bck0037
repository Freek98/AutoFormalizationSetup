  g├Ч-right-orthog : (m n : тДХ) тЖТ ┬м (m тЙб n) тЖТ
    BooleanRingStr._┬╖_ (snd BтИЮ├ЧBтИЮ-quotient) (g├Ч-right-gen m) (g├Ч-right-gen n) тЙб
    BooleanRingStr.ЁЭЯШ (snd BтИЮ├ЧBтИЮ-quotient)
  g├Ч-right-orthog m n mтЙаn =
    let i = encode├Ч (тКО.inr m)
        j = encode├Ч (тКО.inr n)
        iтЙаj : ┬м (i тЙб j)
        iтЙаj = ╬╗ eq тЖТ mтЙаn (encode├Ч-inr-injective m n eq)
    in g├Ч-orthog-helper i j iтЙаj
    where
    g├Ч-orthog-helper-base : (i j : тДХ) тЖТ i < j тЖТ
      BooleanRingStr._┬╖_ (snd BтИЮ├ЧBтИЮ-quotient) (g├Ч i) (g├Ч j) тЙб
      BooleanRingStr.ЁЭЯШ (snd BтИЮ├ЧBтИЮ-quotient)
    g├Ч-orthog-helper-base i j i<j =
      let k = cantorPair i (j тИ╕ suc i)
          rel-eq : relBтИЮ├ЧBтИЮ k тЙб gen i ┬╖ gen j
          rel-eq = cong relBтИЮ├ЧBтИЮ-from-pair (cantorUnpair-pair i (j тИ╕ suc i))
                 тИЩ cong (╬╗ x тЖТ gen i ┬╖ gen x) (i+suc[jтИ╕suc-i]тЙбj i j i<j)
      in sym (IsCommRingHom.pres┬╖ (snd ╧А├Ч) (gen i) (gen j))
         тИЩ cong (fst ╧А├Ч) (sym rel-eq)
         тИЩ QB.zeroOnImage k

    g├Ч-orthog-helper : (i j : тДХ) тЖТ ┬м (i тЙб j) тЖТ
      BooleanRingStr._┬╖_ (snd BтИЮ├ЧBтИЮ-quotient) (g├Ч i) (g├Ч j) тЙб
      BooleanRingStr.ЁЭЯШ (snd BтИЮ├ЧBтИЮ-quotient)
    g├Ч-orthog-helper i j iтЙаj with Cubical.Data.Nat.Order.<Dec i j
    ... | yes i<j = g├Ч-orthog-helper-base i j i<j
    ... | no ┬мi<j with Cubical.Data.Nat.Order.<Dec j i
    ...   | yes j<i =
            BooleanRingStr.┬╖Comm (snd BтИЮ├ЧBтИЮ-quotient) (g├Ч i) (g├Ч j)
            тИЩ g├Ч-orthog-helper-base j i j<i
    ...   | no ┬мj<i =
            ex-falso (iтЙаj (тЙд-antisym (тЙотЖТтЙе ┬мj<i) (тЙотЖТтЙе ┬мi<j)))

  ╧И-right-respects-relBтИЮ : (k : тДХ) тЖТ fst ╧И-right-free (relBтИЮ k) тЙб BooleanRingStr.ЁЭЯШ (snd BтИЮ├ЧBтИЮ-quotient)
  ╧И-right-respects-relBтИЮ k =
