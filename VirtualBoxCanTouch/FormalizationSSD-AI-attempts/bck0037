  (╬╗ pair тЖТ let nf = fst pair
                eq = snd pair
            in sym eq тИЩ f-kernel-normalForm-05a nf (cong (fst f) eq тИЩ fx=0))
  (normalFormExists-trunc x)

f-injective-05a : (x y : тЯи BтИЮ тЯй) тЖТ fst f x тЙб fst f y тЖТ x тЙб y
f-injective-05a x y fx=fy =
  let xy-diff : тЯи BтИЮ тЯй
      xy-diff = x +тИЮ y

      f-xy-diff : fst f xy-diff тЙб (ЁЭЯШтИЮ , ЁЭЯШтИЮ)
