  ╧И-left : BoolHom BтИЮ BтИЮ├ЧBтИЮ-quotient
  ╧И-left = QB.inducedHom BтИЮ├ЧBтИЮ-quotient ╧И-left-free ╧И-left-respects-relBтИЮ

