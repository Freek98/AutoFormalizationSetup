  open import Cubical.Foundations.Equiv
  open import Axioms.StoneDuality using (evaluationMap)

  emptyFunContr : isContr (Sp B тЖТ Bool)
  emptyFunContr = (╬╗ sp тЖТ ex-falso (spEmpty sp)) , ╬╗ f тЖТ funExt (╬╗ sp тЖТ ex-falso (spEmpty sp))

  B-contr : isContr тЯи fst B тЯй
  B-contr = isOfHLevelRespectEquiv 0 (invEquiv (evaluationMap B , SD B)) emptyFunContr

  0тЙб1-in-B : BooleanRingStr.ЁЭЯШ (snd (fst B)) тЙб BooleanRingStr.ЁЭЯЩ (snd (fst B))
  0тЙб1-in-B = isContrтЖТisProp B-contr _ _

open import Cubical.Algebra.CommRing.Properties using (compCommRingEquiv)

compBoolRingEquiv : (A B C : BooleanRing тДУ-zero)
                  тЖТ BooleanRingEquiv A B тЖТ BooleanRingEquiv B C тЖТ BooleanRingEquiv A C
compBoolRingEquiv A B C f g = compCommRingEquiv {A = BooleanRingтЖТCommRing A} {B = BooleanRingтЖТCommRing B} {C = BooleanRingтЖТCommRing C} f g

open import Cubical.Algebra.CommRing.Univalence using (CommRingPath)

commRingPathтЖТboolRingEquiv : (A B : BooleanRing тДУ-zero)
  тЖТ BooleanRingтЖТCommRing A тЙб BooleanRingтЖТCommRing B
  тЖТ BooleanRingEquiv A B
commRingPathтЖТboolRingEquiv A B p = commRingEquivToEquiv , snd commRingEquivToEquiv'
  where
  commRingEquivToEquiv' : CommRingEquiv (BooleanRingтЖТCommRing A) (BooleanRingтЖТCommRing B)
  commRingEquivToEquiv' = invEq (CommRingPath _ _) p

  commRingEquivToEquiv : тЯи A тЯй тЙГ тЯи B тЯй
  commRingEquivToEquiv = fst commRingEquivToEquiv'

Bool-Boole╧Й : Boole╧Й
Bool-Boole╧Й = BoolBR , тИг is-cp-2 тИгтВБ

private
  idBoolHom-local : BoolHom BoolBR BoolBR
  fst idBoolHom-local = idfun Bool
  snd idBoolHom-local .IsCommRingHom.pres0 = refl
  snd idBoolHom-local .IsCommRingHom.pres1 = refl
  snd idBoolHom-local .IsCommRingHom.pres+ _ _ = refl
  snd idBoolHom-local .IsCommRingHom.pres┬╖ _ _ = refl
  snd idBoolHom-local .IsCommRingHom.pres- _ = refl

Sp-Bool-inhabited : тИе Sp Bool-Boole╧Й тИетВБ
Sp-Bool-inhabited = тИг idBoolHom-local тИгтВБ

quotientPreservesBoole╧Й : (╬▒ : binarySequence) тЖТ тИе has-Boole-╧Й' (BoolBR QB./Im ╬▒) тИетВБ
quotientPreservesBoole╧Й ╬▒ = тИг presentationWitness тИгтВБ
  where
  fтВА : тДХ тЖТ тЯи freeBA тДХ тЯй
  fтВА = fst is-cp-2

  equiv : BooleanRingEquiv BoolBR (freeBA тДХ QB./Im fтВА)
  equiv = snd is-cp-2

  ╧АтВА : тЯи freeBA тДХ тЯй тЖТ тЯи freeBA тДХ QB./Im fтВА тЯй
  ╧АтВА = fst QB.quotientImageHom

  equivтБ╗┬╣ : тЯи freeBA тДХ QB./Im fтВА тЯй тЖТ тЯи BoolBR тЯй
  equivтБ╗┬╣ = fst (invEquiv (fst equiv))

  embBR : тЯи BoolBR тЯй тЖТ тЯи freeBA тДХ QB./Im fтВА тЯй
  embBR = fst (fst equiv)

  ╬▒' : тДХ тЖТ тЯи freeBA тДХ QB./Im fтВА тЯй
  ╬▒' n = embBR (╬▒ n)

  open import BooleanRing.FreeBooleanRing.FreeBool using (generator)

  gen : тДХ тЖТ тЯи freeBA тДХ тЯй
  gen = generator

  encode : тДХ тКО тДХ тЖТ тДХ
  encode = Iso.fun тДХтКОтДХтЙЕтДХ

  decode : тДХ тЖТ тДХ тКО тДХ
  decode = Iso.inv тДХтКОтДХтЙЕтДХ

  open BooleanRingStr (snd (freeBA тДХ))

  g : тДХ тЖТ тЯи freeBA тДХ тЯй
  g n = if (╬▒ n) then ЁЭЯЩ else ЁЭЯШ

  h : тДХ тЖТ тЯи freeBA тДХ тЯй
  h n with decode n
  ... | inl m = fтВА m   -- relations from the original presentation
  ... | inr m = g m    -- relations from ╬▒

  presentationWitness : has-Boole-╧Й' (BoolBR QB./Im ╬▒)
  presentationWitness = h , equivToPresentation
    where

    step2-path : BooleanRingтЖТCommRing (freeBA тДХ QB./Im (тКО.rec fтВА g)) тЙб
                 BooleanRingтЖТCommRing ((freeBA тДХ QB./Im fтВА) QB./Im (╧АтВА тИШ g))
    step2-path = BoolQuotientEquiv (freeBA тДХ) fтВА g

    step2-equiv : BooleanRingEquiv (freeBA тДХ QB./Im (тКО.rec fтВА g)) ((freeBA тДХ QB./Im fтВА) QB./Im (╧АтВА тИШ g))
    step2-equiv = commRingPathтЖТboolRingEquiv (freeBA тДХ QB./Im (тКО.rec fтВА g)) ((freeBA тДХ QB./Im fтВА) QB./Im (╧АтВА тИШ g)) step2-path

    hтЙбrecтИШdecode-pointwise : (n : тДХ) тЖТ h n тЙб тКО.rec fтВА g (decode n)
    hтЙбrecтИШdecode-pointwise n with decode n
    ... | inl m = refl
    ... | inr m = refl

    hтЙбrecтИШdecode : h тЙб (тКО.rec fтВА g) тИШ decode
    hтЙбrecтИШdecode = funExt hтЙбrecтИШdecode-pointwise

    import Cubical.Algebra.CommRing.Quotient.ImageQuotient as IQ
    R = BooleanRingтЖТCommRing (freeBA тДХ)

    rec-of-decode : (n : тДХ) тЖТ тКО.rec fтВА g (decode n) тЙб h n
    rec-of-decode n = sym (hтЙбrecтИШdecode-pointwise n)

    encodeтИШdecode : (n : тДХ) тЖТ encode (decode n) тЙб n
    encodeтИШdecode = Iso.sec тДХтКОтДХтЙЕтДХ

    decodeтИШencode : (x : тДХ тКО тДХ) тЖТ decode (encode x) тЙб x
    decodeтИШencode = Iso.ret тДХтКОтДХтЙЕтДХ

    rec-quotient : BooleanRing тДУ-zero
    rec-quotient = freeBA тДХ QB./Im (тКО.rec fтВА g)

    h-quotient : BooleanRing тДУ-zero
    h-quotient = freeBA тДХ QB./Im h

    ╧А-rec : BoolHom (freeBA тДХ) rec-quotient
    ╧А-rec = QB.quotientImageHom

    ╧А-h : BoolHom (freeBA тДХ) h-quotient
    ╧А-h = QB.quotientImageHom

    ╧А-rec-sends-h-to-0 : (n : тДХ) тЖТ ╧А-rec $cr (h n) тЙб BooleanRingStr.ЁЭЯШ (snd rec-quotient)
    ╧А-rec-sends-h-to-0 n =
      ╧А-rec $cr (h n)
        тЙбтЯи cong (╧А-rec $cr_) (sym (rec-of-decode n)) тЯй
      ╧А-rec $cr ((тКО.rec fтВА g) (decode n))
        тЙбтЯи QB.zeroOnImage {B = freeBA тДХ} {f = тКО.rec fтВА g} (decode n) тЯй
      BooleanRingStr.ЁЭЯШ (snd rec-quotient) тИО

    step3-forward-hom : BoolHom h-quotient rec-quotient
    step3-forward-hom = QB.inducedHom {B = freeBA тДХ} {f = h} rec-quotient ╧А-rec ╧А-rec-sends-h-to-0

    rec-eq-h-encode : (x : тДХ тКО тДХ) тЖТ (тКО.rec fтВА g) x тЙб h (encode x)
    rec-eq-h-encode x =
      (тКО.rec fтВА g) x
        тЙбтЯи cong (тКО.rec fтВА g) (sym (decodeтИШencode x)) тЯй
      (тКО.rec fтВА g) (decode (encode x))
        тЙбтЯи rec-of-decode (encode x) тЯй
      h (encode x) тИО

    ╧А-h-sends-rec-to-0 : (x : тДХ тКО тДХ) тЖТ ╧А-h $cr ((тКО.rec fтВА g) x) тЙб BooleanRingStr.ЁЭЯШ (snd h-quotient)
    ╧А-h-sends-rec-to-0 x =
      ╧А-h $cr ((тКО.rec fтВА g) x)
        тЙбтЯи cong (╧А-h $cr_) (rec-eq-h-encode x) тЯй
      ╧А-h $cr (h (encode x))
        тЙбтЯи QB.zeroOnImage {B = freeBA тДХ} {f = h} (encode x) тЯй
      BooleanRingStr.ЁЭЯШ (snd h-quotient) тИО

    step3-backward-hom : BoolHom rec-quotient h-quotient
    step3-backward-hom = QB.inducedHom {B = freeBA тДХ} {f = тКО.rec fтВА g} h-quotient ╧А-h ╧А-h-sends-rec-to-0

    step3-forward : тЯи h-quotient тЯй тЖТ тЯи rec-quotient тЯй
    step3-forward = fst step3-forward-hom

    step3-backward : тЯи rec-quotient тЯй тЖТ тЯи h-quotient тЯй
    step3-backward = fst step3-backward-hom

    step3-forward-eval : step3-forward-hom тИШcr ╧А-h тЙб ╧А-rec
    step3-forward-eval = QB.evalInduce {B = freeBA тДХ} {f = h} rec-quotient ╧А-rec ╧А-rec-sends-h-to-0

    step3-backward-eval : step3-backward-hom тИШcr ╧А-rec тЙб ╧А-h
    step3-backward-eval = QB.evalInduce {B = freeBA тДХ} {f = тКО.rec fтВА g} h-quotient ╧А-h ╧А-h-sends-rec-to-0

    h-quotient-isSet : isSet тЯи h-quotient тЯй
    h-quotient-isSet = BooleanRingStr.is-set (snd h-quotient)

    rec-quotient-isSet : isSet тЯи rec-quotient тЯй
    rec-quotient-isSet = BooleanRingStr.is-set (snd rec-quotient)

    step3-backwardтИШforward-on-╧А : (x : тЯи freeBA тДХ тЯй) тЖТ step3-backward (step3-forward (fst ╧А-h x)) тЙб fst ╧А-h x
    step3-backwardтИШforward-on-╧А x =
      step3-backward (step3-forward (fst ╧А-h x))
        тЙбтЯи cong step3-backward (cong (╬╗ f тЖТ fst f x) step3-forward-eval) тЯй
      step3-backward (fst ╧А-rec x)
        тЙбтЯи cong (╬╗ f тЖТ fst f x) step3-backward-eval тЯй
      fst ╧А-h x тИО

    step3-backwardтИШforward-ext : (step3-backward тИШ step3-forward) тИШ fst ╧А-h тЙб (╬╗ x тЖТ x) тИШ fst ╧А-h
    step3-backwardтИШforward-ext = funExt step3-backwardтИШforward-on-╧А

    step3-backwardтИШforward : (x : тЯи h-quotient тЯй) тЖТ step3-backward (step3-forward x) тЙб x
    step3-backwardтИШforward = funExtтБ╗ (QB.quotientImageHomEpi {B = freeBA тДХ} {f = h} (тЯи h-quotient тЯй , h-quotient-isSet) step3-backwardтИШforward-ext)

    step3-forwardтИШbackward-on-╧А : (y : тЯи freeBA тДХ тЯй) тЖТ step3-forward (step3-backward (fst ╧А-rec y)) тЙб fst ╧А-rec y
    step3-forwardтИШbackward-on-╧А y =
      step3-forward (step3-backward (fst ╧А-rec y))
        тЙбтЯи cong step3-forward (cong (╬╗ f тЖТ fst f y) step3-backward-eval) тЯй
      step3-forward (fst ╧А-h y)
        тЙбтЯи cong (╬╗ f тЖТ fst f y) step3-forward-eval тЯй
      fst ╧А-rec y тИО

    step3-forwardтИШbackward-ext : (step3-forward тИШ step3-backward) тИШ fst ╧А-rec тЙб (╬╗ y тЖТ y) тИШ fst ╧А-rec
    step3-forwardтИШbackward-ext = funExt step3-forwardтИШbackward-on-╧А

    step3-forwardтИШbackward : (y : тЯи rec-quotient тЯй) тЖТ step3-forward (step3-backward y) тЙб y
    step3-forwardтИШbackward = funExtтБ╗ (QB.quotientImageHomEpi {B = freeBA тДХ} {f = тКО.rec fтВА g} (тЯи rec-quotient тЯй , rec-quotient-isSet) step3-forwardтИШbackward-ext)

    step3-iso : Iso тЯи h-quotient тЯй тЯи rec-quotient тЯй
    Iso.fun step3-iso = step3-forward
    Iso.inv step3-iso = step3-backward
    Iso.sec step3-iso = step3-forwardтИШbackward
    Iso.ret step3-iso = step3-backwardтИШforward

    step3-equiv-fun : тЯи h-quotient тЯй тЙГ тЯи rec-quotient тЯй
    step3-equiv-fun = isoToEquiv step3-iso

    step3-equiv' : BooleanRingEquiv h-quotient rec-quotient
    step3-equiv' = step3-equiv-fun , snd step3-forward-hom

    step3-h-eq : freeBA тДХ QB./Im h тЙб freeBA тДХ QB./Im (тКО.rec fтВА g)
    step3-h-eq = equivFun (BoolRingPath h-quotient rec-quotient) step3-equiv'

    step3-equiv : BooleanRingEquiv (freeBA тДХ QB./Im h) (freeBA тДХ QB./Im (тКО.rec fтВА g))
    step3-equiv = invEq (BoolRingPath _ _) step3-h-eq

    target : BooleanRing тДУ-zero
    target = (freeBA тДХ QB./Im fтВА) QB./Im ╬▒'

    embBR-hom : BoolHom BoolBR (freeBA тДХ QB./Im fтВА)
    embBR-hom = fst (fst equiv) , snd equiv

    ╧А-╬▒' : BoolHom (freeBA тДХ QB./Im fтВА) target
    ╧А-╬▒' = QB.quotientImageHom

    composite-hom : BoolHom BoolBR target
    composite-hom = ╧А-╬▒' тИШcr embBR-hom

    composite-sends-╬▒-to-0 : (n : тДХ) тЖТ composite-hom $cr (╬▒ n) тЙб BooleanRingStr.ЁЭЯШ (snd target)
    composite-sends-╬▒-to-0 n = QB.zeroOnImage {f = ╬▒'} n

    forward-hom : BoolHom (BoolBR QB./Im ╬▒) target
    forward-hom = QB.inducedHom target composite-hom composite-sends-╬▒-to-0

    source : BooleanRing тДУ-zero
    source = BoolBR QB./Im ╬▒

    equivтБ╗┬╣-hom : BoolHom (freeBA тДХ QB./Im fтВА) BoolBR
    equivтБ╗┬╣-hom = fst (fst (invBooleanRingEquiv BoolBR (freeBA тДХ QB./Im fтВА) equiv)) ,
                  snd (invBooleanRingEquiv BoolBR (freeBA тДХ QB./Im fтВА) equiv)

    ╧А-╬▒ : BoolHom BoolBR source
    ╧А-╬▒ = QB.quotientImageHom

    backward-composite : BoolHom (freeBA тДХ QB./Im fтВА) source
    backward-composite = ╧А-╬▒ тИШcr equivтБ╗┬╣-hom

    backward-composite-sends-╬▒'-to-0 : (n : тДХ) тЖТ backward-composite $cr (╬▒' n) тЙб BooleanRingStr.ЁЭЯШ (snd source)
    backward-composite-sends-╬▒'-to-0 n =
      backward-composite $cr (╬▒' n)
        тЙбтЯи refl тЯй
      ╧А-╬▒ $cr (equivтБ╗┬╣-hom $cr (embBR (╬▒ n)))
        тЙбтЯи cong (╧А-╬▒ $cr_) (Iso.ret (equivToIso (fst equiv)) (╬▒ n)) тЯй
      ╧А-╬▒ $cr (╬▒ n)
        тЙбтЯи QB.zeroOnImage {f = ╬▒} n тЯй
      BooleanRingStr.ЁЭЯШ (snd source) тИО

    backward-hom : BoolHom target source
    backward-hom = QB.inducedHom source backward-composite backward-composite-sends-╬▒'-to-0

    forward-fun : тЯи source тЯй тЖТ тЯи target тЯй
    forward-fun = fst forward-hom

    backward-fun : тЯи target тЯй тЖТ тЯи source тЯй
    backward-fun = fst backward-hom

    forward-eval : forward-hom тИШcr ╧А-╬▒ тЙб composite-hom
    forward-eval = QB.evalInduce {B = BoolBR} {f = ╬▒} target composite-hom composite-sends-╬▒-to-0

    backward-eval : backward-hom тИШcr ╧А-╬▒' тЙб backward-composite
    backward-eval = QB.evalInduce {B = freeBA тДХ QB./Im fтВА} {f = ╬▒'} source backward-composite backward-composite-sends-╬▒'-to-0

    equivтБ╗┬╣тИШembBRтЙбid : (x : Bool) тЖТ fst equivтБ╗┬╣-hom (embBR x) тЙб x
    equivтБ╗┬╣тИШembBRтЙбid = Iso.ret (equivToIso (fst equiv))

    source-isSet : isSet тЯи source тЯй
    source-isSet = is-set (snd source)
      where open BooleanRingStr

    target-isSet : isSet тЯи target тЯй
    target-isSet = is-set (snd target)
      where open BooleanRingStr

    backwardтИШforward-on-╧А : (x : Bool) тЖТ backward-fun (forward-fun (fst ╧А-╬▒ x)) тЙб fst ╧А-╬▒ x
    backwardтИШforward-on-╧А x =
      backward-fun (forward-fun (fst ╧А-╬▒ x))
        тЙбтЯи cong backward-fun (cong (╬╗ h тЖТ fst h x) forward-eval) тЯй
      backward-fun (fst composite-hom x)
        тЙбтЯи refl тЯй  -- composite-hom = ╧А-╬▒' тИШ embBR-hom
      backward-fun (fst ╧А-╬▒' (embBR x))
        тЙбтЯи cong (╬╗ h тЖТ fst h (embBR x)) backward-eval тЯй
      fst backward-composite (embBR x)
        тЙбтЯи refl тЯй  -- backward-composite = ╧А-╬▒ тИШ equivтБ╗┬╣-hom
      fst ╧А-╬▒ (fst equivтБ╗┬╣-hom (embBR x))
        тЙбтЯи cong (fst ╧А-╬▒) (equivтБ╗┬╣тИШembBRтЙбid x) тЯй
      fst ╧А-╬▒ x тИО

    backwardтИШforward-ext : (backward-fun тИШ forward-fun) тИШ fst ╧А-╬▒ тЙб (╬╗ x тЖТ x) тИШ fst ╧А-╬▒
    backwardтИШforward-ext = funExt backwardтИШforward-on-╧А

    backwardтИШforward : (x : тЯи source тЯй) тЖТ backward-fun (forward-fun x) тЙб x
    backwardтИШforward = funExtтБ╗ (QB.quotientImageHomEpi {B = BoolBR} {f = ╬▒} (тЯи source тЯй , source-isSet) backwardтИШforward-ext)

    embBRтИШequivтБ╗┬╣тЙбid : (y : тЯи freeBA тДХ QB./Im fтВА тЯй) тЖТ embBR (fst equivтБ╗┬╣-hom y) тЙб y
    embBRтИШequivтБ╗┬╣тЙбid = Iso.sec (equivToIso (fst equiv))

    forwardтИШbackward-on-╧А : (y : тЯи freeBA тДХ QB./Im fтВА тЯй) тЖТ forward-fun (backward-fun (fst ╧А-╬▒' y)) тЙб fst ╧А-╬▒' y
    forwardтИШbackward-on-╧А y =
      forward-fun (backward-fun (fst ╧А-╬▒' y))
        тЙбтЯи cong forward-fun (cong (╬╗ h тЖТ fst h y) backward-eval) тЯй
      forward-fun (fst backward-composite y)
        тЙбтЯи refl тЯй  -- backward-composite = ╧А-╬▒ тИШ equivтБ╗┬╣-hom
      forward-fun (fst ╧А-╬▒ (fst equivтБ╗┬╣-hom y))
        тЙбтЯи cong (╬╗ h тЖТ fst h (fst equivтБ╗┬╣-hom y)) forward-eval тЯй
      fst composite-hom (fst equivтБ╗┬╣-hom y)
        тЙбтЯи refl тЯй  -- composite-hom = ╧А-╬▒' тИШ embBR-hom
      fst ╧А-╬▒' (embBR (fst equivтБ╗┬╣-hom y))
        тЙбтЯи cong (fst ╧А-╬▒') (embBRтИШequivтБ╗┬╣тЙбid y) тЯй
      fst ╧А-╬▒' y тИО

    forwardтИШbackward-ext : (forward-fun тИШ backward-fun) тИШ fst ╧А-╬▒' тЙб (╬╗ y тЖТ y) тИШ fst ╧А-╬▒'
    forwardтИШbackward-ext = funExt forwardтИШbackward-on-╧А

    forwardтИШbackward : (y : тЯи target тЯй) тЖТ forward-fun (backward-fun y) тЙб y
    forwardтИШbackward = funExtтБ╗ (QB.quotientImageHomEpi {B = freeBA тДХ QB./Im fтВА} {f = ╬▒'} (тЯи target тЯй , target-isSet) forwardтИШbackward-ext)

    step1-iso : Iso тЯи source тЯй тЯи target тЯй
    Iso.fun step1-iso = forward-fun
    Iso.inv step1-iso = backward-fun
    Iso.sec step1-iso = forwardтИШbackward
    Iso.ret step1-iso = backwardтИШforward

    step1-equiv-fun : тЯи source тЯй тЙГ тЯи target тЯй
    step1-equiv-fun = isoToEquiv step1-iso

    step1-equiv : BooleanRingEquiv (BoolBR QB./Im ╬▒) ((freeBA тДХ QB./Im fтВА) QB./Im ╬▒')
    step1-equiv = step1-equiv-fun , snd forward-hom

    open IsCommRingHom

    embBR-pres0 : embBR false тЙб BooleanRingStr.ЁЭЯШ (snd (freeBA тДХ QB./Im fтВА))
    embBR-pres0 = pres0 (snd equiv)

    embBR-pres1 : embBR true тЙб BooleanRingStr.ЁЭЯЩ (snd (freeBA тДХ QB./Im fтВА))
    embBR-pres1 = pres1 (snd equiv)

