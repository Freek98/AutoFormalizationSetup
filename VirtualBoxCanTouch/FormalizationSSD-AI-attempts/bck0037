  where
  open IsCommRingHom (snd h') renaming (pres0 to h'-pres0 ; pres1 to h'-pres1 ; pres+ to h'-pres+ ; pres┬╖ to h'-pres┬╖)
  open CommRingStr (snd (BooleanRingтЖТCommRing BтИЮ)) renaming (_+_ to _+BтИЮ_ ; _┬╖_ to _┬╖BтИЮ_ ; +IdL to +BтИЮ-IdL ; +IdR to +BтИЮ-IdR)
  open CommRingStr (snd (BooleanRingтЖТCommRing BтИЮ├ЧBтИЮ)) renaming (_+_ to _+BтИЮ├ЧBтИЮ_ ; _┬╖_ to _┬╖BтИЮ├ЧBтИЮ_)
  open import Cubical.Algebra.CommRing using (makeIsCommRingHom)

  h-on-right : тЯи BтИЮ тЯй тЖТ Bool
  h-on-right x = h' $cr (ЁЭЯШтИЮ , x)

  h-on-right-pres0 : h-on-right ЁЭЯШтИЮ тЙб false
  h-on-right-pres0 = h'-pres0

  h-on-right-pres1 : h-on-right ЁЭЯЩтИЮ тЙб true
  h-on-right-pres1 =
    let
      h'-on-1 : h' $cr (ЁЭЯЩтИЮ , ЁЭЯЩтИЮ) тЙб true
      h'-on-1 = h'-pres1
      unit-sum' : (ЁЭЯЩтИЮ , ЁЭЯЩтИЮ) тЙб _+BтИЮ├ЧBтИЮ_ (ЁЭЯЩтИЮ , ЁЭЯШтИЮ) (ЁЭЯШтИЮ , ЁЭЯЩтИЮ)
      unit-sum' = congтВВ _,_ (sym (+BтИЮ-IdR ЁЭЯЩтИЮ)) (sym (+BтИЮ-IdL ЁЭЯЩтИЮ))
      h'-sum : h' $cr (ЁЭЯЩтИЮ , ЁЭЯЩтИЮ) тЙб (h' $cr unit-left) тКХ (h' $cr unit-right)
      h'-sum = cong (h' $cr_) unit-sum' тИЩ h'-pres+ unit-left unit-right
