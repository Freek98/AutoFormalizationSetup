        mтЙаn = mтЙаm+suc-d m d
    in fst ╧И-left-free (gen m ┬╖ gen n)
         тЙбтЯи IsCommRingHom.pres┬╖ (snd ╧И-left-free) (gen m) (gen n) тЯй
       BooleanRingStr._┬╖_ (snd BтИЮ├ЧBтИЮ-quotient) (fst ╧И-left-free (gen m)) (fst ╧И-left-free (gen n))
         тЙбтЯи congтВВ (BooleanRingStr._┬╖_ (snd BтИЮ├ЧBтИЮ-quotient))
