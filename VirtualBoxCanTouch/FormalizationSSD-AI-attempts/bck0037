meet-nf (joinForm ns) (joinForm ms) = joinForm (ns тИйL ms)
meet-nf (joinForm ns) (meetNegForm ms) = joinForm (ns тИЦL ms)
meet-nf (meetNegForm ns) (joinForm ms) = joinForm (ms тИЦL ns)
meet-nf (meetNegForm ns) (meetNegForm ms) = meetNegForm (ns ++ ms)

