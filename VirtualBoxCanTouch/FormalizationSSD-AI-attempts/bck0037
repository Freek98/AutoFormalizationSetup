    where
    open CommRingStr (snd (BooleanRingтЖТCommRing BтИЮ)) using () renaming (+IdL to +left-unit ; +IdR to +right-unit)

  unit-left-trueтЖТunit-right-false : (h : Sp BтИЮ├ЧBтИЮ-Boole╧Й)
    тЖТ h $cr unit-left тЙб true тЖТ h $cr unit-right тЙб false
  unit-left-trueтЖТunit-right-false h pf = true-тКХ-id (h $cr unit-right) chain
    where
    open CommRingStr (snd (BooleanRingтЖТCommRing BoolBR)) using () renaming (_+_ to _тКХBool_)
    h-sum : h $cr (unit-left +├Ч unit-right) тЙб (h $cr unit-left) тКХBool (h $cr unit-right)
    h-sum = IsCommRingHom.pres+ (snd h) unit-left unit-right
    h-one : h $cr (ЁЭЯЩтИЮ , ЁЭЯЩтИЮ) тЙб true
    h-one = IsCommRingHom.pres1 (snd h)
    true-тКХ-id : (b : Bool) тЖТ true тКХBool b тЙб true тЖТ b тЙб false
