  (тДХтИЮ-to-SpBтИЮ ╬▒) $cr (gтИЮ n)
    тЙбтЯи refl тЯй
  (тДХтИЮ-to-SpBтИЮ ╬▒) $cr (fst ╧АтИЮ (gen n))
    тЙбтЯи funExtтБ╗ (cong fst (тДХтИЮ-to-SpBтИЮ-eval ╬▒)) (gen n) тЯй
  fst (тДХтИЮ-to-SpBтИЮ-free ╬▒) (gen n)
    тЙбтЯи funExtтБ╗ (тДХтИЮ-to-SpBтИЮ-free-on-gen ╬▒) n тЯй
  тДХтИЮ-on-gen ╬▒ n
    тЙбтЯи refl тЯй
  fst ╬▒ n тИО

SpBтИЮ-roundtrip : (╬▒ : тДХтИЮ) тЖТ SpBтИЮ-to-тДХтИЮ (тДХтИЮ-to-SpBтИЮ ╬▒) тЙб ╬▒
SpBтИЮ-roundtrip ╬▒ = ╬гтЙбProp
  (╬╗ s тЖТ isPropHitsAtMostOnce s)
  (funExt (SpBтИЮ-roundtrip-seq ╬▒))

gтИЮ-has-witness : (n : тДХ) тЖТ (тДХтИЮ-to-SpBтИЮ (╬┤тИЮ n)) $cr (gтИЮ n) тЙб true
gтИЮ-has-witness n = SpBтИЮ-roundtrip-seq (╬┤тИЮ n) n тИЩ ╬┤тИЮ-hits-n n

gтИЮ-nonzero : (n : тДХ) тЖТ ┬м (gтИЮ n тЙб ЁЭЯШтИЮ)
gтИЮ-nonzero n gn=0 =
  let h = тДХтИЮ-to-SpBтИЮ (╬┤тИЮ n)
      h-gn=t : h $cr (gтИЮ n) тЙб true
      h-gn=t = gтИЮ-has-witness n
      h-0=f : h $cr ЁЭЯШтИЮ тЙб false
      h-0=f = IsCommRingHom.pres0 (snd h)
      h-gn=f : h $cr (gтИЮ n) тЙб false
      h-gn=f = cong (h $cr_) gn=0 тИЩ h-0=f
  in trueтЙвfalse (sym h-gn=t тИЩ h-gn=f)

xor-and-is-or : (a b : Bool) тЖТ (a тКХ b) тКХ (a and b) тЙб a or b
xor-and-is-or false false = refl
xor-and-is-or false true = refl
xor-and-is-or true false = refl
xor-and-is-or true true = refl

h-pres-join-Bool : (h : Sp BтИЮ-Boole╧Й) (a b : тЯи BтИЮ тЯй) тЖТ
  h $cr (a тИитИЮ b) тЙб (h $cr a) or (h $cr b)
h-pres-join-Bool h a b =
  let open IsCommRingHom (snd h) renaming (pres+ to h-pres+ ; pres┬╖ to h-pres┬╖)
  in h $cr (a тИитИЮ b)
       тЙбтЯи refl тЯй
     h $cr (a +тИЮ b +тИЮ (a ┬╖тИЮ b))
       тЙбтЯи h-pres+ (a +тИЮ b) (a ┬╖тИЮ b) тЯй
     (h $cr (a +тИЮ b)) тКХ (h $cr (a ┬╖тИЮ b))
       тЙбтЯи congтВВ _тКХ_ (h-pres+ a b) (h-pres┬╖ a b) тЯй
     ((h $cr a) тКХ (h $cr b)) тКХ ((h $cr a) and (h $cr b))
       тЙбтЯи xor-and-is-or (h $cr a) (h $cr b) тЯй
     (h $cr a) or (h $cr b) тИО

h-join-monotone : (h : Sp BтИЮ-Boole╧Й) (a b : тЯи BтИЮ тЯй) тЖТ
  h $cr a тЙб true тЖТ h $cr (a тИитИЮ b) тЙб true
h-join-monotone h a b ha=t =
  h $cr (a тИитИЮ b)
    тЙбтЯи h-pres-join-Bool h a b тЯй
  (h $cr a) or (h $cr b)
    тЙбтЯи cong (_or (h $cr b)) ha=t тЯй
  true or (h $cr b)
    тЙбтЯи refl тЯй
  true тИО

finJoinтИЮ-zeroтЖТempty : (ns : List тДХ) тЖТ finJoinтИЮ ns тЙб ЁЭЯШтИЮ тЖТ ns тЙб []
finJoinтИЮ-zeroтЖТempty [] _ = refl
finJoinтИЮ-zeroтЖТempty (n тИ╖ rest) join=0 = ex-falso contradiction
  where
  h : Sp BтИЮ-Boole╧Й
  h = тДХтИЮ-to-SpBтИЮ (╬┤тИЮ n)

  h-gn=true : h $cr (gтИЮ n) тЙб true
  h-gn=true = gтИЮ-has-witness n

  h-join=true : h $cr (finJoinтИЮ (n тИ╖ rest)) тЙб true
  h-join=true = h-join-monotone h (gтИЮ n) (finJoinтИЮ rest) h-gn=true

  h-0=false : h $cr ЁЭЯШтИЮ тЙб false
  h-0=false = IsCommRingHom.pres0 (snd h)

  h-join=false : h $cr (finJoinтИЮ (n тИ╖ rest)) тЙб false
  h-join=false = cong (h $cr_) join=0 тИЩ h-0=false

  contradiction : тКе
  contradiction = trueтЙвfalse (sym h-join=true тИЩ h-join=false)

тИЮ-seq : тДХ тЖТ Bool
тИЮ-seq _ = false

тИЮ-hamo : hitsAtMostOnce тИЮ-seq
тИЮ-hamo m n тИЮm=t _ = ex-falso (falseтЙвtrue тИЮm=t)

тДХтИЮ-тИЮ : тДХтИЮ
тДХтИЮ-тИЮ = тИЮ-seq , тИЮ-hamo

hтВА : Sp BтИЮ-Boole╧Й
hтВА = тДХтИЮ-to-SpBтИЮ тДХтИЮ-тИЮ

hтВА-on-gen : (n : тДХ) тЖТ hтВА $cr (gтИЮ n) тЙб false
hтВА-on-gen n = SpBтИЮ-roundtrip-seq тДХтИЮ-тИЮ n

h-pres-neg-Bool : (h : Sp BтИЮ-Boole╧Й) (x : тЯи BтИЮ тЯй) тЖТ
  h $cr (┬мтИЮ x) тЙб not (h $cr x)
h-pres-neg-Bool h x =
  let open IsCommRingHom (snd h) renaming (pres+ to h-pres+ ; pres1 to h-pres1)
  in h $cr (┬мтИЮ x)
       тЙбтЯи refl тЯй
     h $cr (ЁЭЯЩтИЮ +тИЮ x)
       тЙбтЯи h-pres+ ЁЭЯЩтИЮ x тЯй
     (h $cr ЁЭЯЩтИЮ) тКХ (h $cr x)
       тЙбтЯи cong (_тКХ (h $cr x)) h-pres1 тЯй
     true тКХ (h $cr x)
       тЙбтЯи тКХ-comm true (h $cr x) тЯй
     (h $cr x) тКХ true
       тЙбтЯи helper (h $cr x) тЯй
     not (h $cr x) тИО
  where
  helper : (b : Bool) тЖТ b тКХ true тЙб not b
  helper false = refl
  helper true = refl

hтВА-on-neg-gen : (n : тДХ) тЖТ hтВА $cr (┬мтИЮ (gтИЮ n)) тЙб true
hтВА-on-neg-gen n =
  hтВА $cr (┬мтИЮ (gтИЮ n))
    тЙбтЯи h-pres-neg-Bool hтВА (gтИЮ n) тЯй
  not (hтВА $cr (gтИЮ n))
    тЙбтЯи cong not (hтВА-on-gen n) тЯй
  not false
    тЙбтЯи refl тЯй
  true тИО

h-pres-meet-Bool : (h : Sp BтИЮ-Boole╧Й) (a b : тЯи BтИЮ тЯй) тЖТ
  h $cr (a тИзтИЮ b) тЙб (h $cr a) and (h $cr b)
h-pres-meet-Bool h a b = IsCommRingHom.pres┬╖ (snd h) a b

h-meet-preserves-true : (h : Sp BтИЮ-Boole╧Й) (a b : тЯи BтИЮ тЯй) тЖТ
  h $cr a тЙб true тЖТ h $cr b тЙб true тЖТ h $cr (a тИзтИЮ b) тЙб true
h-meet-preserves-true h a b ha=t hb=t =
  h $cr (a тИзтИЮ b)
    тЙбтЯи h-pres-meet-Bool h a b тЯй
  (h $cr a) and (h $cr b)
    тЙбтЯи congтВВ _and_ ha=t hb=t тЯй
  true and true
    тЙбтЯи refl тЯй
  true тИО

hтВА-on-finMeetNeg : (ns : List тДХ) тЖТ hтВА $cr (finMeetNegтИЮ ns) тЙб true
hтВА-on-finMeetNeg [] = IsCommRingHom.pres1 (snd hтВА)
hтВА-on-finMeetNeg (n тИ╖ ns) =
  h-meet-preserves-true hтВА (┬мтИЮ (gтИЮ n)) (finMeetNegтИЮ ns)
    (hтВА-on-neg-gen n)
    (hтВА-on-finMeetNeg ns)

finMeetNegтИЮ-nonzero : (ns : List тДХ) тЖТ ┬м (finMeetNegтИЮ ns тЙб ЁЭЯШтИЮ)
finMeetNegтИЮ-nonzero ns meet=0 = contradiction
  where
  hтВА-meet=true : hтВА $cr (finMeetNegтИЮ ns) тЙб true
  hтВА-meet=true = hтВА-on-finMeetNeg ns

  hтВА-0=false : hтВА $cr ЁЭЯШтИЮ тЙб false
  hтВА-0=false = IsCommRingHom.pres0 (snd hтВА)

  hтВА-meet=false : hтВА $cr (finMeetNegтИЮ ns) тЙб false
  hтВА-meet=false = cong (hтВА $cr_) meet=0 тИЩ hтВА-0=false

  contradiction : тКе
  contradiction = trueтЙвfalse (sym hтВА-meet=true тИЩ hтВА-meet=false)

splitByParity-evens : List тДХ тЖТ List тДХ
splitByParity-evens ns = fst (splitByParity ns)

splitByParity-odds : List тДХ тЖТ List тДХ
splitByParity-odds ns = snd (splitByParity ns)

splitByParity-cons-even : (n : тДХ) (ns : List тДХ) тЖТ isEven n тЙб true тЖТ
  splitByParity-evens (n тИ╖ ns) тЙб half n тИ╖ splitByParity-evens ns
splitByParity-cons-even n ns even-n with isEven n | splitByParity ns
... | true  | (evens , odds) = refl
... | false | (evens , odds) = ex-falso (falseтЙвtrue even-n)

splitByParity-cons-odd : (n : тДХ) (ns : List тДХ) тЖТ isEven n тЙб false тЖТ
  splitByParity-odds (n тИ╖ ns) тЙб half n тИ╖ splitByParity-odds ns
splitByParity-cons-odd n ns odd-n with isEven n | splitByParity ns
... | false | (evens , odds) = refl
... | true  | (evens , odds) = ex-falso (trueтЙвfalse odd-n)

splitByParity-nonempty : (ns : List тДХ) тЖТ
  let (evens , odds) = splitByParity ns
  in evens тЙб [] тЖТ odds тЙб [] тЖТ ns тЙб []
splitByParity-nonempty [] _ _ = refl
splitByParity-nonempty (n тИ╖ ns) evens=[] odds=[] = splitByParity-nonempty-aux (isEven n) refl
  where
  splitByParity-nonempty-aux : (b : Bool) тЖТ isEven n тЙб b тЖТ (n тИ╖ ns) тЙб []
  splitByParity-nonempty-aux true parity =
    let evens-eq = splitByParity-cons-even n ns parity
        contradiction : half n тИ╖ splitByParity-evens ns тЙб []
        contradiction = sym evens-eq тИЩ evens=[]
    in ex-falso (┬мconsтЙбnil contradiction)
  splitByParity-nonempty-aux false parity =
    let odds-eq = splitByParity-cons-odd n ns parity
        contradiction : half n тИ╖ splitByParity-odds ns тЙб []
        contradiction = sym odds-eq тИЩ odds=[]
    in ex-falso (┬мconsтЙбnil contradiction)

splitByParity-ns-nonempty : (ns : List тДХ) тЖТ ┬м (ns тЙб []) тЖТ
  let (evens , odds) = splitByParity ns
  in ┬м ((evens тЙб []) ├Ч (odds тЙб []))
splitByParity-ns-nonempty ns nsтЙа[] (evens=[] , odds=[]) =
  nsтЙа[] (splitByParity-nonempty ns evens=[] odds=[])

f-kernel-joinForm : (ns : List тДХ) тЖТ
  let (evens , odds) = splitByParity ns
  in fst f (finJoinтИЮ ns) тЙб (ЁЭЯШтИЮ , ЁЭЯШтИЮ) тЖТ ns тЙб []
f-kernel-joinForm ns fx=0 =
  let evens = splitByParity-evens ns
      odds = splitByParity-odds ns

      f-eq : fst f (finJoinтИЮ ns) тЙб (finJoinтИЮ evens , finJoinтИЮ odds)
      f-eq = f-on-finJoin ns

      f-split : (finJoinтИЮ evens , finJoinтИЮ odds) тЙб (ЁЭЯШтИЮ , ЁЭЯШтИЮ)
      f-split = sym f-eq тИЩ fx=0

      evens-join=0 : finJoinтИЮ evens тЙб ЁЭЯШтИЮ
      evens-join=0 = cong fst f-split

      odds-join=0 : finJoinтИЮ odds тЙб ЁЭЯШтИЮ
      odds-join=0 = cong snd f-split

      evens=[] : evens тЙб []
      evens=[] = finJoinтИЮ-zeroтЖТempty evens evens-join=0

      odds=[] : odds тЙб []
      odds=[] = finJoinтИЮ-zeroтЖТempty odds odds-join=0

  in splitByParity-nonempty ns evens=[] odds=[]

f-kernel-normalForm : (nf : BтИЮ-NormalForm) тЖТ fst f тЯж nf тЯзnf тЙб (ЁЭЯШтИЮ , ЁЭЯШтИЮ) тЖТ тЯж nf тЯзnf тЙб ЁЭЯШтИЮ
f-kernel-normalForm (joinForm ns) fx=0 =
  let ns=[] : ns тЙб []
      ns=[] = f-kernel-joinForm ns fx=0
  in cong finJoinтИЮ ns=[]
f-kernel-normalForm (meetNegForm ns) fx=0 =
  ex-falso (f-meetNeg-nonzero fx=0)
  where
  h' : тЯи BтИЮ├ЧBтИЮ тЯй тЖТ Bool
  h' (a , b) = hтВА $cr a

  h'-on-f-neg-gen-even : (k : тДХ) тЖТ h' (fst f (┬мтИЮ (gтИЮ (2 ┬╖тДХ k)))) тЙб true
  h'-on-f-neg-gen-even k =
    h' (fst f (┬мтИЮ (gтИЮ (2 ┬╖тДХ k))))
      тЙбтЯи cong h' (f-pres-neg (gтИЮ (2 ┬╖тДХ k))) тЯй
    h' (┬мтИЮ (fst (fst f (gтИЮ (2 ┬╖тДХ k)))) , ┬мтИЮ (snd (fst f (gтИЮ (2 ┬╖тДХ k)))))
      тЙбтЯи cong (╬╗ x тЖТ h' (┬мтИЮ (fst x) , ┬мтИЮ (snd x))) (f-even-gen k) тЯй
    h' (┬мтИЮ (gтИЮ k) , ┬мтИЮ ЁЭЯШтИЮ)
      тЙбтЯи refl тЯй
    hтВА $cr (┬мтИЮ (gтИЮ k))
      тЙбтЯи hтВА-on-neg-gen k тЯй
    true тИО

  h'-on-f-neg-gen-odd : (k : тДХ) тЖТ h' (fst f (┬мтИЮ (gтИЮ (suc (2 ┬╖тДХ k))))) тЙб true
  h'-on-f-neg-gen-odd k =
    h' (fst f (┬мтИЮ (gтИЮ (suc (2 ┬╖тДХ k)))))
      тЙбтЯи cong h' (f-pres-neg (gтИЮ (suc (2 ┬╖тДХ k)))) тЯй
    h' (┬мтИЮ (fst (fst f (gтИЮ (suc (2 ┬╖тДХ k))))) , ┬мтИЮ (snd (fst f (gтИЮ (suc (2 ┬╖тДХ k))))))
      тЙбтЯи cong (╬╗ x тЖТ h' (┬мтИЮ (fst x) , ┬мтИЮ (snd x))) (f-odd-gen k) тЯй
    h' (┬мтИЮ ЁЭЯШтИЮ , ┬мтИЮ (gтИЮ k))
      тЙбтЯи refl тЯй
    hтВА $cr (┬мтИЮ ЁЭЯШтИЮ)
      тЙбтЯи h-pres-neg-Bool hтВА ЁЭЯШтИЮ тЯй
    not (hтВА $cr ЁЭЯШтИЮ)
      тЙбтЯи cong not (IsCommRingHom.pres0 (snd hтВА)) тЯй
    not false
      тЙбтЯи refl тЯй
    true тИО

  h'-on-f-neg-gen : (n : тДХ) тЖТ h' (fst f (┬мтИЮ (gтИЮ n))) тЙб true
  h'-on-f-neg-gen n = h'-on-f-neg-gen-aux (isEven n) refl
    where
    h'-on-f-neg-gen-aux : (b : Bool) тЖТ isEven n тЙб b тЖТ h' (fst f (┬мтИЮ (gтИЮ n))) тЙб true
    h'-on-f-neg-gen-aux true even-n =
      let k = half n
          n=2k : n тЙб 2 ┬╖тДХ k
          n=2k = sym (isEvenтЖТeven n even-n)
      in subst (╬╗ m тЖТ h' (fst f (┬мтИЮ (gтИЮ m))) тЙб true) (sym n=2k) (h'-on-f-neg-gen-even k)
    h'-on-f-neg-gen-aux false odd-n =
      let k = half n
          n=2k+1 : n тЙб suc (2 ┬╖тДХ k)
          n=2k+1 = sym (isEvenтЖТodd n odd-n)
      in subst (╬╗ m тЖТ h' (fst f (┬мтИЮ (gтИЮ m))) тЙб true) (sym n=2k+1) (h'-on-f-neg-gen-odd k)

  h'-pres-┬╖ : (x y : тЯи BтИЮ├ЧBтИЮ тЯй) тЖТ h' (x ┬╖├Ч y) тЙб (h' x) and (h' y)
  h'-pres-┬╖ (aтВБ , bтВБ) (aтВВ , bтВВ) = IsCommRingHom.pres┬╖ (snd hтВА) aтВБ aтВВ

  h'-on-f-finMeetNeg : (ms : List тДХ) тЖТ h' (fst f (finMeetNegтИЮ ms)) тЙб true
  h'-on-f-finMeetNeg [] =
    h' (fst f ЁЭЯЩтИЮ)
      тЙбтЯи cong h' f-pres1 тЯй
    h' (ЁЭЯЩтИЮ , ЁЭЯЩтИЮ)
      тЙбтЯи refl тЯй
    hтВА $cr ЁЭЯЩтИЮ
      тЙбтЯи IsCommRingHom.pres1 (snd hтВА) тЯй
    true тИО
  h'-on-f-finMeetNeg (m тИ╖ ms) =
    h' (fst f (finMeetNegтИЮ (m тИ╖ ms)))
      тЙбтЯи refl тЯй
    h' (fst f ((┬мтИЮ (gтИЮ m)) тИзтИЮ (finMeetNegтИЮ ms)))
      тЙбтЯи cong h' (IsCommRingHom.pres┬╖ (snd f) (┬мтИЮ (gтИЮ m)) (finMeetNegтИЮ ms)) тЯй
    h' ((fst f (┬мтИЮ (gтИЮ m))) ┬╖├Ч (fst f (finMeetNegтИЮ ms)))
      тЙбтЯи h'-pres-┬╖ (fst f (┬мтИЮ (gтИЮ m))) (fst f (finMeetNegтИЮ ms)) тЯй
    (h' (fst f (┬мтИЮ (gтИЮ m)))) and (h' (fst f (finMeetNegтИЮ ms)))
      тЙбтЯи congтВВ _and_ (h'-on-f-neg-gen m) (h'-on-f-finMeetNeg ms) тЯй
    true and true
      тЙбтЯи refl тЯй
    true тИО

  f-meetNeg-nonzero : fst f (finMeetNegтИЮ ns) тЙб (ЁЭЯШтИЮ , ЁЭЯШтИЮ) тЖТ тКе
  f-meetNeg-nonzero f-meetNeg=0 = falseтЙвtrue (sym h'-on-0 тИЩ h'-on-f-meetNeg-eq-0)
    where
    h'-on-0 : h' (ЁЭЯШтИЮ , ЁЭЯШтИЮ) тЙб false
    h'-on-0 = IsCommRingHom.pres0 (snd hтВА)

    h'-on-f-meetNeg : h' (fst f (finMeetNegтИЮ ns)) тЙб true
    h'-on-f-meetNeg = h'-on-f-finMeetNeg ns

    h'-on-f-meetNeg-eq-0 : h' (ЁЭЯШтИЮ , ЁЭЯШтИЮ) тЙб true
    h'-on-f-meetNeg-eq-0 = subst (╬╗ z тЖТ h' z тЙб true) f-meetNeg=0 h'-on-f-meetNeg

llpo-from-SD-aux : (h : Sp BтИЮ-Boole╧Й) тЖТ
  ((k : тДХ) тЖТ h $cr (gтИЮ (2 ┬╖тДХ k)) тЙб false) тКО ((k : тДХ) тЖТ h $cr (gтИЮ (suc (2 ┬╖тДХ k))) тЙб false)
llpo-from-SD-aux h = PT.rec llpo-is-prop go (Sp-f-surjective h)
  where
  open import Cubical.Data.Sum.Properties using (isPropтКО)

  evens-is-prop : isProp ((k : тДХ) тЖТ h $cr (gтИЮ (2 ┬╖тДХ k)) тЙб false)
  evens-is-prop = isProp╬а (╬╗ k тЖТ isSetBool _ _)

  odds-is-prop : isProp ((k : тДХ) тЖТ h $cr (gтИЮ (suc (2 ┬╖тДХ k))) тЙб false)
