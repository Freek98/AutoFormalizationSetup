            тЙбтЯи cong step1-backward-fun (cong (╬╗ hom тЖТ fst hom x) step1-forward-eval) тЯй
          step1-backward-fun (fst composite-hom-1 x)
            тЙбтЯи refl тЯй
          step1-backward-fun (fst ╧А-d' (fst (fst equiv) x))
