      h-and-eq = sym (h-pres┬╖ (gтИЮ m) (gтИЮ n))

      and-is-false : (h $cr (gтИЮ m)) and (h $cr (gтИЮ n)) тЙб false
      and-is-false = h-and-eq тИЩ h-mult

      step1 : true and true тЙб (h $cr (gтИЮ m)) and (h $cr (gтИЮ n))
