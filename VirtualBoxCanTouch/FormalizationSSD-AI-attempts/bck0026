{-# OPTIONS --cubical --lossy-unification --guardedness #-}

{-
  Sequential colimits are closed under Σ-types and path types.

  Based on:
    Sojakova, van Doorn, Rijke,
    "Sequential Colimits in Homotopy Type Theory" (LICS 2020)

  Main results:
    Theorem 5.1: colim(Σ_{(A,a)}(B,b)) ≃ Σ_{x:A∞} B∞(x)
    Theorem 7.4: (ι(n,a₁) ≡ ι(n,a₂)) ≃ colim_k(a₁^{+k} ≡ a₂^{+k})
-}

module SeqColimClosure where

open import Cubical.Foundations.Prelude
open import Cubical.Foundations.Equiv
open import Cubical.Foundations.Isomorphism
open import Cubical.Foundations.HLevels
open import Cubical.Foundations.Function
open import Cubical.Foundations.Transport
open import Cubical.Foundations.GroupoidLaws
open import Cubical.Foundations.Univalence
open import Cubical.Foundations.Path

open import Cubical.Data.Nat
open import Cubical.Data.Sigma
open import Cubical.Data.Sequence
open import Cubical.HITs.SequentialColimit.Base
