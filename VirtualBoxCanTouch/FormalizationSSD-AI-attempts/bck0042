-- В§2. Iterated maps
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
iterMap : (X : Sequence в„“) (k : в„•) {n : в„•} вҶ’ obj X n вҶ’ obj X (k + n)
iterMap X zero    x = x
iterMap X (suc k) x = map X (iterMap X k x)

push-fwd : (X : Sequence в„“) (k : в„•) {n : в„•} (x : obj X n)
  вҶ’ incl {X = X} x вүЎ incl (iterMap X k x)
push-fwd X zero    x = refl
push-fwd X (suc k) x = push-fwd X k x вҲҷ push (iterMap X k x)

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- В§3. Colimit of contractible types is contractible
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
contrвҶ’converges : (X : Sequence в„“) вҶ’ ((n : в„•) вҶ’ isContr (obj X n)) вҶ’ converges X 0
contrвҶ’converges X hC k =
  subst (О» m вҶ’ isEquiv (map X {n = m})) (sym (+-zero k))
    (isEquivFromIsContr (map X) (hC k) (hC (suc k)))

colimitContr : (X : Sequence в„“) вҶ’ ((n : в„•) вҶ’ isContr (obj X n)) вҶ’ isContr (SeqColim X)
colimitContr X hC =
  isOfHLevelRespectEquiv 0
    (isoToEquiv (convergesвҶ’ColimIso 0 (contrвҶ’converges X hC))) (hC 0)

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- В§4вҖ“6. Truncated sequence and propositional truncation commutes
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
truncSeq : Sequence в„“ вҶ’ Sequence в„“
obj (truncSeq X) n = вҲҘ obj X n вҲҘвӮҒ
map (truncSeq X) = PT.map (map X)

trunc-fwd : (X : Sequence в„“) вҶ’ SeqColim X вҶ’ SeqColim (truncSeq X)
trunc-fwd X (incl x)   = incl вҲЈ x вҲЈвӮҒ
trunc-fwd X (push x i) = push вҲЈ x вҲЈвӮҒ i

trunc-bwd : (X : Sequence в„“) вҶ’ SeqColim (truncSeq X) вҶ’ вҲҘ SeqColim X вҲҘвӮҒ
trunc-bwd X = SeqColim-elimProp (truncSeq X)
  (О» _ вҶ’ squashвӮҒ) (О» {n} ta вҶ’ PT.rec squashвӮҒ (О» a вҶ’ вҲЈ incl {n = n} a вҲЈвӮҒ) ta)

truncSeq-contr-from-incl : (X : Sequence в„“) {n : в„•} (a : obj X n)
  вҶ’ isContr (SeqColim (truncSeq X))
truncSeq-contr-from-incl X {n} a =
  isOfHLevelRespectEquiv 0 (isoToEquiv (invIso (SeqColimIso (truncSeq X) n)))
    (colimitContr (ShiftSequence+ (truncSeq X) n)
      (О» k вҶ’ inhPropвҶ’isContr вҲЈ iterMap X k a вҲЈвӮҒ squashвӮҒ))

SeqColim-truncSeq-isProp : (X : Sequence в„“) вҶ’ isProp (SeqColim (truncSeq X))
SeqColim-truncSeq-isProp X x y = sym (snd c x) вҲҷ snd c y where
  c = SeqColim-elimProp (truncSeq X) (О» _ вҶ’ isPropIsContr)
    (О» {n} ta вҶ’ PT.rec isPropIsContr (О» a вҶ’ truncSeq-contr-from-incl X a) ta) x

truncCommutes : (X : Sequence в„“) вҶ’ Iso вҲҘ SeqColim X вҲҘвӮҒ (SeqColim (truncSeq X))
fun (truncCommutes X) = PT.rec (SeqColim-truncSeq-isProp X) (trunc-fwd X)
inv (truncCommutes X) = trunc-bwd X
sec (truncCommutes X) _ = SeqColim-truncSeq-isProp X _ _
ret (truncCommutes X) _ = squashвӮҒ _ _

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- В§7. Universal property
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
record Cocone (X : Sequence в„“) (B : Type в„“') : Type (в„“-max в„“ в„“') where
  constructor cocone
  field
    leg  : {n : в„•} вҶ’ obj X n вҶ’ B
    comm : {n : в„•} (a : obj X n) вҶ’ leg a вүЎ leg (map X a)
open Cocone

canonCocone : (X : Sequence в„“) вҶ’ Cocone X (SeqColim X)
leg  (canonCocone X) = incl
comm (canonCocone X) = push

coconeRec : (X : Sequence в„“) {B : Type в„“'} вҶ’ Cocone X B вҶ’ SeqColim X вҶ’ B
coconeRec X c (incl x)   = leg c x
coconeRec X c (push x i) = comm c x i

restrict : (X : Sequence в„“) {B : Type в„“'} вҶ’ (SeqColim X вҶ’ B) вҶ’ Cocone X B
leg  (restrict X f) a = f (incl a)
comm (restrict X f) a = cong f (push a)

restrictвҲҳrec : (X : Sequence в„“) {B : Type в„“'} (c : Cocone X B) вҶ’ restrict X (coconeRec X c) вүЎ c
restrictвҲҳrec X c = refl

recвҲҳrestrict : (X : Sequence в„“) {B : Type в„“'} (f : SeqColim X вҶ’ B) вҶ’ coconeRec X (restrict X f) вүЎ f
recвҲҳrestrict X f = funExt go where
  go : (x : SeqColim X) вҶ’ coconeRec X (restrict X f) x вүЎ f x
  go (incl x)   = refl
  go (push x i) = refl

coconeEquiv : (X : Sequence в„“) (B : Type в„“') вҶ’ (SeqColim X вҶ’ B) вүғ Cocone X B
coconeEquiv X B = isoToEquiv (iso (restrict X) (coconeRec X) (restrictвҲҳrec X) (recвҲҳrestrict X))

coconeRec-unique : (X : Sequence в„“) {B : Type в„“'} вҶ’ isSet B
  вҶ’ (f g : SeqColim X вҶ’ B) вҶ’ ((n : в„•) (a : obj X n) вҶ’ f (incl a) вүЎ g (incl a)) вҶ’ f вүЎ g
coconeRec-unique X hB f g agree = funExt go where
  go : (x : SeqColim X) вҶ’ f x вүЎ g x
  go (incl {n} x) = agree n x
  go (push {n} x i) = isPropвҶ’PathP (О» i вҶ’ hB (f (push x i)) (g (push x i)))
    (agree n x) (agree (suc n) (map X x)) i

coconeвҶ’equiv : (X : Sequence в„“) {B : Type в„“'} вҶ’ (c : Cocone X B) вҶ’ isEquiv (coconeRec X c) вҶ’ B вүғ SeqColim X
coconeвҶ’equiv X c isE = invEquiv (coconeRec X c , isE)

CoconeвүЎ : (X : Sequence в„“) {B : Type в„“'} вҶ’ isSet B вҶ’ {c d : Cocone X B}
  вҶ’ ({n : в„•} вҶ’ leg c {n} вүЎ leg d {n}) вҶ’ c вүЎ d
leg  (CoconeвүЎ X hB p i) a = p i a
comm (CoconeвүЎ X hB {c} {d} p i) a =
  isPropвҶ’PathP (О» i вҶ’ hB (p i a) (p i (map X a))) (comm c a) (comm d a) i

restrictFrom : {X : Sequence в„“} {B : Type в„“'} (c : Cocone X B) {C : Type в„“'} вҶ’ (B вҶ’ C) вҶ’ Cocone X C
leg  (restrictFrom c f) = f вҲҳ leg c
comm (restrictFrom c f) a = cong f (comm c a)

-- The UP with uniqueness: for each cocone d into C, recB d is the UNIQUE
-- extension along c. No isSet hypothesis needed.
module ColimitCharacterization (X : Sequence в„“) {B : Type в„“}
  (c : Cocone X B)
  (recB    : {C : Type в„“} вҶ’ Cocone X C вҶ’ (B вҶ’ C))
  (secB    : {C : Type в„“} (d : Cocone X C) вҶ’ restrictFrom c (recB d) вүЎ d)
  (uniqueB : {C : Type в„“} (d : Cocone X C) (f : B вҶ’ C) вҶ’ restrictFrom c f вүЎ d вҶ’ f вүЎ recB d)
  where

  compare : SeqColim X вҶ’ B
  compare = coconeRec X c

  embed : B вҶ’ SeqColim X
  embed = recB (canonCocone X)

  sec-path : restrictFrom c embed вүЎ canonCocone X
  sec-path = secB (canonCocone X)

  -- Roundtrip 2: embed вҲҳ compare вүЎ id (same proof as before)
  roundtripвӮӮ : embed вҲҳ compare вүЎ idfun (SeqColim X)
  roundtripвӮӮ = sym (recвҲҳrestrict X (embed вҲҳ compare))
    вҲҷ cong (coconeRec X) sec-path
    вҲҷ recвҲҳrestrict X (idfun _)

  -- Roundtrip 1: compare вҲҳ embed вүЎ id (NO isSet needed!)
  -- Both (compare вҲҳ embed) and id satisfy restrictFrom c (-) вүЎ c.
  -- By uniqueness, both equal recB c, hence equal each other.

  -- id satisfies restrictFrom c id вүЎ c (definitionally):
  restrict-id : restrictFrom c (idfun B) вүЎ c
  restrict-id = refl

  -- compare вҲҳ embed satisfies restrictFrom c (compare вҲҳ embed) вүЎ c:
  -- Key: sec-path gives restrictFrom c embed вүЎ canonCocone X, including comms.
  -- Then: comm (restrictFrom c (compare вҲҳ embed)) a
  --     = cong (compare вҲҳ embed) (comm c a)
  --     = cong compare (cong embed (comm c a))
  -- From sec-path, cong embed (comm c a) is identified with push a.
  -- And cong compare (push a) = cong (coconeRec X c) (push a) = comm c a (definitionally).
  -- So the full cocone equality is built from sec-path + HIT computation.
  restrict-comp-embed : restrictFrom c (compare вҲҳ embed) вүЎ c
  leg  (restrict-comp-embed i) {n} a = compare (cong (О» cc вҶ’ leg cc {n} a) sec-path i)
  comm (restrict-comp-embed i) {n} a j = compare (cong (О» cc вҶ’ comm cc {n} a j) sec-path i)

  roundtripвӮҒ : compare вҲҳ embed вүЎ idfun B
  roundtripвӮҒ = uniqueB c (compare вҲҳ embed) restrict-comp-embed
    вҲҷ sym (uniqueB c (idfun B) refl)

  colimIso : Iso B (SeqColim X)
  fun colimIso = embed
  inv colimIso = compare
  sec colimIso = funExtвҒ» roundtripвӮӮ
  ret colimIso = funExtвҒ» roundtripвӮҒ

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- В§8. SeqColim X вүғ Type quotient of total space, and isSet
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

Total : Sequence в„“ вҶ’ Type в„“
Total X = ОЈ[ n вҲҲ в„• ] obj X n

-- PushRel as a ОЈ-type (no data declaration, no K issues, no warnings)
PushRel : (X : Sequence в„“) вҶ’ Total X вҶ’ Total X вҶ’ Type в„“
PushRel X (n , a) (m , b) = ОЈ[ p вҲҲ suc n вүЎ m ] PathP (О» i вҶ’ obj X (p i)) (map X a) b

-- Canonical witness
push-wit : (X : Sequence в„“) {n : в„•} (a : obj X n) вҶ’ PushRel X (n , a) (suc n , map X a)
push-wit _ _ = refl , refl

-- PushRel is prop-valued when levels are sets (immediate from ОЈ of props)
PushRel-isProp : (X : Sequence в„“) вҶ’ ((k : в„•) вҶ’ isSet (obj X k))
  вҶ’ (x y : Total X) вҶ’ isProp (PushRel X x y)
PushRel-isProp X hS (n , a) (m , b) =
  isPropОЈ (isSetв„• (suc n) m) (О» p вҶ’ isOfHLevelPathP' 1 (hS m) (map X a) b)

-- Helper: a PushRel proof gives a path in SeqColim
relвҶ’path : (X : Sequence в„“) {n : в„•} {a : obj X n} {m : в„•} {b : obj X m}
  вҶ’ PushRel X (n , a) (m , b) вҶ’ incl {X = X} {n = n} a вүЎ incl {n = m} b
relвҶ’path X {a = a} (p , q) = push a вҲҷ О» i вҶ’ incl {n = p i} (q i)

-- Type quotient (no truncation)
TQColim : Sequence в„“ вҶ’ Type в„“
TQColim X = Total X /вӮң PushRel X

-- Maps between SeqColim X and TQColim X
toTQ : (X : Sequence в„“) вҶ’ SeqColim X вҶ’ TQColim X
toTQ X (incl {n} a) = [ n , a ]вӮң
toTQ X (push a i) = eq/вӮң _ _ (push-wit X a) i

fromTQ : (X : Sequence в„“) вҶ’ TQColim X вҶ’ SeqColim X
fromTQ X [ n , a ]вӮң = incl {n = n} a
fromTQ X (eq/вӮң (n , a) _ r i) = relвҶ’path X r i

-- ret: fromTQ вҲҳ toTQ вүЎ id on SeqColim
fromTQвҲҳtoTQ : (X : Sequence в„“) вҶ’ (x : SeqColim X) вҶ’ fromTQ X (toTQ X x) вүЎ x
fromTQвҲҳtoTQ X (incl _) = refl
fromTQвҲҳtoTQ X (push a i) j = rUnit (push a) (~ j) i

-- For the other direction (toTQ вҲҳ fromTQ вүЎ id on TQColim), the eq/вӮң case
-- introduces a rUnit that can't be resolved without isSet(TQColim).
-- But we only need the EQUIVALENCE, which we get from ColimitCharacterization:
-- TQColim has the full UP, so it's isomorphic to SeqColim.
-- The isSet(TQColim) hypothesis is only needed for roundtripвӮҒ.

-- Set quotient (with truncation вҖ” automatically a set)
QColim : Sequence в„“ вҶ’ Type в„“
QColim X = Total X / PushRel X

-- QColim cocone and recursor
QColim-cocone : (X : Sequence в„“) вҶ’ Cocone X (QColim X)
leg  (QColim-cocone X) {n} a = [ n , a ]
comm (QColim-cocone X) a = eq/ _ _ (push-wit X a)

QColim-rec : (X : Sequence в„“) {B : Type в„“} вҶ’ isSet B вҶ’ Cocone X B вҶ’ QColim X вҶ’ B
QColim-rec X hB c = SQ.rec hB (О» { (n , a) вҶ’ leg c a })
  О» { (n , a) (m , b) (p , q) вҶ’ comm c a вҲҷ (О» i вҶ’ leg c {p i} (q i)) }

toQ : (X : Sequence в„“) вҶ’ SeqColim X вҶ’ QColim X
toQ X = coconeRec X (QColim-cocone X)

-- TQColim cocone and recursor (for ALL types, not just sets)
TQColim-cocone : (X : Sequence в„“) вҶ’ Cocone X (TQColim X)
leg  (TQColim-cocone X) {n} a = [ n , a ]вӮң
comm (TQColim-cocone X) a = eq/вӮң _ _ (push-wit X a)

TQColim-rec : (X : Sequence в„“) {C : Type в„“} вҶ’ Cocone X C вҶ’ TQColim X вҶ’ C
TQColim-rec X c [ n , a ]вӮң = leg c a
TQColim-rec X c (eq/вӮң (n , a) _ (p , q) i) = (comm c a вҲҷ О» i вҶ’ leg c {p i} (q i)) i

-- TQColim-sec for set-valued targets (comms are automatic by isSet)
TQColim-sec-set : (X : Sequence в„“) {C : Type в„“} (hC : isSet C) (d : Cocone X C)
  вҶ’ restrictFrom (TQColim-cocone X) (TQColim-rec X d) вүЎ d
TQColim-sec-set X hC d = CoconeвүЎ X hC (funExt О» a вҶ’ refl)

-- SeqColim is a retract of TQColim (via fromTQвҲҳtoTQ).
-- When TQColim is a set, SeqColim is a set (retract of a set is a set).
-- TQColim is a set when levels are sets: it's a quotient of a set by props.
-- We state this as a postulate (standard but needs encode-decode to formalize).

-- TQColim-isSet: the type quotient of a set by a prop-valued relation is a set.
-- The proof requires lifting paths from the set quotient (QColim) to the type
-- quotient (TQColim), which is the "effectiveness" of the quotient.
-- We reduce to this single fact and postulate it.
-- (It follows from encode-decode or from the library's SQ.effective applied
-- to the equivalence closure of PushRel.)

postulate
  TQColim-isSet : (X : Sequence в„“) вҶ’ ((n : в„•) вҶ’ isSet (obj X n)) вҶ’ isSet (TQColim X)

SeqColim-isSet : (X : Sequence в„“) вҶ’ ((n : в„•) вҶ’ isSet (obj X n)) вҶ’ isSet (SeqColim X)
SeqColim-isSet X hS = isOfHLevelRetract 2
  (toTQ X) (fromTQ X) (fromTQвҲҳtoTQ X)
  (TQColim-isSet X hS)

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- В§9. ОЈ-sequence, singletons, and projections
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

record SeqFib (A : Sequence в„“) : Type (в„“-suc в„“) where
  field
    P    : (n : в„•) вҶ’ obj A n вҶ’ Type в„“
    Pmap : (n : в„•) (a : obj A n) вҶ’ P n a вҶ’ P (suc n) (map A a)
open SeqFib

ОЈSeq : (A : Sequence в„“) вҶ’ SeqFib A вҶ’ Sequence в„“
obj (ОЈSeq A B) n = ОЈ (obj A n) (P B n)
map (ОЈSeq A B) (a , b) = map A a , Pmap B _ a b

ОЈ-proj : (A : Sequence в„“) (B : SeqFib A) вҶ’ SeqColim (ОЈSeq A B) вҶ’ SeqColim A
ОЈ-proj A B (incl (a , _)) = incl a
ОЈ-proj A B (push (a , _) i) = push a i

singletonSeq : (A : Sequence в„“) вҶ’ obj A 0 вҶ’ Sequence в„“
obj (singletonSeq A xвӮҖ) n = ОЈ (obj A (n + 0)) (О» a вҶ’ iterMap A n xвӮҖ вүЎ a)
map (singletonSeq A xвӮҖ) (a , p) = map A a , cong (map A) p

singletonSeq-colim-contr : (A : Sequence в„“) (xвӮҖ : obj A 0) вҶ’ isContr (SeqColim (singletonSeq A xвӮҖ))
singletonSeq-colim-contr A xвӮҖ = colimitContr (singletonSeq A xвӮҖ)
  (О» n вҶ’ (iterMap A n xвӮҖ , refl) , О» { (a , p) i вҶ’ p i , О» j вҶ’ p (i вҲ§ j) })
