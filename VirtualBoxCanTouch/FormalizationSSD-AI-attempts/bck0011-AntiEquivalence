-- ═══════════════════════════════════════════════════════════════
-- Part 4: Spectrum of a product ≅ coproduct of spectra
-- ═══════════════════════════════════════════════════════════════

-- For any Boolean rings A and B, the idempotents (1,0) and (0,1) in A×B
-- decompose Sp(A×B) into Sp(A) ⊎ Sp(B).

module SpProduct (A B : BooleanRing ℓ-zero) where
  private
    module BR-A = BooleanRingStr (snd A)
    module BR-B = BooleanRingStr (snd B)
    module BR-P = BooleanRingStr (snd (A ×BR B))
    module BA-A = BooleanAlgebraStr (snd A)
    module BA-B = BooleanAlgebraStr (snd B)

  -- (1,0) + (0,1) = (1,1) in A×B
  idem-sum : BR-P._+_ (BR-A.𝟙 , BR-B.𝟘) (BR-A.𝟘 , BR-B.𝟙) ≡ (BR-A.𝟙 , BR-B.𝟙)
  idem-sum = ΣPathP (BR-A.+IdR BR-A.𝟙 , BR-B.+IdL BR-B.𝟙)

  -- (1,0) · (0,1) = (0,0) in A×B
  idem-prod : BR-P._·_ (BR-A.𝟙 , BR-B.𝟘) (BR-A.𝟘 , BR-B.𝟙) ≡ (BR-A.𝟘 , BR-B.𝟘)
  idem-prod = ΣPathP (BA-A.∧AnnihilR , BA-B.∧AnnihilL)

  -- (0,1) · (0,b) = (0,b)
  factor-right : (b : ⟨ B ⟩) →
    BR-P._·_ (BR-A.𝟘 , BR-B.𝟙) (BR-A.𝟘 , b) ≡ (BR-A.𝟘 , b)
  factor-right b = ΣPathP (BA-A.∧AnnihilL , BR-B.·IdL b)

  -- (1,0) · (a,0) = (a,0)
  factor-left : (a : ⟨ A ⟩) →
    BR-P._·_ (BR-A.𝟙 , BR-B.𝟘) (a , BR-B.𝟘) ≡ (a , BR-B.𝟘)
  factor-left a = ΣPathP (BR-A.·IdL a , BA-B.∧AnnihilL)

  -- Embed Sp(A) into Sp(A×B) via f ↦ (a,b) ↦ f(a)
  left-embed : SpGeneralBooleanRing A → SpGeneralBooleanRing (A ×BR B)
  fst (left-embed f) (a , b) = fst f a
  snd (left-embed f) = makeIsCommRingHom
    (IsCommRingHom.pres1 (snd f))
    (λ x y → IsCommRingHom.pres+ (snd f) (fst x) (fst y))
    (λ x y → IsCommRingHom.pres· (snd f) (fst x) (fst y))

  -- Embed Sp(B) into Sp(A×B) via g ↦ (a,b) ↦ g(b)
  right-embed : SpGeneralBooleanRing B → SpGeneralBooleanRing (A ×BR B)
  fst (right-embed g) (a , b) = fst g b
  snd (right-embed g) = makeIsCommRingHom
    (IsCommRingHom.pres1 (snd g))
    (λ x y → IsCommRingHom.pres+ (snd g) (snd x) (snd y))
    (λ x y → IsCommRingHom.pres· (snd g) (snd x) (snd y))

  -- For γ : Sp(A×B), γ(1,0) ⊕ γ(0,1) = true and γ(1,0) ∧ γ(0,1) = false
  module Dichotomy (γ : SpGeneralBooleanRing (A ×BR B)) where
    private module Γ = IsCommRingHom (snd γ)

    γ-sum : fst γ (BR-A.𝟙 , BR-B.𝟘) ⊕ fst γ (BR-A.𝟘 , BR-B.𝟙) ≡ true
    γ-sum =
      sym (Γ.pres+ (BR-A.𝟙 , BR-B.𝟘) (BR-A.𝟘 , BR-B.𝟙))
      ∙ cong (fst γ) idem-sum ∙ Γ.pres1

    γ-prod : fst γ (BR-A.𝟙 , BR-B.𝟘) and fst γ (BR-A.𝟘 , BR-B.𝟙) ≡ false
    γ-prod =
      sym (Γ.pres· (BR-A.𝟙 , BR-B.𝟘) (BR-A.𝟘 , BR-B.𝟙))
      ∙ cong (fst γ) idem-prod ∙ Γ.pres0

    -- If γ(0,1) = false then γ(0,b) = false for all b
    γ-kills-right : fst γ (BR-A.𝟘 , BR-B.𝟙) ≡ false →
      (b : ⟨ B ⟩) → fst γ (BR-A.𝟘 , b) ≡ false
    γ-kills-right p b =
      cong (fst γ) (sym (factor-right b))
      ∙ Γ.pres· (BR-A.𝟘 , BR-B.𝟙) (BR-A.𝟘 , b)
      ∙ cong (_and fst γ (BR-A.𝟘 , b)) p

    -- If γ(1,0) = false then γ(a,0) = false for all a
    γ-kills-left : fst γ (BR-A.𝟙 , BR-B.𝟘) ≡ false →
      (a : ⟨ A ⟩) → fst γ (a , BR-B.𝟘) ≡ false
    γ-kills-left p a =
      cong (fst γ) (sym (factor-left a))
      ∙ Γ.pres· (BR-A.𝟙 , BR-B.𝟘) (a , BR-B.𝟘)
      ∙ cong (_and fst γ (a , BR-B.𝟘)) p

  -- Correction paths: (a,0) + (b,0) = (a+b, 0+0), need 0+0 = 0
  private
    B-0+0 : BR-B._+_ BR-B.𝟘 BR-B.𝟘 ≡ BR-B.𝟘
    B-0+0 = BR-B.+IdL BR-B.𝟘

    B-0·0 : BR-B._·_ BR-B.𝟘 BR-B.𝟘 ≡ BR-B.𝟘
    B-0·0 = BooleanAlgebraStr.∧AnnihilL (snd B)

    A-0+0 : BR-A._+_ BR-A.𝟘 BR-A.𝟘 ≡ BR-A.𝟘
    A-0+0 = BR-A.+IdL BR-A.𝟘

    A-0·0 : BR-A._·_ BR-A.𝟘 BR-A.𝟘 ≡ BR-A.𝟘
    A-0·0 = BooleanAlgebraStr.∧AnnihilL (snd A)

  -- Restrict γ : Sp(A×B) to Sp(A), given γ(1,0) = true
  restrict-to-left : (γ : SpGeneralBooleanRing (A ×BR B)) →
    fst γ (BR-A.𝟙 , BR-B.𝟘) ≡ true → SpGeneralBooleanRing A
  fst (restrict-to-left γ p) a = fst γ (a , BR-B.𝟘)
  snd (restrict-to-left γ p) = makeIsCommRingHom
    p
    (λ a₁ a₂ →
      cong (fst γ) (ΣPathP (refl , sym B-0+0))
      ∙ IsCommRingHom.pres+ (snd γ) (a₁ , BR-B.𝟘) (a₂ , BR-B.𝟘))
    (λ a₁ a₂ →
      cong (fst γ) (ΣPathP (refl , sym B-0·0))
      ∙ IsCommRingHom.pres· (snd γ) (a₁ , BR-B.𝟘) (a₂ , BR-B.𝟘))

  -- Restrict γ : Sp(A×B) to Sp(B), given γ(0,1) = true
  restrict-to-right : (γ : SpGeneralBooleanRing (A ×BR B)) →
    fst γ (BR-A.𝟘 , BR-B.𝟙) ≡ true → SpGeneralBooleanRing B
  fst (restrict-to-right γ p) b = fst γ (BR-A.𝟘 , b)
  snd (restrict-to-right γ p) = makeIsCommRingHom
    p
    (λ b₁ b₂ →
      cong (fst γ) (ΣPathP (sym A-0+0 , refl))
      ∙ IsCommRingHom.pres+ (snd γ) (BR-A.𝟘 , b₁) (BR-A.𝟘 , b₂))
    (λ b₁ b₂ →
      cong (fst γ) (ΣPathP (sym A-0·0 , refl))
      ∙ IsCommRingHom.pres· (snd γ) (BR-A.𝟘 , b₁) (BR-A.𝟘 , b₂))

  -- Helper for deriving γ(0,1) = true from γ(1,0) = false
  private
    derive-right-true : (γ : SpGeneralBooleanRing (A ×BR B)) →
      fst γ (BR-A.𝟙 , BR-B.𝟘) ≡ false →
      fst γ (BR-A.𝟘 , BR-B.𝟙) ≡ true
    derive-right-true γ eq =
      sym (cong (λ v → v ⊕ fst γ (BR-A.𝟘 , BR-B.𝟙)) eq)
      ∙ Dichotomy.γ-sum γ

    derive-left-true : (γ : SpGeneralBooleanRing (A ×BR B)) →
      fst γ (BR-A.𝟘 , BR-B.𝟙) ≡ false →
      fst γ (BR-A.𝟙 , BR-B.𝟘) ≡ true
    derive-left-true γ eq =
      sym (⊕-identityʳ (fst γ (BR-A.𝟙 , BR-B.𝟘)))
      ∙ cong (fst γ (BR-A.𝟙 , BR-B.𝟘) ⊕_) (sym eq)
      ∙ Dichotomy.γ-sum γ

  -- Forward direction defined via explicit Bool pattern match (no with)
  private
    go : (γ : SpGeneralBooleanRing (A ×BR B)) (b : Bool) →
      fst γ (BR-A.𝟙 , BR-B.𝟘) ≡ b →
      SpGeneralBooleanRing A ⊎ SpGeneralBooleanRing B
    go γ true  p = inl (restrict-to-left γ p)
    go γ false p = inr (restrict-to-right γ (derive-right-true γ p))

  Sp-prod-to-sum : SpGeneralBooleanRing (A ×BR B) → SpGeneralBooleanRing A ⊎ SpGeneralBooleanRing B
  Sp-prod-to-sum γ = go γ (fst γ (BR-A.𝟙 , BR-B.𝟘)) refl

  -- The backward direction: Sp(A) ⊎ Sp(B) → Sp(A×B)
  Sp-sum-to-prod : SpGeneralBooleanRing A ⊎ SpGeneralBooleanRing B →
    SpGeneralBooleanRing (A ×BR B)
  Sp-sum-to-prod (inl f) = left-embed f
  Sp-sum-to-prod (inr g) = right-embed g

  -- Derive γ(0,1) = false from γ(1,0) = true
  -- true ⊕ x = not x, and γ-sum says γ(1,0) ⊕ γ(0,1) = true.
  -- So not γ(0,1) = true, hence γ(0,1) = false.
  private
    left-true→right-false : (γ : SpGeneralBooleanRing (A ×BR B)) →
      fst γ (BR-A.𝟙 , BR-B.𝟘) ≡ true →
      fst γ (BR-A.𝟘 , BR-B.𝟙) ≡ false
    left-true→right-false γ p =
      let step : not (fst γ (BR-A.𝟘 , BR-B.𝟙)) ≡ true
          step = sym (cong (λ v → v ⊕ fst γ (BR-A.𝟘 , BR-B.𝟙)) p)
                 ∙ Dichotomy.γ-sum γ
      in sym (notnot _) ∙ cong not step

    right-true→left-false : (γ : SpGeneralBooleanRing (A ×BR B)) →
      fst γ (BR-A.𝟘 , BR-B.𝟙) ≡ true →
      fst γ (BR-A.𝟙 , BR-B.𝟘) ≡ false
    right-true→left-false γ p =
      let γ10 = fst γ (BR-A.𝟙 , BR-B.𝟘)
          step : not γ10 ≡ true
          step = sym (⊕-comm γ10 true)
                 ∙ sym (cong (γ10 ⊕_) p)
                 ∙ Dichotomy.γ-sum γ
      in sym (notnot _) ∙ cong not step

  -- Key decomposition lemma:
  -- When γ(1,0) = true, γ(0,b) = false for all b,
  -- hence γ(a,b) = γ(a,0) ⊕ γ(0,b) = γ(a,0) ⊕ false = γ(a,0).
  private
    -- (a,b) = (a,0) + (0,b) in A×B
    pair-split : (a : ⟨ A ⟩) (b : ⟨ B ⟩) →
      (a , b) ≡ BR-P._+_ (a , BR-B.𝟘) (BR-A.𝟘 , b)
    pair-split a b = ΣPathP (sym (BR-A.+IdR a) , sym (BR-B.+IdL b))

    decompose-left : (γ : SpGeneralBooleanRing (A ×BR B))
      (p : fst γ (BR-A.𝟙 , BR-B.𝟘) ≡ true) →
      (a : ⟨ A ⟩) (b : ⟨ B ⟩) → fst γ (a , BR-B.𝟘) ≡ fst γ (a , b)
    decompose-left γ p a b =
      let module Γ = IsCommRingHom (snd γ)
          q : fst γ (BR-A.𝟘 , BR-B.𝟙) ≡ false
          q = left-true→right-false γ p
          γ0b : fst γ (BR-A.𝟘 , b) ≡ false
          γ0b = Dichotomy.γ-kills-right γ q b
      in sym (⊕-identityʳ _)
         ∙ cong (fst γ (a , BR-B.𝟘) ⊕_) (sym γ0b)
         ∙ sym (Γ.pres+ (a , BR-B.𝟘) (BR-A.𝟘 , b))
         ∙ cong (fst γ) (sym (pair-split a b))

    decompose-right : (γ : SpGeneralBooleanRing (A ×BR B))
      (p : fst γ (BR-A.𝟘 , BR-B.𝟙) ≡ true) →
      (a : ⟨ A ⟩) (b : ⟨ B ⟩) → fst γ (BR-A.𝟘 , b) ≡ fst γ (a , b)
    decompose-right γ p a b =
      let module Γ = IsCommRingHom (snd γ)
          q : fst γ (BR-A.𝟙 , BR-B.𝟘) ≡ false
          q = right-true→left-false γ p
          γa0 : fst γ (a , BR-B.𝟘) ≡ false
          γa0 = Dichotomy.γ-kills-left γ q a
      in sym (cong (_⊕ fst γ (BR-A.𝟘 , b)) γa0)
         ∙ sym (Γ.pres+ (a , BR-B.𝟘) (BR-A.𝟘 , b))
         ∙ cong (fst γ) (sym (pair-split a b))

  -- ─── sec proof: Sp-prod-to-sum ∘ Sp-sum-to-prod = id ───

  -- For sec, we match on the Bool to unfold `go`
  private
    sec-left : (f : SpGeneralBooleanRing A) →
      Sp-prod-to-sum (left-embed f) ≡ inl f
    sec-left f with fst f BR-A.𝟙 | inspect (fst f) BR-A.𝟙
    ... | true  | _ = cong inl (CommRingHom≡ refl)
    ... | false | [ eq ]ᵢ = ex-falso (false≢true (sym eq ∙ IsCommRingHom.pres1 (snd f)))

    sec-right : (g : SpGeneralBooleanRing B) →
      Sp-prod-to-sum (right-embed g) ≡ inr g
    sec-right g with fst g BR-B.𝟘 | inspect (fst g) BR-B.𝟘
    ... | true  | [ eq ]ᵢ = ex-falso (true≢false (sym eq ∙ IsCommRingHom.pres0 (snd g)))
    ... | false | _ = cong inr (CommRingHom≡ refl)

  -- ─── ret proof: Sp-sum-to-prod ∘ Sp-prod-to-sum = id ───

  -- For ret, we match on the Bool to unfold `go`, then use decomposition
  private
    ret-case : (γ : SpGeneralBooleanRing (A ×BR B)) →
      Sp-sum-to-prod (Sp-prod-to-sum γ) ≡ γ
    ret-case γ with fst γ (BR-A.𝟙 , BR-B.𝟘) | inspect (fst γ) (BR-A.𝟙 , BR-B.𝟘)
    -- true case: go gives inl (restrict-to-left γ eq), then left-embed
    ... | true  | [ eq ]ᵢ =
      CommRingHom≡ (funExt λ { (a , b) → decompose-left γ eq a b })
    -- false case: go gives inr (restrict-to-right γ ...), then right-embed
    ... | false | [ eq ]ᵢ =
      CommRingHom≡ (funExt λ { (a , b) → decompose-right γ (derive-right-true γ eq) a b })

  -- The full Iso
  SpProduct-Iso : Iso (SpGeneralBooleanRing (A ×BR B))
                      (SpGeneralBooleanRing A ⊎ SpGeneralBooleanRing B)
  SpProduct-Iso .Iso.fun = Sp-prod-to-sum
  SpProduct-Iso .Iso.inv = Sp-sum-to-prod
  SpProduct-Iso .Iso.sec (inl f) = sec-left f
  SpProduct-Iso .Iso.sec (inr g) = sec-right g
  SpProduct-Iso .Iso.ret = ret-case


-- ═══════════════════════════════════════════════════════════════
-- Part 5: Booleω closure under products
-- ═══════════════════════════════════════════════════════════════

-- The general result: if A, B ∈ Booleω then A ×BR B ∈ Booleω.
-- Follows from the presentation technique in LLPOwork/LLPO.agda:
-- given A = freeBA ℕ / R_A and B = freeBA ℕ / R_B,
-- construct A×B = freeBA ℕ / R_{A×B} using interleaved generators
-- and an idempotent separator, with 5 families of relations.
-- See LLPOwork/LLPO.agda Part 5 (B∞×B∞-presentation) for a concrete instance.

-- BooleωCat has binary products
×BR-Booleω : Booleω → Booleω → Booleω
×BR-Booleω (A , cpA) (B , cpB) = (A ×BR B) , Booleω-closed-×BR (A , cpA) (B , cpB)

BooleωCat-BinProduct : (X Y : BooleωCat .Category.ob) → BinProduct BooleωCat X Y
BooleωCat-BinProduct X Y .BinProduct.binProdOb = ×BR-Booleω X Y
BooleωCat-BinProduct X Y .BinProduct.binProdPr₁ = pr₁-BR (fst X) (fst Y)
BooleωCat-BinProduct X Y .BinProduct.binProdPr₂ = pr₂-BR (fst X) (fst Y)
BooleωCat-BinProduct X Y .BinProduct.univProp f g =
  BACat-BinProduct (fst X) (fst Y) .BinProduct.univProp f g

BooleωCat-hasBinProducts : BinProducts BooleωCat
BooleωCat-hasBinProducts = BooleωCat-BinProduct

