-- Part 6: StoneCat is univalent
-- ═══════════════════════════════════════════════════════════════

-- StoneCat = Image(SpFunctor) embeds fully faithfully into (SET ℓ-zero)^op
-- via ExtendImage. Since (SET ℓ-zero)^op is univalent and the embedding
-- is fully faithful with embedding on objects, StoneCat is univalent.

open import Cubical.Categories.Instances.Sets
open import Cubical.Categories.Constructions.Opposite
open import CategoryTheory.StuffThatWasInStoneAndShouldBeOrganized

-- ExtendImage is the embedding StoneCat → (SET ℓ-zero)^op
ExtendSp : Functor StoneCat ((SET ℓ-zero) ^op)
ExtendSp = ImageFunctor.ExtendImage SpFunctor

-- ExtendSp is fully faithful (identity on hom-sets by definition)
ExtendSp-FF : isFullyFaithful ExtendSp
ExtendSp-FF B₁ B₂ = idIsEquiv _

module _ (SD : StoneDualityAxiom) where
  -- ExtendSp ∘ SpRestrict = SpFunctor, so the ob-map of ExtendSp
  -- is the same as SpFunctor on objects, which is an embedding
  ExtendSp-EmbObj : isEmbedding (ExtendSp .F-ob)
  ExtendSp-EmbObj = SpEmbeddingIntoSets SD

  SETop-Univalent : isUnivalent ((SET ℓ-zero) ^op)
  SETop-Univalent = isUnivalentOp (isUnivalentSET {ℓ-zero})

  StoneCatUnivalent : isUnivalent StoneCat
  StoneCatUnivalent = Cuniv StoneCat ((SET ℓ-zero) ^op) SETop-Univalent
    ExtendSp ExtendSp-EmbObj ExtendSp-FF

