-- Part 5b: Initial object in BACat (Bool is initial)
-- ═══════════════════════════════════════════════════════════════

open import Cubical.Algebra.BooleanRing.Initial
open import Cubical.Algebra.BooleanRing.Instances.Bool
open import Cubical.Categories.Limits.Terminal
open import Cubical.Categories.Limits.Initial

-- BoolBR is initial in BACat
BACat-Initial : Initial BACat
BACat-Initial .fst = BoolBR
BACat-Initial .snd B .fst = BoolBR→ B
BACat-Initial .snd B .snd f =
  CommRingHom≡ (sym (BoolBR→IsUnique B f))

-- BoolBR is countably presented (proven in Examples.Bool)
open import CountablyPresentedBooleanRings.Examples.Bool using (BoolCP)

BoolBR-Booleω : Booleω
BoolBR-Booleω = BoolCP

-- BoolBR is initial in BooleωCat
BooleωCat-Initial : Initial BooleωCat
BooleωCat-Initial .fst = BoolBR-Booleω
BooleωCat-Initial .snd B .fst = BoolBR→ (fst B)
BooleωCat-Initial .snd B .snd f =
  CommRingHom≡ (sym (BoolBR→IsUnique (fst B) f))

-- BACat has a terminal object: the trivial Boolean ring (0 = 1)
open import CountablyPresentedBooleanRings.Examples.TrivialBA
  using (trivialBooleanRing ; mapToTrivialBooleanRing ; UnitCP)

BACat-Terminal : Terminal BACat
BACat-Terminal .fst = trivialBooleanRing
BACat-Terminal .snd B .fst = mapToTrivialBooleanRing B
BACat-Terminal .snd B .snd f = CommRingHom≡ (funExt λ _ → refl)

-- Terminal in BooleωCat
TrivBR-Booleω : Booleω
TrivBR-Booleω = UnitCP

BooleωCat-Terminal : Terminal BooleωCat
BooleωCat-Terminal .fst = TrivBR-Booleω
BooleωCat-Terminal .snd B .fst = mapToTrivialBooleanRing (fst B)
BooleωCat-Terminal .snd B .snd f = CommRingHom≡ (funExt λ _ → refl)

-- SpRestrict : BooleωCat → StoneCat is an equivalence, so it preserves
-- initial objects. Hence BoolBR is also initial in StoneCat.
-- Similarly, it preserves terminal objects: TrivBR is terminal in StoneCat.
module _ (SD : StoneDualityAxiom) where
  private
    ff = SpFullyFaithful SD

  StoneCat-Initial : Initial StoneCat
  StoneCat-Initial .fst = BoolBR-Booleω
  StoneCat-Initial .snd Z =
    let hom : Category.Hom[_,_] StoneCat BoolBR-Booleω Z
        hom = SpFunctor .F-hom (BoolBR→ (fst Z))
        uniq : (f : Category.Hom[_,_] StoneCat BoolBR-Booleω Z) → hom ≡ f
        uniq f =
          let f-lift : BoolHom BoolBR (fst Z)
              f-lift = invIsEq (ff BoolBR-Booleω Z) f
              f-eq : SpFunctor .F-hom f-lift ≡ f
              f-eq = secIsEq (ff BoolBR-Booleω Z) f
              uniq-lift : BoolBR→ (fst Z) ≡ f-lift
              uniq-lift = CommRingHom≡ (sym (BoolBR→IsUnique (fst Z) f-lift))
          in cong (SpFunctor .F-hom) uniq-lift ∙ f-eq
    in hom , uniq

  StoneCat-Terminal : Terminal StoneCat
  StoneCat-Terminal .fst = TrivBR-Booleω
  StoneCat-Terminal .snd Z =
    let hom : Category.Hom[_,_] StoneCat Z TrivBR-Booleω
        hom = SpFunctor .F-hom (mapToTrivialBooleanRing (fst Z))
        uniq : (f : Category.Hom[_,_] StoneCat Z TrivBR-Booleω) → hom ≡ f
        uniq f =
          let f-lift = invIsEq (ff Z TrivBR-Booleω) f
              f-eq = secIsEq (ff Z TrivBR-Booleω) f
              uniq-lift : mapToTrivialBooleanRing (fst Z) ≡ f-lift
              uniq-lift = CommRingHom≡ (funExt λ _ → refl)
          in cong (SpFunctor .F-hom) uniq-lift ∙ f-eq
    in hom , uniq

