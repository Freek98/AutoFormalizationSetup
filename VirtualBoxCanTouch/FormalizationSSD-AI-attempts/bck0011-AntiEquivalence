-- Part 1: Lemma 1.12 — Sp(B) empty iff B trivial
-- ═══════════════════════════════════════════════════════════════

module SpectrumEmptyImpliesTrivial (SD : StoneDualityAxiom) (B : Booleω) (spEmpty : Sp B → ⊥) where
  open BooleanRingStr (snd (fst B))
  emptyFunContr : isContr (Sp B → Bool)
  emptyFunContr = (λ sp → ex-falso (spEmpty sp)) , λ f → funExt (λ sp → ex-falso (spEmpty sp))

  B-contr : isContr ⟨ fst B ⟩
  B-contr = isOfHLevelRespectEquiv 0 (invEquiv (evaluationMap B , SD B)) emptyFunContr

  0≡1-in-B : 𝟘 ≡ 𝟙
  0≡1-in-B = isContr→isProp B-contr _ _

module TrivialImpliesSpEmpty
  (B : Booleω) (0=1-in-B : BooleanRingStr.𝟘 (snd (fst B)) ≡ BooleanRingStr.𝟙 (snd (fst B))) (f : Sp B) where
  open BooleanRingStr (snd (fst B))
  open IsCommRingHom (snd f)
  spEmpty : ⊥
  spEmpty = false≢true $ false ≡⟨ sym pres0 ⟩ f $cr 𝟘 ≡⟨ cong (fst f) 0=1-in-B ⟩ f $cr 𝟙 ≡⟨ pres1 ⟩ true ∎


-- ═══════════════════════════════════════════════════════════════
-- Part 2: The anti-equivalence Sp : Booleω ≃ StoneCat
-- ═══════════════════════════════════════════════════════════════

-- StoneCat = Image(SpFunctor) has:
--   objects = Booleω objects
--   Hom(B₁,B₂) = (SET^op)[Sp B₁, Sp B₂] = (Sp B₂ → Sp B₁)
-- SpRestrict : Booleω → StoneCat is identity on objects, Sp on morphisms.

SpRestrict : Functor BooleωCat StoneCat
SpRestrict = ImageFunctor.RestrictCodomain SpFunctor

-- SpRestrict is identity on objects, hence trivially essentially surjective
SpRestrict-essSurj : isEssentiallySurj SpRestrict
SpRestrict-essSurj B = ∣ B , idCatIso ∣₁

module AntiEquiv (SD : StoneDualityAxiom) where
  -- SpRestrict is fully faithful (from SpFullyFaithful)
  SpRestrict-FF : isFullyFaithful SpRestrict
  SpRestrict-FF = SpFullyFaithful SD

  -- The anti-equivalence: SpRestrict is a weak equivalence
  SpAntiEquivalence : isWeakEquivalence SpRestrict
  SpAntiEquivalence .isWeakEquivalence.fullfaith = SpRestrict-FF
  SpAntiEquivalence .isWeakEquivalence.esssurj = SpRestrict-essSurj


