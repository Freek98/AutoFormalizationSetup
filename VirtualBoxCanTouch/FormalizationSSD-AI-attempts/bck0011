    _РЅц?_ : (m n : РёЋ) Рєњ Dec (m РЅц n)
    zero РЅц? n = yes zero-РЅц
    suc m РЅц? zero = no (╬╗ ())
    suc m РЅц? suc n with m РЅц? n
    ... | yes mРЅцn = yes (suc-РЅц-suc mРЅцn)
    ... | no ┬гmРЅцn = no (╬╗ { (suc-РЅц-suc mРЅцn) Рєњ ┬гmРЅцn mРЅцn })

  -- Show that findDiagonal returns the correct diagonal (satisfying bounds)
  -- This requires that findDiagonal actually finds the right diagonal
