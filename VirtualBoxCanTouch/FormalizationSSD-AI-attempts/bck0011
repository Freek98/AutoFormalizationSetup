  wРѕИn+nРЅАw w n nРЅцw = РѕИ+-cancel w n nРЅцw

  -- Key: findDiagonal returns a value w such that triangular w РЅц k < triangular (suc w)
  -- This means n = k - triangular w satisfies n РЅц w
  -- and cantorPair m n = triangular(m + n) + n = triangular w + n = k

  -- First: show n РЅц w when n = k - triangular w and k < triangular(suc w)
  nРЅцw-from-bounds : (k w : РёЋ) Рєњ triangular w РЅц k Рєњ k < triangular (suc w)
