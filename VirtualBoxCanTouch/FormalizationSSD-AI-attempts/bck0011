flatten : (РёЋ Рєњ binarySequence) Рєњ binarySequence
flatten ╬▒s k = let (m , n) = cantorUnpair k in ╬▒s m n

-- Countable intersection of closed propositions
-- If each PРѓЎ is closed (witnessed by ╬▒РѓЎ), then Рѕђn.PРѓЎ is closed
closedCountableIntersection : (P : РёЋ Рєњ hProp РёЊ-zero)
                            Рєњ ((n : РёЋ) Рєњ isClosedProp (P n))
                            Рєњ isClosedProp (((n : РёЋ) Рєњ РЪе P n РЪЕ) , isProp╬а (╬╗ n Рєњ snd (P n)))
closedCountableIntersection P ╬▒s = ╬▓ , forward , backward
  where
  -- Get witness sequence for each PРѓЎ
  ╬▒P : РёЋ Рєњ binarySequence
  ╬▒P n = fst (╬▒s n)

  -- Flatten to single sequence
  ╬▓ : binarySequence
  ╬▓ = flatten ╬▒P

  forward : ((n : РёЋ) Рєњ РЪе P n РЪЕ) Рєњ (k : РёЋ) Рєњ ╬▓ k РЅА false
  forward allP k =
    let (m , n) = cantorUnpair k
        PmРєњallFalse = fst (snd (╬▒s m))
    in PmРєњallFalse (allP m) n

  backward : ((k : РёЋ) Рєњ ╬▓ k РЅА false) Рєњ (n : РёЋ) Рєњ РЪе P n РЪЕ
  backward all╬▓False n = allFalseРєњPn all╬▒nFalse
    where
    allFalseРєњPn : ((k : РёЋ) Рєњ ╬▒P n k РЅА false) Рєњ РЪе P n РЪЕ
    allFalseРєњPn = snd (snd (╬▒s n))
    -- ╬▓ (cantorPair n k) = ╬▒P (fst (cantorUnpair (cantorPair n k))) (snd (cantorUnpair (cantorPair n k)))
    -- By cantorUnpair-pair: cantorUnpair (cantorPair n k) = (n, k)
    -- So ╬▓ (cantorPair n k) РЅА ╬▒P n k (by path)
    all╬▒nFalse : (k : РёЋ) Рєњ ╬▒P n k РЅА false
    all╬▒nFalse k =
      ╬▒P n k
        РЅАРЪе cong (╬╗ p Рєњ ╬▒P (fst p) (snd p)) (sym (cantorUnpair-pair n k)) РЪЕ
      ╬▒P (fst (cantorUnpair (cantorPair n k))) (snd (cantorUnpair (cantorPair n k)))
        РЅАРЪе all╬▓False (cantorPair n k) РЪЕ
      false Рѕј

-- Countable union of open propositions (requires MP)
-- If each PРѓЎ is open (witnessed by ╬▒РѓЎ), then РѕЃn.PРѓЎ is open
openCountableUnion : (P : РёЋ Рєњ hProp РёЊ-zero)
                   Рєњ ((n : РёЋ) Рєњ isOpenProp (P n))
                   Рєњ isOpenProp (РѕЦ ╬Б[ n Рѕѕ РёЋ ] РЪе P n РЪЕ РѕЦРѓЂ , squashРѓЂ)
openCountableUnion P ╬▒s = ╬▓ , forward , backward
  where
  -- Get witness sequence for each PРѓЎ
  ╬▒P : РёЋ Рєњ binarySequence
  ╬▒P n = fst (╬▒s n)

  -- Flatten to single sequence
  ╬▓ : binarySequence
  ╬▓ = flatten ╬▒P

  backward : ╬Б[ k Рѕѕ РёЋ ] ╬▓ k РЅА true Рєњ РѕЦ ╬Б[ n Рѕѕ РёЋ ] РЪе P n РЪЕ РѕЦРѓЂ
  backward (k , ╬▓k=t) = РѕБ n , Pn РѕБРѓЂ
    where
    nm : РёЋ ├Ќ РёЋ
    nm = cantorUnpair k
    n = fst nm
    m = snd nm
    ╬▒nm=t : ╬▒P n m РЅА true
    ╬▒nm=t = ╬▓k=t
    existsРєњPn = snd (snd (╬▒s n))
    Pn : РЪе P n РЪЕ
    Pn = existsРєњPn (m , ╬▒nm=t)

