  nРЅцw-from-bounds k w TwРЅцk k<Tsw =
    -- k - triangular w < triangular(suc w) - triangular w = suc w
    -- So k - triangular w РЅц w
    pred-РЅц-pred (РѕИ-mono-< k (triangular w) (triangular (suc w)) TwРЅцk k<Tsw (triangular-suc w))
    where
    -- a РЅц b and b < c and c = b + d implies a - b < d, so a - b РЅц d - 1
    РѕИ-mono-< : (a b c : РёЋ) Рєњ b РЅц a Рєњ a < c Рєњ b < c Рєњ a РѕИ b < c РѕИ b
    РѕИ-mono-< a b (suc c) bРЅцa (suc-РЅц-suc aРЅцc) b<sc with b РЅц? a
    ... | yes _ = suc-РЅц-suc (РѕИ-mono a c b aРЅцc (pred-РЅц-pred b<sc))
      where
