    РѕИ-РЅц zero (suc b) = РЅц-refl
    РѕИ-РЅц (suc a) (suc b) = РЅц-trans (РѕИ-РЅц a b) (nРЅц1+n a)

    -- findDiagonal returns w such that triangular w РЅц k
    -- Proof: by induction on fuel, invariant is triangular acc РЅц k when we return acc
    findDiagonal-TwРЅцk-aux : (fuel k acc : РёЋ) Рєњ triangular acc РЅц k
