  -- w РЅц triangular w for w РЅЦ 1, and trivially for w = 0
  wРЅцtriangular : (w : РёЋ) Рєњ w РЅц triangular w +РёЋ w
  wРЅцtriangular zero = zero-РЅц
  wРЅцtriangular (suc w) = suc-РЅц-suc (РЅц-trans (wРЅцtriangular w) (РЅц-+k-r (triangular w +РёЋ w) (suc w)))
    where
    РЅц-+k-r : (a b : РёЋ) Рєњ a РЅц a +РёЋ b
