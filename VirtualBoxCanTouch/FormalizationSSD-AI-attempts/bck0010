  _<ŠĶá_ : ‚Ąē ‚Üí ‚Ąē ‚Üí Bool
  zero <ŠĶá zero = false
  zero <ŠĶá suc n = true
  suc m <ŠĶá zero = false
  suc m <ŠĶá suc n = m <ŠĶá n

