-- BooleanRing isomorphisms вҶ” categorical isomorphisms
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

open Iso

module _ {R S : BooleanRing в„“} where
  private
    R' = BooleanRingвҶ’CommRing R
    S' = BooleanRingвҶ’CommRing S

  BoolRingIsoIsoCatIso : Iso (BoolRingEquiv R S) (CatIso BooleanRingsCategory R S)
  -- forward: equiv вҶ’ cat iso
  fun BoolRingIsoIsoCatIso ((f , fEqu) , fHom) .fst = f , fHom
  fun BoolRingIsoIsoCatIso ((f , fEqu) , fHom) .snd .inv =
    invEq (f , fEqu) , invCommRingEquiv R' S' ((f , fEqu) , fHom) .snd
  fun BoolRingIsoIsoCatIso ((f , fEqu) , fHom) .snd .sec =
    CommRingHomвүЎ (funExt (secEq (f , fEqu)))
  fun BoolRingIsoIsoCatIso ((f , fEqu) , fHom) .snd .ret =
    CommRingHomвүЎ (funExt (retEq (f , fEqu)))
  -- backward: cat iso вҶ’ equiv
  fst (inv BoolRingIsoIsoCatIso e) =
    isoToEquiv (iso (e .fst .fst) (e .snd .inv .fst)
                    (О» x i вҶ’ fst (e .snd .sec i) x)
                    (О» x i вҶ’ fst (e .snd .ret i) x))
  snd (inv BoolRingIsoIsoCatIso e) = e .fst .snd
  -- roundtrips
  sec BoolRingIsoIsoCatIso x = CatIsoвүЎ _ _ (CommRingHomвүЎ refl)
  ret BoolRingIsoIsoCatIso x =
    ОЈвүЎProp (О» x вҶ’ isPropIsCommRingHom
                     (BooleanRingStrвҶ’CommRingStr (snd R))
                     (fst x)
                     (BooleanRingStrвҶ’CommRingStr (snd S)))
           (ОЈвүЎProp isPropIsEquiv (funExt (О» _ вҶ’ refl)))

-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
-- Univalence
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

-- Univalence at level zero (matching existing infrastructure)
private
  pathToIsoDecomp' : (R S : BooleanRing в„“-zero) вҶ’ (R вүЎ S) вүғ (CatIso BooleanRingsCategory R S)
  pathToIsoDecomp' R S = compEquiv (invEquiv (BoolRingPath R S))
                                   (isoToEquiv BoolRingIsoIsoCatIso)

  pathToIsoDecompAtRefl' : (R : BooleanRing в„“-zero) вҶ’ fst (pathToIsoDecomp' R R) refl вүЎ idCatIso
  pathToIsoDecompAtRefl' R = CatIsoвүЎ _ _
    (CommRingHomвүЎ (BoolRingPathInvReflвүЎIdfun R))

  pathToIsoDecompIsDecomp' : (R S : BooleanRing в„“-zero)
    вҶ’ pathToIso {x = R} {y = S} вүЎ fst (pathToIsoDecomp' R S)
  pathToIsoDecompIsDecomp' R S = funExt $
    J (О» S' p вҶ’ pathToIso {x = R} {y = S'} p вүЎ fst (pathToIsoDecomp' R S') p)
      (pathToIso-refl вҲҷ sym (pathToIsoDecompAtRefl' R))

isUnivalentBooleanRingsCategoryвӮҖ : isUnivalent (BooleanRingsCategory {в„“ = в„“-zero})
isUnivalentBooleanRingsCategoryвӮҖ .univ R S =
  subst isEquiv (sym (pathToIsoDecompIsDecomp' R S)) (snd (pathToIsoDecomp' R S))

