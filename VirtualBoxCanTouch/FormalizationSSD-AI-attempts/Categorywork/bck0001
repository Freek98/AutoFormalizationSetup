PullbackBooleanRingsCategory : Pullbacks {в„“-suc в„“} BooleanRingsCategory
pbOb (PullbackBooleanRingsCategory (cospan A C B Оұ ОІ))       =
  fiberedProductBR A B C Оұ ОІ
pbPrвӮҒ (PullbackBooleanRingsCategory (cospan A C B Оұ ОІ))      =
  fiberedProductBRPrвӮҒ A B C Оұ ОІ
pbPrвӮӮ (PullbackBooleanRingsCategory (cospan A C B Оұ ОІ))      =
  fiberedProductBRPrвӮӮ A B C Оұ ОІ
pbCommutes (PullbackBooleanRingsCategory (cospan A C B Оұ ОІ))  =
  fiberedProductBRPrвӮҒвӮӮCommutes A B C Оұ ОІ
univProp (PullbackBooleanRingsCategory (cospan A C B Оұ ОІ)) {d = D} =
  fiberedProductBRUnivProp A B C Оұ ОІ D

