fst (fst (snd TerminalBooleanRing y)) _ = tt
snd (fst (snd TerminalBooleanRing y)) = makeIsCommRingHom refl (О» _ _ вҶ’ refl) (О» _ _ вҶ’ refl)
snd (snd TerminalBooleanRing y) f = CommRingHomвүЎ (funExt (О» _ вҶ’ refl))

