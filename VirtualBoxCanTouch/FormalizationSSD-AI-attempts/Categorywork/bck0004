-- Fibered product of Boolean rings
-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

module _ (A B C : BooleanRing в„“) (Оұ : BoolHom A C) (ОІ : BoolHom B C) where

  private
    A' = BooleanRingвҶ’CommRing A
    B' = BooleanRingвҶ’CommRing B
    C' = BooleanRingвҶ’CommRing C

    -- The fibered product as a CommRing
    fbCR : CommRing в„“
    fbCR = fiberedProduct A' B' C' Оұ ОІ

  -- The fibered product is a BooleanRing (idempotency holds componentwise)
  fiberedProductBR : BooleanRing в„“
  fiberedProductBR = idemCommRingвҶ’BR fbCR idem
    where
    idem : isIdemRing fbCR
    idem ((a , b) , hab) = ОЈвүЎProp (О» _ вҶ’ is-set (snd C) _ _)
      (О» i вҶ’ В·Idem (snd A) a i , В·Idem (snd B) b i)

  fiberedProductBRPrвӮҒ : BoolHom fiberedProductBR A
  fiberedProductBRPrвӮҒ = fiberedProductPrвӮҒ A' B' C' Оұ ОІ

  fiberedProductBRPrвӮӮ : BoolHom fiberedProductBR B
  fiberedProductBRPrвӮӮ = fiberedProductPrвӮӮ A' B' C' Оұ ОІ

  fiberedProductBRPrвӮҒвӮӮCommutes :
    compCommRingHom fiberedProductBRPrвӮҒ Оұ вүЎ compCommRingHom fiberedProductBRPrвӮӮ ОІ
  fiberedProductBRPrвӮҒвӮӮCommutes = fiberedProductPrвӮҒвӮӮCommutes A' B' C' Оұ ОІ

  fiberedProductBRUnivProp :
    (D : BooleanRing в„“) (h : BoolHom D A) (k : BoolHom D B) вҶ’
    compCommRingHom h Оұ вүЎ compCommRingHom k ОІ вҶ’
    вҲғ![ l вҲҲ BoolHom D fiberedProductBR ]
        (h вүЎ compCommRingHom l fiberedProductBRPrвӮҒ)
      Г— (k вүЎ compCommRingHom l fiberedProductBRPrвӮӮ)
  fiberedProductBRUnivProp D h k H =
    fiberedProductUnivProp A' B' C' Оұ ОІ (BooleanRingвҶ’CommRing D) h k H

