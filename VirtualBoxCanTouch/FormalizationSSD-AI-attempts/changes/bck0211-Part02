      Iso.sec step1-iso = funExtРЂ╗ (QB.quotientImageHomEpi {B = freeBA РёЋ QB./Im f} {f = d'}
        (РЪе target-ring РЪЕ , BooleanRingStr.is-set (snd target-ring)) (funExt step1-forwardРѕўbackward-on-¤ђ))
      Iso.ret step1-iso = funExtРЂ╗ (QB.quotientImageHomEpi {B = fst B} {f = d}
        (РЪе B/d РЪЕ , BooleanRingStr.is-set (snd B/d)) (funExt step1-backwardРѕўforward-on-¤ђ))

      step1-equiv : BooleanRingEquiv B/d target-ring
      step1-equiv = isoToEquiv step1-iso , snd step1-forward-hom

      step1-equiv' : BooleanRingEquiv B/d ((freeBA РёЋ QB./Im f) QB./Im (fst QB.quotientImageHom Рѕў g))
      step1-equiv' = subst (╬╗ seq Рєњ BooleanRingEquiv B/d ((freeBA РёЋ QB./Im f) QB./Im seq))
