mp-from-SD SD ╬▒ ╬▒РЅа0 = MarkovLib.extractFirstHitInBinarySequence.extract ╬▒ (MarkovLib.РѕЃ╬▒n ╬▒ (trivialQuotientРєњ1РѕѕI BoolCR (IQ.genIdeal BoolCR ╬▒) (sym 0РЅА1-CR)))
