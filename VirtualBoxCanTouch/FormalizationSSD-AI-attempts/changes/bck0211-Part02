-- If B is Boole¤Ѕ, then B/d is Boole¤Ѕ for any sequence d (tex: Rule 2 separation)

quotientBySeqHasBoole¤Ѕ : (B : Boole¤Ѕ) (d : РёЋ Рєњ РЪе fst B РЪЕ)
  Рєњ РѕЦ has-Boole-¤Ѕ' (fst B QB./Im d) РѕЦРѓЂ
quotientBySeqHasBoole¤Ѕ B d = PT.rec squashРѓЂ construct (snd B)
  where
  B/d : BooleanRing РёЊ-zero
  B/d = fst B QB./Im d

  construct : has-Boole-¤Ѕ' (fst B) Рєњ РѕЦ has-Boole-¤Ѕ' B/d РѕЦРѓЂ
  construct (f , equiv) = PT.rec squashРѓЂ (╬╗ lifts Рєњ РѕБ constructFromLifts lifts РѕБРѓЂ)
      (countableChoice LiftType (╬╗ n Рєњ QB.quotientImageHomSurjective (d' n)))
    where
    d' : РёЋ Рєњ РЪе freeBA РёЋ QB./Im f РЪЕ
    d' n = fst (fst equiv) (d n)

    LiftType : РёЋ Рєњ Type РёЊ-zero
    LiftType n = ╬Б[ x Рѕѕ РЪе freeBA РёЋ РЪЕ ] fst QB.quotientImageHom x РЅА d' n

    constructFromLifts : ((n : РёЋ) Рєњ LiftType n) Рєњ has-Boole-¤Ѕ' B/d
    constructFromLifts lifts = h , B/d-equiv
      where
      g : РёЋ Рєњ РЪе freeBA РёЋ РЪЕ
      g n = fst (lifts n)

      g-is-section : (n : РёЋ) Рєњ fst QB.quotientImageHom (g n) РЅА d' n
      g-is-section n = snd (lifts n)

      encode : РёЋ Ріј РёЋ Рєњ РёЋ
      encode = Iso.fun РёЋРіјРёЋРЅЁРёЋ

      decode : РёЋ Рєњ РёЋ Ріј РёЋ
      decode = Iso.inv РёЋРіјРёЋРЅЁРёЋ

      h : РёЋ Рєњ РЪе freeBA РёЋ РЪЕ
      h n with decode n
      ... | inl m = f m
      ... | inr m = g m

      step2-equiv : BooleanRingEquiv (freeBA РёЋ QB./Im (Ріј.rec f g))
                                     ((freeBA РёЋ QB./Im f) QB./Im (fst QB.quotientImageHom Рѕў g))
      step2-equiv = commRingPathРєњboolRingEquiv
                      (freeBA РёЋ QB./Im (Ріј.rec f g))
                      ((freeBA РёЋ QB./Im f) QB./Im (fst QB.quotientImageHom Рѕў g))
                      (cong BooleanRingРєњCommRing (BoolQuotientEquiv (freeBA РёЋ) f g))

      hРЅАrecРѕўdecode-pointwise : (n : РёЋ) Рєњ h n РЅА Ріј.rec f g (decode n)
      hРЅАrecРѕўdecode-pointwise n with decode n
      ... | inl m = refl
      ... | inr m = refl

      rec-quotient : BooleanRing РёЊ-zero
      rec-quotient = freeBA РёЋ QB./Im (Ріј.rec f g)

      h-quotient : BooleanRing РёЊ-zero
      h-quotient = freeBA РёЋ QB./Im h

      ¤ђ-rec : BoolHom (freeBA РёЋ) rec-quotient
      ¤ђ-rec = QB.quotientImageHom

      ¤ђ-h : BoolHom (freeBA РёЋ) h-quotient
      ¤ђ-h = QB.quotientImageHom

      ¤ђ-rec-sends-h-to-0 : (n : РёЋ) Рєњ ¤ђ-rec $cr (h n) РЅА BooleanRingStr.­ЮЪў (snd rec-quotient)
      ¤ђ-rec-sends-h-to-0 n =
        ¤ђ-rec $cr (h n)
          РЅАРЪе cong (¤ђ-rec $cr_) (hРЅАrecРѕўdecode-pointwise n) РЪЕ
        ¤ђ-rec $cr ((Ріј.rec f g) (decode n))
          РЅАРЪе QB.zeroOnImage {B = freeBA РёЋ} {f = Ріј.rec f g} (decode n) РЪЕ
        BooleanRingStr.­ЮЪў (snd rec-quotient) Рѕј

      step3-forward-hom : BoolHom h-quotient rec-quotient
      step3-forward-hom = QB.inducedHom {B = freeBA РёЋ} {f = h} rec-quotient ¤ђ-rec ¤ђ-rec-sends-h-to-0

      rec-eq-h-encode : (x : РёЋ Ріј РёЋ) Рєњ (Ріј.rec f g) x РЅА h (encode x)
      rec-eq-h-encode x =
        (Ріј.rec f g) x
          РЅАРЪе cong (Ріј.rec f g) (sym (Iso.ret РёЋРіјРёЋРЅЁРёЋ x)) РЪЕ
        (Ріј.rec f g) (decode (encode x))
          РЅАРЪе sym (hРЅАrecРѕўdecode-pointwise (encode x)) РЪЕ
        h (encode x) Рѕј

      ¤ђ-h-sends-rec-to-0 : (x : РёЋ Ріј РёЋ) Рєњ ¤ђ-h $cr ((Ріј.rec f g) x) РЅА BooleanRingStr.­ЮЪў (snd h-quotient)
      ¤ђ-h-sends-rec-to-0 x =
        ¤ђ-h $cr ((Ріј.rec f g) x)
          РЅАРЪе cong (¤ђ-h $cr_) (rec-eq-h-encode x) РЪЕ
        ¤ђ-h $cr (h (encode x))
          РЅАРЪе QB.zeroOnImage {B = freeBA РёЋ} {f = h} (encode x) РЪЕ
        BooleanRingStr.­ЮЪў (snd h-quotient) Рѕј

      step3-backward-hom : BoolHom rec-quotient h-quotient
      step3-backward-hom = QB.inducedHom {B = freeBA РёЋ} {f = Ріј.rec f g} h-quotient ¤ђ-h ¤ђ-h-sends-rec-to-0

      step3-forward : РЪе h-quotient РЪЕ Рєњ РЪе rec-quotient РЪЕ
      step3-forward = fst step3-forward-hom

      step3-backward : РЪе rec-quotient РЪЕ Рєњ РЪе h-quotient РЪЕ
      step3-backward = fst step3-backward-hom

      step3-forward-eval : step3-forward-hom Рѕўcr ¤ђ-h РЅА ¤ђ-rec
      step3-forward-eval = QB.evalInduce {B = freeBA РёЋ} {f = h} rec-quotient

      step3-backward-eval : step3-backward-hom Рѕўcr ¤ђ-rec РЅА ¤ђ-h
      step3-backward-eval = QB.evalInduce {B = freeBA РёЋ} {f = Ріј.rec f g} h-quotient

      step3-backwardРѕўforward-on-¤ђ : (x : РЪе freeBA РёЋ РЪЕ) Рєњ step3-backward (step3-forward (fst ¤ђ-h x)) РЅА fst ¤ђ-h x
      step3-backwardРѕўforward-on-¤ђ x =
        step3-backward (step3-forward (fst ¤ђ-h x))
          РЅАРЪе cong step3-backward (cong (╬╗ hom Рєњ fst hom x) step3-forward-eval) РЪЕ
        step3-backward (fst ¤ђ-rec x)
          РЅАРЪе cong (╬╗ hom Рєњ fst hom x) step3-backward-eval РЪЕ
        fst ¤ђ-h x Рѕј

      step3-forwardРѕўbackward-on-¤ђ : (y : РЪе freeBA РёЋ РЪЕ) Рєњ step3-forward (step3-backward (fst ¤ђ-rec y)) РЅА fst ¤ђ-rec y
      step3-forwardРѕўbackward-on-¤ђ y =
        step3-forward (step3-backward (fst ¤ђ-rec y))
          РЅАРЪе cong step3-forward (cong (╬╗ hom Рєњ fst hom y) step3-backward-eval) РЪЕ
        step3-forward (fst ¤ђ-h y)
          РЅАРЪе cong (╬╗ hom Рєњ fst hom y) step3-forward-eval РЪЕ
        fst ¤ђ-rec y Рѕј

      step3-iso : Iso РЪе h-quotient РЪЕ РЪе rec-quotient РЪЕ
      Iso.fun step3-iso = step3-forward
      Iso.inv step3-iso = step3-backward
      Iso.sec step3-iso = funExtРЂ╗ (QB.quotientImageHomEpi {B = freeBA РёЋ} {f = Ріј.rec f g}
        (РЪе rec-quotient РЪЕ , BooleanRingStr.is-set (snd rec-quotient)) (funExt step3-forwardРѕўbackward-on-¤ђ))
      Iso.ret step3-iso = funExtРЂ╗ (QB.quotientImageHomEpi {B = freeBA РёЋ} {f = h}
        (РЪе h-quotient РЪЕ , BooleanRingStr.is-set (snd h-quotient)) (funExt step3-backwardРѕўforward-on-¤ђ))

      step3-equiv' : BooleanRingEquiv h-quotient rec-quotient
      step3-equiv' = isoToEquiv step3-iso , snd step3-forward-hom

      target-ring : BooleanRing РёЊ-zero
      target-ring = (freeBA РёЋ QB./Im f) QB./Im d'

      equiv-hom : BoolHom (fst B) (freeBA РёЋ QB./Im f)
      equiv-hom = fst (fst equiv) , snd equiv

      ¤ђ-d' : BoolHom (freeBA РёЋ QB./Im f) target-ring
      ¤ђ-d' = QB.quotientImageHom

      composite-hom-1 : BoolHom (fst B) target-ring
      composite-hom-1 = ¤ђ-d' Рѕўcr equiv-hom

      composite-sends-d-to-0 : (n : РёЋ) Рєњ composite-hom-1 $cr (d n) РЅА BooleanRingStr.­ЮЪў (snd target-ring)
      composite-sends-d-to-0 n = QB.zeroOnImage {f = d'} n

      step1-forward-hom : BoolHom B/d target-ring
      step1-forward-hom = QB.inducedHom target-ring composite-hom-1 composite-sends-d-to-0

      ¤ђ-d : BoolHom (fst B) B/d
      ¤ђ-d = QB.quotientImageHom

      equivРЂ╗┬╣-hom : BoolHom (freeBA РёЋ QB./Im f) (fst B)
      equivРЂ╗┬╣-hom = fst (fst (invBooleanRingEquiv (fst B) (freeBA РёЋ QB./Im f) equiv)) ,
                    snd (invBooleanRingEquiv (fst B) (freeBA РёЋ QB./Im f) equiv)

      backward-composite-1 : BoolHom (freeBA РёЋ QB./Im f) B/d
      backward-composite-1 = ¤ђ-d Рѕўcr equivРЂ╗┬╣-hom

      backward-composite-sends-d'-to-0 : (n : РёЋ) Рєњ backward-composite-1 $cr (d' n) РЅА BooleanRingStr.­ЮЪў (snd B/d)
      backward-composite-sends-d'-to-0 n =
        ¤ђ-d $cr (equivРЂ╗┬╣-hom $cr (fst (fst equiv) (d n)))
          РЅАРЪе cong (¤ђ-d $cr_) (Iso.ret (equivToIso (fst equiv)) (d n)) РЪЕ
        ¤ђ-d $cr (d n)
          РЅАРЪе QB.zeroOnImage {f = d} n РЪЕ
        BooleanRingStr.­ЮЪў (snd B/d) Рѕј

      step1-backward-hom : BoolHom target-ring B/d
      step1-backward-hom = QB.inducedHom B/d backward-composite-1 backward-composite-sends-d'-to-0

      step1-forward-fun : РЪе B/d РЪЕ Рєњ РЪе target-ring РЪЕ
      step1-forward-fun = fst step1-forward-hom

      step1-backward-fun : РЪе target-ring РЪЕ Рєњ РЪе B/d РЪЕ
      step1-backward-fun = fst step1-backward-hom

      step1-forward-eval : step1-forward-hom Рѕўcr ¤ђ-d РЅА composite-hom-1
      step1-forward-eval = QB.evalInduce {B = fst B} {f = d} target-ring

      step1-backward-eval : step1-backward-hom Рѕўcr ¤ђ-d' РЅА backward-composite-1
      step1-backward-eval = QB.evalInduce {B = freeBA РёЋ QB./Im f} {f = d'} B/d

      equivРЂ╗┬╣РѕўequivРЅАid : (x : РЪе fst B РЪЕ) Рєњ fst equivРЂ╗┬╣-hom (fst (fst equiv) x) РЅА x
      equivРЂ╗┬╣РѕўequivРЅАid = Iso.ret (equivToIso (fst equiv))

      equivРѕўequivРЂ╗┬╣РЅАid : (y : РЪе freeBA РёЋ QB./Im f РЪЕ) Рєњ fst (fst equiv) (fst equivРЂ╗┬╣-hom y) РЅА y
      equivРѕўequivРЂ╗┬╣РЅАid = Iso.sec (equivToIso (fst equiv))

      step1-backwardРѕўforward-on-¤ђ : (x : РЪе fst B РЪЕ) Рєњ step1-backward-fun (step1-forward-fun (fst ¤ђ-d x)) РЅА fst ¤ђ-d x
      step1-backwardРѕўforward-on-¤ђ x =
        step1-backward-fun (step1-forward-fun (fst ¤ђ-d x))
          РЅАРЪе cong step1-backward-fun (cong (╬╗ hom Рєњ fst hom x) step1-forward-eval) РЪЕ
        step1-backward-fun (fst composite-hom-1 x)
          РЅАРЪе cong (╬╗ hom Рєњ fst hom (fst (fst equiv) x)) step1-backward-eval РЪЕ
        fst ¤ђ-d (fst equivРЂ╗┬╣-hom (fst (fst equiv) x))
          РЅАРЪе cong (fst ¤ђ-d) (equivРЂ╗┬╣РѕўequivРЅАid x) РЪЕ
        fst ¤ђ-d x Рѕј

      step1-forwardРѕўbackward-on-¤ђ : (y : РЪе freeBA РёЋ QB./Im f РЪЕ) Рєњ
                                     step1-forward-fun (step1-backward-fun (fst ¤ђ-d' y)) РЅА fst ¤ђ-d' y
      step1-forwardРѕўbackward-on-¤ђ y =
        step1-forward-fun (step1-backward-fun (fst ¤ђ-d' y))
          РЅАРЪе cong step1-forward-fun (cong (╬╗ hom Рєњ fst hom y) step1-backward-eval) РЪЕ
        step1-forward-fun (fst backward-composite-1 y)
          РЅАРЪе cong (╬╗ hom Рєњ fst hom (fst equivРЂ╗┬╣-hom y)) step1-forward-eval РЪЕ
        fst ¤ђ-d' (fst (fst equiv) (fst equivРЂ╗┬╣-hom y))
          РЅАРЪе cong (fst ¤ђ-d') (equivРѕўequivРЂ╗┬╣РЅАid y) РЪЕ
