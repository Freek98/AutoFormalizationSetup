-- Trichotomy type avoiding path types (cubical Agda can't pattern-match
-- on Ріј when one branch contains a path type)
data Tri< {РёЊ : Level} {A : Type РёЊ} (_<_ : A Рєњ A Рєњ Type РёЊ) (a b : A) : Type РёЊ where
  is-lt : a < b Рєњ Tri< _<_ a b
  is-eq : ┬г (a < b) Рєњ ┬г (b < a) Рєњ Tri< _<_ a b
  is-gt : b < a Рєњ Tri< _<_ a b

Tri<-elim : Рѕђ {РёЊ РёЊ'} {A : Type РёЊ} {_<_ : A Рєњ A Рєњ Type РёЊ} {a b : A}
  {P : Tri< _<_ a b Рєњ Type РёЊ'}
  Рєњ ((x : a < b) Рєњ P (is-lt x))
  Рєњ ((x : ┬г (a < b)) (y : ┬г (b < a)) Рєњ P (is-eq x y))
  Рєњ ((x : b < a) Рєњ P (is-gt x))
  Рєњ (r : Tri< _<_ a b) Рєњ P r
Tri<-elim f g h (is-lt x) = f x
Tri<-elim f g h (is-eq x y) = g x y
Tri<-elim f g h (is-gt x) = h x

record DecStrictTotalOrder {РёЊ : Level} (A : Type РёЊ) : Type (РёЊ-suc РёЊ) where
  field
    _<sto_ : A Рєњ A Рєњ Type РёЊ
    <sto-prop : (a b : A) Рєњ isProp (a <sto b)
    <sto-irrefl : (a : A) Рєњ ┬г (a <sto a)
    <sto-trans : {a b c : A} Рєњ a <sto b Рєњ b <sto c Рєњ a <sto c
    <sto-tricho : (a b : A) Рєњ Tri< _<sto_ a b
    isSetA : isSet A

