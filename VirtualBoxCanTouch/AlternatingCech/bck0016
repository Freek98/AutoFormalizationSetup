  -- Adjacent face equality: when fst j = suc(fst i) and ¤Ѓ i = ¤Ѓ j,
  -- ¤Ѓ Рѕў punchIn i and ¤Ѓ Рѕў punchIn j agree pointwise.
  -- Uses adj-punchIn-РёЋ: either both punchIns give same value (cong ¤Ѓ),
  -- or they hit i and j (bridged by ¤Ѓeq).
  adj-face-eq : {p : РёЋ} {x : S} (¤Ѓ : Fin (suc (suc p)) Рєњ T x)
    (i j : Fin (suc (suc p)))
    Рєњ suc (fst i) РЅА fst j Рєњ ¤Ѓ i РЅА ¤Ѓ j
    Рєњ (c : Fin (suc p)) Рєњ ¤Ѓ (punchIn i c) РЅА ¤Ѓ (punchIn j c)
  adj-face-eq {p} ¤Ѓ i j siРЅАfj ¤Ѓeq c =
    Ріј.rec
      (╬╗ e Рєњ
        -- same РёЋ value: punchIn-РёЋ (fst i) (fst c) = punchIn-РёЋ (fst j) (fst c)
        -- so punchIn i c = punchIn j c as Fin elements
        let fst-eq : fst (punchIn i c) РЅА fst (punchIn j c)
            fst-eq = punchIn-fst i c РѕЎ e РѕЎ cong (╬╗ z Рєњ punchIn-РёЋ z (fst c)) siРЅАfj
                   РѕЎ sym (punchIn-fst j c)
        in cong ¤Ѓ (╬БРЅАProp (╬╗ k Рєњ isProp<рхЌ {n = k} {m = suc (suc p)}) fst-eq))
      (╬╗ pq Рєњ
        -- punchIn-РёЋ (fst i) (fst c) = suc(fst i) = fst j, and
        -- punchIn-РёЋ (suc(fst i)) (fst c) = fst i
        let pi-eq : fst (punchIn i c) РЅА fst j
