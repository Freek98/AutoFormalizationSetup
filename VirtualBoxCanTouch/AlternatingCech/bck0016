      РіЦ.rec (<sto-irrefl x _ (<sto-trans x p<q q<p))
    -- (lt, eq): ┬гp<q contradicts p<q
    cРѓЂ-antisym-core s x ¤Ѓ (is-lt p<q) (is-eq _ ┬гp<q) = РіЦ.rec (┬гp<q p<q)
    -- (lt, gt): VALID Рђћ need swap involution
