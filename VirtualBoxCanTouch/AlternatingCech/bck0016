          i'РЅаj' p = iРЅаj (sym eq-i РѕЎ cong (punchIn k) p РѕЎ eq-j)
      in i' , j' , i'РЅаj' , (cong ¤Ѓ eq-i РѕЎ ¤ЃiРЅА¤Ѓj РѕЎ sym (cong ¤Ѓ eq-j))

    -- Each term in the alternating sum: for faces that still have repeats, s vanishes
    face-term-zero : {p : РёЋ} {x : S} (s : CРЂ┐ p)
      Рєњ (van : (x : S) (¤Ѓ : Fin (suc p) Рєњ T x) (i j : Fin (suc p))
              Рєњ ┬г (i РЅА j) Рєњ ¤Ѓ i РЅА ¤Ѓ j Рєњ s x ¤Ѓ РЅА Ax.0g x)
      Рєњ (¤Ѓ : Fin (suc (suc p)) Рєњ T x)
