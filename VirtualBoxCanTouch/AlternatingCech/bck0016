      cong (Ax.-_ x) (cong (s x) (╬БРЅАProp (╬╗ _ Рєњ isPropIsOrdered) (sw01-comp ¤Ѓ)))
    -- (eq, lt): contradiction
    cРѓЂ-antisym-core s x ¤Ѓ (is-eq _ ┬гq<p) (is-lt q<p) = РіЦ.rec (┬гq<p q<p)
    -- (eq, eq): VALID Рђћ 0g РЅА -(0g)
    cРѓЂ-antisym-core s x ¤Ѓ (is-eq _ _) (is-eq _ _) =
      sym (GroupProps.GroupTheory.inv1g (AbGroupРєњGroup (A x)))
    -- (eq, gt): contradiction
    cРѓЂ-antisym-core s x ¤Ѓ (is-eq ┬гp<q _) (is-gt p<q) = РіЦ.rec (┬гp<q p<q)
