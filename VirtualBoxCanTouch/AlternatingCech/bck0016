    Рєњ s x (¤Ѓ Рѕў punchIn i) РЅА negPow d (s x (¤Ѓ Рѕў punchIn j))
  face-shift-aux s alt x zero ¤Ѓ i j si+0РЅАfj ¤Ѓeq =
    -- d=0: suc(fst i) = fst j, faces agree pointwise
    let siРЅАfj : suc (fst i) РЅА fst j
