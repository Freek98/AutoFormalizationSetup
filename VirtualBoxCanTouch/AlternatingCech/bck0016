      go-gt : fst j <рхЌ fst i
        Рєњ negPow (fst i) w +A negPow (fst j) v РЅА Ax.0g x
      go-gt j<i =
        let d = fst i РѕИ suc (fst j)
            shift = face-shift s alt x ¤Ѓ j i j<i (sym ¤Ѓeq)
            arith : fst j + d РЅА predРёЋ (fst i)
            arith = +РѕИРЅАpredРёЋ (fst j) (fst i) j<i
            step1 : negPow (fst j) v РЅА negPow (predРёЋ (fst i)) w
            step1 = cong (negPow (fst j)) shift
                   РѕЎ negPow-comp (fst j) d w
                   РѕЎ cong (╬╗ n Рєњ negPow n w) arith
            i>0 : ┬г (fst i РЅА 0)
            i>0 e = ┬г<рхЌ0 {fst j} (subst (fst j <рхЌ_) e j<i)
            pred-suc : suc (predРёЋ (fst i)) РЅА fst i
            pred-suc = sym (suc-predРёЋ (fst i) i>0)
        in Ax.+Comm x _ _
           РѕЎ cong (_+A negPow (fst i) w) step1
           РѕЎ cong (╬╗ n Рєњ negPow (predРёЋ (fst i)) w +A negPow n w) (sym pred-suc)
           РѕЎ negPow-suc-cancel (predРёЋ (fst i)) w
      go : TrichotomyрхЌ (fst i) (fst j) Рєњ _
