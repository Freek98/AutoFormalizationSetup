      cong (s x) (╬БРЅАProp (╬╗ _ Рєњ isPropIsOrdered) refl)
      РѕЎ sym (Gx.invInv x _)
    -- (gt, eq): contradiction
    cРѓЂ-antisym-core s x ¤Ѓ (is-gt q<p) (is-eq ┬гq<p _) = РіЦ.rec (┬гq<p q<p)
    -- (gt, gt): contradiction
