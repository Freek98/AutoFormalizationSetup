  -- Antisymmetry of cРѓЂ-core: case analysis on two trichotomy results
  -- (no path types in scope, so direct pattern matching is safe)
  private
    cРѓЂ-antisym-core : (s : CРЂ┐-ord 1) (x : S) (¤Ѓ : Fin 2 Рєњ T x)
      Рєњ (rРѓЂ : Tri< (_<sto_ x) (¤Ѓ fzero) (¤Ѓ fone))
