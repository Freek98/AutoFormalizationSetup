-- Boolean comparison helpers
private
  ┬г<рхЌ0 : {n : РёЋ} Рєњ n <рхЌ zero Рєњ РіЦ
  ┬г<рхЌ0 {zero} h = h
  ┬г<рхЌ0 {suc _} h = h

  <рхЌ-РЅцрхЌ-trans : {a b c : РёЋ} Рєњ a <рхЌ b Рєњ b РЅцрхЌ c Рєњ a <рхЌ c
  <рхЌ-РЅцрхЌ-trans {zero} {zero} h _ = РіЦ.rec h
  <рхЌ-РЅцрхЌ-trans {zero} {suc b} {zero} _ h = РіЦ.rec (┬г<рхЌ0 {b} h)
  <рхЌ-РЅцрхЌ-trans {zero} {suc _} {suc _} _ _ = tt
  <рхЌ-РЅцрхЌ-trans {suc _} {zero} h _ = РіЦ.rec h
  <рхЌ-РЅцрхЌ-trans {suc _} {suc b} {zero} _ h = РіЦ.rec (┬г<рхЌ0 {b} h)
  <рхЌ-РЅцрхЌ-trans {suc a} {suc b} {suc c} = <рхЌ-РЅцрхЌ-trans {a} {b} {c}

-- punchIn: insert a gap at position i
-- Maps Fin n Рєњ Fin (suc n), skipping position i
-- Recursive definition: punchIn (suc a) (suc c) = fsuc (punchIn a c)
-- This gives definitional reduction for the simplicial identity proof
punchIn : {n : РёЋ} Рєњ Fin (suc n) Рєњ Fin n Рєњ Fin (suc n)
punchIn (zero , _) j = fsuc j
punchIn {suc _} (suc a , p) (zero , _) = fzero
punchIn {suc _} (suc a , p) (suc c , q) = fsuc (punchIn (a , p) (c , q))

-- РёЋ-level punchIn (mirrors Fin version, for proving simplicial identity)
punchIn-РёЋ : РёЋ Рєњ РёЋ Рєњ РёЋ
punchIn-РёЋ zero c = suc c
punchIn-РёЋ (suc a) zero = zero
punchIn-РёЋ (suc a) (suc c) = suc (punchIn-РёЋ a c)

-- Simplicial identity at РёЋ level: for a РЅц b,
--   punchIn a (punchIn b c) = punchIn (suc b) (punchIn a c)
simplicial-РёЋ : (a b c : РёЋ) Рєњ a РЅцрхЌ b
  Рєњ punchIn-РёЋ a (punchIn-РёЋ b c) РЅА punchIn-РёЋ (suc b) (punchIn-РёЋ a c)
simplicial-РёЋ zero b c _ = refl
simplicial-РёЋ (suc a) zero c h = РіЦ.rec (┬г<рхЌ0 {a} h)
simplicial-РёЋ (suc a) (suc b) zero h = refl
simplicial-РёЋ (suc a) (suc b) (suc c) h = cong suc (simplicial-РёЋ a b c h)

-- fst of punchIn agrees with punchIn-РёЋ (definitional)
punchIn-fst : {n : РёЋ} (i : Fin (suc n)) (j : Fin n)
  Рєњ fst (punchIn i j) РЅА punchIn-РёЋ (fst i) (fst j)
punchIn-fst (zero , _) j = refl
punchIn-fst {suc _} (suc a , p) (zero , _) = refl
punchIn-fst {suc _} (suc a , p) (suc c , q) = cong suc (punchIn-fst (a , p) (c , q))

-- Adjacent punchIn: for positions a and suc a, punchIn-РёЋ either gives
-- the same value (when c РЅа a) or swaps a Рєћ suc a (when c = a at РёЋ level)
adj-punchIn-РёЋ : (a c : РёЋ)
  Рєњ (punchIn-РёЋ a c РЅА punchIn-РёЋ (suc a) c)
    Ріј ((punchIn-РёЋ a c РЅА suc a) ├Ќ (punchIn-РёЋ (suc a) c РЅА a))
adj-punchIn-РёЋ zero zero = inr (refl , refl)
adj-punchIn-РёЋ zero (suc c) = inl refl
adj-punchIn-РёЋ (suc a) zero = inl refl
adj-punchIn-РёЋ (suc a) (suc c) =
  Ріј.rec (╬╗ e Рєњ inl (cong suc e))
        (╬╗ pq Рєњ inr (cong suc (fst pq) , cong suc (snd pq)))
        (adj-punchIn-РёЋ a c)

-- Simplicial identity at Fin level (direct pattern matching)
simplicial : {n : РёЋ} (i : Fin (suc (suc n))) (j : Fin (suc n)) (k : Fin n)
  (i' : Fin (suc n)) Рєњ fst i РЅА fst i' Рєњ fst i РЅцрхЌ fst j
  Рєњ punchIn i (punchIn j k) РЅА punchIn (fsuc j) (punchIn i' k)
simplicial (zero , pi) j k (zero , pi') e h = refl
simplicial (zero , pi) j k (suc a' , pi') e h =
  РіЦ.rec (znots e)
simplicial {suc n} (suc a , pi) (zero , pj) k i' e h =
  РіЦ.rec (┬г<рхЌ0 {a} h)
simplicial {suc n} (suc a , pi) (suc b , pj) (zero , pk) (zero , pi') e h =
  РіЦ.rec (snotz e)
simplicial {suc n} (suc a , pi) (suc b , pj) (zero , pk) (suc a' , pi') e h =
  refl
simplicial {suc n} (suc a , pi) (suc b , pj) (suc c , pk) (zero , pi') e h =
  РіЦ.rec (snotz e)
simplicial {suc n} (suc a , pi) (suc b , pj) (suc c , pk) (suc a' , pi') e h =
  cong fsuc (simplicial (a , pi) (b , pj) (c , pk) (a' , pi') (injSuc e) h)

-- Face map: delete position i from a (suc n)-tuple to get an n-tuple
faceMap : {n : РёЋ} {A : Type РёЊ} Рєњ Fin (suc n) Рєњ (Fin (suc n) Рєњ A) Рєњ (Fin n Рєњ A)
faceMap i ¤Ѓ = ¤Ѓ Рѕў punchIn i

-- punchOut: inverse of punchIn (given k РЅа i, find j with punchIn k j = i)
punchOut : {n : РёЋ} Рєњ (k : Fin (suc n)) Рєњ (i : Fin (suc n))
  Рєњ ┬г (fst k РЅА fst i) Рєњ Fin n
punchOut (zero , _) (zero , _) neq = РіЦ.rec (neq refl)
punchOut (zero , _) (suc c , q) _ = (c , q)
punchOut {suc _} (suc a , p) (zero , _) _ = fzero
punchOut {suc _} (suc a , p) (suc c , q) neq =
  fsuc (punchOut (a , p) (c , q) (╬╗ eq Рєњ neq (cong suc eq)))

-- punchIn Рѕў punchOut = id
punchIn-punchOut : {n : РёЋ} (k : Fin (suc n)) (i : Fin (suc n))
  (neq : ┬г (fst k РЅА fst i)) Рєњ punchIn k (punchOut k i neq) РЅА i
punchIn-punchOut (zero , _) (zero , _) neq = РіЦ.rec (neq refl)
punchIn-punchOut (zero , _) (suc c , q) _ = refl
punchIn-punchOut {suc _} (suc a , p) (zero , _) _ = refl
punchIn-punchOut {suc _} (suc a , p) (suc c , q) neq =
  cong fsuc (punchIn-punchOut (a , p) (c , q) (╬╗ eq Рєњ neq (cong suc eq)))

-- Swap two positions
swapFin : {n : РёЋ} Рєњ Fin n Рєњ Fin n Рєњ Fin n Рєњ Fin n
swapFin {n} i j k with discreteFin {n} k i
... | yes _ = j
... | no _ with discreteFin {n} k j
...   | yes _ = i
...   | no _ = k

-- Abstract swap properties (discreteFin is opaque for abstract n in Cubical Agda,
-- so these can't be proved by with-abstraction; concrete cases work fine via sw01┬▓ etc.)
postulate
  swapFin-ij : {n : РёЋ} (i j : Fin n) Рєњ _РЅА_ {A = Fin n} (swapFin {n} i j i) j
  swapFin-ji : {n : РёЋ} (i j : Fin n) Рєњ _РЅА_ {A = Fin n} (swapFin {n} i j j) i
  swapFin-fix : {n : РёЋ} (i j k : Fin n)
    Рєњ ┬г (fst k РЅА fst i) Рєњ ┬г (fst k РЅА fst j) Рєњ _РЅА_ {A = Fin n} (swapFin {n} i j k) k

