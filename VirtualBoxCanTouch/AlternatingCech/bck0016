  -- Helper: if ¤Ѓ has a repeat at (i,j) and k РЅа i,j, then ¤Ѓ Рѕў punchIn k has a repeat
  private
    face-has-repeat : {p : РёЋ} {x : S} (¤Ѓ : Fin (suc (suc p)) Рєњ T x)
      (i j : Fin (suc (suc p))) (k : Fin (suc (suc p)))
      Рєњ ┬г (fst k РЅА fst i) Рєњ ┬г (fst k РЅА fst j)
      Рєњ ┬г (i РЅА j) Рєњ ¤Ѓ i РЅА ¤Ѓ j
