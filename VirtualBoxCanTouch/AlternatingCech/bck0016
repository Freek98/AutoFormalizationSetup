  -- Vanishing: if ¤Ѓ has a repeat, then d s x ¤Ѓ = 0 (for alternating s)
  -- Uses sfg-two-cancel: terms at k РЅа i,j vanish (face-term-zero),
  -- terms at i,j cancel (face-terms-cancel).
  d-vanish-repeat : {p : РёЋ} (s : CРЂ┐ p) (alt : isAlternating s)
    Рєњ (x : S) (¤Ѓ : Fin (suc (suc p)) Рєњ T x)
    Рєњ (i j : Fin (suc (suc p))) Рєњ ┬г (i РЅА j) Рєњ ¤Ѓ i РЅА ¤Ѓ j
    Рєњ d s x ¤Ѓ РЅА Ax.0g x
  d-vanish-repeat {p} s alt x ¤Ѓ i j iРЅаj ¤Ѓeq =
    sfg-two-cancel (suc p) f i j fst-iРЅаj cancel zeros
    where
      f : Fin (suc (suc p)) Рєњ |A| x
      f k = negPow (fst k) (s x (¤Ѓ Рѕў punchIn k))
      fst-iРЅаj : ┬г (fst i РЅА fst j)
      fst-iРЅаj e = iРЅаj (╬БРЅАProp (╬╗ k Рєњ isProp<рхЌ {n = k} {m = suc (suc p)}) e)
      cancel : Ax._+_ x (f i) (f j) РЅА Ax.0g x
      cancel = face-terms-cancel s alt x ¤Ѓ i j iРЅаj ¤Ѓeq
      zeros : (k : Fin (suc (suc p))) Рєњ ┬г (fst k РЅА fst i) Рєњ ┬г (fst k РЅА fst j)
        Рєњ f k РЅА Ax.0g x
      zeros k kРЅаi kРЅаj = face-term-zero s (fst alt) ¤Ѓ i j iРЅаj ¤Ѓeq k kРЅаi kРЅаj

  d-preserves-alt : {p : РёЋ} (s : CРЂ┐ p)
    Рєњ isAlternating s Рєњ isAlternating (d s)
  d-preserves-alt s alt =
    (╬╗ x ¤Ѓ i j iРЅаj ¤Ѓeq Рєњ d-vanish-repeat s alt x ¤Ѓ i j iРЅаj ¤Ѓeq) ,
    (╬╗ x ¤Ѓ i j iРЅаj Рєњ d-antisym-swap s alt x ¤Ѓ i j iРЅаj)

  -- ================================================================
  -- Section 5: Main Theorems (Stacks Project Tag 01FG)
  -- ================================================================

  -- Lemma 20.23.6: The chain homotopy
  -- h_n : CРЂ┐ (suc n) Рєњ CРЂ┐ n such that dРѕўh + hРѕўd = id - ╬║
  -- where ╬║ = c Рѕў ¤ђ
  -- Formula at degree (suc p): for s : CРЂ┐ (suc p),
  --   d (h p s) + h (suc p) (d s) = s - ╬║ s
  postulate
    c¤ђ-homotopic-to-id :
      (╬║ : {n : РёЋ} Рєњ CРЂ┐ n Рєњ CРЂ┐ n)
      (h : (n : РёЋ) Рєњ CРЂ┐ (suc n) Рєњ CРЂ┐ n)
      Рєњ {p : РёЋ} (s : CРЂ┐ (suc p)) (x : S) (¤Ѓ : Fin (suc (suc p)) Рєњ T x)
      Рєњ Ax._+_ x (d (h p s) x ¤Ѓ) (h (suc p) (d s) x ¤Ѓ)
        РЅА Ax._+_ x (s x ¤Ѓ) (Ax.-_ x (╬║ s x ¤Ѓ))

  -- Lemma 20.23.7: Contractibility when U_i = X
  postulate
    contractible-with-section : {p : РёЋ}
      Рєњ (xРѓђ : S) Рєњ T xРѓђ
      Рєњ (s : CРЂ┐-alt (suc p))
      Рєњ ╬Б (CРЂ┐-alt p) (╬╗ t Рєњ d (╬╣map t) РЅА ╬╣map s)

