module GeneralCech {РёЊ : Level}
  (S : Type РёЊ) (T : S Рєњ Type РёЊ) (A : S Рєњ AbGroup РёЊ) where

  |A|_ : S Рєњ Type РёЊ
  |A| x = fst (A x)

  module Ax (x : S) = AbGroupStr (snd (A x))
  module Gx (x : S) = GroupProps.GroupTheory (AbGroupРєњGroup (A x))

  CРЂ┐ : РёЋ Рєњ Type РёЊ
  CРЂ┐ p = (x : S) Рєњ (Fin (suc p) Рєњ T x) Рєњ |A| x

  0C : {p : РёЋ} Рєњ CРЂ┐ p
  0C x _ = Ax.0g x

  negC : {p : РёЋ} Рєњ CРЂ┐ p Рєњ CРЂ┐ p
  negC s x ¤Ѓ = Ax.-_ x (s x ¤Ѓ)

  addC : {p : РёЋ} Рєњ CРЂ┐ p Рєњ CРЂ┐ p Рєњ CРЂ┐ p
  addC s t x ¤Ѓ = Ax._+_ x (s x ¤Ѓ) (t x ¤Ѓ)

  negPow : {x : S} Рєњ РёЋ Рєњ |A| x Рєњ |A| x
  negPow {x} zero a = a
  negPow {x} (suc n) a = Ax.-_ x (negPow n a)

  altFinSum : {x : S} Рєњ {n : РёЋ} Рєњ (Fin n Рєњ |A| x) Рєњ |A| x
  altFinSum {x} {n} f = sumFinGen {n = n} (Ax._+_ x) (Ax.0g x)
    (╬╗ j Рєњ negPow (fst j) (f j))

  d : {p : РёЋ} Рєњ CРЂ┐ p Рєњ CРЂ┐ (suc p)
  d {p} s x ¤Ѓ = altFinSum {x} {suc (suc p)}
    (╬╗ j Рєњ s x (faceMap j ¤Ѓ))

  CРЂ┐AbGroup : (p : РёЋ) Рєњ AbGroup РёЊ
  CРЂ┐AbGroup p = ╬аAbGroup {X = S} (╬╗ x Рєњ
    ╬аAbGroup {X = Fin (suc p) Рєњ T x} (╬╗ _ Рєњ A x))

  -- ================================================================
  -- Properties of negPow
  -- ================================================================

  negPow-two : {x : S} (a : |A| x) Рєњ negPow {x} 2 a РЅА a
  negPow-two {x} a = Gx.invInv x a

  negPow-add : {x : S} (n : РёЋ) (a b : |A| x)
    Рєњ negPow n (Ax._+_ x a b) РЅА Ax._+_ x (negPow n a) (negPow n b)
  negPow-add zero a b = refl
  negPow-add {x} (suc n) a b =
    Ax.-_ x (negPow n (Ax._+_ x a b))
      РЅАРЪе cong (Ax.-_ x) (negPow-add n a b) РЪЕ
    Ax.-_ x (Ax._+_ x (negPow n a) (negPow n b))
      РЅАРЪе Gx.invDistr x (negPow n a) (negPow n b) РЪЕ
    Ax._+_ x (Ax.-_ x (negPow n b)) (Ax.-_ x (negPow n a))
      РЅАРЪе Ax.+Comm x _ _ РЪЕ
    Ax._+_ x (Ax.-_ x (negPow n a)) (Ax.-_ x (negPow n b)) Рѕј

  negPow-0g : {x : S} (n : РёЋ) Рєњ negPow {x} n (Ax.0g x) РЅА Ax.0g x
  negPow-0g zero = refl
  negPow-0g {x} (suc n) =
    Ax.-_ x (negPow n (Ax.0g x))
      РЅАРЪе cong (Ax.-_ x) (negPow-0g n) РЪЕ
    Ax.-_ x (Ax.0g x)
      РЅАРЪе GroupProps.GroupTheory.inv1g (AbGroupРєњGroup (A x)) РЪЕ
    Ax.0g x Рѕј

  -- negPow composes: negPow i (negPow j a) РЅА negPow (i + j) a
  negPow-comp : {x : S} (i j : РёЋ) (a : |A| x)
    Рєњ negPow i (negPow j a) РЅА negPow (i + j) a
  negPow-comp zero j a = refl
  negPow-comp {x} (suc i) j a = cong (Ax.-_ x) (negPow-comp i j a)

  -- negPow distributes over sumFinGen
  negPow-sum : {x : S} {m : РёЋ} (n : РёЋ) (f : Fin m Рєњ |A| x)
    Рєњ negPow n (sumFinGen {n = m} (Ax._+_ x) (Ax.0g x) f)
    РЅА sumFinGen {n = m} (Ax._+_ x) (Ax.0g x) (╬╗ j Рєњ negPow n (f j))
  negPow-sum {m = zero} n f = negPow-0g n
  negPow-sum {x} {m = suc m} n f =
    negPow-add n (f flast) (sumFinGen {n = m} (Ax._+_ x) (Ax.0g x) (f Рѕў injectSuc))
    РѕЎ cong (Ax._+_ x (negPow n (f flast)))
           (negPow-sum {x = x} {m = m} n (f Рѕў injectSuc))

  -- ================================================================
  -- Linearity of d and d┬▓ = 0
  -- ================================================================

  private
    -- Abelian group interchange: (a+b)+(c+d) = (a+c)+(b+d)
    interchange : {x : S} (a b c d' : |A| x)
      Рєњ Ax._+_ x (Ax._+_ x a b) (Ax._+_ x c d')
      РЅА Ax._+_ x (Ax._+_ x a c) (Ax._+_ x b d')
    interchange {x} a b c d' =
      sym (Ax.+Assoc x a b _)
      РѕЎ cong (Ax._+_ x a) (Ax.+Assoc x b c d')
      РѕЎ cong (╬╗ z Рєњ Ax._+_ x a (Ax._+_ x z d')) (Ax.+Comm x b c)
      РѕЎ cong (Ax._+_ x a) (sym (Ax.+Assoc x c b d'))
      РѕЎ Ax.+Assoc x a c _

  -- sumFinGen distributes over +
  sumFinGen-+ : {x : S} {n : РёЋ} (f g : Fin n Рєњ |A| x)
    Рєњ sumFinGen {n = n} (Ax._+_ x) (Ax.0g x) (╬╗ j Рєњ Ax._+_ x (f j) (g j))
    РЅА Ax._+_ x (sumFinGen {n = n} (Ax._+_ x) (Ax.0g x) f)
                (sumFinGen {n = n} (Ax._+_ x) (Ax.0g x) g)
  sumFinGen-+ {x} {zero} f g = sym (Ax.+IdR x _)
  sumFinGen-+ {x} {suc n} f g =
    cong (Ax._+_ x (Ax._+_ x (f flast) (g flast)))
         (sumFinGen-+ {x} {n} (f Рѕў injectSuc) (g Рѕў injectSuc))
    РѕЎ interchange (f flast) (g flast) _ _

  d-pres+ : {p : РёЋ} (s t : CРЂ┐ p) (x : S) (¤Ѓ : Fin (suc (suc p)) Рєњ T x)
    Рєњ d (addC s t) x ¤Ѓ РЅА Ax._+_ x (d s x ¤Ѓ) (d t x ¤Ѓ)
  d-pres+ {p} s t x ¤Ѓ =
    cong (sumFinGen {n = suc (suc p)} (Ax._+_ x) (Ax.0g x))
         (funExt (╬╗ j Рєњ negPow-add (fst j) (s x (faceMap j ¤Ѓ)) (t x (faceMap j ¤Ѓ))))
    РѕЎ sumFinGen-+ {n = suc (suc p)}
                  (╬╗ j Рєњ negPow (fst j) (s x (faceMap j ¤Ѓ)))
                  (╬╗ j Рєњ negPow (fst j) (t x (faceMap j ¤Ѓ)))

  -- For p=0: face map compositions agree on Fin 1 (direct computation)
  -- Cancelling pairs: (0,0)Рєћ(1,0), (0,1)Рєћ(2,0), (1,1)Рєћ(2,1)
  private
    face-comp-00РЅА10 : {B : Type РёЊ} (¤Ѓ : Fin 3 Рєњ B)
      Рєњ ¤Ѓ Рѕў punchIn {2} fzero Рѕў punchIn {1} fzero
      РЅА ¤Ѓ Рѕў punchIn {2} fone Рѕў punchIn {1} fzero
    face-comp-00РЅА10 ¤Ѓ = funExt ╬╗ { (zero , _) Рєњ refl ; (suc _ , q) Рєњ РіЦ.rec q }

    face-comp-01РЅА20 : {B : Type РёЊ} (¤Ѓ : Fin 3 Рєњ B)
      Рєњ ¤Ѓ Рѕў punchIn {2} fzero Рѕў punchIn {1} fone
      РЅА ¤Ѓ Рѕў punchIn {2} (2 , tt) Рѕў punchIn {1} fzero
    face-comp-01РЅА20 ¤Ѓ = funExt ╬╗ { (zero , _) Рєњ refl ; (suc _ , q) Рєњ РіЦ.rec q }

    face-comp-11РЅА21 : {B : Type РёЊ} (¤Ѓ : Fin 3 Рєњ B)
      Рєњ ¤Ѓ Рѕў punchIn {2} fone Рѕў punchIn {1} fone
      РЅА ¤Ѓ Рѕў punchIn {2} (2 , tt) Рѕў punchIn {1} fone
    face-comp-11РЅА21 ¤Ѓ = funExt ╬╗ { (zero , _) Рєњ refl ; (suc _ , q) Рєњ РіЦ.rec q }

  -- Algebraic helpers for d┬▓
  private
    -- Telescoping: (-p + q) + (-q + r) РЅА -p + r
    telescope : {x : S} (p q r : |A| x)
      Рєњ Ax._+_ x (Ax._+_ x (Ax.-_ x p) q)
                  (Ax._+_ x (Ax.-_ x q) r)
      РЅА Ax._+_ x (Ax.-_ x p) r
    telescope {x} p q r =
      sym (Ax.+Assoc x (Ax.-_ x p) q _)
      РѕЎ cong (Ax._+_ x (Ax.-_ x p)) (Ax.+Assoc x q (Ax.-_ x q) r)
      РѕЎ cong (╬╗ z Рєњ Ax._+_ x (Ax.-_ x p) (Ax._+_ x z r)) (Ax.+InvR x q)
      РѕЎ cong (Ax._+_ x (Ax.-_ x p)) (Ax.+IdL x r)

    -- Cancellation: (-c + b) + ((-a + c) + (-b + a)) РЅА 0g
    cancel3 : {x : S} (a b c : |A| x)
      Рєњ Ax._+_ x (Ax._+_ x (Ax.-_ x c) b)
                  (Ax._+_ x (Ax._+_ x (Ax.-_ x a) c)
                            (Ax._+_ x (Ax.-_ x b) a))
      РЅА Ax.0g x
    cancel3 {x} a b c =
      cong (Ax._+_ x (Ax._+_ x (Ax.-_ x c) b))
           (Ax.+Comm x _ _)
      РѕЎ Ax.+Assoc x _ _ _
      РѕЎ cong (╬╗ z Рєњ Ax._+_ x z (Ax._+_ x (Ax.-_ x a) c))
             (telescope c b a)
      РѕЎ telescope c a c
      РѕЎ Ax.+InvL x c

  -- d┬▓ = 0 for degree 0 (direct computation)
  d┬▓-0 : (s : CРЂ┐ 0) (x : S) (¤Ѓ : Fin 3 Рєњ T x)
    Рєњ d (d s) x ¤Ѓ РЅА Ax.0g x
  d┬▓-0 s x ¤Ѓ = step1 РѕЎ step2 РѕЎ cancel3 TРѓђРѓђ TРѓђРѓЂ TРѓЂРѓЂ
    where
      TРѓђРѓђ = s x (¤Ѓ Рѕў punchIn {2} fzero Рѕў punchIn {1} fzero)
      TРѓђРѓЂ = s x (¤Ѓ Рѕў punchIn {2} fzero Рѕў punchIn {1} fone)
      TРѓЂРѓЂ = s x (¤Ѓ Рѕў punchIn {2} fone Рѕў punchIn {1} fone)
      eqРѓЂ = cong (s x) (face-comp-00РЅА10 ¤Ѓ)
      eqРѓѓ = cong (s x) (face-comp-01РЅА20 ¤Ѓ)
      eqРѓЃ = cong (s x) (face-comp-11РЅА21 ¤Ѓ)
      -- Step 1: substitute face-comp equalities (6 vars Рєњ 3 vars)
      step1 = congРѓѓ (Ax._+_ x)
        (cong (╬╗ w Рєњ Ax.-_ x (Ax.-_ x w))
          (congРѓѓ (Ax._+_ x) (cong (Ax.-_ x) (sym eqРѓЃ))
                             (cong (╬╗ z Рєњ Ax._+_ x z (Ax.0g x)) (sym eqРѓѓ))))
        (cong (╬╗ z Рєњ Ax._+_ x
          (Ax.-_ x (Ax._+_ x (Ax.-_ x TРѓЂРѓЂ) (Ax._+_ x z (Ax.0g x))))
          (Ax._+_ x (Ax._+_ x (Ax.-_ x TРѓђРѓЂ) (Ax._+_ x TРѓђРѓђ (Ax.0g x)))
                    (Ax.0g x)))
          (sym eqРѓЂ))
      -- Step 2: simplify using invInv, +IdR, invDistr Рєњ cancel3 form
      step2 = congРѓѓ (Ax._+_ x)
        (Gx.invInv x _ РѕЎ cong (Ax._+_ x (Ax.-_ x TРѓЂРѓЂ)) (Ax.+IdR x TРѓђРѓЂ))
        (congРѓѓ (Ax._+_ x)
          (cong (Ax.-_ x) (cong (Ax._+_ x (Ax.-_ x TРѓЂРѓЂ)) (Ax.+IdR x TРѓђРѓђ))
           РѕЎ Gx.invDistr x (Ax.-_ x TРѓЂРѓЂ) TРѓђРѓђ
           РѕЎ cong (Ax._+_ x (Ax.-_ x TРѓђРѓђ)) (Gx.invInv x TРѓЂРѓЂ))
          (Ax.+IdR x _ РѕЎ cong (Ax._+_ x (Ax.-_ x TРѓђРѓЂ)) (Ax.+IdR x TРѓђРѓђ)))

  -- negPow n a + negPow (suc n) a РЅА 0g  (cancel adjacent signs)
  negPow-suc-cancel : {x : S} (n : РёЋ) (a : |A| x)
    Рєњ Ax._+_ x (negPow n a) (negPow (suc n) a) РЅА Ax.0g x
  negPow-suc-cancel {x} n a = Ax.+InvR x (negPow n a)

  -- Face map composition via simplicial identity
  face-comp : {n : РёЋ} {B : Type РёЊ} (i : Fin (suc (suc n))) (j : Fin (suc n))
    (i' : Fin (suc n)) (¤Ѓ : Fin (suc (suc n)) Рєњ B)
    Рєњ fst i РЅА fst i' Рєњ fst i РЅцрхЌ fst j
    Рєњ faceMap j (faceMap i ¤Ѓ) РЅА faceMap i' (faceMap (fsuc j) ¤Ѓ)
  face-comp i j i' ¤Ѓ e h = funExt (╬╗ k Рєњ cong ¤Ѓ (simplicial i j k i' e h))

  -- Sum of zeros is zero
  sfg-0 : {x : S} (n : РёЋ) (f : Fin n Рєњ |A| x)
    Рєњ (Рѕђ k Рєњ f k РЅА Ax.0g x)
    Рєњ sumFinGen {n = n} (Ax._+_ x) (Ax.0g x) f РЅА Ax.0g x
  sfg-0 zero f h = refl
  sfg-0 {x} (suc n) f h =
    congРѓѓ (Ax._+_ x) (h flast)
      (sfg-0 n (╬╗ k Рєњ f (injectSuc k)) (╬╗ k Рєњ h (injectSuc k)))
    РѕЎ Ax.+IdR x (Ax.0g x)

  -- Sum with a single nonzero term
  sfg-single : {x : S} (n : РёЋ) (f : Fin (suc n) Рєњ |A| x) (i : Fin (suc n))
    Рєњ ((k : Fin (suc n)) Рєњ ┬г (fst k РЅА fst i) Рєњ f k РЅА Ax.0g x)
    Рєњ sumFinGen {n = suc n} (Ax._+_ x) (Ax.0g x) f РЅА f i
  sfg-single {x} zero f (zero , _) h =
    Ax.+IdR x (f fzero)
  sfg-single {x} zero f (suc _ , q) h = РіЦ.rec q
  sfg-single {x} (suc n') f i h with suc n' РЅЪрхЌ fst i
  ... | eqрхЌ p =
    let flastРЅАi : flast РЅА i
        flastРЅАi = ╬БРЅАProp (╬╗ k Рєњ isProp<рхЌ {n = k} {m = suc (suc n')}) p
        -- every injectSuc k has fst k < suc n' = fst i, so k РЅа i
        rest-zero : (k : Fin (suc n')) Рєњ f (injectSuc k) РЅА Ax.0g x
        rest-zero k = h (injectSuc k) ╬╗ e Рєњ
          ┬гm<рхЌm {fst i} (subst (_<рхЌ fst i) e (subst (fst k <рхЌ_) p (snd k)))
    in congРѓѓ (Ax._+_ x) (cong f flastРЅАi)
         (sfg-0 (suc n') (f Рѕў injectSuc) rest-zero)
       РѕЎ Ax.+IdR x (f i)
  ... | ltрхЌ q = РіЦ.rec (┬гm<рхЌm {suc n'} (<рхЌ-РЅцрхЌ-trans {suc n'} {fst i} {suc n'} q (snd i)))
  ... | gtрхЌ q =
    let nРЅаi : ┬г (suc n' РЅА fst i)
        nРЅаi e = ┬гm<рхЌm {fst i} (subst (fst i <рхЌ_) e q)
        i' : Fin (suc n')
        i' = fst i , q
        iSРЅАi : injectSuc i' РЅА i
        iSРЅАi = ╬БРЅАProp (╬╗ k Рєњ isProp<рхЌ {n = k} {m = suc (suc n')}) refl
    in congРѓѓ (Ax._+_ x) (h flast nРЅаi)
         (sfg-single {x} n' (f Рѕў injectSuc) i'
           (╬╗ k kРЅаi' Рєњ h (injectSuc k) kРЅаi'))
       РѕЎ Ax.+IdL x (f (injectSuc i'))
       РѕЎ cong f iSРЅАi

  -- Sum with two nonzero terms that cancel
  sfg-two-cancel : {x : S} (n : РёЋ) (f : Fin (suc n) Рєњ |A| x)
    (i j : Fin (suc n)) Рєњ ┬г (fst i РЅА fst j)
    Рєњ Ax._+_ x (f i) (f j) РЅА Ax.0g x
    Рєњ ((k : Fin (suc n)) Рєњ ┬г (fst k РЅА fst i) Рєњ ┬г (fst k РЅА fst j) Рєњ f k РЅА Ax.0g x)
    Рєњ sumFinGen {n = suc n} (Ax._+_ x) (Ax.0g x) f РЅА Ax.0g x
  -- Base: n=0 means Fin 1, can't have two distinct elements
  sfg-two-cancel {x} zero f i j iРЅаj _ _ = РіЦ.rec (iРЅаj (cong fst (go i) РѕЎ sym (cong fst (go j))))
    where go : (k : Fin 1) Рєњ k РЅА fzero
          go (zero , _) = ╬БРЅАProp (╬╗ z Рєњ isProp<рхЌ {n = z} {m = 1}) refl
          go (suc _ , q) = РіЦ.rec q
  -- Step: n = suc n'
  sfg-two-cancel {x} (suc n') f i j iРЅаj cancel h with suc n' РЅЪрхЌ fst i
  ... | ltрхЌ q = РіЦ.rec (┬гm<рхЌm {suc n'} (<рхЌ-РЅцрхЌ-trans {suc n'} {fst i} {suc n'} q (snd i)))
  ... | eqрхЌ p = goal
    where
      flastРЅАi : flast РЅА i
      flastРЅАi = ╬БРЅАProp (╬╗ k Рєњ isProp<рхЌ {n = k} {m = suc (suc n')}) p
      j<sn : fst j <рхЌ suc n'
      j<sn with suc n' РЅЪрхЌ fst j
      ... | eqрхЌ e = РіЦ.rec (iРЅаj (sym p РѕЎ e))
      ... | ltрхЌ r = РіЦ.rec (┬гm<рхЌm {suc n'} (<рхЌ-РЅцрхЌ-trans {suc n'} {fst j} {suc n'} r (snd j)))
      ... | gtрхЌ r = r
      j' : Fin (suc n')
      j' = fst j , j<sn
      jSРЅАj : injectSuc j' РЅА j
      jSРЅАj = ╬БРЅАProp (╬╗ k Рєњ isProp<рхЌ {n = k} {m = suc (suc n')}) refl
      k<i : (k : Fin (suc n')) Рєњ fst k <рхЌ fst i
      k<i k = subst (fst k <рхЌ_) p (snd k)
      goal : _
      goal = congРѓѓ (Ax._+_ x) (cong f flastРЅАi)
         (sfg-single n' (f Рѕў injectSuc) j'
           (╬╗ k kРЅаj' Рєњ h (injectSuc k)
             (╬╗ e Рєњ ┬гm<рхЌm {fst i} (subst (_<рхЌ fst i) e (k<i k)))
             kРЅаj')
         РѕЎ cong f jSРЅАj)
       РѕЎ cancel
  ... | gtрхЌ q with suc n' РЅЪрхЌ fst j
  ...   | ltрхЌ r = РіЦ.rec (┬гm<рхЌm {suc n'} (<рхЌ-РЅцрхЌ-trans {suc n'} {fst j} {suc n'} r (snd j)))
  ...   | eqрхЌ p =
    let flastРЅАj : flast РЅА j
        flastРЅАj = ╬БРЅАProp (╬╗ k Рєњ isProp<рхЌ {n = k} {m = suc (suc n')}) p
        i' : Fin (suc n')
        i' = fst i , q
        iSРЅАi : injectSuc i' РЅА i
        iSРЅАi = ╬БРЅАProp (╬╗ k Рєњ isProp<рхЌ {n = k} {m = suc (suc n')}) refl
        k<j : (k : Fin (suc n')) Рєњ fst k <рхЌ fst j
        k<j k = subst (fst k <рхЌ_) p (snd k)
    in congРѓѓ (Ax._+_ x) (cong f flastРЅАj)
         (sfg-single n' (f Рѕў injectSuc) i'
           (╬╗ k kРЅаi' Рєњ h (injectSuc k) kРЅаi'
             (╬╗ e Рєњ ┬гm<рхЌm {fst j} (subst (_<рхЌ fst j) e (k<j k))))
         РѕЎ cong f iSРЅАi)
       РѕЎ Ax.+Comm x (f j) (f i) РѕЎ cancel
  ...   | gtрхЌ r =
    let nРЅаi : ┬г (suc n' РЅА fst i)
        nРЅаi e = ┬гm<рхЌm {fst i} (subst (fst i <рхЌ_) e q)
        nРЅаj : ┬г (suc n' РЅА fst j)
        nРЅаj e = ┬гm<рхЌm {fst j} (subst (fst j <рхЌ_) e r)
        i' : Fin (suc n')
        i' = fst i , q
        j' : Fin (suc n')
        j' = fst j , r
        iSРЅАi : injectSuc i' РЅА i
        iSРЅАi = ╬БРЅАProp (╬╗ k Рєњ isProp<рхЌ {n = k} {m = suc (suc n')}) refl
        jSРЅАj : injectSuc j' РЅА j
        jSРЅАj = ╬БРЅАProp (╬╗ k Рєњ isProp<рхЌ {n = k} {m = suc (suc n')}) refl
        i'РЅаj' : ┬г (fst i' РЅА fst j')
        i'РЅаj' = iРЅаj
    in congРѓѓ (Ax._+_ x)
         (h flast nРЅаi nРЅаj)
         (sfg-two-cancel n' (f Рѕў injectSuc) i' j' i'РЅаj'
           (congРѓѓ (Ax._+_ x) (cong f iSРЅАi) (cong f jSРЅАj) РѕЎ cancel)
           (╬╗ k kРЅаi' kРЅаj' Рєњ h (injectSuc k) kРЅаi' kРЅаj'))
       РѕЎ Ax.+IdR x (Ax.0g x)

  -- Fubini: interchange of summation order
  -- ╬Брхб ╬БР▒╝ g(i,j) РЅА ╬БР▒╝ ╬Брхб g(i,j)
  sumFinGen-swap : {x : S} (n m : РёЋ) (g : Fin n Рєњ Fin m Рєњ |A| x)
    Рєњ sumFinGen {n = n} (Ax._+_ x) (Ax.0g x)
        (╬╗ i Рєњ sumFinGen {n = m} (Ax._+_ x) (Ax.0g x) (g i))
    РЅА sumFinGen {n = m} (Ax._+_ x) (Ax.0g x)
        (╬╗ j Рєњ sumFinGen {n = n} (Ax._+_ x) (Ax.0g x) (╬╗ i Рєњ g i j))
  sumFinGen-swap {x} zero m g =
    sym (sfg-0 m (╬╗ _ Рєњ Ax.0g x) (╬╗ _ Рєњ refl))
  sumFinGen-swap {x} (suc n) m g =
    let _+_ = Ax._+_ x ; 0g = Ax.0g x
        ih = sumFinGen-swap {x} n m (╬╗ i Рєњ g (injectSuc i))
        fРѓЂ = g flast
        fРѓѓ = ╬╗ j Рєњ sumFinGen {n = n} _+_ 0g (╬╗ i Рєњ g (injectSuc i) j)
    in cong (_+_ (sumFinGen {n = m} _+_ 0g fРѓЂ)) ih
       РѕЎ sym (sumFinGen-+ {n = m} fРѓЂ fРѓѓ)

  -- General d┬▓ = 0 (uses d┬▓-0 pattern; general case requires simplicial identity)
  postulate
    d┬▓ : {p : РёЋ} (s : CРЂ┐ p) (x : S)
      (¤Ѓ : Fin (suc (suc (suc p))) Рєњ T x)
      Рєњ d (d s) x ¤Ѓ РЅА Ax.0g x

-- ================================================================
-- Section 4: Alternating ─їech Complex
-- ================================================================

module AlternatingCech {РёЊ : Level}
  (S : Type РёЊ) (T : S Рєњ Type РёЊ) (A : S Рєњ AbGroup РёЊ)
  (ordT : (x : S) Рєњ DecStrictTotalOrder (T x)) where

  open GeneralCech S T A public
  open module Ox (x : S) = DecStrictTotalOrder (ordT x)

  -- ================================================================
  -- 4.1: Tuple properties
  -- ================================================================

  isInjTuple : {p : РёЋ} {x : S} Рєњ (Fin (suc p) Рєњ T x) Рєњ Type РёЊ
  isInjTuple ¤Ѓ = Рѕђ i j Рєњ ¤Ѓ i РЅА ¤Ѓ j Рєњ i РЅА j

  hasRepeat : {p : РёЋ} {x : S} Рєњ (Fin (suc p) Рєњ T x) Рєњ Type РёЊ
  hasRepeat ¤Ѓ = ╬Б[ i Рѕѕ _ ] ╬Б[ j Рѕѕ _ ] (┬г (i РЅА j)) ├Ќ (¤Ѓ i РЅА ¤Ѓ j)

  isOrdered : {p : РёЋ} {x : S} Рєњ (Fin (suc p) Рєњ T x) Рєњ Type РёЊ
  isOrdered {p} {x} ¤Ѓ = Рѕђ (i j : Fin (suc p)) Рєњ fst i <рхЌ fst j
    Рєњ _<sto_ x (¤Ѓ i) (¤Ѓ j)

  -- ================================================================
  -- 4.2: Alternating cochains (Definition 20.23.1)
  -- ================================================================

  isAlternating : {p : РёЋ} Рєњ CРЂ┐ p Рєњ Type РёЊ
  isAlternating {p} s =
    ((x : S) (¤Ѓ : Fin (suc p) Рєњ T x) (i j : Fin (suc p))
      Рєњ ┬г (i РЅА j) Рєњ ¤Ѓ i РЅА ¤Ѓ j Рєњ s x ¤Ѓ РЅА Ax.0g x)
    ├Ќ
    ((x : S) (¤Ѓ : Fin (suc p) Рєњ T x) (i j : Fin (suc p))
      Рєњ ┬г (i РЅА j) Рєњ s x (¤Ѓ Рѕў swapFin {suc p} i j) РЅА Ax.-_ x (s x ¤Ѓ))

  CРЂ┐-alt : РёЋ Рєњ Type РёЊ
  CРЂ┐-alt p = ╬Б (CРЂ┐ p) (isAlternating {p})

  -- ================================================================
  -- 4.3: Ordered ─їech complex (Definition 20.23.2)
  -- ================================================================

  OrdTuple : РёЋ Рєњ S Рєњ Type РёЊ
  OrdTuple p x = ╬Б (Fin (suc p) Рєњ T x) (isOrdered {p} {x})

  CРЂ┐-ord : РёЋ Рєњ Type РёЊ
  CРЂ┐-ord p = (x : S) Рєњ OrdTuple p x Рєњ |A| x

  -- ================================================================
  -- 4.4: Comparison maps
  -- ================================================================

  ¤ђmap : {p : РёЋ} Рєњ CРЂ┐ p Рєњ CРЂ┐-ord p
  ¤ђmap s x (¤Ѓ , _) = s x ¤Ѓ

  ╬╣map : {p : РёЋ} Рєњ CРЂ┐-alt p Рєњ CРЂ┐ p
  ╬╣map = fst

  -- ================================================================
  -- 4.5: Sorting infrastructure for degree 1
  -- ================================================================

  sortPair : {x : S} Рєњ T x Рєњ T x Рєњ (T x ├Ќ T x ├Ќ РёЋ)
  sortPair {x} a b with <sto-tricho x a b
  ... | is-lt _ = (a , b , 0)
  ... | is-eq _ _ = (a , b , 0)
  ... | is-gt _ = (b , a , 1)

  -- Ordered pair witness: direct pattern matching on Fin 2
  -- Key: n <рхЌ 0 = РіЦ and suc n <рхЌ suc m = n <рхЌ m definitionally
  mkOrd2 : {x : S} (¤Ѓ : Fin 2 Рєњ T x) Рєњ _<sto_ x (¤Ѓ fzero) (¤Ѓ fone)
    Рєњ isOrdered {1} {x} ¤Ѓ
  mkOrd2 ¤Ѓ a<b (zero , _) (zero , _) p = РіЦ.rec p
  mkOrd2 ¤Ѓ a<b (zero , _) (suc zero , _) _ = a<b
  mkOrd2 ¤Ѓ a<b (zero , _) (suc (suc _) , q) _ = РіЦ.rec q
  mkOrd2 ¤Ѓ a<b (suc zero , _) (zero , _) p = РіЦ.rec p
  mkOrd2 ¤Ѓ a<b (suc zero , _) (suc zero , _) p = РіЦ.rec p
  mkOrd2 ¤Ѓ a<b (suc zero , _) (suc (suc _) , q) _ = РіЦ.rec q
  mkOrd2 ¤Ѓ a<b (suc (suc _) , q) _ _ = РіЦ.rec q

  -- ================================================================
  -- 4.6: Comparison map c for degree 1 (Lemma 20.23.3)
  -- ================================================================

  -- Core of comparison map: takes trichotomy result as explicit argument
  cРѓЂ-core : CРЂ┐-ord 1 Рєњ (x : S) Рєњ (¤Ѓ : Fin 2 Рєњ T x)
    Рєњ Tri< (_<sto_ x) (¤Ѓ fzero) (¤Ѓ fone) Рєњ |A| x
  cРѓЂ-core s x ¤Ѓ (is-lt a<b) = s x (¤Ѓ , mkOrd2 ¤Ѓ a<b)
  cРѓЂ-core s x ¤Ѓ (is-eq _ _) = Ax.0g x
  cРѓЂ-core s x ¤Ѓ (is-gt b<a) = Ax.-_ x
    (s x (¤Ѓ Рѕў swapFin {2} fzero fone , mkOrd2 (¤Ѓ Рѕў swapFin {2} fzero fone) b<a))

  cРѓЂ-fun : CРЂ┐-ord 1 Рєњ CРЂ┐ 1
  cРѓЂ-fun s x ¤Ѓ = cРѓЂ-core s x ¤Ѓ (<sto-tricho x (¤Ѓ fzero) (¤Ѓ fone))

  -- cРѓЂ-fun vanishes when ¤Ѓ fzero РЅА ¤Ѓ fone (repeated entry)
  -- Uses Tri<-elim + lambda to avoid binding path types in pattern LHS
  private
    cРѓЂ-vanish : (s : CРЂ┐-ord 1) (x : S) (¤Ѓ : Fin 2 Рєњ T x)
      Рєњ ¤Ѓ fzero РЅА ¤Ѓ fone Рєњ cРѓЂ-fun s x ¤Ѓ РЅА Ax.0g x
    cРѓЂ-vanish s x ¤Ѓ = ╬╗ eq Рєњ Tri<-elim {P = ╬╗ r Рєњ cРѓЂ-core s x ¤Ѓ r РЅА Ax.0g x}
      (╬╗ a<b Рєњ РіЦ.rec (<sto-irrefl x (¤Ѓ fzero)
        (subst (_<sto_ x (¤Ѓ fzero)) (sym eq) a<b)))
      (╬╗ _ _ Рєњ refl)
      (╬╗ b<a Рєњ РіЦ.rec (<sto-irrefl x (¤Ѓ fzero)
        (subst (╬╗ y Рєњ _<sto_ x y (¤Ѓ fzero)) (sym eq) b<a)))
      (<sto-tricho x (¤Ѓ fzero) (¤Ѓ fone))

  -- Vanishing part of cРѓЂ-alternating: case split on Fin 2 indices,
  -- but keep eq : ¤Ѓ i РЅА ¤Ѓ j as a lambda argument (not on LHS)
  private
    cРѓЂ-alt-vanish : (s : CРЂ┐-ord 1) (x : S) (¤Ѓ : Fin 2 Рєњ T x)
      (i j : Fin 2) Рєњ ┬г (i РЅА j) Рєњ ¤Ѓ i РЅА ¤Ѓ j Рєњ cРѓЂ-fun s x ¤Ѓ РЅА Ax.0g x
    cРѓЂ-alt-vanish s x ¤Ѓ (zero , _) (zero , _) ┬гeq =
      ╬╗ _ Рєњ РіЦ.rec (┬гeq (╬БРЅАProp (╬╗ k Рєњ isProp<рхЌ {n = k} {m = 2}) refl))
    cРѓЂ-alt-vanish s x ¤Ѓ (zero , _) (suc zero , _) _ =
      cРѓЂ-vanish s x ¤Ѓ
    cРѓЂ-alt-vanish s x ¤Ѓ (zero , _) (suc (suc _) , q) _ = ╬╗ _ Рєњ РіЦ.rec q
    cРѓЂ-alt-vanish s x ¤Ѓ (suc zero , _) (zero , _) _ =
      cРѓЂ-vanish s x ¤Ѓ Рѕў sym
    cРѓЂ-alt-vanish s x ¤Ѓ (suc zero , _) (suc zero , _) ┬гeq =
      ╬╗ _ Рєњ РіЦ.rec (┬гeq (╬БРЅАProp (╬╗ k Рєњ isProp<рхЌ {n = k} {m = 2}) refl))
    cРѓЂ-alt-vanish s x ¤Ѓ (suc zero , _) (suc (suc _) , q) _ = ╬╗ _ Рєњ РіЦ.rec q
    cРѓЂ-alt-vanish s x ¤Ѓ (suc (suc _) , q) _ _ = ╬╗ _ Рєњ РіЦ.rec q

  -- isOrdered is a proposition (since _<sto_ is prop-valued)
  isPropIsOrdered : {p : РёЋ} {x : S} {¤Ѓ : Fin (suc p) Рєњ T x}
    Рєњ isProp (isOrdered {p} {x} ¤Ѓ)
  isPropIsOrdered {x = x} {¤Ѓ} =
