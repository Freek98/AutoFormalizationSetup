module ConnectionToPart14 {РёЊ : Level}
  (S : Type РёЊ) (T : S Рєњ Type РёЊ) (A : S Рєњ AbGroup РёЊ) where

  open GeneralCech S T A

  to-simple-CРЂ░ : CРЂ┐ 0 Рєњ ((x : S) Рєњ T x Рєњ |A| x)
  to-simple-CРЂ░ s x t = s x (╬╗ _ Рєњ t)

  from-simple-CРЂ░ : ((x : S) Рєњ T x Рєњ |A| x) Рєњ CРЂ┐ 0
  from-simple-CРЂ░ s x ¤Ѓ = s x (¤Ѓ fzero)

  to-simple-C┬╣ : CРЂ┐ 1 Рєњ ((x : S) Рєњ T x Рєњ T x Рєњ |A| x)
  to-simple-C┬╣ s x u v = s x tup
    where
      tup : Fin 2 Рєњ T x
      tup (zero , _) = u
      tup (suc zero , _) = v

  from-simple-C┬╣ : ((x : S) Рєњ T x Рєњ T x Рєњ |A| x) Рєњ CРЂ┐ 1
  from-simple-C┬╣ s x ¤Ѓ = s x (¤Ѓ fzero) (¤Ѓ fone)

  mk2Tuple : {B : Type РёЊ} Рєњ B Рєњ B Рєњ Fin 2 Рєњ B
  mk2Tuple a b (zero , _) = a
  mk2Tuple a b (suc zero , _) = b

  mk3Tuple : {B : Type РёЊ} Рєњ B Рєњ B Рєњ B Рєњ Fin 3 Рєњ B
  mk3Tuple u v w (zero , _) = u
  mk3Tuple u v w (suc zero , _) = v
  mk3Tuple u v w (suc (suc zero) , _) = w

  -- Face map equalities relating face maps of mk3Tuple to mk2Tuple/¤Ѓ
  private
    face0РЅА : {x : S} (u v w : T x)
      Рєњ faceMap fzero (mk3Tuple u v w) РЅА mk2Tuple v w
    face0РЅА u v w = funExt go where
      go : Рѕђ k Рєњ _
      go (zero , _) = refl
      go (suc zero , _) = refl
      go (suc (suc _) , q) = РіЦ.rec q

    face1РЅА : {x : S} (u v w : T x)
      Рєњ faceMap fone (mk3Tuple u v w) РЅА mk2Tuple u w
    face1РЅА u v w = funExt go where
      go : Рѕђ k Рєњ _
      go (zero , _) = refl
      go (suc zero , _) = refl
      go (suc (suc _) , q) = РіЦ.rec q

    face2РЅА : {x : S} (u v w : T x)
      Рєњ faceMap (2 , tt) (mk3Tuple u v w) РЅА mk2Tuple u v
    face2РЅА u v w = funExt go where
      go : Рѕђ k Рєњ _
      go (zero , _) = refl
      go (suc zero , _) = refl
      go (suc (suc _) , q) = РіЦ.rec q

    mk2РЅА¤Ѓ : {x : S} (¤Ѓ : Fin 2 Рєњ T x) Рєњ mk2Tuple (¤Ѓ fzero) (¤Ѓ fone) РЅА ¤Ѓ
    mk2РЅА¤Ѓ ¤Ѓ = funExt go where
      go : Рѕђ k Рєњ _
      go (zero , _) = refl
      go (suc zero , _) = refl
      go (suc (suc _) , q) = РіЦ.rec q

  section-exact : ((x : S) Рєњ T x)
    Рєњ (╬▓ : CРЂ┐ 1) Рєњ ((x : S) (u v w : T x) Рєњ
        d ╬▓ x (mk3Tuple u v w) РЅА Ax.0g x)
    Рєњ ╬Б (CРЂ┐ 0) (╬╗ ╬▒ Рєњ Рѕђ x ¤Ѓ Рєњ d ╬▒ x ¤Ѓ РЅА ╬▓ x ¤Ѓ)
  section-exact t ╬▓ cocycle = ╬▒ , proof
    where
      ╬▒ : CРЂ┐ 0
      ╬▒ x ¤Ѓ = ╬▓ x (mk2Tuple (t x) (¤Ѓ fzero))

      proof : Рѕђ x ¤Ѓ Рєњ d ╬▒ x ¤Ѓ РЅА ╬▓ x ¤Ѓ
      proof x ¤Ѓ =
        let p = ¤Ѓ fzero ; q = ¤Ѓ fone
            _+_ = Ax._+_ x ; -_ = Ax.-_ x ; 0g = Ax.0g x
            c = ╬▓ x (mk2Tuple (t x) p)  -- = ╬▒ x (faceMap fone ¤Ѓ)
            b = ╬▓ x (mk2Tuple (t x) q)  -- = ╬▒ x (faceMap fzero ¤Ѓ)
            -- Raw cocycle: d ╬▓ x (mk3Tuple (t x) p q) РЅА 0g
            -- Definitionally: -(-(╬▓ face2)) + (-(╬▓ face1) + (╬▓ face0 + 0g)) РЅА 0g
            -- Convert using faceРЅА + invInv to: c + (-b + (╬▓ ¤Ѓ + 0g)) РЅА 0g
            cocyc-conv : (- (- (╬▓ x (faceMap (2 , tt) (mk3Tuple (t x) p q)))))
                         + ((- (╬▓ x (faceMap fone (mk3Tuple (t x) p q))))
                         + (╬▓ x (faceMap fzero (mk3Tuple (t x) p q)) + 0g))
                       РЅА c + ((- b) + (╬▓ x ¤Ѓ + 0g))
            cocyc-conv =
              congРѓѓ _+_
                (Gx.invInv x _ РѕЎ cong (╬▓ x) (face2РЅА (t x) p q))
                (congРѓѓ _+_
                  (cong -_ (cong (╬▓ x) (face1РЅА (t x) p q)))
                  (cong (_+ 0g) (cong (╬▓ x) (face0РЅА (t x) p q РѕЎ mk2РЅА¤Ѓ ¤Ѓ))))
            cocyc' : c + ((- b) + (╬▓ x ¤Ѓ + 0g)) РЅА 0g
            cocyc' = sym cocyc-conv РѕЎ cocycle x (t x) p q
            -- From cocyc': c + (-b + a) = 0 (after +IdR)
            -- invUniqueR: -b + a = -c
            -- Then: -c + b = a (algebraic rearrangement)
            step1 : c + ((- b) + ╬▓ x ¤Ѓ) РЅА 0g
            step1 = subst (╬╗ z Рєњ c + ((- b) + z) РЅА 0g) (Ax.+IdR x (╬▓ x ¤Ѓ)) cocyc'
            step2 : (- b) + ╬▓ x ¤Ѓ РЅА - c
            step2 = Gx.invUniqueR x step1
        in
        (- c) + (b + 0g)
          РЅАРЪе cong ((- c) +_) (Ax.+IdR x b) РЪЕ
        (- c) + b
          РЅАРЪе Ax.+Comm x (- c) b РЪЕ
        b + (- c)
          РЅАРЪе cong (b +_) (sym step2) РЪЕ
        b + ((- b) + ╬▓ x ¤Ѓ)
          РЅАРЪе Ax.+Assoc x b (- b) (╬▓ x ¤Ѓ) РЪЕ
        (b + (- b)) + ╬▓ x ¤Ѓ
          РЅАРЪе cong (_+ ╬▓ x ¤Ѓ) (Ax.+InvR x b) РЪЕ
        0g + ╬▓ x ¤Ѓ
          РЅАРЪе Ax.+IdL x (╬▓ x ¤Ѓ) РЪЕ
        ╬▓ x ¤Ѓ Рѕј

