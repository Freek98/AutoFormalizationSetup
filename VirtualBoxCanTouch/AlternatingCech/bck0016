    in cong (s x) (funExt (adj-face-eq ¤Ѓ i j siРЅАfj ¤Ѓeq))
  face-shift-aux {p} s alt x (suc d') ¤Ѓ i j si+sdРЅАfj ¤Ѓeq = goal
    where
      postulate
        goal : s x (¤Ѓ Рѕў punchIn i) РЅА negPow (suc d') (s x (¤Ѓ Рѕў punchIn j))

  face-shift : {p : РёЋ} (s : CРЂ┐ p) (alt : isAlternating s)
