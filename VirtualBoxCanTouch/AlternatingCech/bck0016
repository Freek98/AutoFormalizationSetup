  -- The two face terms at repeat positions cancel
  -- Proof: WLOG fst i < fst j. By face-shift, s(face i) = negPow d (s(face j)).
  -- Then negPow(fst i)(negPow d v) + negPow(fst j)(v)
  --    = negPow(predРёЋ(fst j))(v) + negPow(fst j)(v) = 0.
  face-terms-cancel : {p : РёЋ} (s : CРЂ┐ p) (alt : isAlternating s)
    Рєњ (x : S) (¤Ѓ : Fin (suc (suc p)) Рєњ T x)
    Рєњ (i j : Fin (suc (suc p))) Рєњ ┬г (i РЅА j) Рєњ ¤Ѓ i РЅА ¤Ѓ j
    Рєњ Ax._+_ x (negPow (fst i) (s x (¤Ѓ Рѕў punchIn i)))
               (negPow (fst j) (s x (¤Ѓ Рѕў punchIn j))) РЅА Ax.0g x
  face-terms-cancel {p} s alt x ¤Ѓ i j iРЅаj ¤Ѓeq = go (fst i РЅЪрхЌ fst j)
    where
      _+A_ = Ax._+_ x ; v = s x (¤Ѓ Рѕў punchIn j) ; w = s x (¤Ѓ Рѕў punchIn i)
      fst-iРЅаj : ┬г (fst i РЅА fst j)
      fst-iРЅаj e = iРЅаj (╬БРЅАProp (╬╗ k Рєњ isProp<рхЌ {n = k} {m = suc (suc p)}) e)
      -- Case fst i < fst j
      go-lt : fst i <рхЌ fst j
        Рєњ negPow (fst i) w +A negPow (fst j) v РЅА Ax.0g x
      go-lt i<j =
        let d = fst j РѕИ suc (fst i)
            shift = face-shift s alt x ¤Ѓ i j i<j ¤Ѓeq
            arith : fst i + d РЅА predРёЋ (fst j)
            arith = +РѕИРЅАpredРёЋ (fst i) (fst j) i<j
            step1 : negPow (fst i) w РЅА negPow (predРёЋ (fst j)) v
            step1 = cong (negPow (fst i)) shift
                   РѕЎ negPow-comp (fst i) d v
                   РѕЎ cong (╬╗ n Рєњ negPow n v) arith
            j>0 : ┬г (fst j РЅА 0)
            j>0 e = ┬г<рхЌ0 {fst i} (subst (fst i <рхЌ_) e i<j)
            pred-suc : suc (predРёЋ (fst j)) РЅА fst j
            pred-suc = sym (suc-predРёЋ (fst j) j>0)
        in cong (_+A negPow (fst j) v) step1
           РѕЎ cong (╬╗ n Рєњ negPow (predРёЋ (fst j)) v +A negPow n v) (sym pred-suc)
           РѕЎ negPow-suc-cancel (predРёЋ (fst j)) v
