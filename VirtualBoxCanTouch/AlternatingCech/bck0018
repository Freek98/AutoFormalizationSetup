-- Section 3: General ДҢech Complex
-- ================================================================

module GeneralCech {в„“ : Level}
  (S : Type в„“) (T : S вҶ’ Type в„“) (A : S вҶ’ AbGroup в„“) where

  |A|_ : S вҶ’ Type в„“
  |A| x = fst (A x)

  module Ax (x : S) = AbGroupStr (snd (A x))
  module Gx (x : S) = GroupProps.GroupTheory (AbGroupвҶ’Group (A x))

  CвҒҝ : в„• вҶ’ Type в„“
  CвҒҝ p = (x : S) вҶ’ (Fin (suc p) вҶ’ T x) вҶ’ |A| x

  0C : {p : в„•} вҶ’ CвҒҝ p
  0C x _ = Ax.0g x

  negC : {p : в„•} вҶ’ CвҒҝ p вҶ’ CвҒҝ p
  negC s x Пғ = Ax.-_ x (s x Пғ)

  addC : {p : в„•} вҶ’ CвҒҝ p вҶ’ CвҒҝ p вҶ’ CвҒҝ p
  addC s t x Пғ = Ax._+_ x (s x Пғ) (t x Пғ)

  negPow : {x : S} вҶ’ в„• вҶ’ |A| x вҶ’ |A| x
  negPow {x} zero a = a
  negPow {x} (suc n) a = Ax.-_ x (negPow n a)

  altFinSum : {x : S} вҶ’ {n : в„•} вҶ’ (Fin n вҶ’ |A| x) вҶ’ |A| x
  altFinSum {x} {n} f = sumFinGen {n = n} (Ax._+_ x) (Ax.0g x)
    (О» j вҶ’ negPow (fst j) (f j))

  d : {p : в„•} вҶ’ CвҒҝ p вҶ’ CвҒҝ (suc p)
  d {p} s x Пғ = altFinSum {x} {suc (suc p)}
    (О» j вҶ’ s x (faceMap j Пғ))

  CвҒҝAbGroup : (p : в„•) вҶ’ AbGroup в„“
  CвҒҝAbGroup p = О AbGroup {X = S} (О» x вҶ’
    О AbGroup {X = Fin (suc p) вҶ’ T x} (О» _ вҶ’ A x))

  -- ================================================================
  -- Properties of negPow
  -- ================================================================

  negPow-two : {x : S} (a : |A| x) вҶ’ negPow {x} 2 a вүЎ a
  negPow-two {x} a = Gx.invInv x a

  negPow-add : {x : S} (n : в„•) (a b : |A| x)
    вҶ’ negPow n (Ax._+_ x a b) вүЎ Ax._+_ x (negPow n a) (negPow n b)
  negPow-add zero a b = refl
  negPow-add {x} (suc n) a b =
    Ax.-_ x (negPow n (Ax._+_ x a b))
      вүЎвҹЁ cong (Ax.-_ x) (negPow-add n a b) вҹ©
    Ax.-_ x (Ax._+_ x (negPow n a) (negPow n b))
      вүЎвҹЁ Gx.invDistr x (negPow n a) (negPow n b) вҹ©
    Ax._+_ x (Ax.-_ x (negPow n b)) (Ax.-_ x (negPow n a))
      вүЎвҹЁ Ax.+Comm x _ _ вҹ©
    Ax._+_ x (Ax.-_ x (negPow n a)) (Ax.-_ x (negPow n b)) вҲҺ

  negPow-0g : {x : S} (n : в„•) вҶ’ negPow {x} n (Ax.0g x) вүЎ Ax.0g x
  negPow-0g zero = refl
  negPow-0g {x} (suc n) =
    Ax.-_ x (negPow n (Ax.0g x))
      вүЎвҹЁ cong (Ax.-_ x) (negPow-0g n) вҹ©
    Ax.-_ x (Ax.0g x)
      вүЎвҹЁ GroupProps.GroupTheory.inv1g (AbGroupвҶ’Group (A x)) вҹ©
    Ax.0g x вҲҺ

  -- negPow composes: negPow i (negPow j a) вүЎ negPow (i + j) a
  negPow-comp : {x : S} (i j : в„•) (a : |A| x)
    вҶ’ negPow i (negPow j a) вүЎ negPow (i + j) a
  negPow-comp zero j a = refl
  negPow-comp {x} (suc i) j a = cong (Ax.-_ x) (negPow-comp i j a)

  -- negPow distributes over sumFinGen
  negPow-sum : {x : S} {m : в„•} (n : в„•) (f : Fin m вҶ’ |A| x)
    вҶ’ negPow n (sumFinGen {n = m} (Ax._+_ x) (Ax.0g x) f)
    вүЎ sumFinGen {n = m} (Ax._+_ x) (Ax.0g x) (О» j вҶ’ negPow n (f j))
  negPow-sum {m = zero} n f = negPow-0g n
  negPow-sum {x} {m = suc m} n f =
    negPow-add n (f flast) (sumFinGen {n = m} (Ax._+_ x) (Ax.0g x) (f вҲҳ injectSuc))
    вҲҷ cong (Ax._+_ x (negPow n (f flast)))
           (negPow-sum {x = x} {m = m} n (f вҲҳ injectSuc))

  -- ================================================================
  -- Linearity of d and dВІ = 0
  -- ================================================================

  private
    -- Abelian group interchange: (a+b)+(c+d) = (a+c)+(b+d)
    interchange : {x : S} (a b c d' : |A| x)
      вҶ’ Ax._+_ x (Ax._+_ x a b) (Ax._+_ x c d')
      вүЎ Ax._+_ x (Ax._+_ x a c) (Ax._+_ x b d')
    interchange {x} a b c d' =
      sym (Ax.+Assoc x a b _)
      вҲҷ cong (Ax._+_ x a) (Ax.+Assoc x b c d')
      вҲҷ cong (О» z вҶ’ Ax._+_ x a (Ax._+_ x z d')) (Ax.+Comm x b c)
      вҲҷ cong (Ax._+_ x a) (sym (Ax.+Assoc x c b d'))
      вҲҷ Ax.+Assoc x a c _

  -- sumFinGen distributes over +
  sumFinGen-+ : {x : S} {n : в„•} (f g : Fin n вҶ’ |A| x)
    вҶ’ sumFinGen {n = n} (Ax._+_ x) (Ax.0g x) (О» j вҶ’ Ax._+_ x (f j) (g j))
    вүЎ Ax._+_ x (sumFinGen {n = n} (Ax._+_ x) (Ax.0g x) f)
                (sumFinGen {n = n} (Ax._+_ x) (Ax.0g x) g)
  sumFinGen-+ {x} {zero} f g = sym (Ax.+IdR x _)
  sumFinGen-+ {x} {suc n} f g =
    cong (Ax._+_ x (Ax._+_ x (f flast) (g flast)))
         (sumFinGen-+ {x} {n} (f вҲҳ injectSuc) (g вҲҳ injectSuc))
    вҲҷ interchange (f flast) (g flast) _ _

  d-pres+ : {p : в„•} (s t : CвҒҝ p) (x : S) (Пғ : Fin (suc (suc p)) вҶ’ T x)
    вҶ’ d (addC s t) x Пғ вүЎ Ax._+_ x (d s x Пғ) (d t x Пғ)
  d-pres+ {p} s t x Пғ =
    cong (sumFinGen {n = suc (suc p)} (Ax._+_ x) (Ax.0g x))
         (funExt (О» j вҶ’ negPow-add (fst j) (s x (faceMap j Пғ)) (t x (faceMap j Пғ))))
    вҲҷ sumFinGen-+ {n = suc (suc p)}
                  (О» j вҶ’ negPow (fst j) (s x (faceMap j Пғ)))
                  (О» j вҶ’ negPow (fst j) (t x (faceMap j Пғ)))

  -- For p=0: face map compositions agree on Fin 1 (direct computation)
  -- Cancelling pairs: (0,0)вҶ”(1,0), (0,1)вҶ”(2,0), (1,1)вҶ”(2,1)
  private
    face-comp-00вүЎ10 : {B : Type в„“} (Пғ : Fin 3 вҶ’ B)
      вҶ’ Пғ вҲҳ punchIn {2} fzero вҲҳ punchIn {1} fzero
      вүЎ Пғ вҲҳ punchIn {2} fone вҲҳ punchIn {1} fzero
    face-comp-00вүЎ10 Пғ = funExt О» { (zero , _) вҶ’ refl ; (suc _ , q) вҶ’ вҠҘ.rec q }

    face-comp-01вүЎ20 : {B : Type в„“} (Пғ : Fin 3 вҶ’ B)
      вҶ’ Пғ вҲҳ punchIn {2} fzero вҲҳ punchIn {1} fone
      вүЎ Пғ вҲҳ punchIn {2} (2 , tt) вҲҳ punchIn {1} fzero
    face-comp-01вүЎ20 Пғ = funExt О» { (zero , _) вҶ’ refl ; (suc _ , q) вҶ’ вҠҘ.rec q }

    face-comp-11вүЎ21 : {B : Type в„“} (Пғ : Fin 3 вҶ’ B)
      вҶ’ Пғ вҲҳ punchIn {2} fone вҲҳ punchIn {1} fone
      вүЎ Пғ вҲҳ punchIn {2} (2 , tt) вҲҳ punchIn {1} fone
    face-comp-11вүЎ21 Пғ = funExt О» { (zero , _) вҶ’ refl ; (suc _ , q) вҶ’ вҠҘ.rec q }

  -- Algebraic helpers for dВІ
  private
    -- Telescoping: (-p + q) + (-q + r) вүЎ -p + r
    telescope : {x : S} (p q r : |A| x)
      вҶ’ Ax._+_ x (Ax._+_ x (Ax.-_ x p) q)
                  (Ax._+_ x (Ax.-_ x q) r)
      вүЎ Ax._+_ x (Ax.-_ x p) r
    telescope {x} p q r =
      sym (Ax.+Assoc x (Ax.-_ x p) q _)
      вҲҷ cong (Ax._+_ x (Ax.-_ x p)) (Ax.+Assoc x q (Ax.-_ x q) r)
      вҲҷ cong (О» z вҶ’ Ax._+_ x (Ax.-_ x p) (Ax._+_ x z r)) (Ax.+InvR x q)
      вҲҷ cong (Ax._+_ x (Ax.-_ x p)) (Ax.+IdL x r)

    -- Cancellation: (-c + b) + ((-a + c) + (-b + a)) вүЎ 0g
    cancel3 : {x : S} (a b c : |A| x)
      вҶ’ Ax._+_ x (Ax._+_ x (Ax.-_ x c) b)
                  (Ax._+_ x (Ax._+_ x (Ax.-_ x a) c)
                            (Ax._+_ x (Ax.-_ x b) a))
      вүЎ Ax.0g x
    cancel3 {x} a b c =
      cong (Ax._+_ x (Ax._+_ x (Ax.-_ x c) b))
           (Ax.+Comm x _ _)
      вҲҷ Ax.+Assoc x _ _ _
      вҲҷ cong (О» z вҶ’ Ax._+_ x z (Ax._+_ x (Ax.-_ x a) c))
             (telescope c b a)
      вҲҷ telescope c a c
      вҲҷ Ax.+InvL x c

  -- dВІ = 0 for degree 0 (direct computation)
  dВІ-0 : (s : CвҒҝ 0) (x : S) (Пғ : Fin 3 вҶ’ T x)
    вҶ’ d (d s) x Пғ вүЎ Ax.0g x
  dВІ-0 s x Пғ = step1 вҲҷ step2 вҲҷ cancel3 TвӮҖвӮҖ TвӮҖвӮҒ TвӮҒвӮҒ
    where
      TвӮҖвӮҖ = s x (Пғ вҲҳ punchIn {2} fzero вҲҳ punchIn {1} fzero)
      TвӮҖвӮҒ = s x (Пғ вҲҳ punchIn {2} fzero вҲҳ punchIn {1} fone)
      TвӮҒвӮҒ = s x (Пғ вҲҳ punchIn {2} fone вҲҳ punchIn {1} fone)
      eqвӮҒ = cong (s x) (face-comp-00вүЎ10 Пғ)
      eqвӮӮ = cong (s x) (face-comp-01вүЎ20 Пғ)
      eqвӮғ = cong (s x) (face-comp-11вүЎ21 Пғ)
      -- Step 1: substitute face-comp equalities (6 vars вҶ’ 3 vars)
      step1 = congвӮӮ (Ax._+_ x)
        (cong (О» w вҶ’ Ax.-_ x (Ax.-_ x w))
          (congвӮӮ (Ax._+_ x) (cong (Ax.-_ x) (sym eqвӮғ))
                             (cong (О» z вҶ’ Ax._+_ x z (Ax.0g x)) (sym eqвӮӮ))))
        (cong (О» z вҶ’ Ax._+_ x
          (Ax.-_ x (Ax._+_ x (Ax.-_ x TвӮҒвӮҒ) (Ax._+_ x z (Ax.0g x))))
          (Ax._+_ x (Ax._+_ x (Ax.-_ x TвӮҖвӮҒ) (Ax._+_ x TвӮҖвӮҖ (Ax.0g x)))
                    (Ax.0g x)))
          (sym eqвӮҒ))
      -- Step 2: simplify using invInv, +IdR, invDistr вҶ’ cancel3 form
      step2 = congвӮӮ (Ax._+_ x)
        (Gx.invInv x _ вҲҷ cong (Ax._+_ x (Ax.-_ x TвӮҒвӮҒ)) (Ax.+IdR x TвӮҖвӮҒ))
        (congвӮӮ (Ax._+_ x)
          (cong (Ax.-_ x) (cong (Ax._+_ x (Ax.-_ x TвӮҒвӮҒ)) (Ax.+IdR x TвӮҖвӮҖ))
           вҲҷ Gx.invDistr x (Ax.-_ x TвӮҒвӮҒ) TвӮҖвӮҖ
           вҲҷ cong (Ax._+_ x (Ax.-_ x TвӮҖвӮҖ)) (Gx.invInv x TвӮҒвӮҒ))
          (Ax.+IdR x _ вҲҷ cong (Ax._+_ x (Ax.-_ x TвӮҖвӮҒ)) (Ax.+IdR x TвӮҖвӮҖ)))

  -- negPow n a + negPow (suc n) a вүЎ 0g  (cancel adjacent signs)
  negPow-suc-cancel : {x : S} (n : в„•) (a : |A| x)
    вҶ’ Ax._+_ x (negPow n a) (negPow (suc n) a) вүЎ Ax.0g x
  negPow-suc-cancel {x} n a = Ax.+InvR x (negPow n a)

  -- Face map composition via simplicial identity
  face-comp : {n : в„•} {B : Type в„“} (i : Fin (suc (suc n))) (j : Fin (suc n))
    (i' : Fin (suc n)) (Пғ : Fin (suc (suc n)) вҶ’ B)
    вҶ’ fst i вүЎ fst i' вҶ’ fst i вүӨбө— fst j
    вҶ’ faceMap j (faceMap i Пғ) вүЎ faceMap i' (faceMap (fsuc j) Пғ)
  face-comp i j i' Пғ e h = funExt (О» k вҶ’ cong Пғ (simplicial i j k i' e h))

  -- Sum of zeros is zero
  sfg-0 : {x : S} (n : в„•) (f : Fin n вҶ’ |A| x)
    вҶ’ (вҲҖ k вҶ’ f k вүЎ Ax.0g x)
    вҶ’ sumFinGen {n = n} (Ax._+_ x) (Ax.0g x) f вүЎ Ax.0g x
  sfg-0 zero f h = refl
  sfg-0 {x} (suc n) f h =
    congвӮӮ (Ax._+_ x) (h flast)
      (sfg-0 n (О» k вҶ’ f (injectSuc k)) (О» k вҶ’ h (injectSuc k)))
    вҲҷ Ax.+IdR x (Ax.0g x)

  -- Sum with a single nonzero term
  sfg-single : {x : S} (n : в„•) (f : Fin (suc n) вҶ’ |A| x) (i : Fin (suc n))
    вҶ’ ((k : Fin (suc n)) вҶ’ В¬ (fst k вүЎ fst i) вҶ’ f k вүЎ Ax.0g x)
    вҶ’ sumFinGen {n = suc n} (Ax._+_ x) (Ax.0g x) f вүЎ f i
  sfg-single {x} zero f (zero , _) h =
    Ax.+IdR x (f fzero)
  sfg-single {x} zero f (suc _ , q) h = вҠҘ.rec q
  sfg-single {x} (suc n') f i h with suc n' вүҹбө— fst i
  ... | eqбө— p =
    let flastвүЎi : flast вүЎ i
        flastвүЎi = ОЈвүЎProp (О» k вҶ’ isProp<бө— {n = k} {m = suc (suc n')}) p
        -- every injectSuc k has fst k < suc n' = fst i, so k вү  i
        rest-zero : (k : Fin (suc n')) вҶ’ f (injectSuc k) вүЎ Ax.0g x
        rest-zero k = h (injectSuc k) О» e вҶ’
          В¬m<бө—m {fst i} (subst (_<бө— fst i) e (subst (fst k <бө—_) p (snd k)))
    in congвӮӮ (Ax._+_ x) (cong f flastвүЎi)
         (sfg-0 (suc n') (f вҲҳ injectSuc) rest-zero)
       вҲҷ Ax.+IdR x (f i)
  ... | ltбө— q = вҠҘ.rec (В¬m<бө—m {suc n'} (<бө—-вүӨбө—-trans {suc n'} {fst i} {suc n'} q (snd i)))
  ... | gtбө— q =
    let nвү i : В¬ (suc n' вүЎ fst i)
        nвү i e = В¬m<бө—m {fst i} (subst (fst i <бө—_) e q)
        i' : Fin (suc n')
        i' = fst i , q
        iSвүЎi : injectSuc i' вүЎ i
        iSвүЎi = ОЈвүЎProp (О» k вҶ’ isProp<бө— {n = k} {m = suc (suc n')}) refl
    in congвӮӮ (Ax._+_ x) (h flast nвү i)
         (sfg-single {x} n' (f вҲҳ injectSuc) i'
           (О» k kвү i' вҶ’ h (injectSuc k) kвү i'))
       вҲҷ Ax.+IdL x (f (injectSuc i'))
       вҲҷ cong f iSвүЎi

  -- Sum with two nonzero terms that cancel
  sfg-two-cancel : {x : S} (n : в„•) (f : Fin (suc n) вҶ’ |A| x)
    (i j : Fin (suc n)) вҶ’ В¬ (fst i вүЎ fst j)
    вҶ’ Ax._+_ x (f i) (f j) вүЎ Ax.0g x
    вҶ’ ((k : Fin (suc n)) вҶ’ В¬ (fst k вүЎ fst i) вҶ’ В¬ (fst k вүЎ fst j) вҶ’ f k вүЎ Ax.0g x)
    вҶ’ sumFinGen {n = suc n} (Ax._+_ x) (Ax.0g x) f вүЎ Ax.0g x
  -- Base: n=0 means Fin 1, can't have two distinct elements
  sfg-two-cancel {x} zero f i j iвү j _ _ = вҠҘ.rec (iвү j (cong fst (go i) вҲҷ sym (cong fst (go j))))
    where go : (k : Fin 1) вҶ’ k вүЎ fzero
          go (zero , _) = ОЈвүЎProp (О» z вҶ’ isProp<бө— {n = z} {m = 1}) refl
          go (suc _ , q) = вҠҘ.rec q
  -- Step: n = suc n'
  sfg-two-cancel {x} (suc n') f i j iвү j cancel h with suc n' вүҹбө— fst i
  ... | ltбө— q = вҠҘ.rec (В¬m<бө—m {suc n'} (<бө—-вүӨбө—-trans {suc n'} {fst i} {suc n'} q (snd i)))
  ... | eqбө— p = goal
    where
      flastвүЎi : flast вүЎ i
      flastвүЎi = ОЈвүЎProp (О» k вҶ’ isProp<бө— {n = k} {m = suc (suc n')}) p
      j<sn : fst j <бө— suc n'
      j<sn with suc n' вүҹбө— fst j
      ... | eqбө— e = вҠҘ.rec (iвү j (sym p вҲҷ e))
      ... | ltбө— r = вҠҘ.rec (В¬m<бө—m {suc n'} (<бө—-вүӨбө—-trans {suc n'} {fst j} {suc n'} r (snd j)))
      ... | gtбө— r = r
      j' : Fin (suc n')
      j' = fst j , j<sn
      jSвүЎj : injectSuc j' вүЎ j
      jSвүЎj = ОЈвүЎProp (О» k вҶ’ isProp<бө— {n = k} {m = suc (suc n')}) refl
      k<i : (k : Fin (suc n')) вҶ’ fst k <бө— fst i
      k<i k = subst (fst k <бө—_) p (snd k)
      goal : _
      goal = congвӮӮ (Ax._+_ x) (cong f flastвүЎi)
         (sfg-single n' (f вҲҳ injectSuc) j'
           (О» k kвү j' вҶ’ h (injectSuc k)
             (О» e вҶ’ В¬m<бө—m {fst i} (subst (_<бө— fst i) e (k<i k)))
             kвү j')
         вҲҷ cong f jSвүЎj)
       вҲҷ cancel
  ... | gtбө— q with suc n' вүҹбө— fst j
  ...   | ltбө— r = вҠҘ.rec (В¬m<бө—m {suc n'} (<бө—-вүӨбө—-trans {suc n'} {fst j} {suc n'} r (snd j)))
  ...   | eqбө— p =
    let flastвүЎj : flast вүЎ j
        flastвүЎj = ОЈвүЎProp (О» k вҶ’ isProp<бө— {n = k} {m = suc (suc n')}) p
        i' : Fin (suc n')
        i' = fst i , q
        iSвүЎi : injectSuc i' вүЎ i
        iSвүЎi = ОЈвүЎProp (О» k вҶ’ isProp<бө— {n = k} {m = suc (suc n')}) refl
        k<j : (k : Fin (suc n')) вҶ’ fst k <бө— fst j
        k<j k = subst (fst k <бө—_) p (snd k)
    in congвӮӮ (Ax._+_ x) (cong f flastвүЎj)
         (sfg-single n' (f вҲҳ injectSuc) i'
           (О» k kвү i' вҶ’ h (injectSuc k) kвү i'
             (О» e вҶ’ В¬m<бө—m {fst j} (subst (_<бө— fst j) e (k<j k))))
         вҲҷ cong f iSвүЎi)
       вҲҷ Ax.+Comm x (f j) (f i) вҲҷ cancel
  ...   | gtбө— r =
    let nвү i : В¬ (suc n' вүЎ fst i)
        nвү i e = В¬m<бө—m {fst i} (subst (fst i <бө—_) e q)
        nвү j : В¬ (suc n' вүЎ fst j)
        nвү j e = В¬m<бө—m {fst j} (subst (fst j <бө—_) e r)
        i' : Fin (suc n')
        i' = fst i , q
        j' : Fin (suc n')
        j' = fst j , r
        iSвүЎi : injectSuc i' вүЎ i
        iSвүЎi = ОЈвүЎProp (О» k вҶ’ isProp<бө— {n = k} {m = suc (suc n')}) refl
        jSвүЎj : injectSuc j' вүЎ j
        jSвүЎj = ОЈвүЎProp (О» k вҶ’ isProp<бө— {n = k} {m = suc (suc n')}) refl
        i'вү j' : В¬ (fst i' вүЎ fst j')
        i'вү j' = iвү j
    in congвӮӮ (Ax._+_ x)
         (h flast nвү i nвү j)
         (sfg-two-cancel n' (f вҲҳ injectSuc) i' j' i'вү j'
           (congвӮӮ (Ax._+_ x) (cong f iSвүЎi) (cong f jSвүЎj) вҲҷ cancel)
           (О» k kвү i' kвү j' вҶ’ h (injectSuc k) kвү i' kвү j'))
       вҲҷ Ax.+IdR x (Ax.0g x)

  -- Fubini: interchange of summation order
  -- ОЈбөў ОЈвұј g(i,j) вүЎ ОЈвұј ОЈбөў g(i,j)
  sumFinGen-swap : {x : S} (n m : в„•) (g : Fin n вҶ’ Fin m вҶ’ |A| x)
    вҶ’ sumFinGen {n = n} (Ax._+_ x) (Ax.0g x)
        (О» i вҶ’ sumFinGen {n = m} (Ax._+_ x) (Ax.0g x) (g i))
    вүЎ sumFinGen {n = m} (Ax._+_ x) (Ax.0g x)
        (О» j вҶ’ sumFinGen {n = n} (Ax._+_ x) (Ax.0g x) (О» i вҶ’ g i j))
  sumFinGen-swap {x} zero m g =
    sym (sfg-0 m (О» _ вҶ’ Ax.0g x) (О» _ вҶ’ refl))
  sumFinGen-swap {x} (suc n) m g =
    let _+_ = Ax._+_ x ; 0g = Ax.0g x
        ih = sumFinGen-swap {x} n m (О» i вҶ’ g (injectSuc i))
        fвӮҒ = g flast
        fвӮӮ = О» j вҶ’ sumFinGen {n = n} _+_ 0g (О» i вҶ’ g (injectSuc i) j)
    in cong (_+_ (sumFinGen {n = m} _+_ 0g fвӮҒ)) ih
       вҲҷ sym (sumFinGen-+ {n = m} fвӮҒ fвӮӮ)

  -- General dВІ = 0 (uses dВІ-0 pattern; general case requires simplicial identity)
  postulate
    dВІ : {p : в„•} (s : CвҒҝ p) (x : S)
      (Пғ : Fin (suc (suc (suc p))) вҶ’ T x)
      вҶ’ d (d s) x Пғ вүЎ Ax.0g x

-- ================================================================
-- Section 4: Alternating ДҢech Complex
-- ================================================================

module AlternatingCech {в„“ : Level}
  (S : Type в„“) (T : S вҶ’ Type в„“) (A : S вҶ’ AbGroup в„“)
  (ordT : (x : S) вҶ’ DecStrictTotalOrder (T x)) where

  open GeneralCech S T A public
  open module Ox (x : S) = DecStrictTotalOrder (ordT x)

  -- ================================================================
  -- 4.1: Tuple properties
  -- ================================================================

  isInjTuple : {p : в„•} {x : S} вҶ’ (Fin (suc p) вҶ’ T x) вҶ’ Type в„“
  isInjTuple Пғ = вҲҖ i j вҶ’ Пғ i вүЎ Пғ j вҶ’ i вүЎ j

  hasRepeat : {p : в„•} {x : S} вҶ’ (Fin (suc p) вҶ’ T x) вҶ’ Type в„“
  hasRepeat Пғ = ОЈ[ i вҲҲ _ ] ОЈ[ j вҲҲ _ ] (В¬ (i вүЎ j)) Г— (Пғ i вүЎ Пғ j)

  isOrdered : {p : в„•} {x : S} вҶ’ (Fin (suc p) вҶ’ T x) вҶ’ Type в„“
  isOrdered {p} {x} Пғ = вҲҖ (i j : Fin (suc p)) вҶ’ fst i <бө— fst j
    вҶ’ _<sto_ x (Пғ i) (Пғ j)

  -- ================================================================
  -- 4.2: Alternating cochains (Definition 20.23.1)
  -- ================================================================

  isAlternating : {p : в„•} вҶ’ CвҒҝ p вҶ’ Type в„“
  isAlternating {p} s =
    ((x : S) (Пғ : Fin (suc p) вҶ’ T x) (i j : Fin (suc p))
      вҶ’ В¬ (i вүЎ j) вҶ’ Пғ i вүЎ Пғ j вҶ’ s x Пғ вүЎ Ax.0g x)
    Г—
    ((x : S) (Пғ : Fin (suc p) вҶ’ T x) (i j : Fin (suc p))
      вҶ’ В¬ (i вүЎ j) вҶ’ s x (Пғ вҲҳ swapFin {suc p} i j) вүЎ Ax.-_ x (s x Пғ))

  CвҒҝ-alt : в„• вҶ’ Type в„“
  CвҒҝ-alt p = ОЈ (CвҒҝ p) (isAlternating {p})

  -- ================================================================
  -- 4.3: Ordered ДҢech complex (Definition 20.23.2)
  -- ================================================================

  OrdTuple : в„• вҶ’ S вҶ’ Type в„“
  OrdTuple p x = ОЈ (Fin (suc p) вҶ’ T x) (isOrdered {p} {x})

  CвҒҝ-ord : в„• вҶ’ Type в„“
  CвҒҝ-ord p = (x : S) вҶ’ OrdTuple p x вҶ’ |A| x

  -- ================================================================
  -- 4.4: Comparison maps
  -- ================================================================

  ПҖmap : {p : в„•} вҶ’ CвҒҝ p вҶ’ CвҒҝ-ord p
  ПҖmap s x (Пғ , _) = s x Пғ

  О№map : {p : в„•} вҶ’ CвҒҝ-alt p вҶ’ CвҒҝ p
  О№map = fst

  -- ================================================================
  -- 4.5: Sorting infrastructure for degree 1
  -- ================================================================

  sortPair : {x : S} вҶ’ T x вҶ’ T x вҶ’ (T x Г— T x Г— в„•)
  sortPair {x} a b with <sto-tricho x a b
  ... | is-lt _ = (a , b , 0)
  ... | is-eq _ _ = (a , b , 0)
  ... | is-gt _ = (b , a , 1)

  -- Ordered pair witness: direct pattern matching on Fin 2
  -- Key: n <бө— 0 = вҠҘ and suc n <бө— suc m = n <бө— m definitionally
  mkOrd2 : {x : S} (Пғ : Fin 2 вҶ’ T x) вҶ’ _<sto_ x (Пғ fzero) (Пғ fone)
    вҶ’ isOrdered {1} {x} Пғ
  mkOrd2 Пғ a<b (zero , _) (zero , _) p = вҠҘ.rec p
  mkOrd2 Пғ a<b (zero , _) (suc zero , _) _ = a<b
  mkOrd2 Пғ a<b (zero , _) (suc (suc _) , q) _ = вҠҘ.rec q
  mkOrd2 Пғ a<b (suc zero , _) (zero , _) p = вҠҘ.rec p
  mkOrd2 Пғ a<b (suc zero , _) (suc zero , _) p = вҠҘ.rec p
  mkOrd2 Пғ a<b (suc zero , _) (suc (suc _) , q) _ = вҠҘ.rec q
  mkOrd2 Пғ a<b (suc (suc _) , q) _ _ = вҠҘ.rec q

  -- ================================================================
  -- 4.6: Comparison map c for degree 1 (Lemma 20.23.3)
  -- ================================================================

  -- Core of comparison map: takes trichotomy result as explicit argument
  cвӮҒ-core : CвҒҝ-ord 1 вҶ’ (x : S) вҶ’ (Пғ : Fin 2 вҶ’ T x)
    вҶ’ Tri< (_<sto_ x) (Пғ fzero) (Пғ fone) вҶ’ |A| x
  cвӮҒ-core s x Пғ (is-lt a<b) = s x (Пғ , mkOrd2 Пғ a<b)
  cвӮҒ-core s x Пғ (is-eq _ _) = Ax.0g x
  cвӮҒ-core s x Пғ (is-gt b<a) = Ax.-_ x
    (s x (Пғ вҲҳ swapFin {2} fzero fone , mkOrd2 (Пғ вҲҳ swapFin {2} fzero fone) b<a))

  cвӮҒ-fun : CвҒҝ-ord 1 вҶ’ CвҒҝ 1
  cвӮҒ-fun s x Пғ = cвӮҒ-core s x Пғ (<sto-tricho x (Пғ fzero) (Пғ fone))

  -- cвӮҒ-fun vanishes when Пғ fzero вүЎ Пғ fone (repeated entry)
  -- Uses Tri<-elim + lambda to avoid binding path types in pattern LHS
  private
    cвӮҒ-vanish : (s : CвҒҝ-ord 1) (x : S) (Пғ : Fin 2 вҶ’ T x)
      вҶ’ Пғ fzero вүЎ Пғ fone вҶ’ cвӮҒ-fun s x Пғ вүЎ Ax.0g x
    cвӮҒ-vanish s x Пғ = О» eq вҶ’ Tri<-elim {P = О» r вҶ’ cвӮҒ-core s x Пғ r вүЎ Ax.0g x}
      (О» a<b вҶ’ вҠҘ.rec (<sto-irrefl x (Пғ fzero)
        (subst (_<sto_ x (Пғ fzero)) (sym eq) a<b)))
      (О» _ _ вҶ’ refl)
      (О» b<a вҶ’ вҠҘ.rec (<sto-irrefl x (Пғ fzero)
        (subst (О» y вҶ’ _<sto_ x y (Пғ fzero)) (sym eq) b<a)))
      (<sto-tricho x (Пғ fzero) (Пғ fone))

  -- Vanishing part of cвӮҒ-alternating: case split on Fin 2 indices,
  -- but keep eq : Пғ i вүЎ Пғ j as a lambda argument (not on LHS)
  private
    cвӮҒ-alt-vanish : (s : CвҒҝ-ord 1) (x : S) (Пғ : Fin 2 вҶ’ T x)
      (i j : Fin 2) вҶ’ В¬ (i вүЎ j) вҶ’ Пғ i вүЎ Пғ j вҶ’ cвӮҒ-fun s x Пғ вүЎ Ax.0g x
    cвӮҒ-alt-vanish s x Пғ (zero , _) (zero , _) В¬eq =
      О» _ вҶ’ вҠҘ.rec (В¬eq (ОЈвүЎProp (О» k вҶ’ isProp<бө— {n = k} {m = 2}) refl))
    cвӮҒ-alt-vanish s x Пғ (zero , _) (suc zero , _) _ =
      cвӮҒ-vanish s x Пғ
    cвӮҒ-alt-vanish s x Пғ (zero , _) (suc (suc _) , q) _ = О» _ вҶ’ вҠҘ.rec q
    cвӮҒ-alt-vanish s x Пғ (suc zero , _) (zero , _) _ =
      cвӮҒ-vanish s x Пғ вҲҳ sym
    cвӮҒ-alt-vanish s x Пғ (suc zero , _) (suc zero , _) В¬eq =
      О» _ вҶ’ вҠҘ.rec (В¬eq (ОЈвүЎProp (О» k вҶ’ isProp<бө— {n = k} {m = 2}) refl))
    cвӮҒ-alt-vanish s x Пғ (suc zero , _) (suc (suc _) , q) _ = О» _ вҶ’ вҠҘ.rec q
    cвӮҒ-alt-vanish s x Пғ (suc (suc _) , q) _ _ = О» _ вҶ’ вҠҘ.rec q

  -- isOrdered is a proposition (since _<sto_ is prop-valued)
  isPropIsOrdered : {p : в„•} {x : S} {Пғ : Fin (suc p) вҶ’ T x}
    вҶ’ isProp (isOrdered {p} {x} Пғ)
  isPropIsOrdered {x = x} {Пғ} =
    isPropО  О» i вҶ’ isPropО  О» j вҶ’ isPropО  О» _ вҶ’ <sto-prop x (Пғ i) (Пғ j)

  -- Swap involution: swapFin {2} fzero fone applied twice = id
  private
    sw01 : Fin 2 вҶ’ Fin 2
    sw01 = swapFin {2} fzero fone

    sw01ВІ : (k : Fin 2) вҶ’ sw01 (sw01 k) вүЎ k
    sw01ВІ (zero , _) = refl
    sw01ВІ (suc zero , _) = refl
    sw01ВІ (suc (suc _) , q) = вҠҘ.rec q

    sw01-comp : {x : S} (Пғ : Fin 2 вҶ’ T x) вҶ’ Пғ вҲҳ sw01 вҲҳ sw01 вүЎ Пғ
    sw01-comp Пғ = funExt (О» k вҶ’ cong Пғ (sw01ВІ k))

  -- Antisymmetry of cвӮҒ-core: case analysis on two trichotomy results
  -- (no path types in scope, so direct pattern matching is safe)
  private
    cвӮҒ-antisym-core : (s : CвҒҝ-ord 1) (x : S) (Пғ : Fin 2 вҶ’ T x)
      вҶ’ (rвӮҒ : Tri< (_<sto_ x) (Пғ fzero) (Пғ fone))
      вҶ’ (rвӮӮ : Tri< (_<sto_ x) (Пғ fone) (Пғ fzero))
      вҶ’ cвӮҒ-core s x (Пғ вҲҳ sw01) rвӮӮ вүЎ Ax.-_ x (cвӮҒ-core s x Пғ rвӮҒ)
    -- (lt, lt): contradiction via transitivity
    cвӮҒ-antisym-core s x Пғ (is-lt p<q) (is-lt q<p) =
      вҠҘ.rec (<sto-irrefl x _ (<sto-trans x p<q q<p))
    -- (lt, eq): В¬p<q contradicts p<q
    cвӮҒ-antisym-core s x Пғ (is-lt p<q) (is-eq _ В¬p<q) = вҠҘ.rec (В¬p<q p<q)
    -- (lt, gt): VALID вҖ” need swap involution
    cвӮҒ-antisym-core s x Пғ (is-lt p<q) (is-gt p<q') =
      cong (Ax.-_ x) (cong (s x) (ОЈвүЎProp (О» _ вҶ’ isPropIsOrdered) (sw01-comp Пғ)))
    -- (eq, lt): contradiction
    cвӮҒ-antisym-core s x Пғ (is-eq _ В¬q<p) (is-lt q<p) = вҠҘ.rec (В¬q<p q<p)
    -- (eq, eq): VALID вҖ” 0g вүЎ -(0g)
    cвӮҒ-antisym-core s x Пғ (is-eq _ _) (is-eq _ _) =
      sym (GroupProps.GroupTheory.inv1g (AbGroupвҶ’Group (A x)))
    -- (eq, gt): contradiction
    cвӮҒ-antisym-core s x Пғ (is-eq В¬p<q _) (is-gt p<q) = вҠҘ.rec (В¬p<q p<q)
    -- (gt, lt): VALID вҖ” invInv
    cвӮҒ-antisym-core s x Пғ (is-gt q<p) (is-lt q<p') =
      cong (s x) (ОЈвүЎProp (О» _ вҶ’ isPropIsOrdered) refl)
      вҲҷ sym (Gx.invInv x _)
    -- (gt, eq): contradiction
    cвӮҒ-antisym-core s x Пғ (is-gt q<p) (is-eq В¬q<p _) = вҠҘ.rec (В¬q<p q<p)
    -- (gt, gt): contradiction
    cвӮҒ-antisym-core s x Пғ (is-gt q<p) (is-gt p<q) =
      вҠҘ.rec (<sto-irrefl x _ (<sto-trans x q<p p<q))

    cвӮҒ-antisym01 : (s : CвҒҝ-ord 1) (x : S) (Пғ : Fin 2 вҶ’ T x)
      вҶ’ cвӮҒ-fun s x (Пғ вҲҳ sw01) вүЎ Ax.-_ x (cвӮҒ-fun s x Пғ)
    cвӮҒ-antisym01 s x Пғ = cвӮҒ-antisym-core s x Пғ
      (<sto-tricho x (Пғ fzero) (Пғ fone))
      (<sto-tricho x (Пғ fone) (Пғ fzero))

  -- For swap(fone, fzero): sw10 k вүЎ sw01 k for all k : Fin 2
  private
    sw10вүЎsw01 : (k : Fin 2) вҶ’ swapFin {2} fone fzero k вүЎ sw01 k
    sw10вүЎsw01 (zero , _) = refl
    sw10вүЎsw01 (suc zero , _) = refl
    sw10вүЎsw01 (suc (suc _) , q) = вҠҘ.rec q

    cвӮҒ-antisym10 : (s : CвҒҝ-ord 1) (x : S) (Пғ : Fin 2 вҶ’ T x)
      вҶ’ cвӮҒ-fun s x (Пғ вҲҳ swapFin {2} fone fzero) вүЎ Ax.-_ x (cвӮҒ-fun s x Пғ)
    cвӮҒ-antisym10 s x Пғ =
      cong (cвӮҒ-fun s x) (funExt (О» k вҶ’ cong Пғ (sw10вүЎsw01 k)))
      вҲҷ cвӮҒ-antisym01 s x Пғ

  -- Full antisymmetry: case split on i,j : Fin 2
  private
    cвӮҒ-alt-antisym : (s : CвҒҝ-ord 1) (x : S) (Пғ : Fin 2 вҶ’ T x)
      (i j : Fin 2) вҶ’ В¬ (i вүЎ j)
      вҶ’ cвӮҒ-fun s x (Пғ вҲҳ swapFin {2} i j) вүЎ Ax.-_ x (cвӮҒ-fun s x Пғ)
    cвӮҒ-alt-antisym s x Пғ (zero , _) (zero , _) В¬eq =
      вҠҘ.rec (В¬eq (ОЈвүЎProp (О» k вҶ’ isProp<бө— {n = k} {m = 2}) refl))
    cвӮҒ-alt-antisym s x Пғ (zero , _) (suc zero , _) _ =
      cвӮҒ-antisym01 s x Пғ
    cвӮҒ-alt-antisym s x Пғ (zero , _) (suc (suc _) , q) _ = вҠҘ.rec q
    cвӮҒ-alt-antisym s x Пғ (suc zero , _) (zero , _) _ =
      cвӮҒ-antisym10 s x Пғ
    cвӮҒ-alt-antisym s x Пғ (suc zero , _) (suc zero , _) В¬eq =
      вҠҘ.rec (В¬eq (ОЈвүЎProp (О» k вҶ’ isProp<бө— {n = k} {m = 2}) refl))
    cвӮҒ-alt-antisym s x Пғ (suc zero , _) (suc (suc _) , q) _ = вҠҘ.rec q
    cвӮҒ-alt-antisym s x Пғ (suc (suc _) , q) _ _ = вҠҘ.rec q

  cвӮҒ-alternating : (s : CвҒҝ-ord 1) вҶ’ isAlternating (cвӮҒ-fun s)
  fst (cвӮҒ-alternating s) = cвӮҒ-alt-vanish s
  snd (cвӮҒ-alternating s) = cвӮҒ-alt-antisym s

  cвӮҒ : CвҒҝ-ord 1 вҶ’ CвҒҝ-alt 1
  cвӮҒ s = cвӮҒ-fun s , cвӮҒ-alternating s

  -- ================================================================
  -- 4.7: ПҖ вҲҳ c = id (Lemma 20.23.4)
  -- ================================================================

  private
    ПҖвҲҳcвӮҒ-core : (s : CвҒҝ-ord 1) (x : S) (Пғ : Fin 2 вҶ’ T x) (ord : isOrdered {1} {x} Пғ)
      вҶ’ (r : Tri< (_<sto_ x) (Пғ fzero) (Пғ fone))
      вҶ’ cвӮҒ-core s x Пғ r вүЎ s x (Пғ , ord)
    ПҖвҲҳcвӮҒ-core s x Пғ ord (is-lt a<b) =
      cong (s x) (ОЈвүЎProp (О» _ вҶ’ isPropIsOrdered) refl)
    ПҖвҲҳcвӮҒ-core s x Пғ ord (is-eq В¬a<b _) = вҠҘ.rec (В¬a<b (ord fzero fone tt))
    ПҖвҲҳcвӮҒ-core s x Пғ ord (is-gt b<a) =
      вҠҘ.rec (<sto-irrefl x (Пғ fzero)
        (<sto-trans x (ord fzero fone tt) b<a))

  ПҖвҲҳcвӮҒ : (s : CвҒҝ-ord 1) вҶ’ (x : S) вҶ’ (ot : OrdTuple 1 x)
    вҶ’ ПҖmap (cвӮҒ-fun s) x ot вүЎ s x ot
  ПҖвҲҳcвӮҒ s x (Пғ , ord) = ПҖвҲҳcвӮҒ-core s x Пғ ord (<sto-tricho x (Пғ fzero) (Пғ fone))

  -- ================================================================
  -- 4.8: d preserves alternating cochains
  -- ================================================================

  -- Helper: if Пғ has a repeat at (i,j) and k вү  i,j, then Пғ вҲҳ punchIn k has a repeat
  private
    face-has-repeat : {p : в„•} {x : S} (Пғ : Fin (suc (suc p)) вҶ’ T x)
      (i j : Fin (suc (suc p))) (k : Fin (suc (suc p)))
      вҶ’ В¬ (fst k вүЎ fst i) вҶ’ В¬ (fst k вүЎ fst j)
      вҶ’ В¬ (i вүЎ j) вҶ’ Пғ i вүЎ Пғ j
      вҶ’ hasRepeat (Пғ вҲҳ punchIn k)
    face-has-repeat Пғ i j k kвү i kвү j iвү j ПғiвүЎПғj =
      let i' = punchOut k i kвү i
          j' = punchOut k j kвү j
          eq-i = punchIn-punchOut k i kвү i
          eq-j = punchIn-punchOut k j kвү j
          i'вү j' : В¬ (i' вүЎ j')
          i'вү j' p = iвү j (sym eq-i вҲҷ cong (punchIn k) p вҲҷ eq-j)
      in i' , j' , i'вү j' , (cong Пғ eq-i вҲҷ ПғiвүЎПғj вҲҷ sym (cong Пғ eq-j))

    -- Each term in the alternating sum: for faces that still have repeats, s vanishes
    face-term-zero : {p : в„•} {x : S} (s : CвҒҝ p)
      вҶ’ (van : (x : S) (Пғ : Fin (suc p) вҶ’ T x) (i j : Fin (suc p))
              вҶ’ В¬ (i вүЎ j) вҶ’ Пғ i вүЎ Пғ j вҶ’ s x Пғ вүЎ Ax.0g x)
      вҶ’ (Пғ : Fin (suc (suc p)) вҶ’ T x)
      вҶ’ (i j : Fin (suc (suc p))) вҶ’ В¬ (i вүЎ j) вҶ’ Пғ i вүЎ Пғ j
      вҶ’ (k : Fin (suc (suc p))) вҶ’ В¬ (fst k вүЎ fst i) вҶ’ В¬ (fst k вүЎ fst j)
      вҶ’ negPow (fst k) (s x (Пғ вҲҳ punchIn k)) вүЎ Ax.0g x
    face-term-zero {x = x} s van Пғ i j iвү j Пғeq k kвү i kвү j =
      let hr = face-has-repeat Пғ i j k kвү i kвү j iвү j Пғeq
          i' = fst hr ; j' = fst (snd hr)
          i'вү j' = fst (snd (snd hr)) ; Пғeq' = snd (snd (snd hr))
      in cong (negPow (fst k)) (van x (Пғ вҲҳ punchIn k) i' j' i'вү j' Пғeq')
         вҲҷ negPow-0g (fst k)

  -- в„• arithmetic: a + (b вҲё suc a) вүЎ predв„• b when a <бө— b
  private
    +вҲёвүЎpredв„• : (a b : в„•) вҶ’ a <бө— b вҶ’ a + (b вҲё suc a) вүЎ predв„• b
    +вҲёвүЎpredв„• zero (suc b') _ = refl
    +вҲёвүЎpredв„• (suc a') (suc (suc b'')) h = cong suc (+вҲёвүЎpredв„• a' (suc b'') h)

  -- в„• arithmetic helpers
  private
    suc+вҲёвүЎ : (a b : в„•) вҶ’ a <бө— b вҶ’ suc a + (b вҲё suc a) вүЎ b
    suc+вҲёвүЎ zero (suc b') _ = refl
    suc+вҲёвүЎ (suc a') (suc (suc b'')) h = cong suc (suc+вҲёвүЎ a' (suc b'') h)

    +1вүЎsuc : (d : в„•) вҶ’ d + 1 вүЎ suc d
    +1вүЎsuc zero = refl
    +1вүЎsuc (suc d') = cong suc (+1вүЎsuc d')

  -- Adjacent face equality: when fst j = suc(fst i) and Пғ i = Пғ j,
  -- Пғ вҲҳ punchIn i and Пғ вҲҳ punchIn j agree pointwise.
  -- Uses adj-punchIn-в„•: either both punchIns give same value (cong Пғ),
  -- or they hit i and j (bridged by Пғeq).
  adj-face-eq : {p : в„•} {x : S} (Пғ : Fin (suc (suc p)) вҶ’ T x)
    (i j : Fin (suc (suc p)))
    вҶ’ suc (fst i) вүЎ fst j вҶ’ Пғ i вүЎ Пғ j
    вҶ’ (c : Fin (suc p)) вҶ’ Пғ (punchIn i c) вүЎ Пғ (punchIn j c)
  adj-face-eq {p} Пғ i j siвүЎfj Пғeq c =
    вҠҺ.rec
      (О» e вҶ’
        -- same в„• value: punchIn-в„• (fst i) (fst c) = punchIn-в„• (fst j) (fst c)
        -- so punchIn i c = punchIn j c as Fin elements
        let fst-eq : fst (punchIn i c) вүЎ fst (punchIn j c)
            fst-eq = punchIn-fst i c вҲҷ e вҲҷ cong (О» z вҶ’ punchIn-в„• z (fst c)) siвүЎfj
                   вҲҷ sym (punchIn-fst j c)
        in cong Пғ (ОЈвүЎProp (О» k вҶ’ isProp<бө— {n = k} {m = suc (suc p)}) fst-eq))
      (О» pq вҶ’
        -- punchIn-в„• (fst i) (fst c) = suc(fst i) = fst j, and
        -- punchIn-в„• (suc(fst i)) (fst c) = fst i
        let pi-eq : fst (punchIn i c) вүЎ fst j
            pi-eq = punchIn-fst i c вҲҷ fst pq вҲҷ siвүЎfj
            pj-eq : fst (punchIn j c) вүЎ fst i
            pj-eq = punchIn-fst j c
                  вҲҷ cong (О» z вҶ’ punchIn-в„• z (fst c)) (sym siвүЎfj)
                  вҲҷ snd pq
            ОЈeq = О» {a} {b} (e : fst a вүЎ fst b) вҶ’
              ОЈвүЎProp (О» k вҶ’ isProp<бө— {n = k} {m = suc (suc p)}) {u = a} {v = b} e
        in cong Пғ (ОЈeq pi-eq)
           вҲҷ sym Пғeq
           вҲҷ sym (cong Пғ (ОЈeq pj-eq)))
      (adj-punchIn-в„• (fst i) (fst c))

  -- Face shift: by induction on gap d where suc(fst i) + d = fst j.
  -- Base: d=0, adjacent faces agree pointwise (Пғ(i) = Пғ(j) bridges the gap).
  -- Step: define Пғ' = Пғ вҲҳ swap(i, i+1). Then:
  --   face i of Пғ = face (i+1) of Пғ'  [punchIn-swap identity]
  --   face j of Пғ' = (face j of Пғ) вҲҳ swap  [swap-punchIn commutation]
  --   By IH on (Пғ', i+1, j, gap-1) + antisymmetry: compose signs.
  face-shift-aux : {p : в„•} (s : CвҒҝ p) (alt : isAlternating s)
    вҶ’ (x : S) (d : в„•) (Пғ : Fin (suc (suc p)) вҶ’ T x)
    вҶ’ (i j : Fin (suc (suc p)))
    вҶ’ suc (fst i) + d вүЎ fst j вҶ’ Пғ i вүЎ Пғ j
    вҶ’ s x (Пғ вҲҳ punchIn i) вүЎ negPow d (s x (Пғ вҲҳ punchIn j))
  face-shift-aux s alt x zero Пғ i j si+0вүЎfj Пғeq =
    -- d=0: suc(fst i) = fst j, faces agree pointwise
    let siвүЎfj : suc (fst i) вүЎ fst j
        siвүЎfj = sym (+-comm (suc (fst i)) 0) вҲҷ si+0вүЎfj
    in cong (s x) (funExt (adj-face-eq Пғ i j siвүЎfj Пғeq))
  face-shift-aux {p} s alt x (suc d') Пғ i j si+sdвүЎfj Пғeq = goal
    where
      -- iвӮҠвӮҒ : next position after i, with bound proof
      si<fj : suc (fst i) <бө— fst j
      si<fj = subst (suc (fst i) <бө—_) si+sdвүЎfj (m<m+sd (suc (fst i)) d')

      iвӮҠвӮҒ-bnd : suc (fst i) <бө— suc (suc p)
      iвӮҠвӮҒ-bnd = <бө—-trans {suc (fst i)} {fst j} {suc (suc p)} si<fj (snd j)

      iвӮҠвӮҒ : Fin (suc (suc p))
      iвӮҠвӮҒ = suc (fst i) , iвӮҠвӮҒ-bnd

      -- Пғ' = Пғ вҲҳ swap(i, iвӮҠвӮҒ)
      Пғ' : Fin (suc (suc p)) вҶ’ T x
      Пғ' = Пғ вҲҳ swapFin {suc (suc p)} i iвӮҠвӮҒ

      -- Gap arithmetic: suc(fst iвӮҠвӮҒ) + d' = fst j
      -- suc(suc(fst i)) + d' вүЎ[cong suc (+-comm ...)]вүЎ suc(fst i) + suc d' вүЎ fst j
      gap' : suc (suc (fst i)) + d' вүЎ fst j
      gap' = cong suc (sym (+-suc (fst i) d')) вҲҷ si+sdвүЎfj

      -- Пғ' has repeat at (iвӮҠвӮҒ, j)
      -- Пғ'(iвӮҠвӮҒ) = Пғ(swap(i,iвӮҠвӮҒ)(iвӮҠвӮҒ)) = Пғ(i) [by swapFin-ji]
      -- Пғ'(j) = Пғ(swap(i,iвӮҠвӮҒ)(j)) = Пғ(j) [by swapFin-fix, since j вү  i and j вү  iвӮҠвӮҒ]
      iвү iвӮҠвӮҒ : В¬ (fst i вүЎ fst iвӮҠвӮҒ)
      iвү iвӮҠвӮҒ e = В¬m<бө—m {fst i} (subst (fst i <бө—_) (sym e) (<бө—sucm {m = fst i}))

      jвү i : В¬ (fst j вүЎ fst i)
      jвү i e = В¬m<бө—m {fst i} (subst (fst i <бө—_) e (<бө—-trans {fst i} {suc (fst i)} {fst j} (<бө—sucm {m = fst i}) si<fj))

      jвү iвӮҠвӮҒ : В¬ (fst j вүЎ suc (fst i))
      jвү iвӮҠвӮҒ e = В¬m<бө—m {suc (fst i)} (subst (suc (fst i) <бө—_) e si<fj)

      Пғ'repeat : Пғ' iвӮҠвӮҒ вүЎ Пғ' j
      Пғ'repeat = cong Пғ (swapFin-ji {suc (suc p)} i iвӮҠвӮҒ)
               вҲҷ Пғeq
               вҲҷ sym (cong Пғ (swapFin-fix {suc (suc p)} i iвӮҠвӮҒ j jвү i jвү iвӮҠвӮҒ))

      -- IH: s x (Пғ' вҲҳ punchIn iвӮҠвӮҒ) = negPow d' (s x (Пғ' вҲҳ punchIn j))
      ih : s x (Пғ' вҲҳ punchIn iвӮҠвӮҒ) вүЎ negPow d' (s x (Пғ' вҲҳ punchIn j))
      ih = face-shift-aux s alt x d' Пғ' iвӮҠвӮҒ j gap' Пғ'repeat

      -- Key identity: swap(i,iвӮҠвӮҒ) вҲҳ punchIn(iвӮҠвӮҒ) = punchIn(i) (pointwise)
      -- Case analysis via adj-punchIn-в„•:
      --   inl: punchIn-в„• values agree, punchIn iвӮҠвӮҒ c avoids both i and iвӮҠвӮҒ,
      --        so swap fixes it, and result = punchIn i c
      --   inr: punchIn iвӮҠвӮҒ c has fst = fst i, swap takes iвҶҰiвӮҠвӮҒ,
      --        and punchIn i c has fst = fst iвӮҠвӮҒ = suc(fst i)
      swap-punchIn-adj : (c : Fin (suc p))
        вҶ’ _вүЎ_ {A = Fin (suc (suc p))} (swapFin {suc (suc p)} i iвӮҠвӮҒ (punchIn iвӮҠвӮҒ c)) (punchIn i c)
      swap-punchIn-adj c = вҠҺ.rec case-same case-swap (adj-punchIn-в„• (fst i) (fst c))
        where
          ОЈeq : {a b : Fin (suc (suc p))} вҶ’ fst a вүЎ fst b вҶ’ a вүЎ b
          ОЈeq = ОЈвүЎProp (О» k вҶ’ isProp<бө— {n = k} {m = suc (suc p)})
          -- punchIn-в„• (fst i) avoids fst i, so result вү  fst i
          punchIn-в„•-avoids : (a c : в„•) вҶ’ В¬ (punchIn-в„• a c вүЎ a)
          punchIn-в„•-avoids zero c e = snotz e
          punchIn-в„•-avoids (suc a) zero e = znots e
          punchIn-в„•-avoids (suc a) (suc c) e = punchIn-в„•-avoids a c (injSuc e)
          case-same : punchIn-в„• (fst i) (fst c) вүЎ punchIn-в„• (suc (fst i)) (fst c)
            вҶ’ swapFin {suc (suc p)} i iвӮҠвӮҒ (punchIn iвӮҠвӮҒ c) вүЎ punchIn i c
          case-same e =
            let piвӮҠвӮҒ-fst = punchIn-fst iвӮҠвӮҒ c
                pi-fst = punchIn-fst i c
                -- fst(punchIn iвӮҠвӮҒ c) вү  fst i (since punchIn-в„•(fst i) avoids fst i, and they agree)
                ne-i : В¬ (fst (punchIn iвӮҠвӮҒ c) вүЎ fst i)
                ne-i h = punchIn-в„•-avoids (fst i) (fst c)
                  (e вҲҷ sym piвӮҠвӮҒ-fst вҲҷ h)
                -- fst(punchIn iвӮҠвӮҒ c) вү  suc(fst i) (punchIn avoids its argument)
                ne-iвӮҠвӮҒ : В¬ (fst (punchIn iвӮҠвӮҒ c) вүЎ fst iвӮҠвӮҒ)
                ne-iвӮҠвӮҒ h = punchIn-в„•-avoids (suc (fst i)) (fst c) (sym (piвӮҠвӮҒ-fst) вҲҷ h)
                -- swap fixes punchIn iвӮҠвӮҒ c
                swap-fix = swapFin-fix {suc (suc p)} i iвӮҠвӮҒ (punchIn iвӮҠвӮҒ c) ne-i ne-iвӮҠвӮҒ
                -- fst equality: punchIn-в„• (suc(fst i)) (fst c) = punchIn-в„• (fst i) (fst c)
                fst-eq : fst (punchIn iвӮҠвӮҒ c) вүЎ fst (punchIn i c)
                fst-eq = piвӮҠвӮҒ-fst вҲҷ sym e вҲҷ sym pi-fst
            in swap-fix вҲҷ ОЈeq fst-eq
          case-swap : (punchIn-в„• (fst i) (fst c) вүЎ suc (fst i))
                    Г— (punchIn-в„• (suc (fst i)) (fst c) вүЎ fst i)
            вҶ’ swapFin {suc (suc p)} i iвӮҠвӮҒ (punchIn iвӮҠвӮҒ c) вүЎ punchIn i c
          case-swap (pi-eq , piвӮҠвӮҒ-eq) =
            let piвӮҠвӮҒ-fst = punchIn-fst iвӮҠвӮҒ c
                pi-fst = punchIn-fst i c
                -- fst(punchIn iвӮҠвӮҒ c) = fst i, so swap takes i вҶҰ iвӮҠвӮҒ
                fst-is-i : fst (punchIn iвӮҠвӮҒ c) вүЎ fst i
                fst-is-i = piвӮҠвӮҒ-fst вҲҷ piвӮҠвӮҒ-eq
                piвӮҠвӮҒ-is-i : punchIn iвӮҠвӮҒ c вүЎ i
                piвӮҠвӮҒ-is-i = ОЈeq fst-is-i
                -- swap(i,iвӮҠвӮҒ)(i) = iвӮҠвӮҒ
                swap-gives-iвӮҠвӮҒ : swapFin {suc (suc p)} i iвӮҠвӮҒ (punchIn iвӮҠвӮҒ c) вүЎ iвӮҠвӮҒ
                swap-gives-iвӮҠвӮҒ = cong (swapFin {suc (suc p)} i iвӮҠвӮҒ) piвӮҠвӮҒ-is-i
                                вҲҷ swapFin-ij {suc (suc p)} i iвӮҠвӮҒ
                -- punchIn i c has fst = suc(fst i) = fst iвӮҠвӮҒ
                pi-is-iвӮҠвӮҒ : punchIn i c вүЎ iвӮҠвӮҒ
                pi-is-iвӮҠвӮҒ = ОЈeq (pi-fst вҲҷ pi-eq)
            in swap-gives-iвӮҠвӮҒ вҲҷ sym pi-is-iвӮҠвӮҒ

      -- Fact 1: Пғ вҲҳ punchIn i = Пғ' вҲҳ punchIn iвӮҠвӮҒ
      fact1 : s x (Пғ вҲҳ punchIn i) вүЎ s x (Пғ' вҲҳ punchIn iвӮҠвӮҒ)
      fact1 = cong (s x) (funExt (О» c вҶ’ sym (cong Пғ (swap-punchIn-adj c))))

      -- Fact 5: s x (Пғ' вҲҳ punchIn j) = -(s x (Пғ вҲҳ punchIn j))
      -- Пғ' вҲҳ punchIn j = Пғ вҲҳ swapFin i iвӮҠвӮҒ вҲҳ punchIn j
      -- Since fst i < fst iвӮҠвӮҒ < fst j, the swap at i,iвӮҠвӮҒ commutes with punchIn j.
      -- More precisely, swap(i,iвӮҠвӮҒ) вҲҳ punchIn j = punchIn j вҲҳ swap(i',iвӮҠвӮҒ')
      -- where i', iвӮҠвӮҒ' are the preimages in Fin(suc p).
      -- Then s(Пғ вҲҳ punchIn j вҲҳ swap(i',iвӮҠвӮҒ')) = -(s(Пғ вҲҳ punchIn j)) by antisymmetry of s.
      postulate
        fact5 : s x (Пғ' вҲҳ punchIn j) вүЎ Ax.-_ x (s x (Пғ вҲҳ punchIn j))

      -- Chain: s(Пғ вҲҳ pI i) =[fact1]= s(Пғ' вҲҳ pI iвӮҠвӮҒ)
      --   =[ih]= negPow d' (s(Пғ' вҲҳ pI j))
      --   =[cong fact5]= negPow d' (-(s(Пғ вҲҳ pI j)))
      --   = negPow d' (negPow 1 (s(Пғ вҲҳ pI j)))
      --   =[negPow-comp]= negPow (d'+1) (s(Пғ вҲҳ pI j))
      --   =[+-comm]= negPow (suc d') (s(Пғ вҲҳ pI j))
      goal : s x (Пғ вҲҳ punchIn i) вүЎ negPow (suc d') (s x (Пғ вҲҳ punchIn j))
      goal = let v = s x (Пғ вҲҳ punchIn j) in
             fact1
           вҲҷ ih
           вҲҷ cong (negPow d') fact5
           вҲҷ negPow-comp d' 1 v
           вҲҷ cong (О» n вҶ’ negPow n v) (+-comm d' 1)

  face-shift : {p : в„•} (s : CвҒҝ p) (alt : isAlternating s)
    вҶ’ (x : S) (Пғ : Fin (suc (suc p)) вҶ’ T x)
    вҶ’ (i j : Fin (suc (suc p))) вҶ’ fst i <бө— fst j вҶ’ Пғ i вүЎ Пғ j
    вҶ’ s x (Пғ вҲҳ punchIn i) вүЎ negPow (fst j вҲё suc (fst i)) (s x (Пғ вҲҳ punchIn j))
  face-shift {p} s alt x Пғ i j i<j Пғeq =
    face-shift-aux s alt x (fst j вҲё suc (fst i)) Пғ i j (suc+вҲёвүЎ (fst i) (fst j) i<j) Пғeq

  -- Key sub-lemmas for d-preserves-alt (to be discharged)
  postulate
    -- Antisymmetry: d s x (Пғ вҲҳ swap i j) = -(d s x Пғ) (for alternating s)
    d-antisym-swap : {p : в„•} (s : CвҒҝ p) (alt : isAlternating s)
      вҶ’ (x : S) (Пғ : Fin (suc (suc p)) вҶ’ T x)
      вҶ’ (i j : Fin (suc (suc p))) вҶ’ В¬ (i вүЎ j)
      вҶ’ d s x (Пғ вҲҳ swapFin {suc (suc p)} i j) вүЎ Ax.-_ x (d s x Пғ)

  -- The two face terms at repeat positions cancel
  -- Proof: WLOG fst i < fst j. By face-shift, s(face i) = negPow d (s(face j)).
  -- Then negPow(fst i)(negPow d v) + negPow(fst j)(v)
  --    = negPow(predв„•(fst j))(v) + negPow(fst j)(v) = 0.
  face-terms-cancel : {p : в„•} (s : CвҒҝ p) (alt : isAlternating s)
    вҶ’ (x : S) (Пғ : Fin (suc (suc p)) вҶ’ T x)
    вҶ’ (i j : Fin (suc (suc p))) вҶ’ В¬ (i вүЎ j) вҶ’ Пғ i вүЎ Пғ j
    вҶ’ Ax._+_ x (negPow (fst i) (s x (Пғ вҲҳ punchIn i)))
               (negPow (fst j) (s x (Пғ вҲҳ punchIn j))) вүЎ Ax.0g x
  face-terms-cancel {p} s alt x Пғ i j iвү j Пғeq = go (fst i вүҹбө— fst j)
    where
      _+A_ = Ax._+_ x ; v = s x (Пғ вҲҳ punchIn j) ; w = s x (Пғ вҲҳ punchIn i)
      fst-iвү j : В¬ (fst i вүЎ fst j)
      fst-iвү j e = iвү j (ОЈвүЎProp (О» k вҶ’ isProp<бө— {n = k} {m = suc (suc p)}) e)
      -- Case fst i < fst j
      go-lt : fst i <бө— fst j
        вҶ’ negPow (fst i) w +A negPow (fst j) v вүЎ Ax.0g x
      go-lt i<j =
        let d = fst j вҲё suc (fst i)
            shift = face-shift s alt x Пғ i j i<j Пғeq
            arith : fst i + d вүЎ predв„• (fst j)
            arith = +вҲёвүЎpredв„• (fst i) (fst j) i<j
            step1 : negPow (fst i) w вүЎ negPow (predв„• (fst j)) v
            step1 = cong (negPow (fst i)) shift
                   вҲҷ negPow-comp (fst i) d v
                   вҲҷ cong (О» n вҶ’ negPow n v) arith
            j>0 : В¬ (fst j вүЎ 0)
            j>0 e = В¬<бө—0 {fst i} (subst (fst i <бө—_) e i<j)
            pred-suc : suc (predв„• (fst j)) вүЎ fst j
            pred-suc = sym (suc-predв„• (fst j) j>0)
        in cong (_+A negPow (fst j) v) step1
           вҲҷ cong (О» n вҶ’ negPow (predв„• (fst j)) v +A negPow n v) (sym pred-suc)
           вҲҷ negPow-suc-cancel (predв„• (fst j)) v
      -- Case fst j < fst i: swap and use commutativity
      go-gt : fst j <бө— fst i
        вҶ’ negPow (fst i) w +A negPow (fst j) v вүЎ Ax.0g x
      go-gt j<i =
        let d = fst i вҲё suc (fst j)
            shift = face-shift s alt x Пғ j i j<i (sym Пғeq)
            arith : fst j + d вүЎ predв„• (fst i)
            arith = +вҲёвүЎpredв„• (fst j) (fst i) j<i
            step1 : negPow (fst j) v вүЎ negPow (predв„• (fst i)) w
            step1 = cong (negPow (fst j)) shift
                   вҲҷ negPow-comp (fst j) d w
                   вҲҷ cong (О» n вҶ’ negPow n w) arith
            i>0 : В¬ (fst i вүЎ 0)
            i>0 e = В¬<бө—0 {fst j} (subst (fst j <бө—_) e j<i)
            pred-suc : suc (predв„• (fst i)) вүЎ fst i
            pred-suc = sym (suc-predв„• (fst i) i>0)
        in Ax.+Comm x _ _
           вҲҷ cong (_+A negPow (fst i) w) step1
           вҲҷ cong (О» n вҶ’ negPow (predв„• (fst i)) w +A negPow n w) (sym pred-suc)
           вҲҷ negPow-suc-cancel (predв„• (fst i)) w
      go : Trichotomyбө— (fst i) (fst j) вҶ’ _
      go (eqбө— e) = вҠҘ.rec (fst-iвү j e)
      go (ltбө— q) = go-lt q
      go (gtбө— q) = go-gt q

  -- Vanishing: if Пғ has a repeat, then d s x Пғ = 0 (for alternating s)
  -- Uses sfg-two-cancel: terms at k вү  i,j vanish (face-term-zero),
  -- terms at i,j cancel (face-terms-cancel).
  d-vanish-repeat : {p : в„•} (s : CвҒҝ p) (alt : isAlternating s)
    вҶ’ (x : S) (Пғ : Fin (suc (suc p)) вҶ’ T x)
    вҶ’ (i j : Fin (suc (suc p))) вҶ’ В¬ (i вүЎ j) вҶ’ Пғ i вүЎ Пғ j
    вҶ’ d s x Пғ вүЎ Ax.0g x
  d-vanish-repeat {p} s alt x Пғ i j iвү j Пғeq =
    sfg-two-cancel (suc p) f i j fst-iвү j cancel zeros
    where
      f : Fin (suc (suc p)) вҶ’ |A| x
      f k = negPow (fst k) (s x (Пғ вҲҳ punchIn k))
      fst-iвү j : В¬ (fst i вүЎ fst j)
      fst-iвү j e = iвү j (ОЈвүЎProp (О» k вҶ’ isProp<бө— {n = k} {m = suc (suc p)}) e)
      cancel : Ax._+_ x (f i) (f j) вүЎ Ax.0g x
      cancel = face-terms-cancel s alt x Пғ i j iвү j Пғeq
      zeros : (k : Fin (suc (suc p))) вҶ’ В¬ (fst k вүЎ fst i) вҶ’ В¬ (fst k вүЎ fst j)
        вҶ’ f k вүЎ Ax.0g x
      zeros k kвү i kвү j = face-term-zero s (fst alt) Пғ i j iвү j Пғeq k kвү i kвү j

  d-preserves-alt : {p : в„•} (s : CвҒҝ p)
    вҶ’ isAlternating s вҶ’ isAlternating (d s)
  d-preserves-alt s alt =
    (О» x Пғ i j iвү j Пғeq вҶ’ d-vanish-repeat s alt x Пғ i j iвү j Пғeq) ,
    (О» x Пғ i j iвү j вҶ’ d-antisym-swap s alt x Пғ i j iвү j)

  -- ================================================================
  -- Section 5: Main Theorems (Stacks Project Tag 01FG)
