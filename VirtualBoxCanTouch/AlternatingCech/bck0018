  section-exact : ((x : S) вҶ’ T x)
    вҶ’ (ОІ : CвҒҝ 1) вҶ’ ((x : S) (u v w : T x) вҶ’
        d ОІ x (mk3Tuple u v w) вүЎ Ax.0g x)
    вҶ’ ОЈ (CвҒҝ 0) (О» Оұ вҶ’ вҲҖ x Пғ вҶ’ d Оұ x Пғ вүЎ ОІ x Пғ)
  section-exact t ОІ cocycle = Оұ , proof
    where
      Оұ : CвҒҝ 0
      Оұ x Пғ = ОІ x (mk2Tuple (t x) (Пғ fzero))

      proof : вҲҖ x Пғ вҶ’ d Оұ x Пғ вүЎ ОІ x Пғ
      proof x Пғ =
        let p = Пғ fzero ; q = Пғ fone
            _+_ = Ax._+_ x ; -_ = Ax.-_ x ; 0g = Ax.0g x
            c = ОІ x (mk2Tuple (t x) p)  -- = Оұ x (faceMap fone Пғ)
            b = ОІ x (mk2Tuple (t x) q)  -- = Оұ x (faceMap fzero Пғ)
            -- Raw cocycle: d ОІ x (mk3Tuple (t x) p q) вүЎ 0g
            -- Definitionally: -(-(ОІ face2)) + (-(ОІ face1) + (ОІ face0 + 0g)) вүЎ 0g
            -- Convert using faceвүЎ + invInv to: c + (-b + (ОІ Пғ + 0g)) вүЎ 0g
            cocyc-conv : (- (- (ОІ x (faceMap (2 , tt) (mk3Tuple (t x) p q)))))
                         + ((- (ОІ x (faceMap fone (mk3Tuple (t x) p q))))
                         + (ОІ x (faceMap fzero (mk3Tuple (t x) p q)) + 0g))
                       вүЎ c + ((- b) + (ОІ x Пғ + 0g))
            cocyc-conv =
              congвӮӮ _+_
                (Gx.invInv x _ вҲҷ cong (ОІ x) (face2вүЎ (t x) p q))
                (congвӮӮ _+_
                  (cong -_ (cong (ОІ x) (face1вүЎ (t x) p q)))
                  (cong (_+ 0g) (cong (ОІ x) (face0вүЎ (t x) p q вҲҷ mk2вүЎПғ Пғ))))
            cocyc' : c + ((- b) + (ОІ x Пғ + 0g)) вүЎ 0g
            cocyc' = sym cocyc-conv вҲҷ cocycle x (t x) p q
            -- From cocyc': c + (-b + a) = 0 (after +IdR)
            -- invUniqueR: -b + a = -c
            -- Then: -c + b = a (algebraic rearrangement)
            step1 : c + ((- b) + ОІ x Пғ) вүЎ 0g
            step1 = subst (О» z вҶ’ c + ((- b) + z) вүЎ 0g) (Ax.+IdR x (ОІ x Пғ)) cocyc'
            step2 : (- b) + ОІ x Пғ вүЎ - c
            step2 = Gx.invUniqueR x step1
        in
        (- c) + (b + 0g)
          вүЎвҹЁ cong ((- c) +_) (Ax.+IdR x b) вҹ©
        (- c) + b
          вүЎвҹЁ Ax.+Comm x (- c) b вҹ©
        b + (- c)
          вүЎвҹЁ cong (b +_) (sym step2) вҹ©
        b + ((- b) + ОІ x Пғ)
          вүЎвҹЁ Ax.+Assoc x b (- b) (ОІ x Пғ) вҹ©
        (b + (- b)) + ОІ x Пғ
          вүЎвҹЁ cong (_+ ОІ x Пғ) (Ax.+InvR x b) вҹ©
        0g + ОІ x Пғ
          вүЎвҹЁ Ax.+IdL x (ОІ x Пғ) вҹ©
        ОІ x Пғ вҲҺ

