-- Boolean comparison helpers
private
  В¬<бө—0 : {n : в„•} вҶ’ n <бө— zero вҶ’ вҠҘ
  В¬<бө—0 {zero} h = h
  В¬<бө—0 {suc _} h = h

  <бө—-вүӨбө—-trans : {a b c : в„•} вҶ’ a <бө— b вҶ’ b вүӨбө— c вҶ’ a <бө— c
  <бө—-вүӨбө—-trans {zero} {zero} h _ = вҠҘ.rec h
  <бө—-вүӨбө—-trans {zero} {suc b} {zero} _ h = вҠҘ.rec (В¬<бө—0 {b} h)
  <бө—-вүӨбө—-trans {zero} {suc _} {suc _} _ _ = tt
  <бө—-вүӨбө—-trans {suc _} {zero} h _ = вҠҘ.rec h
  <бө—-вүӨбө—-trans {suc _} {suc b} {zero} _ h = вҠҘ.rec (В¬<бө—0 {b} h)
  <бө—-вүӨбө—-trans {suc a} {suc b} {suc c} = <бө—-вүӨбө—-trans {a} {b} {c}

-- punchIn: insert a gap at position i
-- Maps Fin n вҶ’ Fin (suc n), skipping position i
-- Recursive definition: punchIn (suc a) (suc c) = fsuc (punchIn a c)
-- This gives definitional reduction for the simplicial identity proof
punchIn : {n : в„•} вҶ’ Fin (suc n) вҶ’ Fin n вҶ’ Fin (suc n)
punchIn (zero , _) j = fsuc j
punchIn {suc _} (suc a , p) (zero , _) = fzero
punchIn {suc _} (suc a , p) (suc c , q) = fsuc (punchIn (a , p) (c , q))

-- в„•-level punchIn (mirrors Fin version, for proving simplicial identity)
punchIn-в„• : в„• вҶ’ в„• вҶ’ в„•
punchIn-в„• zero c = suc c
punchIn-в„• (suc a) zero = zero
punchIn-в„• (suc a) (suc c) = suc (punchIn-в„• a c)

-- Simplicial identity at в„• level: for a вүӨ b,
--   punchIn a (punchIn b c) = punchIn (suc b) (punchIn a c)
simplicial-в„• : (a b c : в„•) вҶ’ a вүӨбө— b
  вҶ’ punchIn-в„• a (punchIn-в„• b c) вүЎ punchIn-в„• (suc b) (punchIn-в„• a c)
simplicial-в„• zero b c _ = refl
simplicial-в„• (suc a) zero c h = вҠҘ.rec (В¬<бө—0 {a} h)
simplicial-в„• (suc a) (suc b) zero h = refl
simplicial-в„• (suc a) (suc b) (suc c) h = cong suc (simplicial-в„• a b c h)

-- fst of punchIn agrees with punchIn-в„• (definitional)
punchIn-fst : {n : в„•} (i : Fin (suc n)) (j : Fin n)
  вҶ’ fst (punchIn i j) вүЎ punchIn-в„• (fst i) (fst j)
punchIn-fst (zero , _) j = refl
punchIn-fst {suc _} (suc a , p) (zero , _) = refl
punchIn-fst {suc _} (suc a , p) (suc c , q) = cong suc (punchIn-fst (a , p) (c , q))

-- Adjacent punchIn: for positions a and suc a, punchIn-в„• either gives
-- the same value (when c вү  a) or swaps a вҶ” suc a (when c = a at в„• level)
adj-punchIn-в„• : (a c : в„•)
  вҶ’ (punchIn-в„• a c вүЎ punchIn-в„• (suc a) c)
    вҠҺ ((punchIn-в„• a c вүЎ suc a) Г— (punchIn-в„• (suc a) c вүЎ a))
adj-punchIn-в„• zero zero = inr (refl , refl)
adj-punchIn-в„• zero (suc c) = inl refl
adj-punchIn-в„• (suc a) zero = inl refl
adj-punchIn-в„• (suc a) (suc c) =
  вҠҺ.rec (О» e вҶ’ inl (cong suc e))
        (О» pq вҶ’ inr (cong suc (fst pq) , cong suc (snd pq)))
        (adj-punchIn-в„• a c)

-- Simplicial identity at Fin level (direct pattern matching)
simplicial : {n : в„•} (i : Fin (suc (suc n))) (j : Fin (suc n)) (k : Fin n)
  (i' : Fin (suc n)) вҶ’ fst i вүЎ fst i' вҶ’ fst i вүӨбө— fst j
  вҶ’ punchIn i (punchIn j k) вүЎ punchIn (fsuc j) (punchIn i' k)
simplicial (zero , pi) j k (zero , pi') e h = refl
simplicial (zero , pi) j k (suc a' , pi') e h =
  вҠҘ.rec (znots e)
simplicial {suc n} (suc a , pi) (zero , pj) k i' e h =
  вҠҘ.rec (В¬<бө—0 {a} h)
simplicial {suc n} (suc a , pi) (suc b , pj) (zero , pk) (zero , pi') e h =
  вҠҘ.rec (snotz e)
simplicial {suc n} (suc a , pi) (suc b , pj) (zero , pk) (suc a' , pi') e h =
  refl
simplicial {suc n} (suc a , pi) (suc b , pj) (suc c , pk) (zero , pi') e h =
  вҠҘ.rec (snotz e)
simplicial {suc n} (suc a , pi) (suc b , pj) (suc c , pk) (suc a' , pi') e h =
  cong fsuc (simplicial (a , pi) (b , pj) (c , pk) (a' , pi') (injSuc e) h)

-- Face map: delete position i from a (suc n)-tuple to get an n-tuple
faceMap : {n : в„•} {A : Type в„“} вҶ’ Fin (suc n) вҶ’ (Fin (suc n) вҶ’ A) вҶ’ (Fin n вҶ’ A)
faceMap i Пғ = Пғ вҲҳ punchIn i

-- punchOut: inverse of punchIn (given k вү  i, find j with punchIn k j = i)
punchOut : {n : в„•} вҶ’ (k : Fin (suc n)) вҶ’ (i : Fin (suc n))
  вҶ’ В¬ (fst k вүЎ fst i) вҶ’ Fin n
punchOut (zero , _) (zero , _) neq = вҠҘ.rec (neq refl)
punchOut (zero , _) (suc c , q) _ = (c , q)
punchOut {suc _} (suc a , p) (zero , _) _ = fzero
punchOut {suc _} (suc a , p) (suc c , q) neq =
  fsuc (punchOut (a , p) (c , q) (О» eq вҶ’ neq (cong suc eq)))

-- punchIn вҲҳ punchOut = id
punchIn-punchOut : {n : в„•} (k : Fin (suc n)) (i : Fin (suc n))
  (neq : В¬ (fst k вүЎ fst i)) вҶ’ punchIn k (punchOut k i neq) вүЎ i
punchIn-punchOut (zero , _) (zero , _) neq = вҠҘ.rec (neq refl)
punchIn-punchOut (zero , _) (suc c , q) _ = refl
punchIn-punchOut {suc _} (suc a , p) (zero , _) _ = refl
punchIn-punchOut {suc _} (suc a , p) (suc c , q) neq =
  cong fsuc (punchIn-punchOut (a , p) (c , q) (О» eq вҶ’ neq (cong suc eq)))

-- Swap two positions (using вүҹбө— for with-matching in proofs)
swapFin : {n : в„•} вҶ’ Fin n вҶ’ Fin n вҶ’ Fin n вҶ’ Fin n
swapFin i j k with fst k вүҹбө— fst i
... | eqбө— _ = j
... | ltбө— _ with fst k вүҹбө— fst j
...   | eqбө— _ = i
...   | _ = k
swapFin i j k | gtбө— _ with fst k вүҹбө— fst j
...   | eqбө— _ = i
...   | _ = k

-- swapFin properties
swapFin-ij : {n : в„•} (i j : Fin n) вҶ’ _вүЎ_ {A = Fin n} (swapFin {n} i j i) j
swapFin-ij i j with fst i вүҹбө— fst i
... | eqбө— _ = refl
... | ltбө— h = вҠҘ.rec (В¬m<бө—m {fst i} h)
... | gtбө— h = вҠҘ.rec (В¬m<бө—m {fst i} h)

swapFin-ji : {n : в„•} (i j : Fin n) вҶ’ _вүЎ_ {A = Fin n} (swapFin {n} i j j) i
swapFin-ji {n} i j with fst j вүҹбө— fst i
... | eqбө— e = ОЈвүЎProp (О» k вҶ’ isProp<бө— {n = k} {m = n}) e
... | ltбө— _ with fst j вүҹбө— fst j
...   | eqбө— _ = refl
...   | ltбө— h = вҠҘ.rec (В¬m<бө—m {fst j} h)
...   | gtбө— h = вҠҘ.rec (В¬m<бө—m {fst j} h)
swapFin-ji {n} i j | gtбө— _ with fst j вүҹбө— fst j
...   | eqбө— _ = refl
...   | ltбө— h = вҠҘ.rec (В¬m<бө—m {fst j} h)
...   | gtбө— h = вҠҘ.rec (В¬m<бө—m {fst j} h)

swapFin-fix : {n : в„•} (i j k : Fin n)
  вҶ’ В¬ (fst k вүЎ fst i) вҶ’ В¬ (fst k вүЎ fst j) вҶ’ _вүЎ_ {A = Fin n} (swapFin {n} i j k) k
swapFin-fix i j k kвү i kвү j with fst k вүҹбө— fst i
... | eqбө— e = вҠҘ.rec (kвү i e)
... | ltбө— _ with fst k вүҹбө— fst j
...   | eqбө— e = вҠҘ.rec (kвү j e)
...   | ltбө— _ = refl
...   | gtбө— _ = refl
swapFin-fix i j k kвү i kвү j | gtбө— _ with fst k вүҹбө— fst j
...   | eqбө— e = вҠҘ.rec (kвү j e)
...   | ltбө— _ = refl
...   | gtбө— _ = refl

-- m <бө— m + suc d (by induction on m)
m<m+sd : (m : в„•) (dd : в„•) вҶ’ m <бө— (m + suc dd)
m<m+sd zero _ = tt
m<m+sd (suc m') dd = m<m+sd m' dd

