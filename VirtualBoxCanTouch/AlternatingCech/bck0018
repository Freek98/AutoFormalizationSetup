  -- Lemma 20.23.6: The chain homotopy
  -- h_n : CвҒҝ (suc n) вҶ’ CвҒҝ n such that dвҲҳh + hвҲҳd = id - Оә
  -- where Оә = c вҲҳ ПҖ
  -- Formula at degree (suc p): for s : CвҒҝ (suc p),
  --   d (h p s) + h (suc p) (d s) = s - Оә s
  postulate
    cПҖ-homotopic-to-id :
      (Оә : {n : в„•} вҶ’ CвҒҝ n вҶ’ CвҒҝ n)
      (h : (n : в„•) вҶ’ CвҒҝ (suc n) вҶ’ CвҒҝ n)
      вҶ’ {p : в„•} (s : CвҒҝ (suc p)) (x : S) (Пғ : Fin (suc (suc p)) вҶ’ T x)
      вҶ’ Ax._+_ x (d (h p s) x Пғ) (h (suc p) (d s) x Пғ)
        вүЎ Ax._+_ x (s x Пғ) (Ax.-_ x (Оә s x Пғ))

  -- Lemma 20.23.7: Contractibility when U_i = X
  postulate
    contractible-with-section : {p : в„•}
      вҶ’ (xвӮҖ : S) вҶ’ T xвӮҖ
      вҶ’ (s : CвҒҝ-alt (suc p))
      вҶ’ ОЈ (CвҒҝ-alt p) (О» t вҶ’ d (О№map t) вүЎ О№map s)

