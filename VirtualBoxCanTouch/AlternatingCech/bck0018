-- Trichotomy type avoiding path types (cubical Agda can't pattern-match
-- on вҠҺ when one branch contains a path type)
data Tri< {в„“ : Level} {A : Type в„“} (_<_ : A вҶ’ A вҶ’ Type в„“) (a b : A) : Type в„“ where
  is-lt : a < b вҶ’ Tri< _<_ a b
  is-eq : В¬ (a < b) вҶ’ В¬ (b < a) вҶ’ Tri< _<_ a b
  is-gt : b < a вҶ’ Tri< _<_ a b

Tri<-elim : вҲҖ {в„“ в„“'} {A : Type в„“} {_<_ : A вҶ’ A вҶ’ Type в„“} {a b : A}
  {P : Tri< _<_ a b вҶ’ Type в„“'}
  вҶ’ ((x : a < b) вҶ’ P (is-lt x))
  вҶ’ ((x : В¬ (a < b)) (y : В¬ (b < a)) вҶ’ P (is-eq x y))
  вҶ’ ((x : b < a) вҶ’ P (is-gt x))
  вҶ’ (r : Tri< _<_ a b) вҶ’ P r
Tri<-elim f g h (is-lt x) = f x
Tri<-elim f g h (is-eq x y) = g x y
Tri<-elim f g h (is-gt x) = h x

record DecStrictTotalOrder {в„“ : Level} (A : Type в„“) : Type (в„“-suc в„“) where
  field
    _<sto_ : A вҶ’ A вҶ’ Type в„“
    <sto-prop : (a b : A) вҶ’ isProp (a <sto b)
    <sto-irrefl : (a : A) вҶ’ В¬ (a <sto a)
    <sto-trans : {a b c : A} вҶ’ a <sto b вҶ’ b <sto c вҶ’ a <sto c
    <sto-tricho : (a b : A) вҶ’ Tri< _<sto_ a b
    isSetA : isSet A

