  -- c‚ÇÅ-fun vanishes when œÉ fzero ‚â° œÉ fone (repeated entry)
  -- Uses Tri<-elim + lambda to avoid binding path types in pattern LHS
  private
    c‚ÇÅ-vanish : (s : C‚Åø-ord 1) (x : S) (œÉ : Fin 2 ‚Üí T x)
      ‚Üí œÉ fzero ‚â° œÉ fone ‚Üí c‚ÇÅ-fun s x œÉ ‚â° Ax.0g x
    c‚ÇÅ-vanish s x œÉ = Œª eq ‚Üí Tri<-elim {P = Œª r ‚Üí c‚ÇÅ-core s x œÉ r ‚â° Ax.0g x}
      (Œª a<b ‚Üí ‚ä•.rec (<sto-irrefl x (œÉ fzero)
        (subst (_<sto_ x (œÉ fzero)) (sym eq) a<b)))
      (Œª _ _ ‚Üí refl)
