            -- Definitionally: -(-(Œ≤ face2)) + (-(Œ≤ face1) + (Œ≤ face0 + 0g)) ‚â° 0g
            -- Convert using face‚â° + invInv to: c + (-b + (Œ≤ œÉ + 0g)) ‚â° 0g
            cocyc-conv : (- (- (Œ≤ x (faceMap (2 , tt) (mk3Tuple (t x) p q)))))
                         + ((- (Œ≤ x (faceMap fone (mk3Tuple (t x) p q))))
                         + (Œ≤ x (faceMap fzero (mk3Tuple (t x) p q)) + 0g))
                       ‚â° c + ((- b) + (Œ≤ x œÉ + 0g))
            cocyc-conv =
              cong‚ÇÇ _+_
