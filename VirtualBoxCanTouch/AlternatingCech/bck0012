module GeneralCech {‚Ñì : Level}
  (S : Type ‚Ñì) (T : S ‚Üí Type ‚Ñì) (A : S ‚Üí AbGroup ‚Ñì) where

  |A|_ : S ‚Üí Type ‚Ñì
  |A| x = fst (A x)

  module Ax (x : S) = AbGroupStr (snd (A x))
  module Gx (x : S) = GroupProps.GroupTheory (AbGroup‚ÜíGroup (A x))

  C‚Åø : ‚Ñï ‚Üí Type ‚Ñì
  C‚Åø p = (x : S) ‚Üí (Fin (suc p) ‚Üí T x) ‚Üí |A| x

  0C : {p : ‚Ñï} ‚Üí C‚Åø p
  0C x _ = Ax.0g x

  negC : {p : ‚Ñï} ‚Üí C‚Åø p ‚Üí C‚Åø p
  negC s x œÉ = Ax.-_ x (s x œÉ)

  addC : {p : ‚Ñï} ‚Üí C‚Åø p ‚Üí C‚Åø p ‚Üí C‚Åø p
  addC s t x œÉ = Ax._+_ x (s x œÉ) (t x œÉ)

  negPow : {x : S} ‚Üí ‚Ñï ‚Üí |A| x ‚Üí |A| x
  negPow {x} zero a = a
  negPow {x} (suc n) a = Ax.-_ x (negPow n a)

  altFinSum : {x : S} ‚Üí {n : ‚Ñï} ‚Üí (Fin n ‚Üí |A| x) ‚Üí |A| x
  altFinSum {x} {n} f = sumFinGen {n = n} (Ax._+_ x) (Ax.0g x)
    (Œª j ‚Üí negPow (fst j) (f j))

  d : {p : ‚Ñï} ‚Üí C‚Åø p ‚Üí C‚Åø (suc p)
  d {p} s x œÉ = altFinSum {x} {suc (suc p)}
    (Œª j ‚Üí s x (faceMap j œÉ))

  C‚ÅøAbGroup : (p : ‚Ñï) ‚Üí AbGroup ‚Ñì
  C‚ÅøAbGroup p = ŒÝAbGroup {X = S} (Œª x ‚Üí
    ŒÝAbGroup {X = Fin (suc p) ‚Üí T x} (Œª _ ‚Üí A x))

  -- ================================================================
  -- Properties of negPow
  -- ================================================================

  negPow-two : {x : S} (a : |A| x) ‚Üí negPow {x} 2 a ‚â° a
  negPow-two {x} a = Gx.invInv x a

  negPow-add : {x : S} (n : ‚Ñï) (a b : |A| x)
    ‚Üí negPow n (Ax._+_ x a b) ‚â° Ax._+_ x (negPow n a) (negPow n b)
  negPow-add zero a b = refl
  negPow-add {x} (suc n) a b =
    Ax.-_ x (negPow n (Ax._+_ x a b))
      ‚â°‚ü® cong (Ax.-_ x) (negPow-add n a b) ‚ü©
    Ax.-_ x (Ax._+_ x (negPow n a) (negPow n b))
      ‚â°‚ü® Gx.invDistr x (negPow n a) (negPow n b) ‚ü©
    Ax._+_ x (Ax.-_ x (negPow n b)) (Ax.-_ x (negPow n a))
      ‚â°‚ü® Ax.+Comm x _ _ ‚ü©
    Ax._+_ x (Ax.-_ x (negPow n a)) (Ax.-_ x (negPow n b)) ‚àé

  negPow-0g : {x : S} (n : ‚Ñï) ‚Üí negPow {x} n (Ax.0g x) ‚â° Ax.0g x
  negPow-0g zero = refl
  negPow-0g {x} (suc n) =
    Ax.-_ x (negPow n (Ax.0g x))
      ‚â°‚ü® cong (Ax.-_ x) (negPow-0g n) ‚ü©
    Ax.-_ x (Ax.0g x)
      ‚â°‚ü® GroupProps.GroupTheory.inv1g (AbGroup‚ÜíGroup (A x)) ‚ü©
    Ax.0g x ‚àé

  -- negPow composes: negPow i (negPow j a) ‚â° negPow (i + j) a
  negPow-comp : {x : S} (i j : ‚Ñï) (a : |A| x)
    ‚Üí negPow i (negPow j a) ‚â° negPow (i + j) a
  negPow-comp zero j a = refl
  negPow-comp {x} (suc i) j a = cong (Ax.-_ x) (negPow-comp i j a)

  -- negPow distributes over sumFinGen
  negPow-sum : {x : S} {m : ‚Ñï} (n : ‚Ñï) (f : Fin m ‚Üí |A| x)
    ‚Üí negPow n (sumFinGen {n = m} (Ax._+_ x) (Ax.0g x) f)
    ‚â° sumFinGen {n = m} (Ax._+_ x) (Ax.0g x) (Œª j ‚Üí negPow n (f j))
  negPow-sum {m = zero} n f = negPow-0g n
  negPow-sum {x} {m = suc m} n f =
    negPow-add n (f flast) (sumFinGen {n = m} (Ax._+_ x) (Ax.0g x) (f ‚àò injectSuc))
    ‚àô cong (Ax._+_ x (negPow n (f flast)))
           (negPow-sum {x = x} {m = m} n (f ‚àò injectSuc))

  -- ================================================================
  -- Linearity of d and d¬≤ = 0
  -- ================================================================

  private
    -- Abelian group interchange: (a+b)+(c+d) = (a+c)+(b+d)
    interchange : {x : S} (a b c d' : |A| x)
      ‚Üí Ax._+_ x (Ax._+_ x a b) (Ax._+_ x c d')
      ‚â° Ax._+_ x (Ax._+_ x a c) (Ax._+_ x b d')
    interchange {x} a b c d' =
      sym (Ax.+Assoc x a b _)
      ‚àô cong (Ax._+_ x a) (Ax.+Assoc x b c d')
      ‚àô cong (Œª z ‚Üí Ax._+_ x a (Ax._+_ x z d')) (Ax.+Comm x b c)
      ‚àô cong (Ax._+_ x a) (sym (Ax.+Assoc x c b d'))
      ‚àô Ax.+Assoc x a c _

  -- sumFinGen distributes over +
  sumFinGen-+ : {x : S} {n : ‚Ñï} (f g : Fin n ‚Üí |A| x)
    ‚Üí sumFinGen {n = n} (Ax._+_ x) (Ax.0g x) (Œª j ‚Üí Ax._+_ x (f j) (g j))
    ‚â° Ax._+_ x (sumFinGen {n = n} (Ax._+_ x) (Ax.0g x) f)
                (sumFinGen {n = n} (Ax._+_ x) (Ax.0g x) g)
  sumFinGen-+ {x} {zero} f g = sym (Ax.+IdR x _)
  sumFinGen-+ {x} {suc n} f g =
    cong (Ax._+_ x (Ax._+_ x (f flast) (g flast)))
         (sumFinGen-+ {x} {n} (f ‚àò injectSuc) (g ‚àò injectSuc))
    ‚àô interchange (f flast) (g flast) _ _

  d-pres+ : {p : ‚Ñï} (s t : C‚Åø p) (x : S) (œÉ : Fin (suc (suc p)) ‚Üí T x)
    ‚Üí d (addC s t) x œÉ ‚â° Ax._+_ x (d s x œÉ) (d t x œÉ)
  d-pres+ {p} s t x œÉ =
    cong (sumFinGen {n = suc (suc p)} (Ax._+_ x) (Ax.0g x))
         (funExt (Œª j ‚Üí negPow-add (fst j) (s x (faceMap j œÉ)) (t x (faceMap j œÉ))))
    ‚àô sumFinGen-+ {n = suc (suc p)}
                  (Œª j ‚Üí negPow (fst j) (s x (faceMap j œÉ)))
                  (Œª j ‚Üí negPow (fst j) (t x (faceMap j œÉ)))

  -- For p=0: face map compositions agree on Fin 1 (direct computation)
  -- Cancelling pairs: (0,0)‚Üî(1,0), (0,1)‚Üî(2,0), (1,1)‚Üî(2,1)
  private
    face-comp-00‚â°10 : {B : Type ‚Ñì} (œÉ : Fin 3 ‚Üí B)
      ‚Üí œÉ ‚àò punchIn {2} fzero ‚àò punchIn {1} fzero
      ‚â° œÉ ‚àò punchIn {2} fone ‚àò punchIn {1} fzero
    face-comp-00‚â°10 œÉ = funExt Œª { (zero , _) ‚Üí refl ; (suc _ , q) ‚Üí ‚ä•.rec q }

    face-comp-01‚â°20 : {B : Type ‚Ñì} (œÉ : Fin 3 ‚Üí B)
      ‚Üí œÉ ‚àò punchIn {2} fzero ‚àò punchIn {1} fone
      ‚â° œÉ ‚àò punchIn {2} (2 , tt) ‚àò punchIn {1} fzero
    face-comp-01‚â°20 œÉ = funExt Œª { (zero , _) ‚Üí refl ; (suc _ , q) ‚Üí ‚ä•.rec q }

    face-comp-11‚â°21 : {B : Type ‚Ñì} (œÉ : Fin 3 ‚Üí B)
      ‚Üí œÉ ‚àò punchIn {2} fone ‚àò punchIn {1} fone
      ‚â° œÉ ‚àò punchIn {2} (2 , tt) ‚àò punchIn {1} fone
    face-comp-11‚â°21 œÉ = funExt Œª { (zero , _) ‚Üí refl ; (suc _ , q) ‚Üí ‚ä•.rec q }

  -- Algebraic helpers for d¬≤
  private
    -- Telescoping: (-p + q) + (-q + r) ‚â° -p + r
    telescope : {x : S} (p q r : |A| x)
      ‚Üí Ax._+_ x (Ax._+_ x (Ax.-_ x p) q)
                  (Ax._+_ x (Ax.-_ x q) r)
      ‚â° Ax._+_ x (Ax.-_ x p) r
    telescope {x} p q r =
      sym (Ax.+Assoc x (Ax.-_ x p) q _)
      ‚àô cong (Ax._+_ x (Ax.-_ x p)) (Ax.+Assoc x q (Ax.-_ x q) r)
      ‚àô cong (Œª z ‚Üí Ax._+_ x (Ax.-_ x p) (Ax._+_ x z r)) (Ax.+InvR x q)
      ‚àô cong (Ax._+_ x (Ax.-_ x p)) (Ax.+IdL x r)

    -- Cancellation: (-c + b) + ((-a + c) + (-b + a)) ‚â° 0g
    cancel3 : {x : S} (a b c : |A| x)
      ‚Üí Ax._+_ x (Ax._+_ x (Ax.-_ x c) b)
                  (Ax._+_ x (Ax._+_ x (Ax.-_ x a) c)
                            (Ax._+_ x (Ax.-_ x b) a))
      ‚â° Ax.0g x
    cancel3 {x} a b c =
      cong (Ax._+_ x (Ax._+_ x (Ax.-_ x c) b))
           (Ax.+Comm x _ _)
      ‚àô Ax.+Assoc x _ _ _
      ‚àô cong (Œª z ‚Üí Ax._+_ x z (Ax._+_ x (Ax.-_ x a) c))
             (telescope c b a)
      ‚àô telescope c a c
      ‚àô Ax.+InvL x c

  -- d¬≤ = 0 for degree 0 (direct computation)
  d¬≤-0 : (s : C‚Åø 0) (x : S) (œÉ : Fin 3 ‚Üí T x)
    ‚Üí d (d s) x œÉ ‚â° Ax.0g x
  d¬≤-0 s x œÉ = step1 ‚àô step2 ‚àô cancel3 T‚ÇÄ‚ÇÄ T‚ÇÄ‚ÇÅ T‚ÇÅ‚ÇÅ
    where
      T‚ÇÄ‚ÇÄ = s x (œÉ ‚àò punchIn {2} fzero ‚àò punchIn {1} fzero)
      T‚ÇÄ‚ÇÅ = s x (œÉ ‚àò punchIn {2} fzero ‚àò punchIn {1} fone)
      T‚ÇÅ‚ÇÅ = s x (œÉ ‚àò punchIn {2} fone ‚àò punchIn {1} fone)
      eq‚ÇÅ = cong (s x) (face-comp-00‚â°10 œÉ)
      eq‚ÇÇ = cong (s x) (face-comp-01‚â°20 œÉ)
      eq‚ÇÉ = cong (s x) (face-comp-11‚â°21 œÉ)
      -- Step 1: substitute face-comp equalities (6 vars ‚Üí 3 vars)
      step1 = cong‚ÇÇ (Ax._+_ x)
        (cong (Œª w ‚Üí Ax.-_ x (Ax.-_ x w))
          (cong‚ÇÇ (Ax._+_ x) (cong (Ax.-_ x) (sym eq‚ÇÉ))
                             (cong (Œª z ‚Üí Ax._+_ x z (Ax.0g x)) (sym eq‚ÇÇ))))
        (cong (Œª z ‚Üí Ax._+_ x
          (Ax.-_ x (Ax._+_ x (Ax.-_ x T‚ÇÅ‚ÇÅ) (Ax._+_ x z (Ax.0g x))))
          (Ax._+_ x (Ax._+_ x (Ax.-_ x T‚ÇÄ‚ÇÅ) (Ax._+_ x T‚ÇÄ‚ÇÄ (Ax.0g x)))
                    (Ax.0g x)))
          (sym eq‚ÇÅ))
      -- Step 2: simplify using invInv, +IdR, invDistr ‚Üí cancel3 form
      step2 = cong‚ÇÇ (Ax._+_ x)
        (Gx.invInv x _ ‚àô cong (Ax._+_ x (Ax.-_ x T‚ÇÅ‚ÇÅ)) (Ax.+IdR x T‚ÇÄ‚ÇÅ))
        (cong‚ÇÇ (Ax._+_ x)
          (cong (Ax.-_ x) (cong (Ax._+_ x (Ax.-_ x T‚ÇÅ‚ÇÅ)) (Ax.+IdR x T‚ÇÄ‚ÇÄ))
           ‚àô Gx.invDistr x (Ax.-_ x T‚ÇÅ‚ÇÅ) T‚ÇÄ‚ÇÄ
