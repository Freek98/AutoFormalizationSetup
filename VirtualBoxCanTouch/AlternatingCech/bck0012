-- Trichotomy type avoiding path types (cubical Agda can't pattern-match
-- on ‚äé when one branch contains a path type)
data Tri< {‚Ñì : Level} {A : Type ‚Ñì} (_<_ : A ‚Üí A ‚Üí Type ‚Ñì) (a b : A) : Type ‚Ñì where
  is-lt : a < b ‚Üí Tri< _<_ a b
  is-eq : ¬¨ (a < b) ‚Üí ¬¨ (b < a) ‚Üí Tri< _<_ a b
  is-gt : b < a ‚Üí Tri< _<_ a b

Tri<-elim : ‚àÄ {‚Ñì ‚Ñì'} {A : Type ‚Ñì} {_<_ : A ‚Üí A ‚Üí Type ‚Ñì} {a b : A}
  {P : Tri< _<_ a b ‚Üí Type ‚Ñì'}
  ‚Üí ((x : a < b) ‚Üí P (is-lt x))
  ‚Üí ((x : ¬¨ (a < b)) (y : ¬¨ (b < a)) ‚Üí P (is-eq x y))
  ‚Üí ((x : b < a) ‚Üí P (is-gt x))
  ‚Üí (r : Tri< _<_ a b) ‚Üí P r
Tri<-elim f g h (is-lt x) = f x
Tri<-elim f g h (is-eq x y) = g x y
Tri<-elim f g h (is-gt x) = h x

record DecStrictTotalOrder {‚Ñì : Level} (A : Type ‚Ñì) : Type (‚Ñì-suc ‚Ñì) where
  field
    _<sto_ : A ‚Üí A ‚Üí Type ‚Ñì
    <sto-prop : (a b : A) ‚Üí isProp (a <sto b)
    <sto-irrefl : (a : A) ‚Üí ¬¨ (a <sto a)
    <sto-trans : {a b c : A} ‚Üí a <sto b ‚Üí b <sto c ‚Üí a <sto c
    <sto-tricho : (a b : A) ‚Üí Tri< _<sto_ a b
    isSetA : isSet A

