                  (cong (_+ 0g) (cong (Œ≤ x) (face0‚â° (t x) p q ‚àô mk2‚â°œÉ œÉ))))
            cocyc' : c + ((- b) + (Œ≤ x œÉ + 0g)) ‚â° 0g
            cocyc' = sym cocyc-conv ‚àô cocycle x (t x) p q
            -- From cocyc': c + (-b + a) = 0 (after +IdR)
            -- invUniqueR: -b + a = -c
