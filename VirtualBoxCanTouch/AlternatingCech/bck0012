  -- Sum with two nonzero terms that cancel
  sfg-two-cancel : {x : S} (n : ‚Ñï) (f : Fin (suc n) ‚Üí |A| x)
    (i j : Fin (suc n)) ‚Üí ¬¨ (fst i ‚â° fst j)
    ‚Üí Ax._+_ x (f i) (f j) ‚â° Ax.0g x
