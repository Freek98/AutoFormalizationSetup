-- Boolean comparison helpers
private
  ¬¨<·µó0 : {n : ‚Ñï} ‚Üí n <·µó zero ‚Üí ‚ä•
  ¬¨<·µó0 {zero} h = h
  ¬¨<·µó0 {suc _} h = h

  <·µó-‚â§·µó-trans : {a b c : ‚Ñï} ‚Üí a <·µó b ‚Üí b ‚â§·µó c ‚Üí a <·µó c
  <·µó-‚â§·µó-trans {zero} {zero} h _ = ‚ä•.rec h
  <·µó-‚â§·µó-trans {zero} {suc b} {zero} _ h = ‚ä•.rec (¬¨<·µó0 {b} h)
  <·µó-‚â§·µó-trans {zero} {suc _} {suc _} _ _ = tt
  <·µó-‚â§·µó-trans {suc _} {zero} h _ = ‚ä•.rec h
