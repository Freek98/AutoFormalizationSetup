        (subst (Œª y ‚Üí _<sto_ x y (œÉ fzero)) (sym eq) b<a)))
      (<sto-tricho x (œÉ fzero) (œÉ fone))

  -- Vanishing part of c‚ÇÅ-alternating: case split on Fin 2 indices,
  -- but keep eq : œÉ i ‚â° œÉ j as a lambda argument (not on LHS)
  private
    c‚ÇÅ-alt-vanish : (s : C‚Åø-ord 1) (x : S) (œÉ : Fin 2 ‚Üí T x)
      (i j : Fin 2) ‚Üí ¬¨ (i ‚â° j) ‚Üí œÉ i ‚â° œÉ j ‚Üí c‚ÇÅ-fun s x œÉ ‚â° Ax.0g x
    c‚ÇÅ-alt-vanish s x œÉ (zero , _) (zero , _) ¬¨eq =
      Œª _ ‚Üí ‚ä•.rec (¬¨eq (Œ£‚â°Prop (Œª k ‚Üí isProp<·µó {n = k} {m = 2}) refl))
    c‚ÇÅ-alt-vanish s x œÉ (zero , _) (suc zero , _) _ =
      c‚ÇÅ-vanish s x œÉ
    c‚ÇÅ-alt-vanish s x œÉ (zero , _) (suc (suc _) , q) _ = Œª _ ‚Üí ‚ä•.rec q
