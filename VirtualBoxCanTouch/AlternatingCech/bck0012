  -- Ordered pair witness: direct pattern matching on Fin 2
  -- Key: n <·µó 0 = ‚ä• and suc n <·µó suc m = n <·µó m definitionally
  mkOrd2 : {x : S} (œÉ : Fin 2 ‚Üí T x) ‚Üí _<sto_ x (œÉ fzero) (œÉ fone)
    ‚Üí isOrdered {1} {x} œÉ
  mkOrd2 œÉ a<b (zero , _) (zero , _) p = ‚ä•.rec p
  mkOrd2 œÉ a<b (zero , _) (suc zero , _) _ = a<b
  mkOrd2 œÉ a<b (zero , _) (suc (suc _) , q) _ = ‚ä•.rec q
