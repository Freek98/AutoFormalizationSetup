  section-exact t Œ≤ cocycle = Œ± , proof
    where
      Œ± : C‚Åø 0
      Œ± x œÉ = Œ≤ x (mk2Tuple (t x) (œÉ fzero))

      proof : ‚àÄ x œÉ ‚Üí d Œ± x œÉ ‚â° Œ≤ x œÉ
      proof x œÉ =
        let p = œÉ fzero ; q = œÉ fone
            _+_ = Ax._+_ x ; -_ = Ax.-_ x ; 0g = Ax.0g x
            c = Œ≤ x (mk2Tuple (t x) p)  -- = Œ± x (faceMap fone œÉ)
            b = Œ≤ x (mk2Tuple (t x) q)  -- = Œ± x (faceMap fzero œÉ)
