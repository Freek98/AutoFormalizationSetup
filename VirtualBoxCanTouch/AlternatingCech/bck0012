-- punchIn: insert a gap at position i
-- Maps Fin n ‚Üí Fin (suc n), skipping position i
-- Recursive definition: punchIn (suc a) (suc c) = fsuc (punchIn a c)
-- This gives definitional reduction for the simplicial identity proof
punchIn : {n : ‚Ñï} ‚Üí Fin (suc n) ‚Üí Fin n ‚Üí Fin (suc n)
punchIn (zero , _) j = fsuc j
punchIn {suc _} (suc a , p) (zero , _) = fzero
punchIn {suc _} (suc a , p) (suc c , q) = fsuc (punchIn (a , p) (c , q))

-- ‚Ñï-level punchIn (mirrors Fin version, for proving simplicial identity)
punchIn-‚Ñï : ‚Ñï ‚Üí ‚Ñï ‚Üí ‚Ñï
punchIn-‚Ñï zero c = suc c
punchIn-‚Ñï (suc a) zero = zero
punchIn-‚Ñï (suc a) (suc c) = suc (punchIn-‚Ñï a c)

-- Simplicial identity at ‚Ñï level: for a ‚â§ b,
--   punchIn a (punchIn b c) = punchIn (suc b) (punchIn a c)
simplicial-‚Ñï : (a b c : ‚Ñï) ‚Üí a ‚â§·µó b
  ‚Üí punchIn-‚Ñï a (punchIn-‚Ñï b c) ‚â° punchIn-‚Ñï (suc b) (punchIn-‚Ñï a c)
simplicial-‚Ñï zero b c _ = refl
simplicial-‚Ñï (suc a) zero c h = ‚ä•.rec (¬¨<·µó0 {a} h)
simplicial-‚Ñï (suc a) (suc b) zero h = refl
simplicial-‚Ñï (suc a) (suc b) (suc c) h = cong suc (simplicial-‚Ñï a b c h)

-- fst of punchIn agrees with punchIn-‚Ñï (definitional)
punchIn-fst : {n : ‚Ñï} (i : Fin (suc n)) (j : Fin n)
  ‚Üí fst (punchIn i j) ‚â° punchIn-‚Ñï (fst i) (fst j)
punchIn-fst (zero , _) j = refl
punchIn-fst {suc _} (suc a , p) (zero , _) = refl
punchIn-fst {suc _} (suc a , p) (suc c , q) = cong suc (punchIn-fst (a , p) (c , q))

-- Simplicial identity at Fin level (direct pattern matching)
simplicial : {n : ‚Ñï} (i : Fin (suc (suc n))) (j : Fin (suc n)) (k : Fin n)
  (i' : Fin (suc n)) ‚Üí fst i ‚â° fst i' ‚Üí fst i ‚â§·µó fst j
  ‚Üí punchIn i (punchIn j k) ‚â° punchIn (fsuc j) (punchIn i' k)
simplicial (zero , pi) j k (zero , pi') e h = refl
simplicial (zero , pi) j k (suc a' , pi') e h =
  ‚ä•.rec (znots e)
simplicial {suc n} (suc a , pi) (zero , pj) k i' e h =
  ‚ä•.rec (¬¨<·µó0 {a} h)
simplicial {suc n} (suc a , pi) (suc b , pj) (zero , pk) (zero , pi') e h =
  ‚ä•.rec (snotz e)
simplicial {suc n} (suc a , pi) (suc b , pj) (zero , pk) (suc a' , pi') e h =
  refl
simplicial {suc n} (suc a , pi) (suc b , pj) (suc c , pk) (zero , pi') e h =
  ‚ä•.rec (snotz e)
simplicial {suc n} (suc a , pi) (suc b , pj) (suc c , pk) (suc a' , pi') e h =
  cong fsuc (simplicial (a , pi) (b , pj) (c , pk) (a' , pi') (injSuc e) h)

-- Face map: delete position i from a (suc n)-tuple to get an n-tuple
faceMap : {n : ‚Ñï} {A : Type ‚Ñì} ‚Üí Fin (suc n) ‚Üí (Fin (suc n) ‚Üí A) ‚Üí (Fin n ‚Üí A)
faceMap i œÉ = œÉ ‚àò punchIn i

-- punchOut: inverse of punchIn (given k ‚âÝ i, find j with punchIn k j = i)
punchOut : {n : ‚Ñï} ‚Üí (k : Fin (suc n)) ‚Üí (i : Fin (suc n))
  ‚Üí ¬¨ (fst k ‚â° fst i) ‚Üí Fin n
punchOut (zero , _) (zero , _) neq = ‚ä•.rec (neq refl)
punchOut (zero , _) (suc c , q) _ = (c , q)
punchOut {suc _} (suc a , p) (zero , _) _ = fzero
punchOut {suc _} (suc a , p) (suc c , q) neq =
  fsuc (punchOut (a , p) (c , q) (Œª eq ‚Üí neq (cong suc eq)))

-- punchIn ‚àò punchOut = id
punchIn-punchOut : {n : ‚Ñï} (k : Fin (suc n)) (i : Fin (suc n))
  (neq : ¬¨ (fst k ‚â° fst i)) ‚Üí punchIn k (punchOut k i neq) ‚â° i
punchIn-punchOut (zero , _) (zero , _) neq = ‚ä•.rec (neq refl)
punchIn-punchOut (zero , _) (suc c , q) _ = refl
punchIn-punchOut {suc _} (suc a , p) (zero , _) _ = refl
punchIn-punchOut {suc _} (suc a , p) (suc c , q) neq =
  cong fsuc (punchIn-punchOut (a , p) (c , q) (Œª eq ‚Üí neq (cong suc eq)))

-- Swap two positions
swapFin : {n : ‚Ñï} ‚Üí Fin n ‚Üí Fin n ‚Üí Fin n ‚Üí Fin n
swapFin {n} i j k with discreteFin {n} k i
... | yes _ = j
... | no _ with discreteFin {n} k j
...   | yes _ = i
...   | no _ = k

