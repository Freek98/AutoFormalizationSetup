    sw01-comp œÉ = funExt (Œª k ‚Üí cong œÉ (sw01¬≤ k))

  -- Antisymmetry of c‚ÇÅ-core: case analysis on two trichotomy results
  -- (no path types in scope, so direct pattern matching is safe)
  private
    c‚ÇÅ-antisym-core : (s : C‚Åø-ord 1) (x : S) (œÉ : Fin 2 ‚Üí T x)
      ‚Üí (r‚ÇÅ : Tri< (_<sto_ x) (œÉ fzero) (œÉ fone))
      ‚Üí (r‚ÇÇ : Tri< (_<sto_ x) (œÉ fone) (œÉ fzero))
      ‚Üí c‚ÇÅ-core s x (œÉ ‚àò sw01) r‚ÇÇ ‚â° Ax.-_ x (c‚ÇÅ-core s x œÉ r‚ÇÅ)
    -- (lt, lt): contradiction via transitivity
    c‚ÇÅ-antisym-core s x œÉ (is-lt p<q) (is-lt q<p) =
      ‚ä•.rec (<sto-irrefl x _ (<sto-trans x p<q q<p))
    -- (lt, eq): ¬¨p<q contradicts p<q
    c‚ÇÅ-antisym-core s x œÉ (is-lt p<q) (is-eq _ ¬¨p<q) = ‚ä•.rec (¬¨p<q p<q)
