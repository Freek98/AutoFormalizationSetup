  ... | lt·µó q = ‚ä•.rec (¬¨m<·µóm {suc n'} (<·µó-‚â§·µó-trans {suc n'} {fst i} {suc n'} q (snd i)))
  ... | gt·µó q =
    let n‚âÝi : ¬¨ (suc n' ‚â° fst i)
